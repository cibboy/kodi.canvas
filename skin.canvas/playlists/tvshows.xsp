<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="tvshows">
    <name>TV Shows</name>
    <match>all</match>
	<rule field="title" operator="doesnotcontain">
        <value>Yoga With Adriene</value>
    </rule>
    <order direction="ascending">title</order>
</smartplaylist>
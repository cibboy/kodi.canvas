<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="episodes">
    <name>Recently Added TV Show Episodes</name>
    <match>all</match>
    <limit>20</limit>
    <rule field="playcount" operator="is">
        <value>0</value>
    </rule>
	<rule field="tvshow" operator="doesnotcontain">
        <value>Yoga With Adriene</value>
    </rule>
    <order direction="descending">dateadded</order>
</smartplaylist>
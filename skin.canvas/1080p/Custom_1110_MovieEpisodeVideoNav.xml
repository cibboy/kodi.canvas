<?xml version="1.0" encoding="UTF-8"?>
<window type="window" id="1110">
	<defaultcontrol always="true">501</defaultcontrol>

	<include content="VideoPlayingRedirect" />
	<onload>RunScript(script.canvas.helper,clear_episode_season_navigation)</onload>
	<onload>Skin.TimerStart(movieepisodevideonavredir)</onload>
	<onload>RunScript(script.canvas.helper,play_show_theme)</onload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml) + !Window.Next(VideoFullScreen.xml)">PlayerControl(stop)</onunload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml)">ClearProperty(Player.PlayingTheme,home)</onunload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml)">PlayerControl(RepeatOff)</onunload>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background with blurred quadrants -->
			<include content="BackgroundQuadrantBlur" />

			<!-- Previous/next season indicators (for episode list view) -->
			<include content="MediaNavPrevNextSeasonIndicators">
				<param name="visible">String.IsEqual(Window(1110).Property(ShowList),true)</param>
			</include>

			<control type="group">
				<top>PADDING_BASE_80P</top>
				<left>PADDING_BASE</left>

				<!-- Selection details -->
				<include content="SelectionDetails" />

				<!-- Item controls -->
				<include content="MediaNavActionButtons">
					<param name="switch_to_601_on_more">String.IsEqual(Window(1110).Property(Content.Type),movie)</param>
				</include>

				<!-- Loading spinner -->
				<include content="LoadingSpinner">
					<param name="condition">!String.IsEqual(Window(1110).Property(ShowList),true)</param>
					<param name="centertop">70%</param>
				</include>

				<!-- Single movie list (always hidden) -->
				<include content="MediaNavItemList" condition="String.IsEqual(Window(1110).Property(Content.Type),movie)">
					<param name="movement">6</param>
					<animation type="Conditional" condition="true"><effect type="fade" start="100" end="0" time="0" tween="cubic" easing="out" /></animation>
					<content>$INFO[Window(1110).Property(Content)]</content>
				</include>

				<!-- Lists -->
				<control type="grouplist" id="400">
					<orientation>vertical</orientation>
					<itemgap>0</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<bottom>0</bottom>
					<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

					<onup>SetFocus(410)</onup>
					<ondown>noop</ondown>

					<!-- Episode list -->
					<include content="MediaNavItemList" condition="String.IsEqual(Window(1110).Property(Content.Type),episode)">
						<param name="movement">2</param>
						<animation type="Conditional" condition="!String.IsEqual(Window(1110).Property(ShowList),true)">
							<effect type="slide" start="0,0" end="0,-99999" time="0" tween="cubic" easing="out" reversible="true" />
						</animation>
						<content>$INFO[Window(1110).Property(Content)]</content>
					</include>

					<!-- Actor list -->
					<include content="MediaNavActorList" />
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<include content="BottomBar" />
		</include>
	</controls>
</window>
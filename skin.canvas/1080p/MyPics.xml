<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>
	<views>501,502</views>
	<onunload>ClearProperty(LibraryNav,pictures)</onunload>

	<controls>
		<!--
			View type redirect button (based on content/source).
			Autochange the view type if not the expected one.
		-->
		<control type="button" id="9999">
			<visible allowhiddenfocus="true">false</visible>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(501)">Sendclick(2)</onfocus>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation]">SetFocus(501)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(502)">Sendclick(2)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetFocus(502)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetProperty(LibraryNav,true,pictures)</onfocus>
		</control>
		<!-- View type selector button (hidden as not used by the user) -->
		<control type="button" id="2">
			<visible>false</visible>
		</control>

		<include content="Center169AspectRatio">
			<!-- 501 view for album navigation from home -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>
				<height>SCREEN_HEIGHT</height>

				<!-- Background -->
				<include content="BackgroundQuadrantBlur" />

				<!-- Content -->
				<control type="group">
					<left>PADDING_BASE</left>
					<top>PADDING_BASE_80P</top>

					<!-- Title -->
					<control type="label">
						<width>auto</width>
						<height>HEIGHT_DETAILS_TITLE</height>
						<aligny>center</aligny>
						<font>TITLE1</font>
						<textcolor>HIGHLIGHT_CONTRAST_LIGHT</textcolor>
						<label>Pictures</label>
					</control>

					<control type="group">
						<top>PADDING_BASE</top>
						<height>HEIGHT_HOME_FULL_WALL_CONTENT</height>

						<!-- Album name -->
						<control type="grouplist">
							<orientation>horizontal</orientation>
							<itemgap>PADDING_BASE_10P</itemgap>
							<usecontrolcoords>true</usecontrolcoords>

							<!-- Album name -->
							<control type="label">
								<left>PADDING_BASE_5P</left>
								<width>auto</width>
								<height>FONT_SIZE_TITLE3</height>
								<aligny>center</aligny>
								<font>SUBTITLE</font>
								<textcolor>HIGHLIGHT_CONTRAST_LIGHT</textcolor>
								<label>$INFO[Container.FolderName]</label>
							</control>
							<!-- Number of items -->
							<control type="label">
								<left>PADDING_BASE_5P</left>
								<width>auto</width>
								<height>FONT_SIZE_TITLE3</height>
								<aligny>center</aligny>
								<font>CAPTION_STRONG</font>
								<textcolor>HIGHLIGHT_CONTRAST_LIGHT</textcolor>
								<label>$INFO[Container.NumItems,(, pictures)]</label>
							</control>
						</control>

						<!-- Media item wall -->
						<include content="ItemWall">
							<param name="id">501</param>
							<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>

							<top>FONT_SIZE_TITLE1</top>
							<bottom>0</bottom>

							<onup>noop</onup>
							<ondown>noop</ondown>

							<!-- Picure layout -->
							<include content="AlbumLayout">
								<param name="art">$INFO[ListItem.Art(thumb)]</param>
								<param name="fallback">$VAR[HomePictureFallbackArt]</param>
								<param name="overlay_icon">$VAR[HomePictureOverlayIcon]</param>
								<param name="dark_unfocused">$PARAM[darken_art]</param>
								<param name="condition">Integer.IsEqual($PARAM[id],302)</param>
								<param name="get_additional_data">false</param>
								<param name="info1">$VAR[HomeAlbumInfo1]</param>
								<param name="info2">$VAR[HomeAlbumInfo2]</param>
								<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
								<param name="info2_color">$VAR[ContrastTextForegroundColor]</param>
							</include>
						</include>
					</control>
				</control>
			</control>

			<!-- 502 view for navigation from settings > library -->
			<include content="MediaNavItemListForLibrary">
				<param name="title">Picture library</param>
			</include>

			<!-- Clock -->
			<include content="TopBar" />
		</include>
	</controls>
</window>
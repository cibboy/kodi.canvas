<window>
	<defaultcontrol>1</defaultcontrol>

	<controls>
		<!-- Darkening layer (with fade) -->
		<include content="DarkeningLayer">
			<param name="colordiffuse">BACKGROUND_OPAQUE35</param>
			<param name="visible_condition">WindowOpen</param>
			<param name="hidden_condition">WindowClose</param>
		</include>

		<!-- Actual menu -->
		<control type="group">
			<!-- Slide in from the side -->
			<include content="ShowHideFadeSlideHorizontalAnimation">
				<param name="slide_amount">300</param>
				<param name="speed">ANIMATION_MID</param>
				<param name="visible_condition">WindowOpen</param>
				<param name="hidden_condition">WindowClose</param>
			</include>

			<width>600</width>
			<height>100%</height>
			<right>0</right>

			<!-- Background -->
			<control type="image">
				<width>100%</width>
				<height>100%</height>
				<texture border="PADDING_HALF" colordiffuse="BACKGROUND_DIALOG">1080p/diffuse/square.png</texture>
				<bordersize>SIZE_ITEM_SHADOW_SQUARE</bordersize>
				<bordertexture border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE" colordiffuse="BACKGROUND">1080p/diffuse/shadow_square.png</bordertexture>
			</control>
			<control type="image">
				<width>100%</width>
				<height>100%</height>
				<texture border="PADDING_HALF" colordiffuse="BACKGROUND" diffuse="1080p/diffuse/legibility.png">1080p/diffuse/square.png</texture>
				<bordersize>SIZE_ITEM_SHADOW_SQUARE</bordersize>
				<aspectratio scalediffuse="true">scale</aspectratio>
			</control>

			<control type="button" id="1">
				<top>PADDING_BASE</top>
				<left>PADDING_BASE</left>
				<!--<width>600</width>
				<height>50</height>
				<align>right</align>
				<aligny>top</aligny>
				<font>subtitle</font>
				<textcolor>AAFFFFFF</textcolor>-->
				<label>Quit</label>
				<onclick>Quit()</onclick>
				<ondown>2</ondown>
			</control>
			<control type="button" id="2">
				<top>500</top>
				<left>PADDING_BASE</left>
				<!--<width>600</width>
				<height>50</height>
				<align>right</align>
				<aligny>top</aligny>
				<font>subtitle</font>
				<textcolor>AAFFFFFF</textcolor>-->
				<label>InterfaceSettings</label>
				<onclick>ActivateWindow(InterfaceSettings)</onclick>
				<onup>1</onup>
			</control>
		</control>

		<!-- Clock (no animation) -->
		<control type="group">
			<include content="ShowHideFadeAnimation">
				<param name="visible_condition">WindowOpen</param>
				<param name="hidden_condition">WindowClose</param>
			</include>
			<include content="TopBar">
				<param name="show_background">false</param>
			</include>
		</control>


<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>1000</defaultcontrol>

	<controls>
		<!-- Background (structure split) -->
		<include content="SettingsBackgroundSplit" />

		<!-- Content structure -->
		<control type="group">
			<animation type="Conditional" condition="!$EXP[HasSettingSectionsFocus]">
				<effect type="slide" end="-1200,0" time="ANIMATION_SLOW" tween="cubic" easing="out" />
			</animation>
			<animation type="Conditional" condition="$EXP[HasSettingSectionsFocus]">
				<effect type="slide" end="0,0" time="ANIMATION_SLOW" tween="cubic" easing="out" />
			</animation>

			<!-- Main categories (left side) -->
			<include content="MainSettings" />

			<!-- List of pages (right side when main settings are visible, left otherwise) -->
			<control type="group">
				<width>WIDTH_BACKGROUND_SPLIT_REMAINING</width>
				<height>SCREEN_HEIGHT</height>
				<left>WIDTH_BACKGROUND_SPLIT</left>

				<!-- List with title -->
				<control type="group">
					<top>PADDING_SETTINGS_VERTICAL</top>
					<bottom>PADDING_SETTINGS_VERTICAL</bottom>
					<right>PADDING_SETTINGS_NARROW_SIDE</right>
					<left>PADDING_SETTINGS_NARROW_SIDE</left>

					<!-- Page name -->
					<control type="label" id="2">
						<width>auto</width>
						<height>FONT_SIZE_TITLE1</height>
						<right>PADDING_SETTINGS_TITLE</right>
						<left>PADDING_SETTINGS_TITLE</left>
						<font>TITLE1</font>
						<label></label>
					</control>

					<!-- Pages -->
					<control type="group">
						<top>OFFSET_SETTINGS_OPTIONS_START</top>

						<!-- List of options -->
						<control type="grouplist" id="3">
							<itemgap>GAP_SETTINGS_GROUPLIST_OPTION</itemgap>
							<usecontrolcoords>true</usecontrolcoords>
							<onleft>SetFocus(1000)</onleft>
							<onright>SetFocus(5)</onright>
						</control>

						<!-- Chevron up (more items) -->
						<control type="image">
							<visible>Integer.IsGreater(Container(3).NumItems,6)</visible>

							<width>60</width>
							<height>60</height>
							<top>PADDING_GROUPLIST_NARROW_VERTICAL_CHEVRON</top>
							<centerleft>50%</centerleft>
							<texture colordiffuse="FOREGROUND_OPAQUE10">1080p/icons/chevron-up.png</texture>
							<aspectratio>keep</aspectratio>
						</control>

						<!-- Chevron down (more items) -->
						<control type="image">
							<visible>Integer.IsGreater(Container(3).NumItems,6)</visible>

							<width>60</width>
							<height>60</height>
							<bottom>PADDING_GROUPLIST_NARROW_VERTICAL_CHEVRON</bottom>
							<centerleft>50%</centerleft>
							<texture colordiffuse="FOREGROUND_OPAQUE10" flipy="true">1080p/icons/chevron-up.png</texture>
							<aspectratio>keep</aspectratio>
						</control>
					</control>
				</control>

				<!-- Page button -->
				<control type="button" id="10">
					<width>WIDTH_SETTINGS_GROUPLIST_NARROW_OPTION</width>
					<height>HEIGHT_BUTTON_DEFAULT</height>
					<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE">1080p/controls/button.png</texturefocus>
					<texturenofocus />
					<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
					<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
					<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
					<textcolor>FOREGROUND_OPAQUE75</textcolor>
					<align>left</align>
					<onclick>SetFocus(5)</onclick>
				</control>

				<!-- Chevron left -->
				<control type="image">
					<include content="FocusFadeAnimation">
						<param name="start">0</param>
						<param name="end">100</param>
						<param name="reference_id">1000</param>
					</include>

					<width>60</width>
					<height>60</height>
					<left>PADDING_HALF</left>
					<centertop>50%</centertop>
					<texture colordiffuse="FOREGROUND_OPAQUE10" flipx="true">1080p/icons/chevron-right.png</texture>
					<aspectratio>keep</aspectratio>
				</control>
			</control>

			<!-- List of options (right side when main settings are not visible) -->
			<control type="group">
				<width>WIDTH_BACKGROUND_SPLIT</width>
				<height>SCREEN_HEIGHT</height>
				<left>SCREEN_WIDTH</left>

				<!-- List with description -->
				<control type="group">
					<top>PADDING_SETTINGS_OPTIONS_VERTICAL_WIDE</top>
					<bottom>PADDING_SETTINGS_VERTICAL</bottom>
					<right>PADDING_SETTINGS_WIDE_SIDE</right>
					<left>PADDING_SETTINGS_WIDE_SIDE</left>

					<!-- Setting description -->
					<control type="group">
						<top>PADDING_BASE</top>
						<height>100</height>

						<!-- Icon -->
						<control type="image">
							<visible>!String.IsEmpty(Control.GetLabel(6))</visible>
							<width>SIZE_SETTINGS_ICON</width>
							<height>SIZE_SETTINGS_ICON</height>
							<top>PADDING_MULT_10</top>
							<left>PADDING_SETTINGS_NARROW_SIDE</left>
							<texture colordiffuse="FOREGROUND_DARK">1080p/icons/info.png</texture>
						</control>

						<!-- Description -->
						<control type="textbox" id="6">
							<left>PADDING_LEFT_SETTINGS_INFO</left>
							<right>PADDING_LEFT_SETTINGS_INFO</right>
							<height>100</height>
							<font>CAPTION</font>
							<textcolor>FOREGROUND_DARK</textcolor>
							<autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
						</control>
					</control>

					<!-- Selected page options -->
					<control type="group">
						<top>OFFSET_SETTINGS_OPTIONS_START</top>

						<!-- List of options -->
						<control type="grouplist" id="5">
							<itemgap>GAP_SETTINGS_GROUPLIST_OPTION</itemgap>
							<usecontrolcoords>true</usecontrolcoords>
							<pagecontrol>60</pagecontrol>
							<onleft>SetFocus(3)</onleft>
							<onright>SetFocus(60)</onright>
						</control>

						<!-- List scrollbar -->
						<control type="scrollbar" id="60">
							<top>PADDING_BASE</top>
							<bottom>PADDING_DOUBLE</bottom>
							<right>PADDING_BASE_NEG</right>
							<onleft>SetFocus(5)</onleft>
						</control>
					</control>
				</control>

				<!-- Section name -->
				<control type="label" id="14">
					<height>HEIGHT_SETTINGS_CAPTION</height>
					<left>PADDING_BUTTON_HORIZONTAL</left>
					<top>OFFSET_SETTINGS_CAPTION</top>
					<label></label>
					<align>left</align>
					<font>SETTINGS_CAPTION</font>
					<textcolor>FOREGROUND_ACCENT_ALT</textcolor>
				</control>

				<!-- Option button -->
				<control type="button" id="7">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
				</control>
				
				<!-- Radio button -->
				<control type="radiobutton" id="8">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<radioposx>OFFSET_SETTINGS_OPTION_RADIO_WIDE</radioposx>
				</control>

				<!-- Spin button -->
				<control type="spincontrolex" id="9">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<spinposx>OFFSET_SETTINGS_OPTION_SPIN_WIDE</spinposx>
				</control>

				<!-- Slider button -->
				<control type="sliderex" id="13">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
				</control>

				<!-- Color button -->
				<control type="colorbutton" id="15">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
				</control>
			</control>
		</control>

		<!-- Clock -->
		<include content="TopBar">
			<param name="show_background">false</param>
		</include>
	</controls>
</window>
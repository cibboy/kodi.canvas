<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>1000</defaultcontrol>

	<controls>
		<!-- Background (structure split) -->
		<include content="SettingsBackgroundSplit">
			<param name="main_id">1000</param>
		</include>

		<!-- Content structure -->
		<control type="group">
			<animation type="Conditional" condition="!Control.HasFocus(1000)">
				<effect type="slide" end="-1200,0" time="ANIMATION_SLOW" tween="cubic" easing="out" />
			</animation>
			<animation type="Conditional" condition="Control.HasFocus(1000)">
				<effect type="slide" end="0,0" time="ANIMATION_SLOW" tween="cubic" easing="out" />
			</animation>

			<!-- Main categories (left side) -->
			<include content="MainSettings">
				<param name="id">1000</param>
				<param name="subpage_id">3</param>
			</include>

			<!-- List of pages (right side when main settings are visible, left otherwise) -->
			<control type="group">
				<width>WIDTH_BACKGROUND_SPLIT_REMAINING</width>
				<height>SCREEN_HEIGHT</height>
				<left>WIDTH_BACKGROUND_SPLIT</left>

				<!-- Chevron -->
				<control type="image">
					<include content="FocusFadeAnimation">
						<param name="start">0</param>
						<param name="end">100</param>
						<param name="reference_id">1000</param>
					</include>

					<width>60</width>
					<height>60</height>
					<left>PADDING_HALF</left>
					<centertop>50%</centertop>
					<texture colordiffuse="FOREGROUND_OPAQUE10" flipx="true">1080p/icons/chevron-right.png</texture>
					<aspectratio>keep</aspectratio>
				</control>

				<!-- List with title -->
				<control type="group">
					<top>PADDING_SETTINGS_VERTICAL</top>
					<bottom>PADDING_SETTINGS_VERTICAL</bottom>
					<right>PADDING_SETTINGS_NARROW_SIDE</right>
					<left>PADDING_SETTINGS_NARROW_SIDE</left>

					<!-- Page name -->
					<control type="label" id="2">
						<width>auto</width>
						<height>FONT_SIZE_TITLE1</height>
						<right>16</right>
						<left>16</left>
						<font>TITLE1</font>
						<label></label>
					</control>

					<!-- Pages -->
					<control type="grouplist" id="3">
						<top>OFFSET_SETTINGS_OPTIONS_START</top>
						<itemgap>GAP_SETTINGS_GROUPLIST_OPTION</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<onleft>SetFocus(1000)</onleft>
						<onright>SetFocus(5)</onright>
					</control>
				</control>

				<!-- Page button -->
				<control type="button" id="10">
					<width>WIDTH_SETTINGS_GROUPLIST_OPTION_NARROW</width>
					<height>HEIGHT_SETTINGS_OPTION</height>
					<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE">1080p/controls/button.png</texturefocus>
					<texturenofocus></texturenofocus>
					<textoffsety>PADDING_SETTINGS_OPTION_VERTICAL</textoffsety>
					<textoffsetx>PADDING_SETTINGS_OPTION_HORIZONTAL</textoffsetx>
					<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
					<textcolor>FOREGROUND_OPAQUE75</textcolor>
					<align>left</align>
					<onclick>SetFocus(5)</onclick>
				</control>
			</control>

			<!-- List of options (right side when main settings are not visible) -->
			<control type="group">
				<width>WIDTH_BACKGROUND_SPLIT</width>
				<height>SCREEN_HEIGHT</height>
				<left>SCREEN_WIDTH</left>

				<!-- List with description -->
				<control type="group">
					<top>PADDING_SETTINGS_OPTIONS_VERTICAL_WIDE</top>
					<bottom>PADDING_SETTINGS_VERTICAL</bottom>
					<right>PADDING_SETTINGS_WIDE_SIDE</right>
					<left>PADDING_SETTINGS_WIDE_SIDE</left>

					<!-- Setting description -->
					<!--todo-->
					<control type="textbox" id="6">
						<description>description area</description>
						<left>0</left>
						<right>0</right>
						<height>90</height>
						<font>BODY_STRONG</font>
						<align>justify</align>
						<textcolor>FOREGROUND_DARK</textcolor>
						<autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
					</control>

					<!-- Selected page options -->
					<control type="grouplist" id="5">
						<top>OFFSET_SETTINGS_OPTIONS_START</top>
						<itemgap>GAP_SETTINGS_GROUPLIST_OPTION</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<onleft>SetFocus(3)</onleft>
					</control>
				</control>

				<!-- Section label -->
				<control type="label" id="14">
					<height>HEIGHT_SETTINGS_CAPTION</height>
					<left>PADDING_SETTINGS_OPTION_HORIZONTAL</left>
					<top>OFFSET_SETTINGS_CAPTION</top>
					<label></label>
					<align>left</align>
					<font>SETTINGS_CAPTION</font>
					<textcolor>FOREGROUND_ACCENT_ALT</textcolor>
				</control>

				<!-- Option button -->
				<control type="button" id="7">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<height>HEIGHT_SETTINGS_OPTION</height>
					<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE">1080p/controls/button.png</texturefocus>
					<texturenofocus></texturenofocus>
					<textoffsety>PADDING_SETTINGS_OPTION_VERTICAL</textoffsety>
					<textoffsetx>PADDING_SETTINGS_OPTION_HORIZONTAL</textoffsetx>
					<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
					<textcolor>FOREGROUND_OPAQUE75</textcolor>
					<align>left</align>
				</control>
				
				<control type="radiobutton" id="8">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<height>HEIGHT_SETTINGS_OPTION</height>
					<textoffsety>PADDING_SETTINGS_OPTION_VERTICAL</textoffsety>
					<textoffsetx>PADDING_SETTINGS_OPTION_HORIZONTAL</textoffsetx>
					<radioposx>OFFSET_SETTINGS_OPTION_RADIO_WIDE</radioposx>
				</control>
			</control>
		</control>


<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>1000</defaultcontrol>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background (structure split) -->
			<include content="SettingsBackground" />

			<!-- Main settings -->
			<control type="group">
				<animation type="Conditional" condition="$EXP[IsSettingsDialogSelectActive] | $EXP[IsSettingsDialogConfirmActive] | $EXP[IsSettingsDialogColorPickerActive]">
					<effect type="slide" end="WIDTH_BACKGROUND_SPLIT_REMAINING_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
				</animation>
				<animation type="Conditional" condition="$EXP[IsSettingsDialogSettingsActive]">
					<effect type="slide" end="SCREEN_WIDTH_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
				</animation>

				<include content="SettingsBackgroundSplit">
					<!--
						When the main sections don't have focus, the split inverts.
						The slide amount should be equivalent to window width - (narrow side * 2) (1920 - 1440).
					-->
					<animation type="Conditional" condition="!$EXP[HasSettingSectionsFocus]">
						<effect type="slide" end="-480,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
					</animation>
					<animation type="Conditional" condition="$EXP[HasSettingSectionsFocus]">
						<effect type="slide" end="0,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
					</animation>
				</include>

				<!-- Content structure -->
				<control type="group">
					<animation type="Conditional" condition="!$EXP[HasSettingSectionsFocus]">
						<effect type="slide" end="WIDTH_BACKGROUND_SPLIT_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
					</animation>
					<animation type="Conditional" condition="$EXP[HasSettingSectionsFocus]">
						<effect type="slide" end="0,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
					</animation>

					<!-- Main categories (left side) -->
					<include content="MainSettings" />

					<!-- Dynamically loaded settings -->
					<include content="DynamicSettings" />
				</control>
			</control>

			<!-- Dialogs -->
			<control type="group">
				<animation type="Conditional" condition="$EXP[IsSettingsDialogSelectActive] | $EXP[IsSettingsDialogConfirmActive] | $EXP[IsSettingsDialogColorPickerActive]">
					<effect type="slide" end="WIDTH_BACKGROUND_SPLIT_REMAINING_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
				</animation>
				<animation type="Conditional" condition="$EXP[IsSettingsDialogSettingsActive]">
					<effect type="slide" end="SCREEN_WIDTH_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
				</animation>

				<left>SCREEN_WIDTH</left>

				<include content="SettingsBackgroundSplit" />
			</control>

			<!-- Clock -->
			<include content="TopBar">
				<param name="show_background">false</param>
			</include>
		</include>
	</controls>
</window>
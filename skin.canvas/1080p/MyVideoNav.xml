<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>
	<views>501,502</views>
	<include content="VideoPlayingRedirect" />
	<!--
		Go to home if not arriving here from settings and not showing 501.
		Basically, this is the case of playing a video from 502 and then exiting
		(it would want to show 502, but it's mixed up because it's coming from
		the video player, and so on. Yeah, just a giant mess of quirks in Kodi...)
	-->
	<onload condition="!$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(501)">ReplaceWindow(home)</onload>
	<onunload>ClearProperty(LibraryNav,videos)</onunload>

	<controls>
		<!--
			View type redirect button (based on content/source).
			Autochange the view type if not the expected one.
		-->
		<control type="button" id="9999">
			<visible allowhiddenfocus="true">false</visible>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation]">SetFocus(501)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(502)">Sendclick(2)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetFocus(502)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetProperty(LibraryNav,true,videos)</onfocus>
		</control>
		<!-- View type selector button (hidden as not used by the user) -->
		<control type="button" id="2">
			<visible>false</visible>
		</control>

		<include content="Center169AspectRatio">
			<!-- 501 view for season/episode navigation from home -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>

				<!-- Background with blurred quadrants -->
				<include content="BackgroundQuadrantBlur" />

				<!-- Previous/next season indicators (for episode list view) -->
				<include content="MediaNavPrevNextSeasonIndicators" />

				<control type="group">
					<top>PADDING_BASE_80P</top>
					<left>PADDING_BASE</left>

					<!-- Selection details -->
					<include content="SelectionDetails" />

					<!-- Item controls -->
					<include content="MediaNavActionButtons" />

					<!-- Lists -->
					<control type="grouplist" id="400">
						<orientation>vertical</orientation>
						<itemgap>0</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<bottom>0</bottom>
						<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

						<onup>SetFocus(410)</onup>
						<ondown>noop</ondown>

						<!-- Media items -->
						<include content="MediaNavItemList" />

						<!-- Actor list -->
						<include content="MediaNavActorList" />
					</control>
				</control>
			</control>

			<!-- 502 view for navigation from settings > library --><!--todo-->
			<control type="group">
				<visible>$EXP[IsMediaNavLibraryNavigation]</visible>

				<!-- Background (monocolor) -->
				<include content="SettingsBackground" />
				
				<!-- Background (structure split) -->
				<include content="SettingsBackgroundSplit" />

				<!-- Left side (title + list) -->
				<include content="FileNavItemList">
					<param name="id">502</param>
					<param name="title">Video library</param>
				</include>

				<!-- Right side (details when no dialog is visible) -->
				<control type="group">
					<visible>!$EXP[IsSettingsAnyDialogActive]</visible>
					<include content="ShowHideFadeSlideHorizontalAnimation">
						<param name="slide_amount">-100</param>
					</include>

					<width>WIDTH_BACKGROUND_SPLIT_REMAINING</width>
					<height>SCREEN_HEIGHT</height>
					<left>WIDTH_BACKGROUND_SPLIT</left>

					<control type="group">
						<top>PADDING_BASE_80P</top>
						<bottom>PADDING_BASE_80P</bottom>
						<right>PADDING_SETTINGS_NARROW_SIDE</right>
						<left>PADDING_SETTINGS_NARROW_SIDE</left>

						<control type="grouplist">
							<orientation>vertical</orientation>
							<itemgap>PADDING_BASE_20P</itemgap>
							<usecontrolcoords>true</usecontrolcoords>

							<top>PADDING_BASE_80P</top>

							<!-- Icon -->
							<control type="image">
								<visible>$EXP[IsListIconTranslatedNative]</visible>
								<centerleft>50%</centerleft>
								<width>100</width>
								<height>100</height>
								<texture fallback="1080p/icons/file.png">$VAR[ListIconTranslated]</texture>
								<aspectratio>keep</aspectratio>
							</control>
							<!-- Preview -->
							<control type="image">
								<visible>!$EXP[IsListIconTranslatedNative]</visible>
								<centerleft>50%</centerleft>
								<width>500</width>
								<height>300</height>
								<texture fallback="1080p/fallback/file.png">$VAR[ListIconTranslated]</texture>
								<aspectratio>keep</aspectratio>
							</control>

							<!-- Size -->
							<include content="FileNavInfoLabel">
								<param name="visible">!String.IsEmpty(ListItem.Size)</param>
								<param name="label">Size</param>
								<param name="value">$INFO[ListItem.Size]</param>
							</include>
							<!-- File name -->
							<include content="FileNavInfoLabel">
								<param name="visible">!String.IsEmpty(ListItem.FileName) + !String.IsEqual(ListItem.FileName,add)</param>
								<param name="label">File name</param>
								<param name="value">$INFO[ListItem.FileName]</param>
							</include>
							<!-- Folder -->
							<include content="FileNavInfoLabel">
								<param name="visible">!String.IsEmpty(ListItem.Path) + !ListItem.IsFolder</param>
								<param name="label">Folder</param>
								<param name="value">$INFO[ListItem.Path]</param>
							</include>
							<!-- Path -->
							<include content="FileNavInfoLabel">
								<param name="visible">!String.IsEmpty(ListItem.FileNameAndPath) + !String.IsEqual(ListItem.FileNameAndPath,add)</param>
								<param name="label">Full path</param>
								<param name="value">$INFO[ListItem.FileNameAndPath]</param>
								<param name="wrap">true</param>
							</include>
							<!-- Add source (special case) -->
							<include content="FileNavInfoLabel">
								<param name="visible">String.IsEqual(ListItem.FileNameAndPath,add)</param>
								<param name="label">Add source</param>
							</include>
						</control>
					</control>
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<control type="group">
				<visible>!Window.Previous(SettingsCategory.xml)</visible>
				<include content="BottomBar" />
			</control>
		</include>
	</controls>
</window>
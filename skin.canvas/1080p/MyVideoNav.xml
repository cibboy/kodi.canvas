<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>
	<views>501,502</views>
	<include content="VideoPlayingRedirect" />

	<controls>
		<!-- todo:Window.Previous(SettingsCategory.xml) is not enough of a check (test: play a video from 502, finish it and it returns where the previous is obviously not SettingsCategory.xml) -->
		<!--
			View type redirect button (based on content/source).
			Autochange the view type if not the expected one.
		-->
		<control type="button" id="9999">
			<visible allowhiddenfocus="true">false</visible>
			<onfocus condition="!Window.Previous(SettingsCategory.xml) + !Control.IsVisible(501)">Sendclick(2)</onfocus>
			<onfocus condition="!Window.Previous(SettingsCategory.xml)">SetFocus(501)</onfocus>
			<onfocus condition="Window.Previous(SettingsCategory.xml) + !Control.IsVisible(502)">Sendclick(2)</onfocus>
			<onfocus condition="Window.Previous(SettingsCategory.xml)">SetFocus(502)</onfocus>
		</control>
		<!-- View type selector button (hidden as not used by the user) -->
		<control type="button" id="2">
			<visible>false</visible>
		</control>

		<include content="Center169AspectRatio">
			<!-- 501 view for season/episode navigation from home -->
			<control type="group">
				<visible>!Window.Previous(SettingsCategory.xml)</visible>

				<!-- Background with blurred quadrants -->
				<include content="BackgroundQuadrantBlur" />

				<!-- Previous/next season indicators (for episode list view) -->
				<include content="MediaNavPrevNextSeasonIndicators" />

				<control type="group">
					<top>PADDING_BASE_80P</top>
					<left>PADDING_BASE</left>

					<!-- Selection details -->
					<include content="SelectionDetails" />

					<!-- Item controls -->
					<include content="MediaNavActionButtons" />

					<!-- Lists -->
					<control type="grouplist" id="400">
						<orientation>vertical</orientation>
						<itemgap>0</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<bottom>0</bottom>
						<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

						<onup>SetFocus(410)</onup>
						<ondown>noop</ondown>

						<!-- Media items -->
						<include content="MediaNavItemList" />

						<!-- Actor list -->
						<include content="MediaNavActorList" />
					</control>
				</control>
			</control>

			<!-- 502 view for navigation from settings > library --><!--todo-->
			<control type="group">
				<visible>Window.Previous(SettingsCategory.xml)</visible>

				<!-- Background (monocolor) -->
				<include content="SettingsBackground" />

				<control type="label">
					<visible>Control.IsVisible(502)</visible>
					<left>300</left>
					<label>true</label>
				</control>

				<control type="wraplist" id="502">
					<autoscroll>false</autoscroll>
					<orientation>vertical</orientation>
					
					<itemlayout width="500" height="100">
						<control type="label">
							<label>$INFO[ListItem.Label]</label>
							<font>BODY</font>
						</control>
					</itemlayout>
					<focusedlayout width="500" height="100">
						<control type="label">
							<label>$INFO[ListItem.Label]</label>
							<font>BODY_STRONG</font>
						</control>
						<control type="button">
							<label>$INFO[ListItem.Label]</label>
							<font>BODY_STRONG</font>
						</control>
					</focusedlayout>
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<control type="group">
				<visible>!Window.Previous(SettingsCategory.xml)</visible>
				<include content="BottomBar" />
			</control>
		</include>
	</controls>
</window>
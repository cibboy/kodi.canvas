<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>
	<views>501,502</views>
	<include content="VideoPlayingRedirect" />
	<!--
		Go to home if not arriving here from settings and showing 502.
		Basically, this is the case of playing a video from 502 and then exiting
		(it would want to show 502, but it's mixed up because it's coming from
		the video player, and so on. Yeah, just a giant mess of quirks in Kodi...)
	-->
	<onload condition="!$EXP[IsMediaNavLibraryNavigation] + Control.IsVisible(502)">ReplaceWindow(home)</onload>
	<onload>RunScript(script.canvas.helper,clear_episode_season_navigation)</onload>
	<onload>RunScript(script.canvas.helper,populate_prev_next_season)</onload>
	<!-- Sleep 1 second to give Kodi the chance to complete focusing on 501 -->
	<onload>AlarmClock(play_show_theme,RunScript(script.canvas.helper,play_show_theme),00:00:01,silent)</onload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml) + !Window.Next(VideoFullScreen.xml)">PlayerControl(stop)</onunload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml)">ClearProperty(Player.PlayingTheme,home)</onunload>
	<onunload condition="$EXP[IsTvShowThemePlaying] + !Window.Next(MyVideoNav.xml)">PlayerControl(RepeatOff)</onunload>
	<onunload>CancelAlarm(play_show_theme,silent)</onunload>
	<onunload>ClearProperty(LibraryNav,videos)</onunload>

	<controls>
		<!--
			View type redirect button (based on content/source).
			Autochange the view type if not the expected one.
		-->
		<control type="button" id="9999">
			<visible allowhiddenfocus="true">false</visible>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(501)">Sendclick(2)</onfocus>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation]">SetFocus(501)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(502)">Sendclick(2)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetFocus(502)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetProperty(LibraryNav,true,videos)</onfocus>
		</control>
		<!-- View type selector button (hidden as not used by the user) -->
		<control type="button" id="2">
			<visible>false</visible>
		</control>

		<include content="Center169AspectRatio">
			<!-- 501 view for season/episode navigation from home -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>

				<!-- Background with blurred quadrants -->
				<include content="BackgroundQuadrantBlur" />

				<!-- Previous/next season indicators (for episode list view) -->
				<include content="MediaNavPrevNextSeasonIndicators" />

				<control type="group">
					<top>PADDING_BASE_80P</top>
					<left>PADDING_BASE</left>

					<!-- Selection details -->
					<include content="SelectionDetails" />

					<!-- Item controls -->
					<include content="MediaNavActionButtons" />

					<!-- Loading spinner -->
					<include content="LoadingSpinner">
						<param name="condition">Container(501).IsUpdating</param>
						<param name="centertop">70%</param>
					</include>

					<!-- Lists -->
					<control type="grouplist" id="400">
						<orientation>vertical</orientation>
						<itemgap>0</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<bottom>0</bottom>
						<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

						<onup>SetFocus(410)</onup>
						<ondown>noop</ondown>

						<!-- Media items -->
						<include content="MediaNavItemList" />

						<!-- Actor list -->
						<include content="MediaNavActorList" />
					</control>
				</control>
			</control>

			<!-- 502 view for navigation from settings > library -->
			<include content="MediaNavItemListForLibrary">
				<param name="title">Video library</param>
			</include>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>
				<include content="BottomBar" />
			</control>
		</include>
	</controls>
</window>
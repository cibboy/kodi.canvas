<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Default button to force redirect: either to play or resume action button -->
			<control type="button" id="9999">
				<include content="Hidden" />
				<onfocus condition="$EXP[HasMediaNavActionPlay]">SetFocus(510)</onfocus>
				<onfocus condition="$EXP[HasMediaNavActionResume]">SetFocus(511)</onfocus>
			</control>

			<!-- Background -->
			<include content="MediaNavBackground" />

			<!-- Content -->
			<control type="group">
				<top>PADDING_BASE</top>
				<left>PADDING_MULT_120</left>

				<!-- Selection details -->
				<include content="MediaNavSelectionDetails" />

				<!-- Actual content after selection details -->
				<control type="group">
					<top>OFFSET_AFTER_DETAILS</top>

					<!-- Action buttons -->
					<include content="MediaNavActionButtons" />

					<!-- Lists -->
					<control type="grouplist" id="100">
						<top>OFFSET_MEDIANAV_AFTER_ACTIONBUTTONS</top>
						<height>HEIGHT_MEDIANAV_LISTS_CONTAINER</height>

						<!-- Season list (for TV shows) -->
						<include content="MediaNavSeasonList" />
						<!-- Episode list (for seasons and episodes) -->
						<include content="MediaNavEpisodeList" />

						<!-- Actor list -->
						<include content="MediaNavActorList" />
					</control>
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Bottom bar -->
			<include content="BottomBar">
				<param name="show">$EXP[HasMediaNavDetailsStudio]</param>
				<param name="show_studio">$EXP[HasMediaNavDetailsStudio]</param>
				<param name="studio">$VAR[MediaNavDetailsStudio]</param>
			</include>

			<control type="label">
				<label>$INFO[Container.Content]</label>
				<textcolor>FFFF0000</textcolor>
			</control>
			<control type="label">
				<top>50</top>
				<label>$INFO[Container.Content(files)]</label>
				<textcolor>FFFF0000</textcolor>
			</control>
			<control type="label">
				<top>100</top>
				<label>$INFO[Container.FolderPath]</label>
				<textcolor>FFFF0000</textcolor>
			</control>
			<control type="label">
				<top>150</top>
				<label>$INFO[Container.FolderName]</label>
				<textcolor>FFFF0000</textcolor>
			</control>
			<control type="label">
				<top>200</top>
				<label>##$INFO[Window(videos).Property(List.111.HasContent)]çç</label>
				<textcolor>FFFF0000</textcolor>
			</control>
		</include>
	</controls>
</window>
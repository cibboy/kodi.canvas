<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>400</defaultcontrol>
	<controls>
		<include content="Center169AspectRatio">
			<!-- Background (for non-integrated version) -->
			<include content="StandardFlyoutBackground">
				<param name="visible">!$EXP[IsSettingsFileBrowserActive] + !$EXP[IsPlayerVisible]</param>
			</include>

			<!-- Picture preview -->
			<control type="image">
				<!-- Slide in from the side -->
				<include content="ShowHideFadeSlideHorizontalAnimation">
					<param name="slide_amount">300</param>
					<param name="speed">ANIMATION_MID</param>
					<param name="delay_in">ANIMATION_MID</param>
					<param name="visible_condition">WindowOpen</param>
					<param name="hidden_condition">WindowClose</param>
				</include>
				
				<width>800</width>
				<height>880</height>
				<centertop>50%</centertop>
				<right>750</right>
				<fadetime>ANIMATION_SLOW</fadetime>
				<texture>$INFO[Container(451).ListItem.Icon]</texture>
				<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
				<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
				<aspectratio scalediffuse="false" align="right">keep</aspectratio>
			</control>

			<include content="DialogContainer">
				<param name="close_animation">!$EXP[IsSettingsFileBrowserActive] + !$EXP[IsPlayerVisible]</param>

				<include content="DialogContainerContent">
					<!-- Header -->
					<include content="StandardDialogHeader">
						<param name="id">411</param>
					</include>

					<control type="grouplist" id="400">
						<orientation>vertical</orientation>
						<usecontrolcoords>true</usecontrolcoords>
						<itemgap>GAP_SETTINGS_LIST_OPTION</itemgap>

						<top>OFFSET_SETTINGS_OPTIONS_START</top>
						<height>HEIGHT_SETTINGS_DIALOG_LIST</height>

						<onup condition="Control.IsVisible(413)">SetFocus(413)</onup>
						<onup condition="!Control.IsVisible(413) + Control.IsVisible(415)">SetFocus(415)</onup>
						<ondown>SetFocus(451,0,absolute)</ondown>

						<!-- Single selection list -->
						<control type="list" id="451">
							<itemgap>GAP_SETTINGS_LIST_OPTION</itemgap>
							<usecontrolcoords>true</usecontrolcoords>
							<height>HEIGHT_DIALOG_LIMITED_LIST</height>

							<onup condition="Control.IsVisible(413)">SetFocus(413)</onup>
							<onup condition="!Control.IsVisible(413) + Control.IsVisible(415)">SetFocus(415)</onup>
							<ondown condition="Control.IsVisible(415)">SetFocus(415)</ondown>
							<ondown condition="!Control.IsVisible(415) + Control.IsVisible(413)">SetFocus(413)</ondown>
							<onright>Close</onright>

							<focusedlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
								<!-- Fake button selection -->
								<control type="image">
									<height>HEIGHT_BUTTON_DEFAULT</height>
									<texture colordiffuse="$VAR[FileBrowserOptionButtonColor]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
								</control>
								<!-- Content -->
								<include content="SettingsOptionContentWithIcon">
									<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
									<param name="icon_color">FOREGROUND_INVERSE</param>
									<param name="icon_type_circle">true</param>
									<param name="icon">$INFO[ListItem.Icon]</param>
									<param name="text_color">FOREGROUND_INVERSE</param>
									<param name="text_color_selected">FOREGROUND_ACCENT_ALT</param>
									<param name="text">$INFO[ListItem.Label]</param>
									<param name="single_line">true</param>
									<param name="scroll">true</param>
								</include>
							</focusedlayout>

							<itemlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
								<include content="SettingsOptionContentWithIcon">
									<param name="icon_type_circle">true</param>
									<param name="icon">$INFO[ListItem.Icon]</param>
									<param name="text">$INFO[ListItem.Label]</param>
									<param name="single_line">true</param>
									<param name="scroll">false</param>
								</include>
							</itemlayout>
						</control>

						<!-- Create folder -->
						<control type="button" id="415">
							<width>100%</width>
							<label>Create folder</label>
						</control>
						<!-- Ok -->
						<control type="button" id="413">
							<width>100%</width>
							<label>Ok</label>
						</control>
						<!-- Cancel not necessary as the control can be closed with back or right -->
					</control>
				</include>
			</include>
		</include>
	</controls>
</window>
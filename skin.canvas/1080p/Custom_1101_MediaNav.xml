<?xml version="1.0" encoding="UTF-8"?>
<window type="window" id="1101">
	<defaultcontrol always="true">9999</defaultcontrol>

	<!-- Reset focus to first element of grouplist when closing, so we are correct for next open -->
	<onunload>SetFocus(101)</onunload>
	<onunload>SetFocus(102)</onunload>

	<controls>
		<!-- Default button to force redirect either to play or resume action button -->
		<control type="button" id="9999">
			<onfocus condition="$EXP[HasMediaNavActionPlay]">SetFocus(10)</onfocus>
			<onfocus condition="$EXP[HasMediaNavActionResume]">SetFocus(11)</onfocus>
		</control>

		<!-- Background -->
		<include content="MediaNavBackground" />

		<!-- Content -->
		<control type="group">
			<top>PADDING_BASE</top>
			<left>PADDING_MULT_120</left>

			<!-- Selection details (not for albums) -->
			<include content="MediaNavSelectionDetails" />

			<!-- Actual content after selection details -->
			<control type="group">
				<top>OFFSET_AFTER_DETAILS</top>

				<!-- Action buttons -->
				<include content="MediaNavActionButtons" />

				<!-- Lists -->
				<control type="grouplist" id="100">
					<top>OFFSET_MEDIANAV_AFTER_ACTIONBUTTONS</top>
					<height>HEIGHT_MEDIANAV_LISTS_CONTAINER</height>

					<!-- Season list (for TV shows) -->
					<include content="MediaNavSeasonList" condition="$EXP[IsMediaNavTVShow]" />

					<!-- Episode list (for seasons and episodes) -->
					<include content="MediaNavEpisodeList" condition="$EXP[IsMediaNavSeason] | $EXP[IsMediaNavEpisode]" />

					<!-- Actor list -->
					<include content="MediaNavActorList" />
				</control>
			</control>
		</control>

		<!-- Clock -->
		<include content="TopBar" />

		<!-- Bottom bar -->
		<include content="BottomBar">
			<param name="show">$EXP[HasMediaNavDetailsStudio]</param>
			<param name="show_studio">$EXP[HasMediaNavDetailsStudio]</param>
			<param name="studio">$VAR[MediaNavDetailsStudio]</param>
		</include>
	</controls>
</window>
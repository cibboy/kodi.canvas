<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- Prevent opening if from library navigation, as it wouldn't work as expected -->
	<onload condition="$EXP[IsMediaNavLibraryNavigation]">Close</onload>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background with blurred quadrants -->
			<include content="BackgroundQuadrantBlur" />

			<!-- Details -->
			<control type="group">
				<top>PADDING_BASE_80P</top>
				<left>PADDING_BASE</left>
				<right>PADDING_BASE</right>

				<include content="VideoInfoDetails" />
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<include content="BottomBar" />
		</include>
	</controls>
</window>
<?xml version="1.0" encoding="UTF-8"?>
<window type="window" id="1150">
	<defaultcontrol always="true">2</defaultcontrol>
	<onload condition="Integer.IsLess(Player.Progress,90) | Window.Previous(filemanager)">PlayerControl(Stop)</onload>
	<onload condition="Integer.IsLess(Player.Progress,90) | Window.Previous(filemanager)">Back</onload>
	<!-- Next episode info should be avaiable from onload on player -->
	<onload>AlarmClock(focus_next,SetFocus(2),00:00:01,silent)</onload>

	<controls>
		<include content="Center169AspectRatio">

			<!-- Background with blurred quadrants -->
			<include content="BackgroundQuadrantBlur" />

			<!-- Darkening -->
			<include content="DarkeningLayer">
				<param name="colordiffuse">BACKGROUND_OPAQUE75</param>
			</include>

			<!-- Content -->
			<control type="group">
				<top>80</top>
				<left>PADDING_BASE</left>
				<bottom>PADDING_BASE</bottom>

				<!-- Title/clearlogo -->
				<include content="DetailsTitleClearlogo" />

				<!-- Current video -->
				<control type="group">
					<top>180</top>
					<width>600</width>
					<height>HEIGHT_NEXTVIDEO_SECTION</height>

					<!-- Hidden button for actions -->
					<control type="button" id="1">
						<visible allowhiddenfocus="true">false</visible>
						<onback>PlayerControl(Stop)</onback>
						<onback>ClearProperty(Player.Item.DBID,home)</onback>
						<onclick condition="Player.HasVideo">ActivateWindow(12005)</onclick>
						<onclick condition="!Player.HasVideo">PlayMedia($INFO[Window(home).Property(Player.Item.FilenameAndPath)],noresume,playoffset=0)</onclick>
						<ondown condition="String.IsEqual(Window(home).Property(Player.NextItem.Present),true)">SetFocus(2)</ondown>
					</control>

					<!-- Now playing label -->
					<control type="label">
						<!-- Focus fade -->
						<include content="VideoNextFocusAnimation">
							<param name="reference_control_id">1</param>
						</include>

						<font>BODY_STRONG</font>
						<textcolor>$VAR[ColorsAccentForeground]</textcolor>
						<label>$VAR[VideoNextCurrentLabel]</label>
					</control>

					<!-- Current video -->
					<control type="group">
						<top>PADDING_BASE_60P</top>
						<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
						<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>

						<!-- Thumbnail of current episode -->
						<control type="group">
							<bottom>0</bottom>
							<right>0</right>
							<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
							<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>

							<!-- Thumbnail -->
							<control type="image">
								<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
								<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>
								<texture fallback="1080p/fallback/landscape.png">$INFO[Window(home).Property(Player.Item.Thumb)]</texture>
								<aspectratio scalediffuse="false">scale</aspectratio>
							</control>
							<!-- Play icon -->
							<control type="group">
								<centertop>50%</centertop>
								<centerleft>50%</centerleft>
								<width>100</width>
								<height>100</height>

								<control type="image">
									<centertop>50%</centertop>
									<centerleft>50%</centerleft>
									<width>100</width>
									<height>100</height>
									<texture colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/button-circle.png</texture>
								</control>
								<control type="image">
									<centertop>50%</centertop>
									<centerleft>50%</centerleft>
									<width>45</width>
									<height>45</height>
									<texture colordiffuse="BACKGROUND_OPAQUE75">1080p/icons/play.png</texture>
								</control>
							</control>
						</control>
						<!-- Force 16:9 on video with black bars, where video does not have that aspect ratio -->
						<control type="image">
							<visible>Player.HasVideo</visible>
							<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
							<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>
							<texture colordiffuse="BACKGROUND">diffuse.png</texture>
						</control>
						<!-- Video -->
						<control type="videowindow">
							<visible>Player.HasVideo</visible>
							<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
							<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>
						</control>
						<!-- Unfocus darkening -->
						<include content="VideoNextUnFocusArtDarkening">
							<param name="reference_control_id">1</param>
						</include>
					</control>
				</control>

				<!-- Hidden button for playing next episode -->
				<control type="button" id="2">
					<visible allowhiddenfocus="true">false</visible>
					<onback>PlayerControl(Stop)</onback>
					<onback>ClearProperty(Player.Item.DBID,home)</onback>
					<onclick>PlayMedia($INFO[Window(home).Property(Player.NextItem.File)])</onclick>
					<onup>SetFocus(1)</onup>
					<onfocus condition="!String.IsEqual(Window(home).Property(Player.NextItem.Present),true)">SetFocus(1)</onfocus>
				</control>
				<!-- Next video -->
				<control type="group">
					<visible>String.IsEqual(Window(home).Property(Player.NextItem.Present),true)</visible>

					<bottom>0</bottom>
					<right>PADDING_BASE</right>
					<width>1250</width>
					<height>HEIGHT_NEXTVIDEO_SECTION</height>

					<!-- Next episode label -->
					<control type="label">
						<!-- Focus fade -->
						<include content="VideoNextFocusAnimation">
							<param name="reference_control_id">2</param>
						</include>

						<right>0</right>
						<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
						<align>right</align>
						<font>BODY_STRONG</font>
						<textcolor>$VAR[ColorsAccentForeground]</textcolor>
						<label>Next episode</label>
					</control>

					<!-- Thumbnail of next episode -->
					<control type="group">
						<bottom>0</bottom>
						<right>0</right>
						<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
						<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>

						<!-- Thumbnail -->
						<control type="image">
							<width>WIDTH_NEXTVIDEO_LANDSCAPE</width>
							<height>HEIGHT_NEXTVIDEO_LANDSCAPE</height>
							<texture fallback="1080p/fallback/landscape.png">$INFO[Window(home).Property(Player.NextItem.Thumb)]</texture>
							<aspectratio scalediffuse="false">scale</aspectratio>
						</control>
						<!-- Play icon -->
						<control type="group">
							<visible>Control.HasFocus(2)</visible>
							<centertop>50%</centertop>
							<centerleft>50%</centerleft>
							<width>100</width>
							<height>100</height>

							<control type="image">
								<centertop>50%</centertop>
								<centerleft>50%</centerleft>
								<width>100</width>
								<height>100</height>
								<texture colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/button-circle.png</texture>
							</control>
							<control type="image">
								<centertop>50%</centertop>
								<centerleft>50%</centerleft>
								<width>45</width>
								<height>45</height>
								<texture colordiffuse="BACKGROUND_OPAQUE75">1080p/icons/play.png</texture>
							</control>
						</control>
						<!-- Unfocus darkening -->
						<include content="VideoNextUnFocusArtDarkening">
							<param name="reference_control_id">2</param>
						</include>
					</control>

					<!-- Details of next episode -->
					<control type="grouplist">
						<!-- Focus fade -->
						<include content="VideoNextFocusAnimation">
							<param name="reference_control_id">2</param>
						</include>

						<itemgap>PADDING_BASE_20P</itemgap>
						<top>PADDING_BASE_30P</top>

						<!-- TV show episode title -->
						<control type="label">
							<width>650</width>
							<height>HEIGHT_DETAILS_INFOLINE</height>
							<aligny>center</aligny>
							<font>SUBTITLE</font>
							<textcolor>$VAR[ContrastTextHighlightColor]</textcolor>
							<label>$INFO[Window(home).Property(Player.NextItem.Title)]</label>
						</control>

						<!-- Media info -->
						<control type="grouplist">
							<orientation>horizontal</orientation>
							<itemgap>PADDING_BASE_10P</itemgap>
							<height>HEIGHT_DETAILS_INFOLINE</height>
							<top>OFFSET_DETAILS_INFOLINE_CONTENT</top>

							<!-- Episode -->
							<include content="DetailsInfoText">
								<param name="text">S$INFO[Window(home).Property(Player.NextItem.Season)]·E$INFO[Window(home).Property(Player.NextItem.Episode)]</param>
								<param name="textcolor">$VAR[ColorsContrastForeground]</param>
								<param name="visible">!String.IsEmpty(Window(home).Property(Player.NextItem.Season)) + !String.IsEmpty(Window(home).Property(Player.NextItem.Episode))</param>
							</include>
							<!-- Premiered -->
							<include content="DetailsInfoText">
								<param name="text">$INFO[Window(home).Property(Player.NextItem.Premiered)]</param>
								<param name="textcolor">$VAR[ColorsContrastForeground]</param>
								<param name="visible">!String.IsEmpty(Window(home).Property(Player.NextItem.Premiered))</param>
							</include>
							<!-- Duration -->
							<include content="DetailsInfoText">
								<param name="text">$INFO[Window(home).Property(Player.NextItem.Duration)]</param>
								<param name="textcolor">$VAR[ColorsContrastForeground]</param>
								<param name="visible">!String.IsEmpty(Window(home).Property(Player.NextItem.Duration))</param>
							</include>
						</control>

						<!-- Summary -->
						<control type="textbox">
							<width>700</width>
							<height>200</height>

							<font>BODY2</font>
							<textcolor>$VAR[ColorsContrastForeground]</textcolor>
							<label>$INFO[Window(home).Property(Player.NextItem.Plot)]</label>
							<autoscroll delay="10000" time="1000" repeat="10000">true</autoscroll>
						</control>
					</control>
				</control>

				<!-- Hints -->
				<control type="grouplist">
					<orientation>horizontal</orientation>
					<itemgap>PADDING_BASE_10P</itemgap>
					<usecontrolcoords>true</usecontrolcoords>
					
					<height>HEIGHT_NEXTVIDEO_HINTS</height>
					<bottom>0</bottom>

					<!-- Back -->
					<control type="image">
						<centertop>50%</centertop>
						<width>SIZE_NEXTVIDEO_HINTS_ICON</width>
						<height>SIZE_NEXTVIDEO_HINTS_ICON</height>
						<texture colordiffuse="FOREGROUND">1080p/icons/back.png</texture>
					</control>
					<control type="label">
						<width>auto</width>
						<height>HEIGHT_NEXTVIDEO_HINTS</height>
						<aligny>center</aligny>
						<font>CAPTION_STRONG</font>
						<textcolor>FOREGROUND</textcolor>
						<label>Back</label>
					</control>

					<!-- Padding -->
					<control type="label">
						<width>PADDING_BASE_20P</width>
					</control>

					<!-- Ok -->
					<control type="image">
						<centertop>50%</centertop>
						<width>SIZE_NEXTVIDEO_HINTS_ICON</width>
						<height>SIZE_NEXTVIDEO_HINTS_ICON</height>
						<texture colordiffuse="FOREGROUND">1080p/icons/watched-bg.png</texture>
					</control>
					<control type="label">
						<width>auto</width>
						<height>HEIGHT_NEXTVIDEO_HINTS</height>
						<aligny>center</aligny>
						<font>CAPTION_STRONG</font>
						<textcolor>FOREGROUND</textcolor>
						<label>$VAR[VideoNextOkHint]</label>
					</control>
				</control>
			</control>
		</include>
	</controls>
</window>
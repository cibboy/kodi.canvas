<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- Default: safety hidden button to show side menu if something goes wrong -->
	<defaultcontrol>99999</defaultcontrol>
	<!-- Wait until lists have loaded, then move to the first one available -->
	<onload>Skin.TimerStart(homelistselection)</onload>
	<include content="VideoPlayingRedirect" />

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background with blurred quadrants -->
			<include content="BackgroundQuadrantBlur" />

			<!-- Darkening layer for when the left menu has focus -->
			<include content="DarkeningLayer">
				<param name="visible">$EXP[HasHomeMenuFocus]</param>
			</include>

			<!--
				Hidden list with ID 501 that mimics the currently selected list in order to have
				the same list ID across all windows where to pick details from.
			-->
			<include content="HomeActiveItemSyncList" />

			<!-- Loading spinner -->
			<control type="image">
				<visible>!$EXP[HasHomeLoaded]</visible>
				<animation effect="rotate" start="360" end="0" center="auto" time="ANIMATION_CRAWL" reversible="false" loop="true" condition="true">Conditional</animation>

				<width>100</width>
				<height>100</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-50.png</texture>
			</control>
			<!-- Safety button to show side menu if loading fails somehow -->
			<control type="button" id="99999">
				<visible allowhiddenfocus="true">false</visible>
				<onfocus condition="$EXP[HasHomeLoaded]">SetFocus(200)</onfocus>
				<onback>SetFocus(1001,0)</onback>
				<onleft>SetFocus(1001,0)</onleft>
				<onright>SetFocus(1001,0)</onright>
				<onup>SetFocus(1001,0)</onup>
				<ondown>SetFocus(1001,0)</ondown>
			</control>

			<!-- Main content -->
			<control type="group">
				<!-- Hide the content while initially loading lists -->
				<animation type="Conditional" condition="!$EXP[HasHomeLoaded]"><effect type="slide" start="0,0" end="0,-99999" time="0" tween="cubic" easing="out" reversible="true" /></animation>
				
				<top>PADDING_BASE_80P</top>
				<left>OFFSET_HOME_MENU_END_NEG</left>	<!-- Start assuming the side menu doesn't have focus. The animation will take care of shifting -->

				<control type="group">
					<animation type="Conditional" condition="$EXP[HasHomeMenuFocus]"><effect type="slide" start="0,0" end="OFFSET_HOME_MENU_END,0" time="ANIMATION_FAST" tween="cubic" easing="out" reversible="true" /></animation>
					
					<!-- Menu -->
					<include content="HomeMainMenu" />

					<!-- Content -->
					<control type="group">
						<left>WIDTH_HOME_MENU</left>

						<control type="group">
							<left>PADDING_BASE_60P</left>

							<!-- Selection details -->
							<control type="group">
								<visibile>!$EXP[IsHomeFullHeightMediaListVisible]</visibile>
								<include content="SelectionDetails" />
							</control>

							<!-- Empty list information -->
							<include content="HomeEmptyListInfoPlaceholder">
								<param name="visible">$EXP[IsHomeEmptyListPlaceholderVisible]</param>
							</include>

							<!-- Content (lists) -->
							<include content="HomeListsContent">
								<param name="darken_art">$EXP[HasHomeMenuFocus]</param>
							</include>
						</control>
					</control>
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<include content="BottomBar" />

			<!-- Right modal menus -->
			<include content="HomeMenuFlyout" />
		</include>
	</controls>
</window>
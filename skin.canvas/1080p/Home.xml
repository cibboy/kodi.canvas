<?xml version="1.0" encoding="UTF-8"?>
<window>
	<onload>RunScript(script.canvas.helper,init_home)</onload>
	<defaultcontrol>1</defaultcontrol>

	<controls>
		<!-- Background (fallback/default + blur quadrants/art) -->
		<control type="image">
			<width>100%</width>
			<height>100%</height>
			<texture>1080p/fallback/bg.png</texture>
		</control>
		<include content="BackgroundQuadrantBlur">
			<param name="visible">!$EXP[IsHomeLoading]</param>
			<param name="art">$VAR[HomeBackgroundArt]</param>
			<param name="show_art">!$EXP[IsHomeActivePagePictures]</param>
			<param name="blur">$VAR[HomeBlurArt]</param>
			<param name="blur_mode">$VAR[HomeBlurArtMode]</param>
		</include>

		<!-- Dark overlay to background for when the menu has focus -->
		<include content="DarkeningLayer">
			<param name="visible">Control.HasFocus(1)</param>
		</include>

		<!-- Window contents -->
		<control type="group">
			<!-- Main menu -->
			<include content="HomeMainMenu" />

			<!-- Content -->
			<include content="HomeContent" />

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Bottom bar -->
			<include content="BottomBar">
				<param name="show">$EXP[HasHomeDetailsStudio] + !$EXP[IsHomeLoading]</param>
				<param name="show_studio">$EXP[HasHomeDetailsStudio]</param>
				<param name="studio">$VAR[HomeDetailsStudio]</param>
			</include>

			<!-- Right modal menu -->
			<include content="HomeModalMenu" />
		</control>
	</controls>
</window>
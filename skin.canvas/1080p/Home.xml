<?xml version="1.0" encoding="UTF-8"?>
<window>
	<onload>RunScript(script.canvas.helper,init_home)</onload>
	<defaultcontrol>1</defaultcontrol>

	<controls>
		<!-- Background -->
		<include content="Background">
			<param name="show_art">!String.IsEqual(Window.Property(Home.ActivePage),pictures)</param>
		</include>

		<!-- Dark overlay on the left to improve legibility of text -->
		<include content="LegibilityDarkeningLayer">
			<param name="visible">!Control.HasFocus(1)</param>
		</include>

		<!-- Dark overlay to background for when the menu has focus -->
		<include content="DarkeningLayer">
			<param name="visible">Control.HasFocus(1)</param>
		</include>

		<!-- Window contents -->
		<control type="group">
			<!-- Main menu -->
			<include content="HomeMainMenu" />

			<!-- Content -->
			<include content="HomeContent" />

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Bottom bar -->
			<include content="BottomBar" />
		</control>
	</controls>
</window>
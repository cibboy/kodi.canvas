<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- Default: safety hidden button to show side menu if something goes wrong -->
	<defaultcontrol>99999</defaultcontrol>
	<!-- Wait until lists have loaded, then move to the first one available -->
	<onload condition="Skin.HasSetting(canvas.development) | !$EXP[HasHomeLoaded]">Skin.TimerStart(homelistselection)</onload>
	<include content="VideoPlayingRedirect" />

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background with blurred quadrants -->
			<include content="BackgroundQuadrantBlur" />

			<!-- Darkening layer for when the left menu has focus -->
			<include content="DarkeningLayer">
				<param name="visible">$EXP[HasHomeMenuFocus]</param>
			</include>

			<!-- Loading spinner -->
			<include content="LoadingSpinner">
				<param name="condition">!$EXP[HasHomeLoaded]</param>
				<param name="centertop">50%</param>
			</include>
			<!-- Safety button to show side menu if loading fails somehow -->
			<control type="button" id="99999">
				<visible allowhiddenfocus="true">false</visible>
				<onfocus condition="$EXP[HasHomeLoaded]">SetFocus(7000)</onfocus>
				<onback>SetFocus(1001,0)</onback>
				<onleft>SetFocus(1001,0)</onleft>
				<onright>SetFocus(1001,0)</onright>
				<onup>SetFocus(1001,0)</onup>
				<ondown>SetFocus(1001,0)</ondown>
			</control>

			<!-- Main content -->
			<control type="group">
				<!-- Hide the content while initially loading lists -->
				<animation type="Conditional" condition="!$EXP[HasHomeLoaded]">
					<effect type="slide" start="0,0" end="0,-99999" time="0" tween="cubic" easing="out" reversible="true" />
				</animation>
				
				<top>PADDING_BASE_80P</top>
				<left>OFFSET_HOME_MENU_END_NEG</left>	<!-- Start assuming the side menu doesn't have focus. The animation will take care of shifting -->

				<control type="group">
					<animation type="Conditional" condition="$EXP[HasHomeMenuFocus] | $EXP[IsHomeFlyoutVisible]">
						<effect type="slide" start="0,0" end="OFFSET_HOME_MENU_END,0" time="ANIMATION_FAST" tween="cubic" easing="out" reversible="true" />
					</animation>
					
					<!-- Menu -->
					<include content="HomeMainMenu" />

					<!-- Content -->
					<control type="group">
						<left>WIDTH_HOME_MENU</left>

						<control type="group">
							<left>PADDING_BASE_60P</left>

							<!-- Selection details -->
							<include content="SelectionDetails" />

							<!-- Content (lists) -->
							<include content="HomeListsContent">
								<param name="darken_art">$EXP[HasHomeMenuFocus]</param>
							</include>
						</control>
					</control>
				</control>
			</control>

			<!-- Clock -->
			<include content="TopBar" />

			<!-- Studio -->
			<include content="BottomBar" />

			<!-- Right modal menus -->
			<include content="HomeMenuFlyout" />
			<include content="HomeFilterFlyout" />
		</include>
	</controls>
</window>
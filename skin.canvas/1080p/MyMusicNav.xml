<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">9999</defaultcontrol>
	<views>501,502</views>
	<onunload>ClearProperty(LibraryNav,music)</onunload>

	<controls>
		<!--
			View type redirect button (based on content/source).
			Autochange the view type if not the expected one.
		-->
		<control type="button" id="9999">
			<visible allowhiddenfocus="true">false</visible>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(501)">Sendclick(2)</onfocus>
			<onfocus condition="!$EXP[IsMediaNavLibraryNavigation]">SetFocus(501)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(502)">Sendclick(2)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetFocus(502)</onfocus>
			<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetProperty(LibraryNav,true,music)</onfocus>
		</control>
		<!-- View type selector button (hidden as not used by the user) -->
		<control type="button" id="2">
			<visible>false</visible>
		</control>

		<include content="Center169AspectRatio">
			<!-- 501 view for album navigation from home -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>

				<!-- Background -->
				<include content="BackgroundSingleBlur">
					<param name="darken">false</param>
				</include>
				<!-- Darkening overlay -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<fadetime>ANIMATION_CRAWL</fadetime>
					<texture colordiffuse="BACKGROUND_OPAQUE50" diffuse="1080p/diffuse/background.png" flipx="true" flipy="true">diffuse.png</texture>
				</control>

				<control type="group">
					<top>PADDING_BASE_80P</top>
					<left>PADDING_BASE_200P</left>

					<!-- Details -->
					<control type="grouplist">
						<itemgap>PADDING_BASE_20P</itemgap>

						<!-- Album title -->
						<control type="group">
							<height>HEIGHT_DETAILS_TITLE_SECTION</height>
							<control type="label">
								<top>40</top>
								<width>1400</width>
								<height>HEIGHT_DETAILS_TITLE</height>
								<aligny>center</aligny>
								<font>TITLE1</font>
								<textcolor>$VAR[ContrastTextHighlightColor]</textcolor>
								<label>$INFO[ListItem.Album]</label>
							</control>
						</control>

						<!-- Year -->
						<include content="DetailsInfoText">
							<param name="text">$INFO[ListItem.Year]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
						</include>

						<!-- Artist -->
						<include content="DetailsInfoText">
							<param name="text">$INFO[ListItem.Artist]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
						</include>
					</control>

					<!-- Cover -->
					<control type="image">
						<top>PADDING_BASE_200P</top>
						<right>PADDING_BASE_200P</right>
						<width>SIZE_PLAYER_ALBUMART</width>
						<height>SIZE_PLAYER_ALBUMART</height>
						<texture fallback="1080p/fallback/music.png" background="true" diffuse="1080p/diffuse/square.png">$INFO[ListItem.Art(thumb)]</texture>
						<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
						<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
						<aspectratio scalediffuse="false">scale</aspectratio>
					</control>

					<!-- Available songs -->
					<control type="group">
						<top>PADDING_BASE_200P</top>
						<bottom>PADDING_BASE_150P</bottom>

						<control type="group">
							<top>PADDING_BASE_150P</top>

							<!-- Label -->
							<include content="ListLabel">
								<param name="id">99501</param>
								<param name="label">Songs</param>
								<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
							</include>

							<!-- List of songs -->
							<control type="list" id="501">
								<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>
								<top>OFFSET_HOME_LIST_AFTER_LABEL</top>
								<bottom>0</bottom>

								<onright>SetFocus(600)</onright>

								<itemlayout width="WIDTH_ALBUMNAV_ITEM" height="HEIGHT_ALBUMNAV_ITEM">
									<include content="AlbumNavSongListLayoutContent">
										<param name="font">CAPTION</param>
									</include>
								</itemlayout>

								<focusedlayout width="WIDTH_ALBUMNAV_ITEM" height="HEIGHT_ALBUMNAV_ITEM">
									<include content="AlbumNavSongListLayoutContent">
										<param name="font">CAPTION_STRONG</param>
										<param name="highlight_background">BACKGROUND_OPAQUE20</param>
									</include>
								</focusedlayout>
							</control>
						</control>
					</control>

					<!-- Play all -->
					<control type="grouplist" id="600">
						<orientation>horizontal</orientation>
						<itemgap>0</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<defaultcontrol always="true">94600</defaultcontrol>

						<right>PADDING_BASE_200P</right>
						<bottom>PADDING_BASE_150P</bottom>
						<width>SIZE_PLAYER_ALBUMART</width>
						<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

						<onleft>SetFocus(501)</onleft>

						<!-- Left part of the button (with space for icon) -->
						<control type="image" id="91600">
							<left>PADDING_BASE_20P</left>
							<width>WIDTH_MEDIANAV_ACTIONBUTTON_START</width>
							<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
							<texture colordiffuse="$VAR[AlbumNavPlayAllButtonColor]">1080p/controls/round-button-extended-start.png</texture>
						</control>
						<!-- Icon -->
						<control type="image" id="92600">
							<left>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED</left>
							<top>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP</top>
							<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
							<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
							<texture colordiffuse="$VAR[AlbumNavContrastButtonIconColor]">1080p/icons/play.png</texture>
						</control>
						<!-- Actual button (with autowidth text) -->
						<control type="button" id="94600">
							<width>auto</width>
							<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

							<texturefocus colordiffuse="$VAR[AlbumNavPlayAllButtonColor]">1080p/controls/round-button-middle.png</texturefocus>
							<texturenofocus colordiffuse="$VAR[AlbumNavPlayAllButtonColor]">1080p/controls/round-button-middle.png</texturenofocus>
							<font>BODY2_STRONG</font>
							<textcolor>$VAR[AlbumNavContrastButtonIconColor]</textcolor>
							<focusedcolor>BACKGROUND_OPAQUE75</focusedcolor>
							<textoffsety>0</textoffsety>
							<textoffsetx>0</textoffsetx>
							<label>  Play all</label>

							<onclick>SetFocus(501)</onclick>
							<onclick>RunScript(script.canvas.helper,play_full_album,$INFO[Container(501).FolderPath])</onclick>
							<onclick>PlayerControl(RandomOff)</onclick>
						</control>
						<!-- Right part of the button -->
						<control type="image" id="93600">
							<width>WIDTH_MEDIANAV_ACTIONBUTTON_END</width>
							<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
							<texture colordiffuse="$VAR[AlbumNavPlayAllButtonColor]" flipx="true">1080p/controls/round-button-start.png</texture>
						</control>
					</control>
				</control>
			</control>

			<!-- 502 view for navigation from settings > library -->
			<include content="MediaNavItemListForLibrary">
				<param name="title">Music library</param>
			</include>

			<!-- Clock -->
			<include content="TopBar" />
		</include>
	</controls>
</window>
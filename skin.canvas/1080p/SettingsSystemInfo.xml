<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>94</defaultcontrol>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Background (monocolor) -->
			<include content="SettingsBackground" />

			<control type="group">
				<top>PADDING_BASE_80P</top>
				<bottom>PADDING_BASE</bottom>
				<left>0</left>
				<right>PADDING_BASE</right>
				
				<!-- Menu -->
				<control type="group">
					<width>WIDTH_HOME_MENU</width>

					<!-- Logo -->
					<control type="image">
						<width>SIZE_HOME_MENU_LOGO</width>
						<height>SIZE_HOME_MENU_LOGO</height>
						<centerleft>50%</centerleft>
						<texture colordiffuse="HIGHLIGHT">$VAR[LogoIcon]</texture>
						<aspectratio>keep</aspectratio>
					</control>

					<!-- Menu -->
					<control type="grouplist" id="200">
						<orientation>vertical</orientation>
						<itemgap>-20</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<top>200</top>
						<bottom>0</bottom>

						<onright condition="Control.IsVisibile(30)">SetFocus(60)</onright>

						<include content="SysteminfoMenuItem">
							<param name="id">95</param>
							<param name="icon">1080p/icons/systeminfo.png</param>
							<param name="onup">100</param>
							<param name="ondown">94</param>
						</include>
						<include content="SysteminfoMenuItem">
							<param name="id">94</param>
							<param name="icon">1080p/icons/drive.png</param>
							<param name="onup">95</param>
							<param name="ondown">96</param>
						</include>
						<include content="SysteminfoMenuItem">
							<param name="id">96</param>
							<param name="icon">1080p/icons/network.png</param>
							<param name="onup">94</param>
							<param name="ondown">97</param>
						</include>
						<include content="SysteminfoMenuItem">
							<param name="id">97</param>
							<param name="icon">1080p/icons/video.png</param>
							<param name="onup">96</param>
							<param name="ondown">98</param>
						</include>
						<include content="SysteminfoMenuItem">
							<param name="id">98</param>
							<param name="icon">1080p/icons/system.png</param>
							<param name="onup">97</param>
							<param name="ondown">100</param>
						</include>
						<include content="SysteminfoMenuItem">
							<param name="id">100</param>
							<param name="icon">1080p/icons/info.png</param>
							<param name="onup">98</param>
							<param name="ondown">95</param>
							<param name="onright">60</param>
						</include>
					</control>
				</control>

				<!-- Content -->
				<control type="group">
					<left>350</left>
					<right>0</right>
					<height>100%</height>

					<!-- Title -->
					<control type="label" id="40">
						<width>auto</width>
						<height>HEIGHT_DETAILS_TITLE</height>
						<aligny>center</aligny>
						<font>TITLE2</font>
						<textcolor>HIGHLIGHT</textcolor>
						<label></label>
					</control>

					<!-- Content (labels) -->
					<control type="grouplist">
						<orientation>vertical</orientation>
						<itemgap>PADDING_BASE_20P</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<left>0</left>
						<right>0</right>
						<top>HEIGHT_DETAILS_TITLE_SECTION</top>
						<bottom>0</bottom>

						<!-- Labels -->
						<include content="SysteminfoLabel"><param name="id">2</param></include>
						<include content="SysteminfoLabel"><param name="id">3</param></include>
						<include content="SysteminfoLabel"><param name="id">4</param></include>
						<include content="SysteminfoLabel"><param name="id">5</param></include>
						<include content="SysteminfoLabel"><param name="id">6</param></include>
						<include content="SysteminfoLabel"><param name="id">7</param></include>
						<include content="SysteminfoLabel"><param name="id">8</param></include>
						<include content="SysteminfoLabel"><param name="id">9</param></include>
						<include content="SysteminfoLabel"><param name="id">10</param></include>
						<include content="SysteminfoLabel"><param name="id">11</param></include>
						<include content="SysteminfoLabel"><param name="id">12</param></include>
						<include content="SysteminfoLabel"><param name="id">13</param></include>
					</control>
					<!-- Content (privacy) -->
					<control type="grouplist">
						<orientation>vertical</orientation>
						<itemgap>PADDING_BASE_20P</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<left>0</left>
						<right>0</right>
						<top>HEIGHT_DETAILS_TITLE_SECTION</top>
						<bottom>0</bottom>

						<!-- Privacy policy -->
						<control type="textbox" id="30">
							<width>1000</width>
							<!-- SCREEN_HEIGHT - PADDING_BASE_80P - HEIGHT_DETAILS_TITLE - 100 (build info with padding) - PADDING_BASE -->
							<height>640</height>
							<font>BODY</font>
							<align>left</align>
							<textcolor>FOREGROUND</textcolor>
							<label></label>
							<pagecontrol>60</pagecontrol>
							<autoscroll delay="5000" repeat="7500" time="5000">!Control.HasFocus(60)</autoscroll>
						</control>
						

						<!-- Build info -->
						<control type="grouplist">
							<visible>Control.IsVisible(30)</visible>
							<orientation>horizontal</orientation>
							<itemgap>PADDING_BASE_10P</itemgap>

							<top>PADDING_BASE_30P</top>
							<width>100%</width>
							<height>FONT_SIZE_SUBTITLE</height>

							<include content="SysteminfoLabel">
								<param name="id">152</param>
								<param name="font">CAPTION_STRONG</param>
								<param name="color">HIGHLIGHT</param>
								<param name="label">Build:</param>
							</include>
							<include content="SysteminfoLabel">
								<param name="id">400</param>
								<param name="font">CAPTION</param>
								<param name="color">HIGHLIGHT</param>
								<param name="label">$INFO[System.BuildVersionShort]$INFO[System.BuildVersionCode, (,)]</param>
							</include>
							<include content="SysteminfoLabel">
								<param name="id">401</param>
								<param name="font">CAPTION_STRONG</param>
								<param name="color">HIGHLIGHT</param>
								<param name="label">  Git:</param>
							</include>
							<include content="SysteminfoLabel">
								<param name="id">402</param>
								<param name="font">CAPTION</param>
								<param name="color">HIGHLIGHT</param>
								<param name="label">$INFO[System.BuildVersionGit]</param>
							</include>
							<include content="SysteminfoLabel">
								<param name="id">153</param>
								<param name="font">CAPTION_STRONG</param>
								<param name="color">HIGHLIGHT</param>
								<param name="label">  Date:</param>
							</include>
							<include content="SysteminfoLabel">
								<param name="id">53</param>
								<param name="font">CAPTION</param>
								<param name="color">HIGHLIGHT</param>
							</include>
						</control>
					</control>

					<!-- Privacy scrollbar -->
					<control type="scrollbar" id="60">
						<right>0</right>
						<top>HEIGHT_DETAILS_TITLE_SECTION</top>
						<!-- SCREEN_HEIGHT - PADDING_BASE_80P - HEIGHT_DETAILS_TITLE - 100 (build info with padding) - PADDING_BASE -->
						<height>640</height>
						<orientation>vertical</orientation>
						<onleft>SetFocus(200)</onleft>
						<visible>Control.IsVisible(30)</visible>
					</control>

					<!-- Additional system info -->
					<control type="grouplist">
						<visible>Control.HasFocus(95)</visible>
						<orientation>vertical</orientation>
						<itemgap>PADDING_BASE_10P</itemgap>

						<left>0</left>
						<right>0</right>
						<bottom>0</bottom>
						<height>138</height>	<!-- (FONT_SIZE_SUBTITLE * 2) + (12 * 2) + (PADDING_BASE_10P * 3) -->

						<!-- RAM values, with bar -->
						<include content="SysteminfoLabel">
							<param name="id">410</param>
							<param name="font">CAPTION_STRONG</param>
							<param name="color">HIGHLIGHT</param>
							<param name="label">Memory: $INFO[System.Memory(used)] [B]/[/B] $INFO[System.Memory(total)] [B]-[/B] $INFO[System.Memory(used.percent)]</param>
						</include>
						<control type="progress">
							<width>730</width>
							<info>System.Memory(used)</info>
						</control>
						<!-- CPU values, with bar -->
						<include content="SysteminfoLabel">
							<param name="visible">System.SupportsCPUUsage</param>
							<param name="id">411</param>
							<param name="font">CAPTION_STRONG</param>
							<param name="color">HIGHLIGHT</param>
							<param name="label">CPU: $INFO[System.CPUUsage]</param>
						</include>
						<control type="progress">
							<width>730</width>
							<info>System.CPUUsage</info>
							<visible>System.SupportsCPUUsage</visible>
						</control>
					</control>
				</control>
			</control>
		</include>
	</controls>
</window>
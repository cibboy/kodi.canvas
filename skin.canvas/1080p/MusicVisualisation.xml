<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol></defaultcontrol>

	<controls>
		<!-- Background -->
		<control type="image">
			<!-- Fake blur by using huge zoom, so it's responsive to changes -->
			<animation condition="true" effect="zoom" center="auto" end="10000" time="0">Conditional</animation>
			<!-- Continuous fading and back + slide (VERY slow) to give a sense of motion -->
			<animation condition="true" effect="fade" start="100" end="50" time="5000" pulse="true">Conditional</animation>
			<animation condition="true" effect="slide" start="-500,-200" end="500,200" time="360000" pulse="true">Conditional</animation>
			<width>100%</width>
			<height>100%</height>
			<texture fallback="1080p/fallback/bg.png">$INFO[Player.Art(thumb)]</texture>
			<aspectratio>scale</aspectratio>
		</control>
		<!-- Darkening -->
		<include content="DarkeningLayer" />

		<!-- Art and info -->
		<control type="group">
			<top>PADDING_BASE_150P</top>
			<bottom>PADDING_BASE_200P</bottom>
			<right>PADDING_BASE_200P</right>
			<left>PADDING_BASE_200P</left>

			<!-- Cover -->
			<control type="image">
				<visible>!String.IsEmpty(Player.Art(thumb))</visible>
				<width>SIZE_PLAYER_ALBUMART</width>
				<height>SIZE_PLAYER_ALBUMART</height>
				<texture background="true" diffuse="1080p/diffuse/square.png">$INFO[Player.Art(thumb)]</texture>
				<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
				<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
				<aspectratio scalediffuse="false">scale</aspectratio>
			</control>

			<!-- Info -->
			<control type="grouplist">
				<orientation>vertical</orientation>
				<itemgap>PADDING_BASE_20P</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<width>WIDTH_PLAYER_MUSICINFO</width>
				<height>100%</height>
				<right>0</right>

				<!-- Title -->
				<control type="label">
					<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
					<height>FONT_SIZE_TITLE1</height>
					<font>TITLE2</font>
					<textcolor>HIGHLIGHT</textcolor>
					<label>$VAR[DetailsTitle]</label>
				</control>

				<!-- Album name -->
				<control type="label">
					<top>PADDING_BASE_10P</top>
					<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
					<height>HEIGHT_DETAILS_INFOLINE</height>
					<font>SUBTITLE</font>
					<label>$VAR[DetailsTitle2]</label>
				</control>

				<!-- Track number -->
				<control type="label">
					<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
					<font>CAPTION_STRONG</font>
					<label>$VAR[DetailsTrackNumber]</label>
				</control>

				<!-- Artist -->
				<control type="label">
					<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
					<font>CAPTION_STRONG</font>
					<label>$VAR[DetailsArtist]</label>
				</control>

				<!-- Year -->
				<control type="label">
					<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
					<font>CAPTION_STRONG</font>
					<label>$VAR[DetailsYear]</label>
				</control>
			</control>
		</control>

		<!-- Pause icon -->
		<include content="PlayerStatusIndicatorFade">
			<param name="id">100</param>
			<param name="size">SIZE_PLAYER_STATUS_INDICATOR</param>
			<param name="icon">1080p/icons/pause.png</param>
			<param name="condition">Player.Paused</param>
		</include>
		<!-- Forwarding icon -->
		<include content="PlayerStatusIndicatorFade">
			<param name="id">101</param>
			<param name="size">SIZE_PLAYER_STATUS_INDICATOR</param>
			<param name="icon">1080p/icons/ff.png</param>
			<param name="condition">Player.Forwarding</param>
		</include>
		<!-- Rewinding icon -->
		<include content="PlayerStatusIndicatorFade">
			<param name="id">102</param>
			<param name="size">SIZE_PLAYER_STATUS_INDICATOR</param>
			<param name="icon">1080p/icons/ff.png</param>
			<param name="flip_icon">true</param>
			<param name="condition">Player.Rewinding</param>
		</include>

		<!-- Caching spinner -->
		<control type="image" id="103">
			<visible>Player.Caching</visible>
			<animation effect="rotate" start="360" end="0" center="auto" time="ANIMATION_CRAWL" reversible="false" loop="true" condition="true">Conditional</animation>

			<width>100</width>
			<height>100</height>
			<centertop>50%</centertop>
			<centerleft>50%</centerleft>
			<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-50.png</texture>
		</control>

		<!-- Seek right -->
		<include content="PlayerSeekingIndicator">
			<param name="id">104</param>
			<param name="condition">Player.Seeking + !String.StartsWith(Player.SeekStepSize,-) + !String.IsEmpty(Player.SeekStepSize)</param>
			<param name="darkening_left">SCREEN_WIDTH_HALF</param>
			<param name="content_left">1520</param>
			<param name="slide_to">200</param>
		</include>
		<!-- Seek left -->
		<include content="PlayerSeekingIndicator">
			<param name="id">105</param>
			<param name="flip">true</param>
			<param name="condition">Player.Seeking + String.StartsWith(Player.SeekStepSize,-) + !String.IsEmpty(Player.SeekStepSize)</param>
			<param name="darkening_left">0</param>
			<param name="content_left">0</param>
			<param name="slide_from">300</param>
			<param name="slide_to">100</param>
		</include>

		<!-- Progress and time (during seeking) -->
		<control type="group" id="300">
			<visible>Player.Seeking + !Window.IsActive(VideoOSD.xml)</visible>
			<include content="ShowHideFadeSlideVerticalAnimation">
				<param name="speed">ANIMATION_MID</param>
				<param name="delay_out">$VAR[PlayerOSDSeekProgressHideDelay]</param>
			</include>

			<include content="PlayerOSDProgress" />
		</control>
	</controls>
</window>
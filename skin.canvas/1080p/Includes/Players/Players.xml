<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Players/Variables.xml" />

	<!-- Fading indicator (like pause or forwarding/rewinding) -->
	<include name="PlayerStatusIndicatorFade">
		<param name="id"></param>
		<param name="size"></param>
		<param name="icon"></param>
		<param name="flip_icon">false</param>
		<param name="text"></param>
		<param name="condition">false</param>

		<definition>
			<control type="image" id="$PARAM[id]">
				<!-- Show only on condition, zoom and fade out briefly -->
				<visible>$PARAM[condition]</visible>
				<animation type="Visible" reversible="false">
					<effect type="zoom" start="100" end="200" time="ANIMATION_CRAWL" tween="circle" easing="out" center="auto" />
					<effect type="fade" start="100" end="0" time="ANIMATION_CRAWL" tween="circle" easing="out" />
				</animation>

				<width>$PARAM[size]</width>
				<height>$PARAM[size]</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture flipx="$PARAM[flip_icon]">$PARAM[icon]</texture>
			</control>
		</definition>
	</include>

	<!-- Seeking indicator -->
	<include name="PlayerSeekingIndicator">
		<param name="id"></param>
		<param name="size"></param>
		<param name="flip">false</param>
		<param name="condition">false</param>
		<param name="darkening_left"></param>
		<param name="content_left"></param>
		<param name="slide_from">0</param>
		<param name="slide_to">0</param>

		<definition>
			<!-- Darkening -->
			<control type="image" id="$PARAM[id]">
				<!-- Show only on condition, fade -->
				<visible>$PARAM[condition]</visible>
				<include content="ShowHideFadeAnimation" />

				<width>50%</width>
				<height>100%</height>
				<left>$PARAM[darkening_left]</left>
				<texture flipx="$PARAM[flip]" colordiffuse="BACKGROUND">1080p/diffuse/fade-seek.png</texture>
			</control>

			<!-- Indicator -->
			<control type="image" id="$PARAM[id]">
				<!-- Show only on condition, slide and fade out briefly -->
				<visible>$PARAM[condition]</visible>
				<animation type="Visible" reversible="false">
					<effect type="slide" start="$PARAM[slide_from],0" end="$PARAM[slide_to],0" time="ANIMATION_CRAWL" tween="circle" easing="out" center="auto" />
					<effect type="fade" start="100" end="0" time="ANIMATION_CRAWL" tween="circle" easing="out" />
				</animation>

				<width>SIZE_PLAYER_SEEK_INDICATOR</width>
				<height>SIZE_PLAYER_SEEK_INDICATOR</height>
				<centertop>50%</centertop>
				<left>$PARAM[content_left]</left>
				<texture flipx="$PARAM[flip]">1080p/icons/chevron-right.png</texture>
			</control>

			<!-- Amount -->
			<control type="label" id="$PARAM[id]">
				<!-- Show only on condition, fade -->
				<visible>$PARAM[condition]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">ANIMATION_CRAWL</param>
				</include>

				<centertop>50%</centertop>
				<left>$PARAM[content_left]</left>
				<height>$PARAM[size]</height>
				<width>400</width>
				<align>center</align>
				<aligny>center</aligny>
				<font>TITLE3</font>
				<textcolor>HIGHLIGHT</textcolor>
				<label>$INFO[Player.SeekStepSize]</label>
			</control>
		</definition>
	</include>

	<!-- Generic OSD -->
	<include name="PlayerOSD">
		<param name="onleft">SetFocus(100)</param>
		<param name="onright">SetFocus(100)</param>
		<param name="ondown">noop</param>

		<definition>
			<control type="group">
				<width>SCREEN_WIDTH</width>
				<height>HEIGHT_OSD</height>
				<bottom>0</bottom>

				<!-- Hidden button for progress focus -->
				<control type="button" id="150">
					<visible allowhiddenfocus="true">false</visible>
					<onup>Close</onup>
					<ondown>SetFocus(102)</ondown>
					<!-- [Video OSD] With click activate frame advance, with left/right advance by frame (seek otherwise)-->
					<onleft condition="!String.IsEqual(Window(videoosd).Property(FrameAdvance),true) | !$EXP[IsVideoPlayerVisible]">PlayerControl(SmallSkipBackward)</onleft>
					<onleft condition="String.IsEqual(Window(videoosd).Property(FrameAdvance),true)">Seek(-1)</onleft>
					<onright condition="!String.IsEqual(Window(videoosd).Property(FrameAdvance),true) | !$EXP[IsVideoPlayerVisible]">PlayerControl(SmallSkipForward)</onright>
					<onright condition="String.IsEqual(Window(videoosd).Property(FrameAdvance),true)">PlayerControl(FrameAdvance(1))</onright>
					<onclick condition="$EXP[IsVideoPlayerVisible] + !String.IsEqual(Window(videoosd).Property(FrameAdvance),true)">SetProperty(FrameAdvance,true,videoosd)</onclick>
					<onclick condition="$EXP[IsVideoPlayerVisible] + String.IsEqual(Window(videoosd).Property(FrameAdvance),true)">ClearProperty(FrameAdvance)</onclick>
				</control>

				<!-- Darkening -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<texture colordiffuse="BACKGROUND_OPAQUE90">1080p/diffuse/fade-osd.png</texture>
				</control>

				<!-- Progress and time -->
				<include content="PlayerOSDProgress" />

				<!-- Controls -->
				<control type="grouplist" id="100">
					<orientation>horizontal</orientation>
					<itemgap>PADDING_BASE_20P_NEG</itemgap>
					<usecontrolcoords>true</usecontrolcoords>
					<defaultcontrol>102</defaultcontrol>

					<height>SIZE_OSD_BUTTON_BIG_FOCUS</height>
					<left>PADDING_BASE_125P</left>
					<right>PADDING_BASE_125P</right>
					<centerbottom>PADDING_BASE_125P</centerbottom>

					<onleft>$PARAM[onleft]</onleft>
					<onright>$PARAM[onright]</onright>
					<onup>SetFocus(150)</onup>
					<ondown>$PARAM[ondown]</ondown>

					<!-- Previous/Rewind -->
					<include content="PlayerOSDButton">
						<param name="id">101</param>
						<param name="size">SIZE_OSD_BUTTON</param>
						<param name="size_focus">SIZE_OSD_BUTTON_FOCUS</param>
						<param name="size_icon">SIZE_OSD_BUTTON_ICON</param>
						<param name="icon">$VAR[PlayerOSDNextForwardIcon]</param>
						<param name="flip_icon">true</param>
						<param name="action">$VAR[PlayerOSDPrevRewindAction]</param>
					</include>
					<!-- Play/pause -->
					<include content="PlayerOSDButton">
						<param name="id">102</param>
						<param name="size">SIZE_OSD_BUTTON_BIG</param>
						<param name="size_focus">SIZE_OSD_BUTTON_BIG_FOCUS</param>
						<param name="size_icon">SIZE_OSD_BUTTON_BIG_ICON</param>
						<param name="icon">$VAR[PlayerOSDPlayPauseIcon]</param>
						<param name="action">PlayerControl(Play)</param>
					</include>
					<!-- Next/Forward -->
					<include content="PlayerOSDButton">
						<param name="id">103</param>
						<param name="size">SIZE_OSD_BUTTON</param>
						<param name="size_focus">SIZE_OSD_BUTTON_FOCUS</param>
						<param name="size_icon">SIZE_OSD_BUTTON_ICON</param>
						<param name="icon">$VAR[PlayerOSDNextForwardIcon]</param>
						<param name="action">$VAR[PlayerOSDNextForwardAction]</param>
					</include>
				</control>

				<!-- Custom controls -->
				<nested />
			</control>
		</definition>
	</include>
	<!-- OSD progress -->
	<include name="PlayerOSDProgress">
		<definition>
			<!-- Progress -->
			<control type="group" id="301">
				<centerbottom>OFFSET_OSD_PROGRESS</centerbottom>
				<left>PADDING_BASE_125P</left>
				<right>PADDING_BASE_125P</right>
				<height>12</height>
				
				<control type="progress" id="302">	<!-- Caching -->
					<texturebg colordiffuse="FOREGROUND_OPAQUE50" border="6">1080p/progress/bg.png</texturebg>
					<midtexture colordiffuse="FOREGROUND_OPAQUE50" border="6">1080p/progress/mid.png</midtexture>
					<info>Player.ProgressCache</info>
				</control>
				<control type="progress" id="303">	<!-- Actual progress -->
					<texturebg colordiffuse="TRANSPARENT" border="6">1080p/progress/bg.png</texturebg>
					<info>Player.Progress</info>
				</control>
				<control type="ranges" id="304">	<!-- Chapters -->
					<info>Player.Chapters</info>
				</control>
				<control type="progress" id="305">	<!-- Progress nib (visible when focus is on progress) -->
					<visible>Control.HasFocus(150)</visible>
					<include content="ShowHideFadeAnimation">
						<param name="speed">ANIMATION_FAST</param>
					</include>

					<top>-8</top>
					<left>-12</left>
					<height>12</height>
					<texturebg colordiffuse="TRANSPARENT" border="6">1080p/progress/bg.png</texturebg>
					<midtexture colordiffuse="TRANSPARENT" border="6">1080p/progress/mid.png</midtexture>
					<righttexture colordiffuse="$VAR[PlayerOSDProgressNibColor]" border="10">1080p/progress/nib.png</righttexture>
					<info>Player.Progress</info>
				</control>
			</control>

			<!-- Time -->
			<control type="group" id="310">
				<bottom>OFFSET_OSD_PROGRESS</bottom>
				<left>PADDING_BASE_125P</left>
				<right>PADDING_BASE_125P</right>
				<height>FONT_SIZE_CAPTION2</height>

				<!-- Elapsed -->
				<control type="label" id="311">
					<top>PADDING_BASE_30P</top>
					<font>CAPTION_STRONG</font>
					<label>$VAR[PlayerOSDElapsedTime]</label>
				</control>
				<!-- Remaining -->
				<control type="label" id="312">
					<top>PADDING_BASE_30P</top>
					<right>0</right>
					<width>100%</width>
					<font>CAPTION_STRONG</font>
					<align>right</align>
					<label>-$INFO[Player.TimeRemaining()]</label>
				</control>
			</control>
		</definition>
	</include>
	<!-- OSD info text -->
	<include name="PlayerOSDInfoText">	
		<param name="visible">true</param>
		<param name="text"></param>

		<definition>
			<control type="label">
				<visible>$PARAM[visible]</visible>
				<bottom>6</bottom>
				<height>FONT_SIZE_CAPTION</height>
				<width>auto</width>
				<aligny>center</aligny>
				<font>CAPTION_STRONG</font>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>
	<!-- OSD button -->
	<include name="PlayerOSDButton">
		<param name="id"></param>
		<param name="size"></param>
		<param name="size_focus"></param>
		<param name="size_icon"></param>
		<param name="icon"></param>
		<param name="flip_icon">false</param>
		<param name="action"></param>

		<definition>
			<control type="group" id="99$PARAM[id]">
				<width>SIZE_OSD_BUTTON_BIG_FOCUS</width>
				<height>SIZE_OSD_BUTTON_BIG_FOCUS</height>

				<!-- Background -->
				<control type="image">	<!-- Without focus -->
					<visible>!Control.HasFocus($PARAM[id])</visible>

					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>$PARAM[size]</width>
					<height>$PARAM[size]</height>
					<fadetime>0</fadetime>
					<texture colordiffuse="BACKGROUND_OPAQUE20">1080p/diffuse/circle.png</texture>
				</control>
				<control type="image">	<!-- With focus -->
					<visible>Control.HasFocus($PARAM[id])</visible>

					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>$PARAM[size_focus]</width>
					<height>$PARAM[size_focus]</height>
					<fadetime>0</fadetime>
					<texture colordiffuse="FOREGROUND_ACCENT">1080p/controls/button-circle.png</texture>
				</control>

				<!-- Icon -->
				<control type="image">	<!-- Without focus -->
					<visible>!Control.HasFocus($PARAM[id])</visible>

					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>$PARAM[size_icon]</width>
					<height>$PARAM[size_icon]</height>
					<fadetime>0</fadetime>
					<texture colordiffuse="FOREGROUND_OPAQUE75" flipx="$PARAM[flip_icon]">$PARAM[icon]</texture>
				</control>
				<control type="image">	<!-- With focus -->
					<visible>Control.HasFocus($PARAM[id])</visible>

					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>$PARAM[size_icon]</width>
					<height>$PARAM[size_icon]</height>
					<fadetime>0</fadetime>
					<texture colordiffuse="BACKGROUND_OPAQUE75" flipx="$PARAM[flip_icon]">$PARAM[icon]</texture>
				</control>
			</control>

			<!-- Hidden button for action -->
			<control type="button" id="$PARAM[id]">
				<visible allowhiddenfocus="true">false</visible>
				<onclick>$PARAM[action]</onclick>
			</control>
		</definition>
	</include>

	<!-- DialogSettings for player -->
	<include name="PlayerDialogSettings">
		<control type="group">
			<include content="ShowHideFadeSlideVerticalAnimation">
				<param name="speed">ANIMATION_MID</param>
				<param name="visible_condition">WindowOpen</param>
				<param name="hidden_condition">WindowClose</param>
			</include>

			<top>PADDING_BASE_80P</top>
			<bottom>PADDING_BASE_80P</bottom>
			<width>WIDTH_BACKGROUND_SPLIT</width>
			
			<!-- Options -->
			<control type="group">
				<left>PADDING_SETTINGS_WIDE_SIDE</left>
				<right>PADDING_SETTINGS_WIDE_SIDE</right>

				<!-- Option name -->
				<control type="label" id="2">
					<width>auto</width>
					<top>PADDING_BASE_30P</top>
					<height>FONT_SIZE_TITLE3</height>
					<right>PADDING_SETTINGS_TITLE</right>
					<left>PADDING_SETTINGS_TITLE</left>
					<font>TITLE3</font>
					<label></label>
				</control>

				<!-- List of options -->
				<control type="grouplist" id="5">
					<itemgap>GAP_SETTINGS_LIST_OPTION</itemgap>
					<usecontrolcoords>true</usecontrolcoords>
					
					<top>OFFSET_SETTINGS_OPTIONS_START</top>
					<height>HEIGHT_SETTINGS_DIALOG_LIST</height>
					<width>100%</width>

					<!-- Close dialog on left, go to ok/cancel on right -->
					<onleft>Back</onleft>
					<onright>SetFocus(999)</onright>
				</control>

				<!-- Button template -->
				<control type="button" id="7">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<texturefocus colordiffuse="$VAR[SettingsOptionButtonColor]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
				</control>
				<!-- Radiobutton template -->
				<control type="radiobutton" id="8">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<radioposx>OFFSET_SETTINGS_OPTION_RADIO_WIDE</radioposx>
					<texturefocus colordiffuse="$VAR[SettingsOptionButtonColor]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
				</control>
				<!-- Spin control template -->
				<control type="spincontrolex" id="9">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<spinposx>OFFSET_SETTINGS_OPTION_SPIN_WIDE</spinposx>
					<texturefocus colordiffuse="$VAR[SettingsOptionButtonColor]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
				</control>
				<!-- Image template -->
				<control type="image" id="11">
					<visible>false</visible>
					<width>0</width>
					<height>0</height>
					<texture>transparent.png</texture>
				</control>
				<!-- Edit template -->
				<control type="edit" id="12">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<height>HEIGHT_BUTTON_DEFAULT</height>
					<label></label>
					<hinttext></hinttext>
				</control>
				<!-- Slider template -->
				<control type="sliderex" id="13">
					<width>WIDTH_SETTINGS_OPTION_WIDE</width>
					<texturefocus colordiffuse="$VAR[SettingsOptionButtonColor]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
				</control>
				<!-- Label template -->
				<control type="label" id="14">
					<height>HEIGHT_SETTINGS_CAPTION</height>
					<left>PADDING_BUTTON_HORIZONTAL</left>
					<top>OFFSET_SETTINGS_CAPTION</top>
					<label>ciao</label>
					<align>left</align>
					<font>SETTINGS_CAPTION</font>
					<textcolor>FOREGROUND_ACCENT_ALT</textcolor>
				</control>
			</control>
		</control>
	</include>
	<!-- DialogSubtitles for player -->
	<include name="PlayerDialogSubtitles">
		<control type="group">
			<include content="ShowHideFadeSlideHorizontalAnimation">
				<param name="speed">ANIMATION_MID</param>
				<param name="visible_condition">WindowOpen</param>
				<param name="hidden_condition">WindowClose</param>
			</include>

			<top>PADDING_BASE_80P</top>
			<bottom>PADDING_BASE_80P</bottom>
			<right>PADDING_BASE_80P</right>
			<width>WIDTH_BACKGROUND_SPLIT_REMAINING</width>

			<control type="label" id="998">
				<top>OFFSET_SETTINGS_OPTIONS_START</top>
				<label>No subtitle services available</label>
			</control>

			<!-- Focus trapper -->
			<control type="button" id="999">
				<visible allowhiddenfocus="true">0</visible>
				<onleft>Close</onleft>
			</control>
		</control>
	</include>

	<!-- Video next focus animation -->
	<include name="VideoNextUnFocusArtDarkening">
		<param name="reference_control_id"></param>

		<definition>
			<!-- Unfocus darkening -->
			<control type="image">
				<include content="VideoNextFocusAnimation">
					<param name="reference_control_id">$PARAM[reference_control_id]</param>
					<param name="start">100</param>
					<param name="end">0</param>
				</include>

				<width>100%</width>
				<height>100%</height>
				<texture colordiffuse="BACKGROUND_OPAQUE50">diffuse.png</texture>
			</control>
		</definition>
	</include>
	<!-- Video next focus animation -->
	<include name="VideoNextFocusAnimation">
		<param name="reference_control_id"></param>
		<param name="start">50</param>
		<param name="end">100</param>

		<definition>
			<animation type="Conditional" condition="Control.HasFocus($PARAM[reference_control_id])">
				<effect type="fade" start="$PARAM[start]" end="$PARAM[end]" time="ANIMATION_FAST" tween="linear" easing="out" />
			</animation>
			<animation type="Conditional" condition="!Control.HasFocus($PARAM[reference_control_id])">
				<effect type="fade" start="$PARAM[end]" end="$PARAM[start]" time="ANIMATION_FAST" tween="linear" easing="out" />
			</animation>
		</definition>
	</include>
</includes>
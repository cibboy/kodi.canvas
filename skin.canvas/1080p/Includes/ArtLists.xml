<?xml version="1.0" encoding="UTF-8"?>
<!--todo: progress indicators-->
<includes>
	<!-- Horizontal strip of landscape elements, with label and optional logo -->
	<!--todo: add more info beyond logo? (like season and episode number)-->
	<!--todo: logo is wip and partially broken-->
	<include name="LandscapeStrip">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="art"></param>
		<param name="logo"></param>
		<param name="episode"></param>
		<param name="title"></param>
		<param name="onfocus">noop</param>
		<param name="onchange">noop</param>
		<param name="onback">noop</param>
		<param name="onup">noop</param>
		<param name="ondown">noop</param>
		<param name="onleft">noop</param>
		<param name="onright">noop</param>

		<definition>
			<control type="group">
				<height>HEIGHT_LANDSCAPE_STRIP_CONTAINER</height>

				<control type="label">
					<font>BODY_STRONG</font>
					<textcolor>FOREGROUND</textcolor>
					<label>$PARAM[label]</label>
				</control>

				<control type="fixedlist" id="$PARAM[id]">
					<top>PADDING_BASE_1.2X</top>
					<autoscroll>false</autoscroll>
					<orientation>horizontal</orientation>
					<onfocus>$PARAM[onfocus]</onfocus>
					<onback>$PARAM[onback]</onback>
					<onleft>$PARAM[onleft]</onleft>
					<onright>$PARAM[onright]</onright>
					<onup>$PARAM[onup]</onup>
					<ondown>$PARAM[ondown]</ondown>

					<itemlayout width="WIDTH_LANDSCAPE_STRIP_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE">
						<control type="group">
							<!-- Landscape item -->
							<control type="image">
								<width>WIDTH_LANDSCAPE</width>
								<height>HEIGHT_LANDSCAPE</height>
								<texture fallback="1080p/fallback/landscape.png" background="true" diffuse="1080p/diffuse/landscape.png">$PARAM[art]</texture>
								<bordertexture border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE" colordiffuse="BACKGROUND">1080p/diffuse/shadow_square.png</bordertexture>
								<bordersize>SIZE_ITEM_SHADOW_SQUARE</bordersize>
								<aspectratio scalediffuse="false">scale</aspectratio>
							</control>

							<!-- Info -->
							<control type="group">
								<top>OFFSET_LANDSCAPE_STRIP_CLEARLOGO</top>

								<control type="group">
									<top>SIZE_ITEM_SHADOW_SQUARE</top>
									<left>SIZE_ITEM_SHADOW_SQUARE</left>
									<right>SIZE_ITEM_SHADOW_SQUARE</right>
									<width>100%</width>

									<!-- Logo -->
									<control type="image">
										<width>WIDTH_CLEARLOGO_SMALL</width>
										<height>HEIGHT_CLEARLOGO_SMALL</height>
										<texture background="true">$PARAM[logo]</texture>
										<aspectratio align="left">keep</aspectratio>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<right>0</right>
										<top>PADDING_BASE_0.1X</top>
										<width>100</width>
										<aligny>center</aligny>
										<font>CAPTION2</font>
										<textcolor>FOREGROUND</textcolor>
										<label>$PARAM[episode]</label>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<font>CAPTION</font>
										<textcolor>FOREGROUND</textcolor>
										<label>$PARAM[title]</label>
									</control>
								</control>
							</control>
						</control>
					</itemlayout>
					
					<focusedlayout width="WIDTH_LANDSCAPE_STRIP_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE">
						<control type="group">
							<animation type="Focus"><effect type="zoom" start="100" end="110" time="ANIMATION_FAST" tween="cubic" easing="out" center="auto" /></animation>
							<animation type="Unfocus"><effect type="zoom" start="110" end="100" time="ANIMATION_FAST" tween="cubic" easing="out" center="auto" /></animation>

							<!-- Update selected item info -->
							<control type="button">
								<include content="Hidden" />
								<onfocus>$PARAM[onchange]</onfocus>
							</control>

							<!-- Landscape item -->
							<control type="image">
								<width>WIDTH_LANDSCAPE</width>
								<height>HEIGHT_LANDSCAPE</height>
								<texture fallback="1080p/fallback/landscape.png" background="true" diffuse="1080p/diffuse/landscape.png">$PARAM[art]</texture>
								<bordertexture border="SIZE_ITEM_SHADOW_SQUARE_DOUBLE" colordiffuse="BACKGROUND">1080p/diffuse/shadow_square.png</bordertexture>
								<bordersize>SIZE_ITEM_SHADOW_SQUARE</bordersize>
								<aspectratio scalediffuse="false">scale</aspectratio>
							</control>

							<!-- Info -->
							<control type="group">
								<top>OFFSET_LANDSCAPE_STRIP_CLEARLOGO</top>

								<control type="group">
									<top>SIZE_ITEM_SHADOW_SQUARE</top>
									<left>SIZE_ITEM_SHADOW_SQUARE</left>
									<right>SIZE_ITEM_SHADOW_SQUARE</right>
									<width>100%</width>

									<!-- Logo -->
									<control type="image">
										<width>WIDTH_CLEARLOGO_SMALL</width>
										<height>HEIGHT_CLEARLOGO_SMALL</height>
										<texture background="true">$PARAM[logo]</texture>
										<aspectratio align="left">keep</aspectratio>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<right>PADDING_BASE_0.1X</right>
										<top>PADDING_BASE_0.1X</top>
										<width>100</width>
										<aligny>center</aligny>
										<font>CAPTION2</font>
										<textcolor>FOREGROUND</textcolor>
										<label>$PARAM[episode]</label>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<font>CAPTION</font>
										<textcolor>FOREGROUND</textcolor>
										<label>$PARAM[title]</label>
									</control>
								</control>
							</control>
						</control>
					</focusedlayout>

					<content>$PARAM[content]</content>
				</control>
			</control>
		</definition>
	</include>


<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is active element a TV show episode? -->
	<expression name="IsDetailsItemTypeEpisode">
		[$EXP[IsVideoPlayerVisible] + !String.IsEmpty(VideoPlayer.Episode)] |
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,episode)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,episode)]
	</expression>
	<!-- Is active element a TV show season? -->
	<expression name="IsDetailsItemTypeSeason">
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,season)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,season)]
	</expression>
	<!-- Is active element a TV show? -->
	<expression name="IsDetailsItemTypeTvShow">
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,tvshow)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,tvshow)]
	</expression>
	<!-- Is active element a movie? -->
	<expression name="IsDetailsItemTypeMovie">
		[$EXP[IsVideoPlayerVisible] + String.IsEmpty(VideoPlayer.Episode)] |
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,movie)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,movie)]
	</expression>
	<!-- Is active element a song? -->
	<expression name="IsDetailsItemTypeSong">
		$EXP[IsMusicPlayerVisible] |
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,song)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsMusicPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,song)]
	</expression>
	<!-- Is active element an album? -->
	<expression name="IsDetailsItemTypeAlbum">
		[$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.DBTYPE,album)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsMusicPlayerVisible] + String.IsEqual(Container(501).ListItem.DBTYPE,album)]
	</expression>
	<!-- Is active element video? -->
	<expression name="IsDetailsItemTypeVideo">$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeMovie]</expression>
	<!-- Is active element video-like? -->
	<expression name="IsDetailsItemTypeVideoLike">$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeSeason] | $EXP[IsDetailsItemTypeTvShow] | $EXP[IsDetailsItemTypeMovie]</expression>
	<!-- Is active element music? -->
	<expression name="IsDetailsItemTypeMusic">$EXP[IsDetailsItemTypeSong] | $EXP[IsDetailsItemTypeAlbum]</expression>


	<!-- Is custom clearlogo available? -->
	<expression name="IsDetailsClearlogoAvailable">!String.IsEmpty(Window(home).Property(Details.Clearlogo))</expression>

	<!-- Has studio? -->
	<expression name="HasDetailsStudio">!String.IsEmpty(Window(home).Property(Details.Studio))</expression>

	<!-- Has resolution? -->
	<expression name="HasDetailsResolution">!String.IsEmpty(Window(home).Property(Details.VideoResolution))</expression>
	<!-- Has video codec? -->
	<expression name="HasDetailsVideoCodec">!String.IsEmpty(Window(home).Property(Details.VideoCodec))</expression>
	<!-- Has ascpect ratio? -->
	<expression name="HasDetailsAspectRatio">!String.IsEmpty(Window(home).Property(Details.AspectRatio))</expression>
	<!-- Is HDR? -->
	<expression name="IsDetailsHdr">!String.IsEmpty(Window(home).Property(Details.HdrType))</expression>
	<!-- Has audio channels? -->
	<expression name="HasDetailsAudioChannels">!String.IsEmpty(Window(home).Property(Details.AudioChannels))</expression>
	<!--todo-->
	<expression name="HasDetailsAudioChannelsStream1">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioChannels.1))] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioChannels.1))]
	</expression>
	<!--todo-->
	<expression name="HasDetailsAudioChannelsStream2">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioChannels.2))] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioChannels.2))]
	</expression>
	<!-- Has audio language? -->
	<!--todo-->
	<expression name="HasDetailsAudioLanguageStream1">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioLanguage.1)) + !String.IsEqual(ListItem.Property(AudioLanguage.1),und)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioLanguage.1)) + !String.IsEqual(Container(501).ListItem.Property(AudioLanguage.1),und)]
	</expression>
	<!--todo-->
	<expression name="HasDetailsAudioLanguageStream2">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioLanguage.2)) + !String.IsEqual(ListItem.Property(AudioLanguage.2),und)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioLanguage.2)) + !String.IsEqual(Container(501).ListItem.Property(AudioLanguage.2),und)]
	</expression>
	<!-- Has audio codec? -->
	<!--todo-->
	<expression name="HasDetailsAudioCodecStream1">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioCodec.1))] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioCodec.1))]
	</expression>
	<!--todo-->
	<expression name="HasDetailsAudioCodecStream2">
		[$EXP[IsDialogInfoVisible] + !String.IsEmpty(ListItem.Property(AudioCodec.2))] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !String.IsEmpty(Container(501).ListItem.Property(AudioCodec.2))]
	</expression>

	<!-- Has year? -->
	<expression name="HasDetailsYear">!String.IsEmpty(Window(home).Property(Details.Year))</expression>

	<!-- Has episode number? -->
	<expression name="HasDetailsEpisodeNumber">!String.IsEmpty(Window(home).Property(Details.EpisodeNumber))</expression>
	<!-- Has episode premiered? -->
	<expression name="HasDetailsEpisodePremiered">!String.IsEmpty(Window(home).Property(Details.EpisodePremiere))</expression>
	<!-- Has number of episodes? -->
	<expression name="HasDetailsNumberOfEpisodes">!String.IsEmpty(Window(home).Property(Details.NumberOfEpisodes))</expression>

	<!-- Has artist? -->
	<expression name="HasDetailsArtist">!String.IsEmpty(Window(home).Property(Details.Artist))</expression>

	<!-- Has duration? -->
	<expression name="HasDetailsDuration">!String.IsEmpty(Window(home).Property(Details.Duration))</expression>

	<!-- Has MPAA? -->
	<expression name="HasDetailsMpaa">!String.IsEmpty(Window(home).Property(Details.Mpaa))</expression>

	<!-- Has status? -->
	<expression name="HasDetailsStatus">!String.IsEmpty(Window(home).Property(Details.Status))</expression>

	<!-- Has track number? -->
	<expression name="HasDetailsTrackNumber">!String.IsEmpty(Window(home).Property(Details.TrackNumber))</expression>

	<!-- Has genre? -->
	<expression name="HasDetailsGenre">!String.IsEmpty(Window(home).Property(Details.Genre))</expression>

	<!-- Has director? -->
	<expression name="HasDetailsDirector">!String.IsEmpty(Window(home).Property(Details.Director))</expression>
	<!-- Has writer? -->
	<expression name="HasDetailsWriter">!String.IsEmpty(Window(home).Property(Details.Writer))</expression>
	<!-- Has file path? -->
	<expression name="HasDetailsFilePath">!String.IsEmpty(Window(home).Property(Details.FilePath))</expression>

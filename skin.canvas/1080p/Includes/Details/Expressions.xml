	<!-- Is watched? -->
	<!--todo-->
	<expression name="IsDetailsWatched">
		[$EXP[IsDialogInfoVisible] + Integer.IsGreater(ListItem.PlayCount,0)] |
		[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + !$EXP[IsMusicPlayerVisible] + Integer.IsGreater(Container(501).ListItem.PlayCount,0)]
	</expression>
	<!-- Is all new? -->
	<!--todo-->
	<expression name="IsDetailsAllNew">
		[$EXP[IsDetailsItemTypeSeason] | $EXP[IsDetailsItemTypeTvShow]] +
		[
			[$EXP[IsDialogInfoVisible] + Integer.IsEqual(ListItem.Property(WatchedEpisodes),0)] |
			[!$EXP[IsDialogInfoVisible] + !$EXP[IsVideoPlayerVisible] + Integer.IsEqual(Container(501).ListItem.Property(WatchedEpisodes),0)]
		]
	</expression>
	<!-- Is resumable? -->
	<!--todo-->
	<expression name="IsDetailsResumable">
		[
			!$EXP[IsVideoPlayerVisible] +
			!$EXP[IsMusicPlayerVisible] +
			[
				[$EXP[IsDialogInfoVisible] + ListItem.IsResumable] |
				[!$EXP[IsDialogInfoVisible] + Container(501).ListItem.IsResumable]
			] +
			!String.IsEmpty(Window(home).Property(Item.TimeRemaining))
		] |
		[
			[$EXP[IsVideoPlayerVisible] | $EXP[IsMusicPlayerVisible]] +
			!String.IsEmpty(Window(home).Property(Player.Item.TimeRemaining))
		]
	</expression>

	<!-- Has tags? -->
	<expression name="HasDetailsTags">
		$EXP[HasDetailsResolution] | $EXP[IsDetailsHdr] | $EXP[HasDetailsAudioChannels]
	</expression>
	<!-- Has info? -->
	<expression name="HasDetailsInfo">
		$EXP[HasDetailsYear] |
		$EXP[HasDetailsEpisodeNumber] | $EXP[HasDetailsEpisodePremiered] |
		$EXP[HasDetailsArtist] |
		$EXP[HasDetailsDuration] |
		$EXP[HasDetailsMpaa] |
		$EXP[HasDetailsStatus] |
		$EXP[HasDetailsTrackNumber]
	</expression>
</includes>
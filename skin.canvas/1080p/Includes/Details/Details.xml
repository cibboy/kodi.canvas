<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Details/Variables.xml" />
	<include file="Includes/Details/Expressions.xml" />

	<!-- Infoline text -->
	<include name="DetailsInfoText">
		<param name="text"></param>
		<param name="textcolor">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="visible">true</param>
		<param name="width_limit">400</param>

		<definition>
			<control type="label">
				<visible>$PARAM[visible]</visible>

				<width max="$PARAM[width_limit]">auto</width>
				<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

				<font>CAPTION_STRONG</font>
				<aligny>center</aligny>
				<textcolor>$PARAM[textcolor]</textcolor>
				<label>$PARAM[text] </label>
			</control>
		</definition>
	</include>
	<!-- Infoline text (label + value) -->
	<include name="DetailsInfoLabelValue">
		<param name="label"></param>
		<param name="value"></param>
		<param name="textcolor">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="visible">true</param>
		<param name="width_limit">400</param>

		<definition>
			<control type="grouplist">
				<visible>$PARAM[visible]</visible>
				<orientation>horizontal</orientation>
				<itemgap>PADDING_BASE_10P</itemgap>

				<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

				<!-- Label -->
				<control type="label">
					<width>auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

					<font>CAPTION_STRONG</font>
					<aligny>center</aligny>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$PARAM[label]:</label>
				</control>

				<!-- Value -->
				<control type="label">
					<width max="$PARAM[width_limit]">auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

					<font>CAPTION</font>
					<aligny>center</aligny>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$PARAM[value]</label>
				</control>
			</control>
		</definition>
	</include>
	<!-- Infoline custom components -->
	<include name="DetailsInfoCustom">
		<param name="visible">true</param>

		<definition>
			<control type="grouplist">
				<visible>$PARAM[visible]</visible>
				<orientation>horizontal</orientation>
				<itemgap>PADDING_BASE_10P</itemgap>

				<height>HEIGHT_DETAILS_INFOLINE_CUSTOM</height>

				<!-- Custom compoenents -->
				<nested />
			</control>
		</definition>
	</include>

	<!-- Infoline tag -->
	<include name="DetailsInfoTag">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND</param>
		<param name="height">HEIGHT_DETAILS_INFOLINE_TAG</param>

		<definition>
			<control type="button">
				<visible>$PARAM[visible]</visible>
				<width>auto</width>
				<height>$PARAM[height]</height>

				<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
				<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
				<font>CAPTION2_STRONG</font>
				<textoffsetx>OFFSET_X_DETAILS_TAG</textoffsetx>
				<textoffsety>OFFSET_Y_DETAILS_TAG</textoffsety>
				<align>right</align>
				<textcolor>$PARAM[textcolor]</textcolor>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>

	<!-- Infoline tag with icon -->
	<include name="DetailsInfoTagWithIcon">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND_ACCENT</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<width>100%</width>

				<!-- Text (must include empty space for icon, if necessary) with background -->
				<control type="button">
					<width>auto</width>
					<height>HEIGHT_DETAILS_INFOLINE_TAG</height>

					<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
					<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
					<font>CAPTION2_STRONG</font>
					<textoffsetx>OFFSET_X_DETAILS_TAG</textoffsetx>
					<textoffsety>OFFSET_Y_DETAILS_TAG</textoffsety>
					<align>right</align>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$PARAM[text]</label>
				</control>

				<!-- Icon (will be over the empty space left in button) -->
				<nested />
			</control>
		</definition>
	</include>


	<!-- Title/clearlogo -->
	<include name="DetailsTitleClearlogo">
		<definition>
			<control type="group">
				<height>HEIGHT_DETAILS_TITLE_SECTION</height>

				<!-- Title (if clearlogo not available) -->
				<control type="label">
					<visible>![$EXP[IsDetailsClearlogoAvailable]]</visible>
					<top>40</top>
					<width>1000</width>
					<height>HEIGHT_DETAILS_TITLE</height>
					<aligny>center</aligny>
					<font>TITLE1</font>
					<textcolor>$VAR[ContrastTextHighlightColor]</textcolor>
					<label>$VAR[DetailsTitle]</label>
				</control>
				<!-- Clearlogo -->
				<control type="image">
					<width>WIDTH_DETAILS_CLEARLOGO</width>
					<height>HEIGHT_DETAILS_CLEARLOGO</height>
					<fadetime>ANIMATION_SLOW</fadetime>
					<texture background="true">$VAR[DetailsClearlogo]</texture>
					<aspectratio align="left">keep</aspectratio>
				</control>
			</control>
		</definition>
	</include>

	<!-- Details -->
	<include name="SelectionDetails">
		<param name="plot_height">HEIGHT_DETAILS_PLOT</param>
		<param name="show_progress">true</param>

		<definition>
			<control type="grouplist">
				<itemgap>PADDING_BASE_20P</itemgap>

				<!-- Title/clearlogo -->
				<include content="DetailsTitleClearlogo" />

				<!-- Media info lines -->
				<control type="grouplist">
					<height>HEIGHT_DETAILS_INFOLINE_DOUBLE</height>
					<itemgap>0</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<!-- TV show episode title / season title / album name -->
					<control type="label">
						<visible>$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeSeason] | $EXP[IsDetailsItemTypeSong]</visible>

						<width>1000</width>
						<height>HEIGHT_DETAILS_INFOLINE</height>
						<aligny>center</aligny>
						<font>SUBTITLE</font>
						<textcolor>$VAR[ContrastTextHighlightColor]</textcolor>
						<label>$VAR[DetailsTitle2]</label>
					</control>

					<!-- Media info -->
					<control type="grouplist">
						<orientation>horizontal</orientation>
						<itemgap>PADDING_BASE_10P</itemgap>
						<height>HEIGHT_DETAILS_INFOLINE</height>
						<top>OFFSET_DETAILS_INFOLINE_CONTENT</top>

						<!-- Resolution -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsResolution]</param>
							<param name="visible">$EXP[HasDetailsResolution]</param>
						</include>
						<!-- HDR -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsHdrType]</param>
							<param name="visible">$EXP[IsDetailsHdr]</param>
						</include>
						<!-- Audio channels -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsAudioChannels]</param>
							<param name="visible">$EXP[HasDetailsAudioChannels]</param>
						</include>

						<!-- Padding -->
						<include content="DetailsInfoText">
							<param name="text"> </param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsTags]</param>
						</include>

						<!-- Year -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsYear]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsYear]</param>
						</include>
						<!-- Episode -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsEpisodeNumber]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsEpisodeNumber]</param>
						</include>
						<!-- Premiered -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsEpisodePremiere]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsEpisodePremiered]</param>
						</include>
						<!-- Number of episodes -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsNumberOfEpisodes]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsNumberOfEpisodes]</param>
						</include>
						<!-- Artist -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsArtist]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsArtist]</param>
						</include>
						<!-- Duration -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsDuration]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsDuration]</param>
						</include>
						<!-- Mpaa -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsMpaa]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsMpaa]</param>
						</include>
						<!-- Status -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsStatus]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsStatus]</param>
						</include>
						<!-- Track -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsTrackNumber]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsTrackNumber]</param>
						</include>

						<!-- Padding -->
						<include content="DetailsInfoText">
							<param name="text"> </param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">[$EXP[HasDetailsTags] | $EXP[HasDetailsInfo]] + $PARAM[show_progress]</param>
						</include>

						<!-- Watched status -->
						<include content="DetailsInfoTagWithIcon">
							<!-- Text has space for icon -->
							<param name="text">      Watched</param>
							<param name="visible">$EXP[IsDetailsItemTypeVideoLike] + !$EXP[IsDetailsResumable] + $EXP[IsDetailsWatched] + !$EXP[IsDetailsAllNew] + $PARAM[show_progress]</param>

							<!-- Icon -->
							<control type="image">
								<width>SIZE_DETAILS_WATCHED_ICON</width>
								<height>SIZE_DETAILS_WATCHED_ICON</height>
								<top>OFFSET_TOP_DETAILS_WATCHED_ICON</top>
								<left>OFFSET_LEFT_DETAILS_WATCHED_ICON</left>
								<texture colordiffuse="FOREGROUND_ACCENT">1080p/icons/watched.png</texture>
							</control>
						</include>
						<!-- All new -->
						<include content="DetailsInfoTag">
							<param name="text">All new</param>
							<param name="visible">$EXP[IsDetailsItemTypeVideoLike] + $EXP[IsDetailsAllNew] + $PARAM[show_progress]</param>
							<param name="textcolor">FOREGROUND_ACCENT</param>
						</include>
						<!-- Episodes remaining -->
						<include content="DetailsInfoTagWithIcon">
							<!-- Text has space for icon -->
							<param name="text">      $VAR[DetailsEpisodesRemaining]</param>
							<param name="visible">$EXP[IsDetailsItemTypeVideoLike] + !$EXP[IsDetailsWatched] + !$EXP[IsDetailsAllNew] + [$EXP[IsDetailsItemTypeTvShow] | $EXP[IsDetailsItemTypeSeason]] + $PARAM[show_progress]</param>

							<!-- Round icon -->
							<control type="group">
								<width>SIZE_DETAILS_PERCENT_ICON</width>
								<height>SIZE_DETAILS_PERCENT_ICON</height>
								<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
								<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
								
								<control type="image">
									<texture colordiffuse="FOREGROUND_OPAQUE10">1080p/progress/circle-100.png</texture>
								</control>
								<control type="image">
									<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$VAR[DetailsPercentPlayed].png</texture>
								</control>
							</control>
						</include>
						<!-- Time remaining -->
						<include content="DetailsInfoTagWithIcon">
							<!-- Text has space for icon -->
							<param name="text">      $VAR[DetailsTimeRemaining]</param>
							<param name="visible">$EXP[IsDetailsItemTypeVideoLike] + $EXP[IsDetailsResumable] + $EXP[IsDetailsItemTypeVideo] + $PARAM[show_progress]</param>

							<!-- Round icon -->
							<control type="group">
								<width>SIZE_DETAILS_PERCENT_ICON</width>
								<height>SIZE_DETAILS_PERCENT_ICON</height>
								<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
								<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
								
								<control type="image">
									<texture colordiffuse="FOREGROUND_OPAQUE10">1080p/progress/circle-100.png</texture>
								</control>
								<control type="image">
									<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$VAR[DetailsPercentPlayed].png</texture>
								</control>
							</control>
						</include>
					</control>

					<!-- Additional media info (not for items with additional title, like episodes) -->
					<control type="grouplist">
						<visible>!$EXP[IsDetailsItemTypeEpisode] + !$EXP[IsDetailsItemTypeSong]</visible>

						<orientation>horizontal</orientation>
						<itemgap>PADDING_BASE_10P</itemgap>
						<height>HEIGHT_DETAILS_INFOLINE</height>
						<top>OFFSET_DETAILS_INFOLINE_CONTENT</top>

						<!-- Genre -->
						<include content="DetailsInfoText">
							<param name="text">$VAR[DetailsGenre]</param>
							<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
							<param name="visible">$EXP[HasDetailsGenre]</param>
							<param name="width_limit">0</param>
						</include>
					</control>
				</control>

				<!-- Summary -->
				<control type="textbox">
					<width>700</width>
					<height>$PARAM[plot_height]</height>

					<font>BODY2</font>
					<textcolor>$VAR[ContrastTextForegroundColor]</textcolor>
					<label>$VAR[DetailsPlot]</label>
					<autoscroll delay="10000" time="1000" repeat="10000">true</autoscroll>
				</control>

				<!-- Custom details -->
				<nested />
			</control>
		</definition>
	</include>

	<!-- Video info details -->
	<include name="VideoInfoDetails">
		<definition>
			<!-- Details -->
			<include content="SelectionDetails">
				<param name="plot_height">HEIGHT_VIDEOINFO_PLOT</param>

				<!-- Additional details -->
				<control type="grouplist">
					<itemgap>PADDING_BASE_10P</itemgap>

					<!-- Padding -->
					<control type="label">
						<height>PADDING_BASE_10P</height>
					</control>

					<!-- Director -->
					<include content="DetailsInfoLabelValue">
						<param name="label">Director</param>
						<param name="value">$VAR[DetailsDirector]</param>
						<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
						<param name="visible">$EXP[HasDetailsDirector]</param>
						<param name="width_limit">1000</param>
					</include>
					<!-- Writer -->
					<include content="DetailsInfoLabelValue">
						<param name="label">Writer</param>
						<param name="value">$VAR[DetailsWriter]</param>
						<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
						<param name="visible">$EXP[HasDetailsWriter]</param>
						<param name="width_limit">1000</param>
					</include>
					<!-- Path -->
					<include content="DetailsInfoLabelValue">
						<param name="label">Path</param>
						<param name="value">$VAR[DetailsFilePath]</param>
						<param name="textcolor">$VAR[ContrastTextForegroundColor]</param>
						<param name="visible">$EXP[HasDetailsFilePath]</param>
						<param name="width_limit">1000</param>
					</include>

					<!-- Padding -->
					<control type="label">
						<height>PADDING_BASE_10P</height>
					</control>

					<!-- Video resolution, codec and aspect ratio -->
					<include content="DetailsInfoCustom">
						<param name="visible">$EXP[HasDetailsResolution] | $EXP[HasDetailsVideoCodec] | $EXP[HasDetailsAspectRatio]</param>

						<!-- Icon -->
						<control type="image">
							<width>HEIGHT_DETAILS_INFOLINE_CUSTOM</width>
							<height>HEIGHT_DETAILS_INFOLINE_CUSTOM</height>
							<texture colordiffuse="$VAR[ContrastTextForegroundColor]">1080p/icons/video.png</texture>
						</control>

						<!-- Resolution -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsResolution]</param>
							<param name="visible">$EXP[HasDetailsResolution]</param>
						</include>
						<!-- Video codec -->
						<include content="DetailsInfoTag">
							<param name="text">[UPPERCASE]$VAR[DetailsVideoCodec][/UPPERCASE]</param>
							<param name="visible">$EXP[HasDetailsVideoCodec]</param>
						</include>
						<!-- Aspect ratio -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsAspectRatio]</param>
							<param name="visible">$EXP[HasDetailsAspectRatio]</param>
						</include>
					</include>
					<!-- Audio language, codec and channels, max 2 streams -->
					<include content="DetailsInfoCustom">
						<param name="visible">[$EXP[HasDetailsAudioCodecStream1] + $EXP[HasDetailsAudioChannelsStream1]] | [$EXP[HasDetailsAudioCodecStream2] + $EXP[HasDetailsAudioChannelsStream2]]</param>

						<!-- Icon -->
						<control type="image">
							<width>HEIGHT_DETAILS_INFOLINE_CUSTOM</width>
							<height>HEIGHT_DETAILS_INFOLINE_CUSTOM</height>
							<texture colordiffuse="$VAR[ContrastTextForegroundColor]">1080p/icons/speaker.png</texture>
						</control>

						<!-- Stream 1 -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsAudioStream1]</param>
							<param name="visible">$EXP[HasDetailsAudioCodecStream1] + $EXP[HasDetailsAudioChannelsStream1]</param>
						</include>
						<!-- Stream 2 -->
						<include content="DetailsInfoTag">
							<param name="text">$VAR[DetailsAudioStream2]</param>
							<param name="visible">$EXP[HasDetailsAudioCodecStream2] + $EXP[HasDetailsAudioChannelsStream2]</param>
						</include>
					</include>
					<!-- Subtitles language (ita/eng) -->
					<include content="DetailsInfoCustom">
						<param name="visible">$EXP[HasDetailsEngSubtitle] | $EXP[HasDetailsItaSubtitle]</param>

						<!-- Icon -->
						<control type="image">
							<width>HEIGHT_DETAILS_INFOLINE_CUSTOM</width>
							<height>HEIGHT_DETAILS_INFOLINE_CUSTOM</height>
							<texture colordiffuse="$VAR[ContrastTextForegroundColor]">1080p/icons/subtitles.png</texture>
						</control>

						<!-- Eng -->
						<include content="DetailsInfoTag">
							<param name="text">Eng</param>
							<param name="visible">$EXP[HasDetailsEngSubtitle]</param>
						</include>
						<!-- Ira -->
						<include content="DetailsInfoTag">
							<param name="text">Ita</param>
							<param name="visible">$EXP[HasDetailsItaSubtitle]</param>
						</include>
					</include>
				</control>
			</include>

			<!-- Landscape art (episodes) -->
			<control type="group">
				<visible>$EXP[IsDetailsItemTypeEpisode]</visible>

				<bottom>200</bottom>
				<right>0</right>
				<width>WIDTH_DETAILS_LANDSCAPE</width>
				<height>HEIGHT_DETAILS_LANDSCAPE</height>

				<include content="ArtListsLandscape">
					<param name="art">$INFO[ListItem.Art(thumb)]</param>
					<param name="width">WIDTH_DETAILS_LANDSCAPE</param>
					<param name="height">HEIGHT_DETAILS_LANDSCAPE</param>
					<param name="show_decorators">false</param>
				</include>
			</control>
			<!-- Poster art (non episodes) -->
			<control type="group">
				<visible>!$EXP[IsDetailsItemTypeEpisode]</visible>

				<bottom>200</bottom>
				<right>0</right>
				<width>WIDTH_DETAILS_POSTER</width>
				<height>HEIGHT_DETAILS_POSTER</height>

				<include content="ArtListsPoster">
					<param name="art">$INFO[ListItem.Art(poster)]</param>
					<param name="width">WIDTH_DETAILS_POSTER</param>
					<param name="height">HEIGHT_DETAILS_POSTER</param>
					<param name="show_decorators">false</param>
				</include>
			</control>
		</definition>
	</include>

	<!-- Music info details -->
	<include name="MusicInfoDetails">
		<param name="show_art">true</param>
		<param name="art"></param>
		<param name="art_fallback"></param>

		<definition>
			<!-- Background -->
			<control type="image">
				<!-- Fake blur by using huge zoom, so it's responsive to changes -->
				<animation condition="true" effect="zoom" center="auto" end="10000" time="0">Conditional</animation>
				<!-- Continuous fading and back + slide (VERY slow) to give a sense of motion -->
				<animation condition="true" effect="fade" start="100" end="50" time="5000" pulse="true">Conditional</animation>
				<animation condition="true" effect="slide" start="-500,-200" end="500,200" time="360000" pulse="true">Conditional</animation>
				<width>100%</width>
				<height>100%</height>
				<texture fallback="1080p/fallback/bg.png">$PARAM[art]</texture>
				<aspectratio>scale</aspectratio>
			</control>
			<!-- Darkening -->
			<include content="DarkeningLayer" />

			<!-- Art and info -->
			<control type="group">
				<top>PADDING_BASE_150P</top>
				<bottom>PADDING_BASE_200P</bottom>
				<right>PADDING_BASE_200P</right>
				<left>PADDING_BASE_200P</left>

				<!-- Cover -->
				<control type="image">
					<visible>$PARAM[show_art]</visible>
					<width>SIZE_PLAYER_ALBUMART</width>
					<height>SIZE_PLAYER_ALBUMART</height>
					<texture fallback="$PARAM[art_fallback]" background="true" diffuse="1080p/diffuse/square.png">$PARAM[art]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>

				<!-- Info -->
				<control type="grouplist">
					<orientation>vertical</orientation>
					<itemgap>PADDING_BASE_20P</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<width>WIDTH_PLAYER_MUSICINFO</width>
					<height>100%</height>
					<right>0</right>

					<!-- Title -->
					<control type="label">
						<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
						<height>FONT_SIZE_TITLE1</height>
						<font>TITLE2</font>
						<textcolor>HIGHLIGHT</textcolor>
						<label>$VAR[DetailsTitle]</label>
					</control>

					<!-- Album name -->
					<control type="label">
						<top>PADDING_BASE_10P</top>
						<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
						<height>HEIGHT_DETAILS_INFOLINE</height>
						<font>SUBTITLE</font>
						<label>$VAR[DetailsTitle2]</label>
					</control>

					<!-- Track number and year -->
					<control type="grouplist">
						<orientation>horizontal</orientation>
						<itemgap>PADDING_BASE_30P</itemgap>
						<usecontrolcoords>true</usecontrolcoords>

						<width>WIDTH_PLAYER_MUSICINFO</width>
						<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

						<!-- Track number -->
						<control type="label">
							<visible>$EXP[HasDetailsTrackNumber]</visible>
							<width>auto</width>
							<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
							<font>CAPTION_STRONG</font>

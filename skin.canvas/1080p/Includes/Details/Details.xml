<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Details/Variables.xml" />

	<!-- Infoline text -->
	<include name="DetailsInfoText">
		<param name="text"></param>
		<param name="textcolor">FOREGROUND</param>
		<param name="visible">true</param>

		<definition>
			<control type="label">
				<visible>$PARAM[visible]</visible>

				<width>auto</width>
				<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

				<font>CAPTION_STRONG</font>
				<aligny>center</aligny>
				<textcolor>$PARAM[textcolor]</textcolor>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>

	<!-- Infoline tag -->
	<include name="DetailsInfoTag">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND</param>

		<definition>
			<control type="button">
				<visible>$PARAM[visible]</visible>
				<width>auto</width>
				<height>HEIGHT_DETAILS_INFOLINE</height>

				<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
				<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
				<font>CAPTION2_STRONG</font>
				<textoffsetx>8</textoffsetx>
				<textoffsety>-1</textoffsety>
				<align>right</align>
				<textcolor>$PARAM[textcolor]</textcolor>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>

	<!-- Infoline tag with icon -->
	<include name="DetailsInfoTagWithIcon">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND_ACCENT</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<width>100%</width>

				<!-- Text (must include empty space for icon, if necessary) with background -->
				<control type="button">
					<width>auto</width>
					<height>HEIGHT_DETAILS_INFOLINE</height>

					<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
					<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
					<font>CAPTION2_STRONG</font>
					<textoffsetx>8</textoffsetx>
					<textoffsety>-1</textoffsety>
					<align>right</align>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$PARAM[text]</label>
				</control>

				<!-- Icon (will be over the empty space left in button) -->
				<nested />
			</control>
		</definition>
	</include>


	<!-- Details -->
	<include name="SelectionDetails">
		<param name="visible">true</param>
		<param name="clearlogo"></param>
		<param name="title"></param>
		<param name="has_clearlogo">false</param>
		<param name="subtitle"></param>
		<param name="has_subtitle">false</param>
		<param name="resolution"></param>
		<param name="has_resolution">false</param>
		<param name="hdr"></param>
		<param name="has_hdr">false</param>
		<param name="channels"></param>
		<param name="has_channels">false</param>
		<param name="year"></param>
		<param name="has_year">false</param>
		<param name="episode"></param>
		<param name="has_episode">false</param>
		<param name="premiered"></param>
		<param name="has_premiered">false</param>
		<param name="artist"></param>
		<param name="has_artist">false</param>
		<param name="duration"></param>
		<param name="has_duration">false</param>
		<param name="mpaa"></param>
		<param name="has_mpaa">false</param>
		<param name="status"></param>
		<param name="has_status">false</param>
		<param name="track"></param>
		<param name="has_track">false</param>
		<param name="is_watched">false</param>
		<param name="is_allnew">false</param>
		<param name="episodes_remaining"></param>
		<param name="has_episodes_remaining">false</param>
		<param name="time_remaining"></param>
		<param name="has_time_remaining">false</param>
		<param name="percentage_watched"></param>
		<param name="genre"></param>
		<param name="has_genre">false</param>
		<param name="plot"></param>
		<param name="highlight_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="foreground_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="clearlogo_fadetime">ANIMATION_FAST</param>

		<definition>
			<control type="grouplist">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation" />

				<itemgap>PADDING_MULT_10</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<!-- Title/clearlogo -->
				<control type="group">
					<height>HEIGHT_CLEARLOGO_BIG</height>

					<!-- Title (if clearlogo not available) -->
					<control type="label">
						<visible>!$PARAM[has_clearlogo]</visible>

						<width>1000</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<aligny>center</aligny>
						<font>TITLE1</font>
						<textcolor>$PARAM[highlight_color]</textcolor>
						<label>$PARAM[title]</label>
					</control>
					<!-- Clearlogo -->
					<control type="image">
						<width>WIDTH_CLEARLOGO_BIG</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<fadetime>$PARAM[clearlogo_fadetime]</fadetime>
						<texture background="true">$PARAM[clearlogo]</texture>
						<aspectratio align="left">keep</aspectratio>
					</control>
				</control>

				<!-- Subtitle -->
				<control type="label">
					<visible>$PARAM[has_subtitle]</visible>

					<width>1000</width>
					<height>HEIGHT_DETAILS_SUBTITLE</height>
					<font>SUBTITLE</font>
					<textcolor>$PARAM[highlight_color]</textcolor>
					<label>$PARAM[subtitle]</label>
				</control>

				<!-- Info line 1 -->
				<control type="grouplist">
					<orientation>horizontal</orientation>
					<itemgap>PADDING_MULT_30</itemgap>
					<height>HEIGHT_DETAILS_INFOLINE</height>
					<centertop>HEIGHT_DETAILS_INFOLINE</centertop>

					<!-- Resolution -->
					<include content="DetailsInfoTag">
						<param name="text">$PARAM[resolution]</param>
						<param name="visible">$PARAM[has_resolution]</param>
					</include>
					<!-- HDR -->
					<include content="DetailsInfoTag">
						<param name="text">$PARAM[hdr]</param>
						<param name="visible">$PARAM[has_hdr]</param>
					</include>
					<!-- Audio channels -->
					<include content="DetailsInfoTag">
						<param name="text">$PARAM[channels]</param>
						<param name="visible">$PARAM[has_channels]</param>
					</include>

					<!-- Year -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[year]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_year]</param>
					</include>
					<!-- Episode -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[episode]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_episode]</param>
					</include>
					<!-- Premiered -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[premiered]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_premiered]</param>
					</include>
					<!-- Artist -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[artist]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_artist]</param>
					</include>
					<!-- Duration -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[duration]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_duration]</param>
					</include>
					<!-- Mpaa -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[mpaa]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_mpaa]</param>
					</include>
					<!-- Status -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[status]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_status]</param>
					</include>
					<!-- Track -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[track]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_track]</param>
					</include>

					<!-- Watched status -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      Watched</param>
						<param name="visible">$PARAM[is_watched]</param>

						<!-- Icon -->
						<control type="image">
							<width>SIZE_DETAILS_WATCHED_ICON</width>
							<height>SIZE_DETAILS_WATCHED_ICON</height>
							<top>OFFSET_TOP_DETAILS_WATCHED_ICON</top>
							<left>OFFSET_LEFT_DETAILS_WATCHED_ICON</left>
							<texture colordiffuse="FOREGROUND_ACCENT">1080p/icons/check.png</texture>
						</control>
					</include>

					<!-- All new -->
					<include content="DetailsInfoTag">
						<param name="text">All new</param>
						<param name="visible">!$PARAM[is_watched] + $PARAM[is_allnew]</param>
						<param name="textcolor">FOREGROUND_ACCENT</param>
					</include>

					<!-- Episodes remaining -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      $PARAM[episodes_remaining]</param>
						<param name="visible">!$PARAM[is_watched] + $PARAM[has_episodes_remaining] + !$PARAM[is_allnew]</param>

						<!-- Round icon -->
						<control type="group">
							<width>SIZE_DETAILS_PERCENT_ICON</width>
							<height>SIZE_DETAILS_PERCENT_ICON</height>
							<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
							<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
							
							<control type="image">
								<texture colordiffuse="FOREGROUND_OPAQUE10">1080p/progress/circle-100.png</texture>
							</control>
							<control type="image">
								<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$PARAM[percentage_watched].png</texture>
							</control>
						</control>
					</include>

					<!-- Time remaining -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      $PARAM[time_remaining]</param>
						<param name="visible">$PARAM[has_time_remaining]</param>

						<!-- Round icon -->
						<control type="group">
							<width>SIZE_DETAILS_PERCENT_ICON</width>
							<height>SIZE_DETAILS_PERCENT_ICON</height>
							<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
							<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
							
							<control type="image">
								<texture colordiffuse="FOREGROUND_OPAQUE10">1080p/progress/circle-100.png</texture>
							</control>
							<control type="image">
								<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$PARAM[percentage_watched].png</texture>
							</control>
						</control>
					</include>
				</control>

				<!-- Info line 2 -->
				<control type="grouplist">
					<visible>$PARAM[has_genre]</visible>

					<orientation>horizontal</orientation>
					<itemgap>PADDING_MULT_30</itemgap>
					<height>HEIGHT_DETAILS_INFOLINE</height>

					<!-- Genre -->
					<include content="DetailsInfoText">
						<param name="text">$PARAM[genre]</param>
						<param name="textcolor">$PARAM[foreground_color]</param>
						<param name="visible">$PARAM[has_genre]</param>
					</include>
				</control>

				<!-- Summary -->
				<control type="textbox">
					<width>700</width>
					<height>160</height>
					<top>10</top>

					<font>BODY2</font>
					<textcolor>$PARAM[foreground_color]</textcolor>
					<label>$PARAM[plot]</label>
				</control>
			</control>
		</definition>
	</include>
</includes>
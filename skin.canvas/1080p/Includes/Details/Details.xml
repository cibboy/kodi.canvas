<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Details/Variables.xml" />
	<include file="Includes/Details/Expressions.xml" />

	<include name="DetailsInfoOffsetWithSubtitle">
		<top>FONT_SIZE_SUBTITLE</top>
	</include>
	<include name="DetailsSummaryOffsetWithInfo2">
		<top>FONT_SIZE_CAPTION</top>
	</include>

	<include name="SelectionDetails">
		<param name="visible">true</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation" />
			
				<!-- Title/clearlogo -->
				<control type="group">
					<height>HEIGHT_CLEARLOGO_BIG</height>

					<!-- Title (if clearlogo not available) -->
					<control type="label">
						<visible>!$EXP[HasDetailsClearlogo]</visible>

						<width>1000</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<aligny>center</aligny>
						<font>TITLE1</font>
						<textcolor>HIGHLIGHT</textcolor>
						<label>$VAR[DetailsTitle]</label>
					</control>
					<!-- Clearlogo -->
					<control type="image">
						<visible>$EXP[HasDetailsClearlogo]</visible>

						<width>WIDTH_CLEARLOGO_BIG</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<fadetime>ANIMATION_FAST</fadetime>
						<texture background="true">$VAR[DetailsClearlogo]</texture>
						<aspectratio align="left">keep</aspectratio>
					</control>
				</control>

				<control type="group">
					<top>HEIGHT_CLEARLOGO_BIG</top>

					<!-- Subtitle -->
					<control type="label">
						<visible>$EXP[HasDetailsSubtitle]</visible>

						<width>1000</width>
						<height>FONT_SIZE_SUBTITLE</height>
						<font>SUBTITLE</font>
						<textcolor>HIGHLIGHT</textcolor>
						<label>$VAR[DetailsSubtitle]</label>
					</control>

					<!-- Info line 1 + Info line 2 + Summary -->
					<control type="group">
						<!-- If subtitle is present, add further offset -->
						<include content="DetailsInfoOffsetWithSubtitle" condition="$EXP[HasDetailsSubtitle]" />

						<!-- Info line 1 -->
						<control type="grouplist">
							<orientation>horizontal</orientation>
							<width>800</width>
							<height>FONT_SIZE_CAPTION</height>

							<!--todo: resolution, audio channels, hdr-->
							
							<!-- Info string -->
							<control type="label">
								<height>FONT_SIZE_CAPTION</height>
								<font>CAPTION_STRONG</font>
								<textcolor>FOREGROUND_DARK</textcolor>
								<label>$VAR[DetailsInfo]</label>
							</control>

							<!-- Watched status -->
							<control type="group">
								<visible>$EXP[IsDetailsWatched]</visible>
								<width>200</width>

								<control type="image">
									<width>SIZE_STATUS</width>
									<height>SIZE_STATUS</height>
									<texture background="true" colordiffuse="FOREGROUND_ACCENT">1080p/icons/check.png</texture>
									<aspectratio align="left">keep</aspectratio>
								</control>
								<control type="label">
									<left>PADDING_MULT_60</left>
									<width>200</width>
									<height>FONT_SIZE_CAPTION</height>
									<font>CAPTION_STRONG</font>
									<textcolor>FOREGROUND_DARK</textcolor>
									<label>Watched</label>
								</control>
							</control>

							<!-- Time remaining -->
							<control type="group">
								<visible>$EXP[HasDetailsTimeRemaining]</visible>
								<width>200</width>

								<control type="image">
									<width>SIZE_STATUS</width>
									<height>SIZE_STATUS</height>
									<texture background="true" colordiffuse="FOREGROUND_ACCENT">1080p/progress/$VAR[DetailsWatchedPercentage].png</texture>
									<aspectratio align="left">keep</aspectratio>
								</control>
								<control type="label">
									<left>PADDING_MULT_60</left>
									<width>200</width>
									<height>FONT_SIZE_CAPTION</height>
									<font>CAPTION_STRONG</font>
									<textcolor>FOREGROUND_DARK</textcolor>
									<label>$VAR[DetailsTimeRemaining] left</label>
								</control>
							</control>
						</control>

						<!-- Info line 2 + Summary -->
						<control type="group">
							<top>FONT_SIZE_CAPTION</top>

							<!-- Info line 2 -->
							<control type="label">
								<visible>$EXP[HasDetailsInfo2]</visible>
								<width>1000</width>
								<height>FONT_SIZE_CAPTION</height>

								<font>CAPTION_STRONG</font>
								<textcolor>FOREGROUND_DARK</textcolor>
								<label>$VAR[DetailsInfo2]</label>
							</control>

							<!-- Summary -->
							<control type="textbox">
								<!-- If info line 2 is present, add further offset -->
								<include content="DetailsSummaryOffsetWithInfo2" condition="$EXP[HasDetailsInfo2]" />
								<width>800</width>
								<height>170</height>

								<font>BODY2</font>
								<textcolor>FOREGROUND</textcolor>
								<label>$VAR[DetailsSummary]</label>
							</control>
						</control>
					</control>
				</control>
			</control>
		</definition>
	</include>
</includes>
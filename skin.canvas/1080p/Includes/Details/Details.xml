						<!-- Year -->
						<control type="label">
							<visible>$EXP[HasDetailsYear]</visible>
							<width>auto</width>
							<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
							<font>CAPTION_STRONG</font>
							<label>$VAR[DetailsYear]</label>
						</control>
					</control>

					<!-- Artist -->
					<control type="label">
						<width max="WIDTH_PLAYER_MUSICINFO">auto</width>
						<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>
						<font>CAPTION_STRONG</font>
						<label>$VAR[DetailsArtist]</label>
					</control>
				</control>
			</control>

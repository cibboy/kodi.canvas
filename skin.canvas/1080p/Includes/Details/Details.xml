<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Details/Variables.xml" />
	<include file="Includes/Details/Expressions.xml" />

	<!-- Infoline text -->
	<include name="DetailsInfoText">
		<param name="text"></param>
		<param name="visible">true</param>

		<definition>
			<control type="label">
				<visible>$PARAM[visible]</visible>

				<width>auto</width>
				<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

				<font>CAPTION_STRONG</font>
				<aligny>center</aligny>
				<textcolor>FOREGROUND</textcolor>
				<shadowcolor>BACKGROUND_OPAQUE10</shadowcolor>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>

	<!-- Infoline tag -->
	<include name="DetailsInfoTag">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND</param>

		<definition>
			<control type="button">
				<visible>$PARAM[visible]</visible>
				<width>auto</width>
				<height>HEIGHT_DETAILS_INFOLINE</height>

				<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
				<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
				<font>CAPTION2_STRONG</font>
				<textoffsetx>8</textoffsetx>
				<textoffsety>-1</textoffsety>
				<align>right</align>
				<textcolor>$PARAM[textcolor]</textcolor>
				<label>$PARAM[text]</label>
			</control>
		</definition>
	</include>

	<!-- Infoline tag with icon -->
	<include name="DetailsInfoTagWithIcon">
		<param name="text"></param>
		<param name="visible">true</param>
		<param name="bgcolor">BACKGROUND_OPAQUE50</param>
		<param name="textcolor">FOREGROUND_ACCENT</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<width>100%</width>

				<!-- Text (must include empty space for icon, if necessary) with background -->
				<control type="button">
					<width>auto</width>
					<height>HEIGHT_DETAILS_INFOLINE</height>

					<texturefocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturefocus>
					<texturenofocus colordiffuse="$PARAM[bgcolor]" border="8">1080p/diffuse/tag.png</texturenofocus>
					<font>CAPTION2_STRONG</font>
					<textoffsetx>8</textoffsetx>
					<textoffsety>-1</textoffsety>
					<align>right</align>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$PARAM[text]</label>
				</control>

				<!-- Icon (will be over the empty space left in button) -->
				<nested />
			</control>
		</definition>
	</include>


	<!-- Details -->
	<include name="SelectionDetails">
		<param name="visible">true</param>

		<definition>
			<control type="grouplist">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation" />

				<itemgap>PADDING_MULT_10</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<!-- Title/clearlogo -->
				<control type="group">
					<height>HEIGHT_CLEARLOGO_BIG</height>

					<!-- Title (if clearlogo not available) -->
					<control type="label">
						<visible>!$EXP[HasDetailsClearlogo]</visible>

						<width>1000</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<aligny>center</aligny>
						<font>TITLE1</font>
						<textcolor>HIGHLIGHT</textcolor>
						<shadowcolor>BACKGROUND_OPAQUE10</shadowcolor>
						<label>$VAR[DetailsTitle]</label>
					</control>
					<!-- Clearlogo -->
					<control type="image">
						<visible>$EXP[HasDetailsClearlogo]</visible>

						<width>WIDTH_CLEARLOGO_BIG</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<fadetime>ANIMATION_FAST</fadetime>
						<texture background="true">$VAR[DetailsClearlogo]</texture>
						<aspectratio align="left">keep</aspectratio>
					</control>
				</control>

				<!-- Subtitle -->
				<control type="label">
					<visible>$EXP[HasDetailsSubtitle]</visible>

					<width>1000</width>
					<height>HEIGHT_DETAILS_SUBTITLE</height>
					<font>SUBTITLE</font>
					<textcolor>HIGHLIGHT</textcolor>
					<shadowcolor>BACKGROUND_OPAQUE10</shadowcolor>
					<label>$VAR[DetailsSubtitle]</label>
				</control>

				<!-- Info line 1 -->
				<control type="grouplist">
					<orientation>horizontal</orientation>
					<itemgap>PADDING_MULT_30</itemgap>
					<height>HEIGHT_DETAILS_INFOLINE</height>
					<centertop>HEIGHT_DETAILS_INFOLINE</centertop>

					<!-- Resolution -->
					<include content="DetailsInfoTag">
						<param name="text">$VAR[DetailsResolution]</param>
						<param name="visible">$EXP[HasDetailsResolution]</param>
					</include>
					<!-- HDR -->
					<include content="DetailsInfoTag">
						<param name="text">$VAR[DetailsHdr]</param>
						<param name="visible">$EXP[HasDetailsHdr]</param>
					</include>
					<!-- Audio channels -->
					<include content="DetailsInfoTag">
						<param name="text">$VAR[DetailsAudioChannels]</param>
						<param name="visible">$EXP[HasDetailsAudioChannels]</param>
					</include>

					<!-- Year -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsYear]</param>
						<param name="visible">$EXP[HasDetailsYear]</param>
					</include>
					<!-- Episode -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsEpisode]</param>
						<param name="visible">$EXP[HasDetailsEpisode]</param>
					</include>
					<!-- Premiered -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsPremiered]</param>
						<param name="visible">$EXP[HasDetailsPremiered]</param>
					</include>
					<!-- Artist -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsArtist]</param>
						<param name="visible">$EXP[HasDetailsArtist]</param>
					</include>
					<!-- Duration -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsDuration]</param>
						<param name="visible">$EXP[HasDetailsDuration]</param>
					</include>
					<!-- Mpaa -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsMpaa]</param>
						<param name="visible">$EXP[HasDetailsMpaa]</param>
					</include>
					<!-- Status -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsStatus]</param>
						<param name="visible">$EXP[HasDetailsStatus]</param>
					</include>
					<!-- Track -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsTrack]</param>
						<param name="visible">$EXP[HasDetailsTrack]</param>
					</include>

					<!-- Watched status -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      Watched</param>
						<param name="visible">$EXP[IsDetailsWatched]</param>

						<!-- Icon -->
						<control type="image">
							<width>SIZE_DETAILS_WATCHED_ICON</width>
							<height>SIZE_DETAILS_WATCHED_ICON</height>
							<top>OFFSET_TOP_DETAILS_WATCHED_ICON</top>
							<left>OFFSET_LEFT_DETAILS_WATCHED_ICON</left>
							<texture colordiffuse="FOREGROUND_ACCENT">1080p/icons/check.png</texture>
							<aspectratio align="left">keep</aspectratio>
						</control>
					</include>

					<!-- Episodes remaining -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      $VAR[DetailsEpisodesRemaining]</param>
						<param name="visible">!$EXP[IsDetailsWatched] + $EXP[HasDetailsEpisodesRemaining] + !$EXP[IsAllNew]</param>

						<!-- Round icon -->
						<control type="group">
							<width>SIZE_DETAILS_PERCENT_ICON</width>
							<height>SIZE_DETAILS_PERCENT_ICON</height>
							<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
							<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
							
							<control type="image">
								<texture colordiffuse="FOREGROUND_DARK">1080p/progress/circle-100.png</texture>
								<aspectratio align="left">keep</aspectratio>
							</control>
							<control type="image">
								<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$VAR[DetailsWatchedPercentage].png</texture>
								<aspectratio align="left">keep</aspectratio>
							</control>
						</control>
					</include>

					<!-- All new -->
					<include content="DetailsInfoTagWithIcon">
						<param name="text">All new</param>
						<param name="visible">!$EXP[IsDetailsWatched] + $EXP[IsAllNew]</param>
					</include>

					<!-- Time remaining -->
					<include content="DetailsInfoTagWithIcon">
						<!-- Text has space for icon -->
						<param name="text">      $VAR[DetailsTimeRemaining]</param>
						<param name="visible">$EXP[HasDetailsTimeRemaining]</param>

						<!-- Round icon -->
						<control type="group">
							<width>SIZE_DETAILS_PERCENT_ICON</width>
							<height>SIZE_DETAILS_PERCENT_ICON</height>
							<top>OFFSET_TOP_DETAILS_PERCENT_ICON</top>
							<left>OFFSET_LEFT_DETAILS_PERCENT_ICON</left>
							
							<control type="image">
								<texture colordiffuse="FOREGROUND_DARK">1080p/progress/circle-100.png</texture>
								<aspectratio align="left">keep</aspectratio>
							</control>
							<control type="image">
								<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$VAR[DetailsWatchedPercentage].png</texture>
								<aspectratio align="left">keep</aspectratio>
							</control>
						</control>
					</include>
				</control>

				<!-- Info line 2 -->
				<control type="grouplist">
					<visible>$EXP[HasDetailsGenre]</visible>

					<orientation>horizontal</orientation>
					<itemgap>PADDING_MULT_30</itemgap>
					<height>HEIGHT_DETAILS_INFOLINE</height>

					<!-- Genre -->
					<include content="DetailsInfoText">
						<param name="text">$VAR[DetailsGenre]</param>
						<param name="visible">$EXP[HasDetailsGenre]</param>
					</include>
				</control>

				<!-- Summary -->
				<control type="textbox">
					<width>700</width>
					<height>160</height>
					<top>10</top>

					<font>BODY2</font>
					<textcolor>FOREGROUND</textcolor>
					<shadowcolor>BACKGROUND_OPAQUE10</shadowcolor>
					<label>$VAR[DetailsSummary]</label>
				</control>
			</control>
		</definition>
	</include>
</includes>
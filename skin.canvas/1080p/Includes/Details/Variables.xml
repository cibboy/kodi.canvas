	<!-- Audio language -->
	<variable name="DetailsAudioLanguageStream1">
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Property(AudioLanguage.1)]</value>
		<value condition="!$EXP[IsVideoPlayerVisible]">$INFO[Container(501).ListItem.Property(AudioLanguage.1)]</value>
	</variable>
	<variable name="DetailsAudioLanguageStream2">
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Property(AudioLanguage.2)]</value>
		<value condition="!$EXP[IsVideoPlayerVisible]">$INFO[Container(501).ListItem.Property(AudioLanguage.2)]</value>
	</variable>
	<!-- Audio codec -->
	<variable name="DetailsAudioCodecStream1">
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Property(AudioCodec.1)]</value>

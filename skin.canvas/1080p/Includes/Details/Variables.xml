		<value condition="!$EXP[IsVideoPlayerVisible] + !$EXP[IsMusicPlayerVisible] + [$EXP[IsDetailsItemTypeTvShow] | $EXP[IsDetailsItemTypeSeason]]">$INFO[Container(501).ListItem.Property(WatchedEpisodePercent)]</value>

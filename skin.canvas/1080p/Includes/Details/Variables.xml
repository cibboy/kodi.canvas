<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Custom clearlogo -->
	<variable name="DetailsClearlogo">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[Window(home).Property(Player.Item.Clearlogo)]</value>
		<value>$INFO[Window(home).Property(Item.Clearlogo)]</value>
	</variable>
	<!-- Title -->
	<variable name="DetailsTitle">
		<!-- Episodes and seasons show TV show title -->
		<value condition="$EXP[IsVideoPlayerVisible] + [$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeSeason]]">$INFO[VideoPlayer.TVShowTitle]</value>
		<value condition="$EXP[IsDialogInfoVisible] + [$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeSeason]]">$INFO[ListItem.TVShowTitle]</value>
		<!-- Everything else shows the actual item title -->
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.Title]</value>
		<value condition="$EXP[IsMusicPlayerVisible]">$INFO[MusicPlayer.Title]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Title]</value>
		<!-- Episodes and seasons show TV show title -->
		<value condition="$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeSeason]">$INFO[Container(501).ListItem.TVShowTitle]</value>
		<!-- Everything else shows the actual item title -->
		<value>$INFO[Container(501).ListItem.Title]</value>
	</variable>

	<!-- Episode title for episodes, season title for seasons, album name for songs -->
	<variable name="DetailsTitle2">
		<!-- Episode title -->
		<value condition="$EXP[IsVideoPlayerVisible] + $EXP[IsDetailsItemTypeEpisode]">$INFO[VideoPlayer.Title]</value>
		<value condition="$EXP[IsDialogInfoVisible] + $EXP[IsDetailsItemTypeEpisode]">$INFO[ListItem.Title]</value>
		<!-- Season title -->
		<value condition="$EXP[IsVideoPlayerVisible] + $EXP[IsDetailsItemTypeSeason]">$INFO[VideoPlayer.Title]</value>
		<value condition="$EXP[IsDialogInfoVisible] + $EXP[IsDetailsItemTypeSeason]">$INFO[ListItem.Title]</value>
		<!-- Album name -->
		<value condition="$EXP[IsMusicPlayerVisible] + $EXP[IsDetailsItemTypeSong]">$INFO[MusicPlayer.Album]</value>
		<value condition="$EXP[IsDialogInfoVisible] + $EXP[IsDetailsItemTypeSong]">$INFO[ListItem.Album]</value>
		<!-- Episode title -->
		<value condition="$EXP[IsDetailsItemTypeEpisode]">$INFO[Container(501).ListItem.Title]</value>
		<!-- Season title -->
		<value condition="$EXP[IsDetailsItemTypeSeason]">$INFO[Container(501).ListItem.Title]</value>
		<!-- Album name -->
		<value condition="$EXP[IsDetailsItemTypeSong]">$INFO[Container(501).ListItem.Album]</value>
	</variable>

	<!-- Studio -->
	<variable name="DetailsStudio">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.Studio]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Studio]</value>
		<value>$INFO[Container(501).ListItem.Studio]</value>
	</variable>

	<!-- Resolution -->
	<variable name="DetailsResolution">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.VideoResolution]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.VideoResolution]</value>
		<value>$INFO[Container(501).ListItem.VideoResolution]</value>
	</variable>
	<!-- Video codec -->
	<variable name="DetailsVideoCodec">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.VideoCodec]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.VideoCodec]</value>
		<value>$INFO[Container(501).ListItem.VideoCodec]</value>
	</variable>
	<!-- Aspect ratio -->
	<variable name="DetailsAspectRatio">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.VideoAspect]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.VideoAspect]</value>
		<value>$INFO[Container(501).ListItem.VideoAspect]</value>
	</variable>
	<!-- HDR type -->
	<variable name="DetailsHdrType">
		<value condition="$EXP[IsVideoPlayerVisible] + String.IsEqual(ListItem.HdrType,hdr10)">HDR</value>
		<value condition="$EXP[IsVideoPlayerVisible] + String.IsEqual(ListItem.HdrType,dolbyvision)">Dolby Vision</value>
		<value condition="$EXP[IsVideoPlayerVisible] + String.IsEqual(ListItem.HdrType,hlg)">HLG</value>
		<value condition="$EXP[IsVideoPlayerVisible]">[UPPERCASE]$INFO[VideoPlayer.HdrType][/UPPERCASE]</value>
		<value condition="$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.HdrType,hdr10)">HDR</value>
		<value condition="$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.HdrType,dolbyvision)">Dolby Vision</value>
		<value condition="$EXP[IsDialogInfoVisible] + String.IsEqual(ListItem.HdrType,hlg)">HLG</value>
		<value condition="$EXP[IsDialogInfoVisible]">[UPPERCASE]$INFO[ListItem.HdrType][/UPPERCASE]</value>
		<value condition="String.IsEqual(Container(501).ListItem.HdrType,hdr10)">HDR</value>
		<value condition="String.IsEqual(Container(501).ListItem.HdrType,dolbyvision)">Dolby Vision</value>
		<value condition="String.IsEqual(Container(501).ListItem.HdrType,hlg)">HLG</value>
		<value>[UPPERCASE]$INFO[Container(501).ListItem.HdrType][/UPPERCASE]</value>
	</variable>

		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Artist]</value>
		<value>$INFO[Container(501).ListItem.Artist]</value>
	</variable>

	<!-- Duration -->
	<variable name="DetailsDuration">
		<value condition="$EXP[IsVideoPlayerVisible] + !String.IsEqual(Player.Duration(h),0)">$INFO[Player.Duration(h)]h $INFO[Player.Duration(mm)]m</value>
		<value condition="$EXP[IsVideoPlayerVisible] + String.IsEqual(Player.Duration(h),0)">$INFO[Player.Duration(mm)]m</value>
		<value condition="$EXP[IsMusicPlayerVisible] + !String.IsEqual(Player.Duration(h),0)">$INFO[Player.Duration(h)]h $INFO[Player.Duration(mm)]m $INFO[Player.Duration(ss)]s</value>
		<value condition="$EXP[IsMusicPlayerVisible] + String.IsEqual(Player.Duration(h),0)">$INFO[Player.Duration(m)]m $INFO[Player.Duration(ss)]s</value>

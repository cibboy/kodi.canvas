	</variable>

	<!-- Year -->
	<variable name="DetailsYear">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.Year]</value>
		<value condition="$EXP[IsMusicPlayerVisible]">$INFO[MusicPlayer.Year]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Year]</value>
		<value>$INFO[Container(501).ListItem.Year]</value>
	</variable>

	<!-- Episode number -->
	<variable name="DetailsEpisodeNumber">
		<value condition="$EXP[IsVideoPlayerVisible]">S$INFO[VideoPlayer.Season]·E$INFO[VideoPlayer.Episode]</value>
		<value condition="$EXP[IsDialogInfoVisible]">S$INFO[ListItem.Season]·E$INFO[ListItem.Episode]</value>
		<value>S$INFO[Container(501).ListItem.Season]·E$INFO[Container(501).ListItem.Episode]</value>
	</variable>
	<!-- Episode premiere -->
	<variable name="DetailsEpisodePremiere">
		<value condition="$EXP[IsVideoPlayerVisible]">$INFO[VideoPlayer.Premiered]</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Premiered]</value>
		<value>$INFO[Container(501).ListItem.Premiered]</value>
	</variable>
	<!-- Number of episodes -->
	<variable name="DetailsNumberOfEpisodes">
		<value condition="$EXP[IsDialogInfoVisible] + Integer.IsGreater(ListItem.Property(TotalEpisodes),1)">$INFO[ListItem.Property(TotalEpisodes)] episodes</value>
		<value condition="$EXP[IsDialogInfoVisible]">$INFO[ListItem.Property(TotalEpisodes)] episode</value>
		<value condition="!$EXP[IsVideoPlayerVisible] + Integer.IsGreater(Container(501).ListItem.Property(TotalEpisodes),1)">$INFO[Container(501).ListItem.Property(TotalEpisodes)] episodes</value>
		<value condition="!$EXP[IsVideoPlayerVisible]">$INFO[Container(501).ListItem.Property(TotalEpisodes)] episode</value>
	</variable>


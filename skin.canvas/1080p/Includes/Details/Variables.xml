<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Custom clearlogo -->
	<variable name="DetailsClearlogo">
		<value>$INFO[Window(home).Property(Details.Clearlogo)]</value>
	</variable>
	<!-- Title -->
	<variable name="DetailsTitle">
		<value>$INFO[Window(home).Property(Details.Title)]</value>
	</variable>

	<!-- Episode title for episodes, season title for seasons, album name for songs -->
	<variable name="DetailsTitle2">
		<value>$INFO[Window(home).Property(Details.Title2)]</value>
	</variable>

	<!-- Studio -->
	<variable name="DetailsStudio">
		<value>$INFO[Window(home).Property(Details.Studio)]</value>
	</variable>

	<!-- Resolution -->
	<variable name="DetailsResolution">
		<value>$INFO[Window(home).Property(Details.VideoResolution)]</value>
	</variable>
	<!-- Video codec -->
	<variable name="DetailsVideoCodec">
		<value>$INFO[Window(home).Property(Details.VideoCodec)]</value>
	</variable>
	<!-- Aspect ratio -->
	<variable name="DetailsAspectRatio">
		<value>$INFO[Window(home).Property(Details.AspectRatio)]</value>
	</variable>
	<!-- HDR type -->
	<variable name="DetailsHdrType">
		<value>$INFO[Window(home).Property(Details.HdrType)]</value>
	</variable>
	<!-- Audio channels -->
	<variable name="DetailsAudioChannels">
		<value>$INFO[Window(home).Property(Details.AudioChannels)]</value>
	</variable>
	<variable name="DetailsAudioChannelsStream1">
		<value>$INFO[Window(home).Property(Details.AudioChannels.1)]</value>
	</variable>
	<variable name="DetailsAudioChannelsStream2">
		<value>$INFO[Window(home).Property(Details.AudioChannels.2)]</value>
	</variable>
	<!-- Audio language -->
	<variable name="DetailsAudioLanguageStream1">
		<value>$INFO[Window(home).Property(Details.AudioLanguage.1)]</value>
	</variable>
	<variable name="DetailsAudioLanguageStream2">
		<value>$INFO[Window(home).Property(Details.AudioLanguage.2)]</value>
	</variable>
	<!-- Audio codec -->
	<variable name="DetailsAudioCodecStream1">
		<value>$INFO[Window(home).Property(Details.AudioCodec.1)]</value>
	</variable>
	<variable name="DetailsAudioCodecStream2">
		<value>$INFO[Window(home).Property(Details.AudioCodec.2)]</value>
	</variable>

	<!-- Year -->
	<variable name="DetailsYear">
		<value>$INFO[Window(home).Property(Details.Year)]</value>
	</variable>

	<!-- Episode number -->
	<variable name="DetailsEpisodeNumber">
		<value>$INFO[Window(home).Property(Details.EpisodeNumber)]</value>
	</variable>
	<!-- Episode premiere -->
	<variable name="DetailsEpisodePremiere">
		<value>$INFO[Window(home).Property(Details.EpisodePremiere)]</value>
	</variable>
	<!-- Number of episodes -->
	<variable name="DetailsNumberOfEpisodes">
		<value>$INFO[Window(home).Property(Details.NumberOfEpisodes)]</value>
	</variable>

	<!-- Artist -->
	<variable name="DetailsArtist">
		<value>$INFO[Window(home).Property(Details.Artist)]</value>
	</variable>

	<!-- Duration -->
	<variable name="DetailsDuration">
		<value>$INFO[Window(home).Property(Details.Duration)]</value>
	</variable>

	<!-- MPAA -->
	<variable name="DetailsMpaa">
		<value>$INFO[Window(home).Property(Details.Mpaa)]</value>
	</variable>

	<!-- Status -->
	<variable name="DetailsStatus">
		<value>$INFO[Window(home).Property(Details.Status)]</value>
	</variable>

	<!-- Track number -->
	<variable name="DetailsTrackNumber">
		<value>Track $INFO[Window(home).Property(Details.TrackNumber)]</value>
	</variable>

	<!-- Genre -->
	<variable name="DetailsGenre">
		<value>$INFO[Window(home).Property(Details.Genre)]</value>
	</variable>

	<!-- Episodes remaining -->
	<variable name="DetailsEpisodesRemaining">
		<value>$INFO[Window(home).Property(Details.EpisodesRemaining)]</value>
	</variable>
	<!-- Percent played -->
	<variable name="DetailsPercentPlayed">
		<value>$INFO[Window(home).Property(Details.PercentagePlayed)]</value>
	</variable>
	<!-- Time remaining -->
	<variable name="DetailsTimeRemaining">
		<value>$INFO[Window(home).Property(Details.TimeRemaining)] left</value>
	</variable>

	<!-- Plot -->
	<variable name="DetailsPlot">
		<value>$INFO[Window(home).Property(Details.Plot)]</value>
	</variable>

	<!-- Director -->
	<variable name="DetailsDirector">
		<value>$INFO[Window(home).Property(Details.Director)]</value>
	</variable>
	<!-- Writer -->
	<variable name="DetailsWriter">
		<value>$INFO[Window(home).Property(Details.Writer)]</value>
	</variable>
	<!-- File path -->
	<variable name="DetailsFilePath">
		<value>$INFO[Window(home).Property(Details.FilePath)]</value>
	</variable>
	<!-- Audio stream -->
	<variable name="DetailsAudioStream1">
		<value condition="!$EXP[IsVideoPlayerVisible] + $EXP[HasDetailsAudioLanguageStream1]">[CAPITALIZE]$VAR[DetailsAudioLanguageStream1][/CAPITALIZE] / [UPPERCASE]$VAR[DetailsAudioCodecStream1][/UPPERCASE] / $VAR[DetailsAudioChannelsStream1]</value>
		<value condition="!$EXP[IsVideoPlayerVisible]">[UPPERCASE]$VAR[DetailsAudioCodecStream1][/UPPERCASE] / $VAR[DetailsAudioChannelsStream1]</value>
	</variable>
	<variable name="DetailsAudioStream2">
		<value condition="!$EXP[IsVideoPlayerVisible] + $EXP[HasDetailsAudioLanguageStream1] + $EXP[HasDetailsAudioCodecStream2] + $EXP[HasDetailsAudioChannelsStream2]">[CAPITALIZE]$VAR[DetailsAudioLanguageStream2][/CAPITALIZE] / [UPPERCASE]$VAR[DetailsAudioCodecStream2][/UPPERCASE] / $VAR[DetailsAudioChannelsStream2]</value>
		<value condition="!$EXP[IsVideoPlayerVisible] + $EXP[HasDetailsAudioCodecStream2] + $EXP[HasDetailsAudioChannelsStream2]">[UPPERCASE]$VAR[DetailsAudioCodecStream2][/UPPERCASE] / $VAR[DetailsAudioChannelsStream2]</value>
	</variable>


	<!-- Constants -->
	<constant name="HEIGHT_DETAILS_TITLE_SECTION">160</constant>
	<constant name="HEIGHT_DETAILS_TITLE">90</constant>
	<constant name="HEIGHT_DETAILS_CLEARLOGO">150</constant>
	<constant name="WIDTH_DETAILS_CLEARLOGO">800</constant>

	<constant name="HEIGHT_DETAILS_INFOLINE">36</constant>
	<constant name="HEIGHT_DETAILS_INFOLINE_DOUBLE">76</constant>
	<constant name="HEIGHT_DETAILS_INFOLINE_TAG">34</constant>
	<constant name="HEIGHT_DETAILS_INFOLINE_TAG_SMALL">32</constant>
	<constant name="HEIGHT_DETAILS_INFOLINE_TEXT">32</constant>
	<constant name="OFFSET_DETAILS_INFOLINE_CONTENT">4</constant>
	<constant name="HEIGHT_DETAILS_INFOLINE_CUSTOM">40</constant>
	<constant name="HEIGHT_DETAILS_PLOT">160</constant>
	<constant name="HEIGHT_VIDEOINFO_PLOT">315</constant>

	<constant name="OFFSET_X_DETAILS_TAG">8</constant>
	<constant name="OFFSET_Y_DETAILS_TAG">-2</constant>

	<constant name="HEIGHT_DETAILS_POSTER">585</constant>
	<constant name="WIDTH_DETAILS_POSTER">410</constant>
	<constant name="HEIGHT_DETAILS_LANDSCAPE">338</constant>
	<constant name="WIDTH_DETAILS_LANDSCAPE">600</constant>

	<constant name="SIZE_DETAILS_WATCHED_ICON">25</constant>
	<constant name="OFFSET_TOP_DETAILS_WATCHED_ICON">5</constant>
	<constant name="OFFSET_LEFT_DETAILS_WATCHED_ICON">6</constant>

	<constant name="SIZE_DETAILS_PERCENT_ICON">38</constant>
	<constant name="OFFSET_TOP_DETAILS_PERCENT_ICON">-2</constant>
	<constant name="OFFSET_LEFT_DETAILS_PERCENT_ICON">-1</constant>
</includes>
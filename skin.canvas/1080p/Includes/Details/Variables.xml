		<value condition="!$EXP[IsDetailsItemTypeVideo] + String.IsEqual(Container(501).ListItem.Duration(h),0)">$INFO[Container(501).ListItem.Duration(m)]m $INFO[Container(501).ListItem.Duration(ss)]s</value>
	</variable>


		<value condition="$EXP[IsDetailsItemTypeVideo] + !String.IsEqual(Container(501).ListItem.Duration(h),0)">$INFO[Container(501).ListItem.Duration(h)]h $INFO[Container(501).ListItem.Duration(mm)]m</value>

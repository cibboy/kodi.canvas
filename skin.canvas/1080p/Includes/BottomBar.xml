<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="BottomBar">
		<param name="show">false</param>
		<param name="show_studio">false</param>
		<param name="studio"></param>

		<definition>
			<control type="group">
				<visible>$PARAM[show]</visible>
				<include content="ShowHideFadeAnimation" />

				<bottom>0</bottom>
				<height>360</height>

				<!-- Darkening -->
				<control type="image">
					<width>1920</width>
					<height>360</height>
					<texture colordiffuse="BACKGROUND_OPAQUE90" flipy="true">1080p/diffuse/corner.png</texture>
				</control>

				<!-- Studio logo -->
				<control type="image">
					<visible>$PARAM[show_studio]</visible>
					<width>WIDTH_STUDIO_LOGO</width>
					<height>HEIGHT_STUDIO_LOGO</height>
					<right>PADDING_BASE</right>
					<bottom>PADDING_MULT_120</bottom>
					<fadetime>ANIMATION_MID</fadetime>
					<texture>$PARAM[studio]</texture>
				</control>
			</control>
		</definition>
	</include>
</includes>
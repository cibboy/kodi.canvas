<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="BottomBar">
		<definition>
			<control type="group">
				<visible>$EXP[HasDetailsStudio]</visible>
				<include content="ShowHideFadeAnimation" />

				<bottom>0</bottom>
				<height>360</height>

				<!-- Darkening -->
				<control type="image">
					<width>1920</width>
					<height>360</height>
					<texture colordiffuse="BACKGROUND_OPAQUE90" flipy="true">1080p/diffuse/corner.png</texture>
				</control>

				<!-- Studio logo -->
				<control type="image">
					<!-- On home, slide with the side menu -->
					<animation type="Conditional" condition="$EXP[HasHomeMenuFocus]"><effect type="slide" start="0,0" end="OFFSET_HOME_MENU_END,0" time="ANIMATION_FAST" tween="cubic" easing="out" reversible="true" /></animation>

					<width>WIDTH_STUDIO_LOGO</width>
					<height>HEIGHT_STUDIO_LOGO</height>
					<right>PADDING_BASE</right>
					<bottom>PADDING_BASE_10P</bottom>
					<fadetime>ANIMATION_MID</fadetime>
					<texture>resource://resource.images.studios.coloured/$VAR[DetailsStudio].png</texture>
				</control>
			</control>
		</definition>
	</include>
</includes>
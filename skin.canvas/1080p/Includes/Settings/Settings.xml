						<align>left</align>
						<font>SETTINGS_CAPTION</font>
						<textcolor>FOREGROUND_ACCENT_ALT</textcolor>
					</control>
				</control>
			
				<!-- Action buttons -->
				<control type="group">
					<top>OFFSET_SETTINGS_OPTIONS_START</top>
					<left>WIDTH_BACKGROUND_SPLIT</left>
					<width>WIDTH_BACKGROUND_SPLIT_REMAINING</width>

					<control type="grouplist" id="999">
						<!-- Hide when a secondary dialog appears -->
						<visible>!$EXP[IsSettingsAnySimpleDialogActive]</visible>
						<animation type="Visible">
							<effect type="fade" end="100" time="ANIMATION_FAST" tween="circle" easing="out" />
						</animation>
						<animation type="Hidden">
							<effect type="fade" end="0" time="ANIMATION_FAST" tween="circle" easing="out" />
						</animation>

						<left>PADDING_SETTINGS_NARROW_SIDE</left>
						<right>PADDING_SETTINGS_NARROW_SIDE</right>

						<!-- Go to options on left -->
						<onleft>SetFocus(5)</onleft>

						<!-- Ok -->
						<control type="button" id="28">
							<width>100%</width>
						</control>
						<!-- Cancel -->
						<control type="button" id="29">
							<width>100%</width>
						</control>
						<!-- Clear/settings -->
						<control type="button" id="30">
							<width>100%</width>

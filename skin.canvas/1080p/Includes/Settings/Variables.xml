<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Icons -->
	<variable name="SettingsInterfaceIcon"><value>1080p/icons/interface.png</value></variable>
	<variable name="SettingsSystemIcon"><value>1080p/icons/system.png</value></variable>
	<variable name="SettingsServicesIcon"><value>1080p/icons/services.png</value></variable>
	<variable name="SettingsPlayerIcon"><value>1080p/icons/player.png</value></variable>
	<variable name="SettingsLibraryIcon"><value>1080p/icons/library.png</value></variable>

	<!-- Settings complexity level icon -->
	<variable name="SettingsComplexityLevelIcon">
		<value condition="String.StartsWith(Control.GetLabel(20),$LOCALIZE[10039])">1080p/icons/settings-expert.png</value>
		<value condition="String.StartsWith(Control.GetLabel(20),$LOCALIZE[10038])">1080p/icons/settings-advanced.png</value>
		<value condition="String.StartsWith(Control.GetLabel(20),$LOCALIZE[10037])">1080p/icons/settings-standard.png</value>
		<value condition="String.StartsWith(Control.GetLabel(20),$LOCALIZE[10036])">1080p/icons/settings-basic.png</value>
	</variable>

	<!-- DialogSelect icons for settings -->
	<variable name="SettingsDialogSelectIcon">
		<value condition="$EXP[HasSettingsDialogSelectIcon]">$INFO[ListItem.Icon]</value>
		<!--
			Addon fallback icons:
			- Skin
			- GUI sounds
			- Service for weather information
			- Music visualization
			- Service for TV show subtitles
			- Service for movie subtitles
			- Provider for music album info
			- Provider for music artist info
		-->
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[166])">1080p/icons/interface.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[15108])">1080p/icons/speaker.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[24029])">1080p/icons/weather.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[250])">1080p/icons/music.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[24116])">1080p/icons/speaker.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[24118])">1080p/icons/speaker.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[20193])">1080p/icons/music.png</value>
		<value condition="!$EXP[HasSettingsDialogSelectIcon] + String.IsEqual(Control.GetLabel(1),$LOCALIZE[20194])">1080p/icons/music.png</value>
	</variable>

	<!-- Button background texture color diffuse to allow fade when dialog open -->
	<variable name="SettingsOptionButtonColor">
		<value condition="!$EXP[IsSettingsAnySimpleDialogActive]">BACKGROUND_INVERSE_OPAQUE90</value>
		<value condition="$EXP[IsSettingsAnySimpleDialogActive]">BACKGROUND_INVERSE_OPAQUE50</value>
	</variable>

	<!-- Constants -->
	<constant name="WIDTH_BACKGROUND_SPLIT">1200</constant>
	<constant name="WIDTH_BACKGROUND_SPLIT_NEG">-1200</constant>
	<constant name="WIDTH_BACKGROUND_SPLIT_REMAINING">720</constant>
	<constant name="WIDTH_BACKGROUND_SPLIT_REMAINING_NEG">-720</constant>

	<constant name="PADDING_SETTINGS_WIDE_SIDE">100</constant>
	<constant name="PADDING_SETTINGS_NARROW_SIDE">80</constant>
	
	<constant name="OFFSET_SETTINGS_OPTIONS_START">150</constant>
	<constant name="OFFSET_SETTINGS_EXPERT_START">750</constant>	<!-- List offset + list height = 150 + (120 * 5) = 750 -->
	<constant name="PADDING_SETTINGS_TITLE">16</constant>
	<constant name="PADDING_LEFT_SETTINGS_INFO">160</constant>

	<constant name="HEIGHT_SETTINGS_DIALOG_LIST">750</constant>

	<constant name="OFFSET_SETTINGS_OPTIONS_CONTENT">100</constant>
	<constant name="OFFSET_SETTINGS_EXPERT_CONTENT">160</constant>	<!-- Standard option offset + standard button padding = 100 + 60 -->
	<constant name="GAP_SETTINGS_LIST_OPTION">-30</constant>
	<constant name="WIDTH_SETTINGS_GROUPLIST_NARROW_OPTION">560</constant>	<!-- If we use 100% we lose the right border somehow... -->
	<constant name="PADDING_LIST_NARROW_VERTICAL_CHEVRON">-40</constant>

	<constant name="WIDTH_SETTINGS_OPTION_WIDE">1000</constant>
	<constant name="HEIGHT_SETTINGS_CAPTION">100</constant>
	<constant name="OFFSET_SETTINGS_CAPTION">80</constant>
	<constant name="OFFSET_SETTINGS_OPTION_RADIO_WIDE">920</constant>
	<constant name="OFFSET_SETTINGS_OPTION_SPIN_WIDE">50</constant>
	<constant name="PADDING_SETTINGS_OPTIONS_VERTICAL_WIDE">55</constant>

	<constant name="SIZE_SETTINGS_ICON">40</constant>
	<constant name="HEIGHT_SETTINGS_OPTION_CONTAINER">120</constant>
	<constant name="HEIGHT_SETTINGS_OPTION_CONTENT">70</constant>
	<constant name="OFFSET_SETTINGS_OPTION_TITLE">-10</constant>
	<constant name="OFFSET_SETTINGS_OPTION_TITLE_SINGLELINE">38</constant>

	<constant name="SIZE_SETTINGS_DIALOG_SELECTIONMARK">24</constant>
	<constant name="SIZE_SETTINGS_DIALOG_COLOR">90</constant>
	<constant name="SIZE_SETTINGS_DIALOG_COLOR_PADDED">88</constant>
	<constant name="OFFSET_SETTINGS_DIALOG_OPTIONS_SELECTIONMARK_CONTENT">80</constant>
</includes>
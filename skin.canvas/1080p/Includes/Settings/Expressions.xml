<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is any settings page active? -->
	<expression name="IsAnySettingsPageActive">
		Window.IsActive(SettingsCategory.xml) | 
		$EXP[IsMediaNavLibraryNavigation]
	</expression>

	<!-- Is interface settings page active? -->
	<expression name="IsInterfaceSettingsPageActive">Window.IsActive(interfacesettings)</expression>
	<!-- Is system settings page active? -->
	<expression name="IsSystemSettingsPageActive">Window.IsActive(systemsettings)</expression>
	<!-- Is service settings page active? -->
	<expression name="IsServiceSettingsPageActive">Window.IsActive(servicesettings)</expression>
	<!-- Is player settings page active? -->
	<expression name="IsPlayerSettingsPageActive">Window.IsActive(playersettings)</expression>
	<!-- Is media settings page active? -->
	<expression name="IsMediaSettingsPageActive">Window.IsActive(mediasettings)</expression>

	<!-- Is DialogSelect active in settings? -->
	<expression name="IsSettingsDialogSelectActive">
		$EXP[IsAnySettingsPageActive] +
		[
			Window.IsVisible(selectdialog) |
			Window.IsVisible(peripherals)
		]
	</expression>
	<!-- Is DialogConfirm active in settings? -->
	<expression name="IsSettingsDialogConfirmActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(DialogConfirm.xml)
	</expression>
	<!-- Is DialogContextMenu active in settings? -->
	<expression name="IsSettingsDialogContextMenuActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(DialogContextMenu.xml)
	</expression>
	<!-- Is DialogColorPicker active in settings? -->
	<expression name="IsSettingsDialogColorPickerActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(dialogcolorpicker)
	</expression>
	<!-- Is DialogSettings active in settings? -->
	<expression name="IsSettingsDialogSettingsActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(DialogSettings.xml)
	</expression>
	<!-- Is DialogAddonSettings active in settings? -->
	<expression name="IsSettingsDialogAddonSettingsActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(DialogAddonSettings.xml)
	</expression>
	<!-- Is DialogMediaSource active in settings? -->
	<expression name="IsSettingsDialogMediaSourceActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(DialogMediaSource.xml)
	</expression>
	<!-- Is FileBrowser active in settings? -->
	<expression name="IsSettingsFileBrowserActive">
		$EXP[IsAnySettingsPageActive] +
		Window.IsVisible(FileBrowser.xml)
	</expression>
	<!-- Is any "simple" dialog active in settings? -->
	<expression name="IsSettingsAnySimpleDialogActive">
		$EXP[IsSettingsDialogSelectActive] |
		$EXP[IsSettingsDialogConfirmActive] |
		$EXP[IsSettingsDialogColorPickerActive] |
		$EXP[IsSettingsFileBrowserActive]
	</expression>
	<!-- Is any dialog active in settings? -->
	<expression name="IsSettingsAnyDialogActive">
		$EXP[IsSettingsDialogSelectActive] |
		$EXP[IsSettingsDialogConfirmActive] |
		$EXP[IsSettingsDialogContextMenuActive] |
		$EXP[IsSettingsDialogColorPickerActive] |
		$EXP[IsSettingsDialogSettingsActive] |
		$EXP[IsSettingsDialogAddonSettingsActive] |
		$EXP[IsSettingsFileBrowserActive]
	</expression>

	<!-- Has DialogSelect an actual icon? -->
	<expression name="HasSettingsDialogSelectIcon">!String.IsEmpty(ListItem.Icon) + !String.IsEqual(ListItem.Icon,DefaultAddon.png)</expression>

	<!--
		Has main section list focus?
		Consider:
		- Section list (ID: 1000)
		- Expert level (ID: 20)
	-->
	<expression name="HasSettingSectionsFocus">
		Control.HasFocus(1000) |
		Control.HasFocus(20)
	</expression>
</includes>
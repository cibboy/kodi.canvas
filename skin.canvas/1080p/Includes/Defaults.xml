<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Label -->
	<default type="label">
		<align>left</align>
		<font>BODY</font>
		<scroll>false</scroll>
		<textcolor>FOREGROUND</textcolor>
		<selectedcolor>FOREGROUND_ACCENT</selectedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
	</default>

	<!-- Button -->
	<default type="button">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Toggle button -->
	<default type="togglebutton">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<alttexturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</alttexturefocus>
		<alttexturenofocus />
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Radio button -->
	<default type="radiobutton">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<textureradioonfocus colordiffuse="FOREGROUND_ACCENT_ALT">1080p/controls/check-on.png</textureradioonfocus>
		<textureradioonnofocus colordiffuse="FOREGROUND_OPAQUE35">1080p/controls/check-on.png</textureradioonnofocus>
		<textureradioondisabled colordiffuse="FOREGROUND_INVERSE_OPAQUE75">1080p/controls/check-on.png</textureradioondisabled>
		<textureradioofffocus colordiffuse="FOREGROUND_ACCENT_ALT">1080p/controls/check-off.png</textureradioofffocus>
		<textureradiooffnofocus colordiffuse="FOREGROUND_OPAQUE35">1080p/controls/check-off.png</textureradiooffnofocus>
		<textureradiooffdisabled colordiffuse="FOREGROUND_INVERSE_OPAQUE75">1080p/controls/check-off.png</textureradiooffdisabled>
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<radiowidth>24</radiowidth>
		<radioheight>24</radioheight>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Spin button -->
	<default type="spincontrolex">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<textureup colordiffuse="FOREGROUND_INVERSE">1080p/controls/spin-up.png</textureup>
		<textureupfocus colordiffuse="FOREGROUND_ACCENT_ALT">1080p/controls/spin-up.png</textureupfocus>
		<textureupdisabled colordiffuse="FOREGROUND_OPAQUE35">1080p/controls/spin-up.png</textureupdisabled>
		<texturedown colordiffuse="FOREGROUND_INVERSE" flipy="true">1080p/controls/spin-up.png</texturedown>
		<texturedownfocus colordiffuse="FOREGROUND_ACCENT_ALT" flipy="true">1080p/controls/spin-up.png</texturedownfocus>
		<texturedowndisabled colordiffuse="FOREGROUND_OPAQUE35" flipy="true">1080p/controls/spin-up.png</texturedowndisabled>
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<spinwidth>50</spinwidth>
		<spinheight>50</spinheight>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Slider button -->
	<default type="sliderex">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<texturesliderbar colordiffuse="FOREGROUND_INVERSE" border="6">1080p/progress/bg.png</texturesliderbar>
		<texturesliderbardisabled colordiffuse="FOREGROUND_OPAQUE35" border="6">1080p/progress/bg.png</texturesliderbardisabled>
		<textureslidernib colordiffuse="FOREGROUND_OPAQUE50">1080p/progress/mid.png</textureslidernib>
		<textureslidernibfocus colordiffuse="FOREGROUND_ACCENT">1080p/progress/mid.png</textureslidernibfocus>
		<textureslidernibdisabled colordiffuse="FOREGROUND_INVERSE_OPAQUE75">1080p/progress/mid.png</textureslidernibdisabled>
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<sliderwidth>150</sliderwidth>
		<sliderheight>12</sliderheight>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Color button -->
	<default type="colorbutton">
		<width>auto</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus />
		<texturecolormask>1080p/controls/colorpicker.png</texturecolormask>
		<texturecolordisabledmask colordiffuse="FOREGROUND_OPAQUE35">1080p/controls/colorpicker.png</texturecolordisabledmask>
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<align>left</align>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
		<colorwidth>100</colorwidth>
		<colorheight>26</colorheight>
	</default>

	<!-- Edit -->
	<default type="edit">
		<width>500</width>
		<height>HEIGHT_BUTTON_DEFAULT</height>
		<texturefocus colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
		<texturenofocus colordiffuse="BACKGROUND_INVERSE_OPAQUE20" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
		<font>BUTTON</font>
		<textcolor>FOREGROUND_OPAQUE75</textcolor>
		<focusedcolor>FOREGROUND_INVERSE</focusedcolor>
		<disabledcolor>FOREGROUND_OPAQUE35</disabledcolor>
		<invalidcolor>FOREGROUND_ERROR</invalidcolor>
		<textoffsety>PADDING_BUTTON_VERTICAL</textoffsety>
		<textoffsetx>PADDING_BUTTON_HORIZONTAL</textoffsetx>
		<aligny>center</aligny>
		<pulseonselect>false</pulseonselect>
	</default>

	<!-- Scrollbar -->
	<default type="scrollbar">
		<width>10</width>
        <texturesliderbackground colordiffuse="FOREGROUND_OPAQUE10" border="4">1080p/controls/scrollbar-vertical-bg.png</texturesliderbackground>
        <texturesliderbar colordiffuse="FOREGROUND_DARKER" border="4">1080p/controls/scrollbar-vertical.png</texturesliderbar>
		<texturesliderbarfocus colordiffuse="FOREGROUND_ACCENT" border="4">1080p/controls/scrollbar-vertical.png</texturesliderbarfocus>
        <textureslidernib/>
        <textureslidernibfocus/>
        <showonepage>false</showonepage>
        <orientation>vertical</orientation>
    </default>

	<!-- Progress -->
	<default type="progress">
		<height>12</height>
		<texturebg colordiffuse="BACKGROUND_OPAQUE50" border="6">1080p/progress/bg.png</texturebg>
		<midtexture colordiffuse="FOREGROUND_ACCENT" border="6">1080p/progress/mid.png</midtexture>
	</default>

	<!-- Ranges -->
	<default type="ranges">
		<height>12</height>
		<texturebg colordiffuse="TRANSPARENT">1080p/controls/marker-bg.png</texturebg>
		<righttexture colordiffuse="BACKGROUND_OPAQUE50">1080p/controls/marker.png</righttexture>
	</default>
</includes>

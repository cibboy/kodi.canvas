<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<variable name="Clearlogo">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Property(Clearlogo.Big)]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),120)">$INFO[Container(120).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),130)">$INFO[Container(130).ListItem.Property(Clearlogo.Big)]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),140)">$INFO[Container(140).ListItem.Property(Clearlogo.Big)]</value>
	</variable>
	<variable name="Title">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode)">$INFO[Container(101).ListItem.TVShowTitle]</value>
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Title]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.TVShowTitle]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Title]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Title]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Title]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),120)">$INFO[Container(120).ListItem.Title]</value>
		<!-- Yoga --><!--todo-->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),130)">$INFO[Container(130).ListItem.Title]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),140)">$INFO[Container(140).ListItem.Title]</value>
	</variable>
	<variable name="Subtitle">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode)">$INFO[Container(101).ListItem.Title]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Title]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Album]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),140)">$INFO[Container(140).ListItem.Album]</value>
	</variable>
	<variable name="Info"><!--todo: rating time_left/watched-->
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode)">S$INFO[Container(101).ListItem.Season]·E$INFO[Container(101).ListItem.Episode]   $INFO[Container(101).ListItem.Premiered]   $INFO[Container(101).ListItem.Property(DurationString)]   $INFO[Container(101).ListItem.Mpaa]</value>
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Year]   $INFO[Container(101).ListItem.Property(DurationString)]   $INFO[Container(101).ListItem.Mpaa]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">S$INFO[Container(102).ListItem.Season]·E$INFO[Container(102).ListItem.Episode]   $INFO[Container(102).ListItem.Premiered]   $INFO[Container(102).ListItem.Property(DurationString)]   $INFO[Container(102).ListItem.Mpaa]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Year]   $INFO[Container(103).ListItem.Property(DurationString)]   $INFO[Container(103).ListItem.Mpaa]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Year]   $INFO[Container(104).ListItem.Artist]   $INFO[Container(104).ListItem.Property(DurationString)]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Year]   $INFO[Container(110).ListItem.Property(DurationString)]   $INFO[Container(110).ListItem.Mpaa]</value>
		<!-- TV shows --><!--todo-->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),120)">$INFO[Container(120).ListItem.Year] • $INFO[Container(120).ListItem.Status] • $INFO[Container(120).ListItem.Genre]</value>
		<!-- Yoga --><!--todo-->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),130)">$INFO[Container(130).ListItem.Year] • $INFO[Container(130).ListItem.Status] • $INFO[Container(130).ListItem.Genre]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),140)">$INFO[Container(140).ListItem.Year]   $INFO[Container(140).ListItem.Artist]   $INFO[Container(140).ListItem.Property(DurationString)]</value>
	</variable>
	<variable name="Info2">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),movie)">$INFO[Container(101).ListItem.Genre]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Genre]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Genre]</value>
	</variable>
	<variable name="Summary">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Plot]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Plot]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Plot]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Plot]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Plot]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),120)">$INFO[Container(120).ListItem.Plot]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),130)">$INFO[Container(130).ListItem.Plot]</value>
	</variable>

	<!-- Continue watching -->
	<!-- Recently added episodes -->
	<!-- Recently added movies -->
	<!-- Recently added music -->
	<!-- Movies -->
	<!-- TV shows -->
	<!-- Yoga -->
	<!-- Music -->
	<expression name="HasClearlogo">
		[String.IsEqual(Window(home).Property(Home.ActiveListId),101) + !String.IsEmpty(Container(101).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),102) + !String.IsEmpty(Container(102).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),103) + !String.IsEmpty(Container(103).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),104) + !String.IsEmpty(Container(104).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),110) + !String.IsEmpty(Container(110).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),120) + !String.IsEmpty(Container(120).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),130) + !String.IsEmpty(Container(130).ListItem.Property(Clearlogo.Big))] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),140) + !String.IsEmpty(Container(140).ListItem.Property(Clearlogo.Big))]
	</expression>
	<!-- Continue watching -->
	<!-- Recently added episodes -->
	<!-- Recently added music -->
	<!-- TV shows -->
	<!-- Music -->
	<expression name="HasSubtitle">
		[String.IsEqual(Window(home).Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode) + !String.IsEmpty(Container(101).ListItem.Title)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),102) + !String.IsEmpty(Container(102).ListItem.Title)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),104) + !String.IsEmpty(Container(104).ListItem.Album)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),140) + !String.IsEmpty(Container(140).ListItem.Album)]
	</expression>
	<!-- Recently added movies -->
	<!-- Movies -->
	<expression name="HasInfo2">
		[String.IsEqual(Window(home).Property(Home.ActiveListId),101) + !String.IsEmpty(Container(101).ListItem.Genre)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),103) + !String.IsEmpty(Container(103).ListItem.Genre)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),110) + !String.IsEmpty(Container(110).ListItem.Title)]
	</expression>

	<include name="SelectionDetails">
		<param name="visible">true</param>

		<definition>
			<control type="grouplist">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation" />

				<itemgap>PADDING_BASE_0.5X</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<!-- Title/clearlogo -->
				<control type="group">
					<height>HEIGHT_CLEARLOGO_BIG</height>

					<!-- Title (if clearlogo not available) -->
					<control type="label">
						<visible>!$EXP[HasClearlogo]</visible>

						<width>1000</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<aligny>center</aligny>
						<font>TITLE1</font>
						<textcolor>HIGHLIGHT</textcolor>
						<label>$VAR[Title]</label>
					</control>
					<!-- Clearlogo -->
					<control type="image">
						<visible>$EXP[HasClearlogo]</visible>

						<width>WIDTH_CLEARLOGO_BIG</width>
						<height>HEIGHT_CLEARLOGO_BIG</height>
						<fadetime>ANIMATION_FAST</fadetime>
						<texture background="true">$VAR[Clearlogo]</texture>
						<aspectratio align="left">keep</aspectratio>
					</control>
				</control>

				<!-- Subtitle -->
				<control type="label">
					<visible>$EXP[HasSubtitle]</visible>

					<width>1000</width>
					<height>FONT_SIZE_SUBTITLE</height>
					<font>SUBTITLE</font>
					<textcolor>HIGHLIGHT</textcolor>
					<label>$VAR[Subtitle]</label>
				</control>

				<!-- Info -->
				<control type="label">
					<width>1000</width>
					<height>FONT_SIZE_CAPTION</height>
					<font>CAPTION_STRONG</font>
					<textcolor>FOREGROUND_DARK</textcolor>
					<label>$VAR[Info]</label>
				</control>
				<!-- Genre for movies -->
				<control type="label">
					<top>PADDING_BASE_-0.3X</top>
					<visible>$EXP[HasInfo2]</visible>
					<width>1000</width>
					<height>FONT_SIZE_CAPTION</height>
					<font>CAPTION_STRONG</font>
					<textcolor>FOREGROUND_DARK</textcolor>
					<label>$VAR[Info2]</label>
				</control>

				<!-- Summary -->
				<control type="textbox">
					<width>800</width>
					<height>170</height>
					<font>BODY2</font>
					<textcolor>FOREGROUND</textcolor>
					<label>$VAR[Summary]</label>
				</control>
			</control>
		</definition>
	</include>
</includes>
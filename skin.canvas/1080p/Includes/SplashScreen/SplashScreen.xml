<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/SplashScreen/Variables.xml" />

	<!-- Background -->
	<include name="SplashBackground">
		<!-- Full background -->
		<control type="image">
			<!-- Fade in with logo -->
			<animation effect="fade" start="0" end="100" time="ANIMATION_SLOW" delay="SPLASH_LOGOTEXTFADE_DELAY" tween="circle" easing="in">WindowOpen</animation>

			<width>SCREEN_WIDTH</width>
			<height>SCREEN_HEIGHT</height>

			<texture colordiffuse="BACKGROUND_SETTINGS_TINT">diffuse.png</texture>
		</control>
		<!-- Layer 1 -->
		<control type="image">
			<!-- Slide in after logo fade in -->
			<animation effect="slide" start="WIDTH_SPLASH_BG,0" end="0,0" time="SPLASH_BGSLIDE_TIME" delay="SPLASH_BG1SLIDE_DELAY" tween="circle" easing="out">WindowOpen</animation>

			<width>WIDTH_SPLASH_BG</width>
			<height>SCREEN_HEIGHT</height>
			<right>0</right>

			<texture colordiffuse="FOREGROUND_ACCENT">1080p/diffuse/splash.png</texture>
		</control>
		<!-- Layer 2 -->
		<control type="image">
			<!-- Slide in after logo fade in with a delay -->
			<animation effect="slide" start="WIDTH_SPLASH_BG,0" end="WIDTH_SPLASH_BG2_SLIDE,0" time="SPLASH_BGSLIDE_TIME" delay="SPLASH_BG2SLIDE_DELAY" tween="circle" easing="out">WindowOpen</animation>

			<width>WIDTH_SPLASH_BG</width>
			<height>SCREEN_HEIGHT</height>
			<right>0</right>

			<texture colordiffuse="FOREGROUND_ACCENT2">1080p/diffuse/splash.png</texture>
		</control>
	</include>

	<!-- Logo -->
	<include name="SplashLogo">
		<param name="color">HIGHLIGHT</param>

		<definition>
			<!-- Kodi logo -->
			<control type="image">
				<width>150</width>
				<height>150</height>
				<centerleft>50%</centerleft>
				<centertop>320</centertop>

				<texture colordiffuse="$PARAM[color]">special://xbmc/media/vendor_icon.png</texture>
				<aspectratio>keep</aspectratio>
			</control>

			<!-- Kodi name -->
			<control type="label">
				<height>200</height>
				<width>800</width>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>

				<font>LOGO</font>
				<textcolor>$PARAM[color]</textcolor>
				<align>center</align>
				<aligny>center</aligny>
				<label>KODI</label>
			</control>
		</definition>
	</include>
	<!-- With Canvas -->
	<include name="SplashCanvas">
		<param name="color">HIGHLIGHT</param>

		<definition>
			<!-- With Canvas label -->
			<control type="label">
				<height>50</height>
				<width>100</width>
				<top>980</top>
				<left>1670</left>

				<font>CAPTION_STRONG</font>
				<textcolor>$PARAM[color]</textcolor>
				<align>left</align>
				<aligny>center</aligny>
				<label>with</label>
			</control>
			<control type="label">
				<height>50</height>
				<width>150</width>
				<top>977</top>
				<left>1730</left>

				<font>BODY_STRONG</font>
				<textcolor>$PARAM[color]</textcolor>
				<align>left</align>
				<aligny>center</aligny>
				<label>Canvas</label>
			</control>
		</definition>
	</include>

	<!-- Splash screen -->
	<include name="SplashScreen">
		<control type="group">
			<!-- Background -->
			<include content="SplashBackground" />

			<!-- Logo -->
			<control type="group">
				<!-- White -->
				<control type="group">
					<!-- Fade in, initiate fade out during background slide in (to give way to the dark one), the zoom in -->
					<animation type="WindowOpen">
						<effect type="fade" start="0" end="100" time="SPLASH_LOGOTEXTFADE_TIME" delay="SPLASH_LOGOTEXTFADE_DELAY" tween="circle" easing="in" />
						<effect type="fade" start="100" end="0" time="SPLASH_LOGOCOLORFADE_TIME" delay="SPLASH_LOGOCOLORFADE_DELAY" tween="circle" easing="out" />
						<effect type="zoom" start="110" end="100" time="SPLASH_LOGOZOOM_TIME" delay="SPLASH_LOGOZOOM_DELAY" tween="back" easing="out" center="auto" />
					</animation>

					<include content="SplashLogo">
						<param name="color">HIGHLIGHT</param>
					</include>
				</control>

				<!-- Accent -->
				<control type="group">
					<!-- Initiate fade in during background slide in (for better contrast), the zoom in -->
					<animation type="WindowOpen">
						<effect type="fade" start="0" end="100" time="SPLASH_LOGOCOLORFADE_TIME" delay="SPLASH_LOGOCOLORFADE_DELAY" tween="circle" easing="out" />
						<effect type="zoom" start="110" end="100" time="SPLASH_LOGOZOOM_TIME" delay="SPLASH_LOGOZOOM_DELAY" tween="back" easing="out" center="auto" />
					</animation>

					<include content="SplashLogo">
						<param name="color">BACKGROUND_SETTINGS_TINT</param>
					</include>
				</control>
			</control>
		</control>

		<!-- Logo -->
		<control type="group">
			<!-- White -->
			<control type="group">
				<!-- Fade in, initiate fade out during background slide in (to give way to the dark one) -->
				<animation type="WindowOpen">
					<effect type="fade" start="0" end="100" time="SPLASH_LOGOTEXTFADE_TIME" delay="SPLASH_LOGOTEXTFADE_DELAY" tween="circle" easing="in" />
					<effect type="fade" start="100" end="0" time="SPLASH_LOGOCOLORFADE_TIME" delay="SPLASH_TEXTCOLORFADE_DELAY" tween="circle" easing="out" />
				</animation>

				<include content="SplashCanvas">
					<param name="color">HIGHLIGHT</param>
				</include>
			</control>

			<!-- Accent -->
			<control type="group">
				<!-- Initiate fade in during background slide in (for better contrast) -->
				<animation type="WindowOpen">
					<effect type="fade" start="0" end="100" time="SPLASH_LOGOCOLORFADE_TIME" delay="SPLASH_TEXTCOLORFADE_DELAY" tween="circle" easing="out" />
				</animation>

				<include content="SplashCanvas">
					<param name="color">BACKGROUND_SETTINGS_TINT</param>
				</include>
			</control>
		</control>
	</include>

	<!-- First time wizard -->
	<include name="FirstTimeWizard">
		<include content="SettingsBackground" />

		<control type="group">
			<top>PADDING_BASE</top>
			<bottom>PADDING_BASE</bottom>
			<left>PADDING_BASE</left>
			<right>PADDING_BASE</right>

			<!-- Title -->
			<control type="label">
				<width>100%</width>
				<height>FONT_SIZE_TITLE2</height>
				<font>TITLE2</font>
				<align>center</align>
				<label>Welcome to [COLOR FOREGROUND_ACCENT]Canvas[/COLOR]</label>
			</control>

			<control type="grouplist">
				<orientation>vertical</orientation>
				<itemgap>PADDING_BASE</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<top>PADDING_BASE</top>

				<!-- Description -->
				<control type="label">
					<top>PADDING_BASE</top>
					<width>100%</width>
					<height>FONT_SIZE_SUBTITLE</height>
					<font>CAPTION</font>
					<align>center</align>
					<label>[COLOR FOREGROUND_ACCENT]Canvas[/COLOR] is a minimalistic Kodi skin. Some settings require a tweak for optimal results. Here is what will be changed:</label>
				</control>

				<!-- List of changes -->
				<control type="panel">
					<width>1350</width>
					<height>400</height>
					<centerleft>50%</centerleft>

					<itemlayout width="675" height="FIRSTRUN_LISTITEM_HEIGHT">
						<!-- Checkmark -->
						<control type="image">
							<width>30</width>
							<height>30</height>
							<left>PADDING_BASE_20P</left>
							<top>8</top>
							<texture colordiffuse="FOREGROUND_ACCENT">1080p/icons/watched.png</texture>
						</control>

						<!-- Text -->
						<control type="label">
							<left>70</left>
							<width>auto</width>
							<height>FIRSTRUN_LISTITEM_HEIGHT</height>
							<font>CAPTION</font>
							<aligny>top</aligny>
							<label>$INFO[ListItem.Label]</label>
						</control>
					</itemlayout>

					<focusedlayout></focusedlayout>

					<content>
						<item id="1"><label>Disable mouse</label></item>
						<item id="2"><label>Cache buffer: 256MB</label></item>
						<item id="3"><label>Cache read factor: adaptive</label></item>
						<item id="4"><label>Preferred audio language: English</label></item>
						<item id="5"><label>Prefer default audio language: false</label></item>
						<item id="6"><label>No subtitles by default</label></item>
						<item id="7"><label>Default video action: resume</label></item>
						<item id="8"><label>Hide "all items" entry</label></item>
						<item id="9"><label>Never flatten TV Show seasons</label></item>
						<item id="10"><label>Select first unwatched season/episode on first entry</label></item>
						<item id="11"><label>Remove Kodi splash screen</label></item>
					</content>
				</control>
			</control>

			<control type="grouplist">
				<orientation>horizontal</orientation>
				<itemgap>PADDING_BASE_50P</itemgap>
				<usecontrolcoords>true</usecontrolcoords>
				<align>center</align>

				<bottom>0</bottom>

				<!-- Continue (first run) -->
				<control type="button" id="1">
					<visible>!Window.Is(skinsettings)</visible>
					<bottom>0</bottom>
					<width>auto</width>
					<label>Continue</label>
					<onclick>Skin.SetBool(canvas.firstrun,true)</onclick>
					<onclick>RunScript(script.canvas.helper,apply_customizations)</onclick>
					<onclick>ReplaceWindow(home)</onclick>
				</control>
				<!-- Apply (from skin settings) -->
				<control type="button" id="2">
					<visible>Window.Is(skinsettings)</visible>
					<bottom>0</bottom>
					<width>auto</width>
					<label>Apply</label>
					<onclick>Skin.SetBool(canvas.firstrun,true)</onclick>
					<onclick>RunScript(script.canvas.helper,apply_customizations)</onclick>
					<onclick>Back</onclick>
				</control>
				<!-- Clear cache (from skin settings) -->
				<control type="button" id="3">
					<visible>Window.Is(skinsettings)</visible>
					<bottom>0</bottom>
					<width>auto</width>
					<label>Clear cache</label>
					<onclick>RunScript(script.canvas.helper,clear_custom_cache)</onclick>
					<onclick>Back</onclick>
				</control>
			</control>
		</control>
	</include>
</includes>
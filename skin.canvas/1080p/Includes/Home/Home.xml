	<!-- Flyout menu -->
	<include name="HomeMenuFlyout">
		<include content="StandardFlyoutBase">
			<param name="visible">$EXP[IsHomeMenuFlyoutVisible]</param>

			<include content="StandardFlyoutStructure">
				<!-- Horizontal list of icon buttons -->
				<control type="list" id="1000">
					<top>OFFSET_HOME_FLYOUT_HORIZONTAL_LIST_TOP</top>
					<left>OFFSET_HOME_FLYOUT_HORIZONTAL_LIST_LEFT</left>
					<orientation>horizontal</orientation>

					<onback>SetFocus(1)</onback>
					<ondown>SetFocus(1001,0)</ondown>
					<onclick>SetFocus(1)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<include content="HomeIconButtonForFlyout" />
					</itemlayout>
					<focusedlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is not actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Settings -->
						<item id="1">
							<thumb>$VAR[SettingsIcon]</thumb>
							<property name="onclick">RunScript(script.canvas.helper,home_to_active_settings,$INFO[Window(settings).Property(Settings.ActivePage)])</property>
						</item>
					</content>
				</control>

				<!-- Vertical list of buttons -->
				<control type="list" id="1001">
					<top>OFFSET_HOME_FLYOUT_LIST</top>
					<bottom>PADDING_BASE</bottom>
					<left>PADDING_HALF</left>
					<right>PADDING_HALF</right>

					<onback>SetFocus(1)</onback>
					<onup>SetFocus(1000,0)</onup>
					<onclick>SetFocus(1)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<include content="HomeButtonContentWithIconForFlyout" />
					</itemlayout>
					<focusedlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1001)</visible>
							<!-- Fake button selection -->
							<control type="image">
								<height>HEIGHT_HOME_FLYOUT_BUTTON</height>
								<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
							</control>
							<!-- Content -->
							<include content="HomeButtonContentWithIconForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
								<param name="text_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1001)</visible>
							<include content="HomeButtonContentWithIconForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Shutdown -->
						<item id="1">
							<thumb>$VAR[ShutdownIcon]</thumb>
							<label>Shutdown</label>
							<property name="onclick">PowerDown()</property>
						</item>
						<!-- Exit -->
						<item id="2">
							<thumb>$VAR[QuitIcon]</thumb>
							<label>Quit</label>
							<property name="onclick">Quit()</property>
						</item>
						<!-- Update libraries -->
						<item id="3">
							<thumb>$VAR[UpdateLibrariesIcon]</thumb>
							<label>Update libraries</label>
							<property name="onclick">UpdateLibrary()</property>
						</item>
						<!-- Reload home -->
						<item id="4">
							<thumb>$VAR[ReloadHomeIcon]</thumb>
							<label>Reload home</label>
							<!-- Use script to change window property Nonce, used in lists dynamic content, so it gets refreshed -->
							<property name="onclick">RunScript(script.canvas.helper,reload_home)</property>
						</item>
						<!-- Addons -->
						<item id="5">
							<thumb>$VAR[AddonsIcon]</thumb>
							<label>Addons</label>
							<property name="onclick">ActivateWindow(addonbrowser)</property>
						</item>
						<!-- File manager -->
						<item id="6">
							<thumb>$VAR[FileManagerIcon]</thumb>
							<label>File manager</label>
							<property name="onclick">ActivateWindow(filebrowser)</property>
						</item>
						<!-- System info -->

<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Home/Variables.xml" />
	<include file="Includes/Home/Expressions.xml" />


	<!-- Horizontal list of media items. Form factor is based on content type -->
	<include name="HomeItemStrip">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>
		<param name="darken_art">false</param>

		<definition>
			<control type="group" id="98$PARAM[id]">
				<visible>Container($PARAM[id]).IsUpdating | !Integer.IsEqual(Container($PARAM[id]).NumItems,0)</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

				<!-- Label -->
				<include content="ListLabel">
					<param name="id">99$PARAM[id]</param>
					<param name="label">$PARAM[label]</param>
					<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
				</include>

				<!-- Media item strip -->
				<include content="ItemStrip">
					<param name="id">$PARAM[id]</param>

					<top>OFFSET_HOME_LIST_AFTER_LABEL</top>
					<height>HEIGHT_LIST_CONTAINER</height>

					<onfocus>SetProperty(ActiveListId,$PARAM[id],home)</onfocus>
					<onup>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],up)</onup>
					<ondown>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],down)</ondown>
					<onright>noop</onright>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onclick>$PARAM[onclick]</onclick>

					<!-- Season layout -->
					<include content="PosterLayout">
						<param name="art">$VAR[HomePosterArt]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],101) | Integer.IsEqual($PARAM[id],103) | Integer.IsEqual($PARAM[id],110)</param>
						<param name="sync_501">true</param>
					</include>
					<!-- Episode layout -->
					<include content="LandscapeLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],102)</param>
						<param name="show_info">true</param>
						<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
						<param name="sync_501">true</param>
					</include>
					<!-- Music layout -->
					<include content="AlbumLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],104)</param>
						<param name="sync_501">true</param>
						<param name="info1">$VAR[HomeAlbumInfo1]</param>
						<param name="info2">$VAR[HomeAlbumInfo2]</param>
						<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
						<param name="info2_color">$VAR[ContrastTextForegroundColor]</param>
					</include>

					<content>$PARAM[content]</content>
				</include>
			</control>
		</definition>
	</include>
	<!-- Wall of media items. Form factor is based on content type -->
	<include name="HomeItemWall">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>
		<param name="darken_art">false</param>

		<definition>
			<control type="group" id="98$PARAM[id]">
				<visible>Container($PARAM[id]).IsUpdating | !Integer.IsEqual(Container($PARAM[id]).NumItems,0)</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

				<!-- Label -->
				<include content="ListLabel">
					<param name="id">99$PARAM[id]</param>
					<param name="label">$PARAM[label]</param>
					<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
				</include>

				<!-- Media item strip -->
				<include content="ItemWall">
					<param name="id">$PARAM[id]</param>

					<top>OFFSET_HOME_LIST_AFTER_LABEL</top>
					<height>HEIGHT_LIST_CONTAINER</height>

					<onfocus>SetProperty(ActiveListId,$PARAM[id],home)</onfocus>
					<onup>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],up)</onup>
					<ondown>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],down)</ondown>
					<onright>noop</onright>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onclick>$PARAM[onclick]</onclick>

					<!-- Season layout -->
					<include content="PosterLayout">
						<param name="art">$VAR[HomePosterArt]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],106) | Integer.IsEqual($PARAM[id],108)</param>
						<param name="sync_501">true</param>
					</include>
					<!-- Music layout -->
					<include content="AlbumLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],112)</param>
						<param name="sync_501">true</param>
						<param name="info1">$VAR[HomeAlbumInfo1]</param>
						<param name="info2">$VAR[HomeAlbumInfo2]</param>
						<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
						<param name="info2_color">$VAR[ContrastTextForegroundColor]</param>
					</include>

					<content>$PARAM[content]</content>
				</include>
			</control>
		</definition>
	</include>
	<!--
		Empty placeholder for list of items. This is considered content, not a placeholder for empty lists.
		It allows to switch from bottom half of screen lists to full height wall of items.
	-->
	<include name="HomeItemEmptyPage">
		<param name="id"></param>
		<param name="routing_id"></param>

		<definition>
			<control type="group" id="96$PARAM[id]">
				<visible>Container($PARAM[routing_id]).IsUpdating | !Integer.IsEqual(Container($PARAM[routing_id]).NumItems,0)</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

				<control type="button" id="$PARAM[id]">
					<visible allowhiddenfocus="true">false</visible>
					<onback>SetFocus(200)</onback>
				</control>
			</control>
		</definition>
	</include>
	<!--
		Empty placeholder for full height list of items. This is considered content, not a placeholder for empty lists.
		It allows to switch from full height wall of items to bottom half of screen lists.
	-->
	<include name="HomeItemEmptyPageFullHeight">
		<param name="id"></param>

		<definition>
			<control type="group" id="96$PARAM[id]">
				<height>SCREEN_HEIGHT</height>

				<control type="button" id="$PARAM[id]">
					<visible allowhiddenfocus="true">false</visible>
					<onback>SetFocus(200)</onback>
				</control>
			</control>
		</definition>
	</include>
	<!-- Full height wall of media items. Form factor is based on content type -->
	<include name="HomeItemFullWall">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>
		<param name="darken_art">false</param>

		<definition>
			<control type="group" id="98$PARAM[id]">
				<visible>Container($PARAM[id]).IsUpdating | !Integer.IsEqual(Container($PARAM[id]).NumItems,0)</visible>
				<height>SCREEN_HEIGHT</height>

				<!-- Label -->
				<control type="label">
					<width>1000</width>
					<height>HEIGHT_DETAILS_TITLE</height>
					<aligny>center</aligny>
					<font>TITLE1</font>
					<textcolor>HIGHLIGHT_CONTRAST_LIGHT</textcolor>
					<label>$PARAM[label]</label>
				</control>

				<!-- Media item strip -->
				<include content="ItemWall">
					<param name="id">$PARAM[id]</param>

					<top>HEIGHT_DETAILS_TITLE_SECTION</top>
					<height>HEIGHT_HOME_FULL_WALL_CONTENT</height>

					<onfocus>SetProperty(ActiveListId,$PARAM[id],home)</onfocus>
					<onfocus>RunScript(script.canvas.helper,clear_listitem_properties)</onfocus>
					<onup>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],up)</onup>
					<ondown>noop</ondown>
					<onright>noop</onright>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onclick>$PARAM[onclick]</onclick>

					<!-- Picure layout -->
					<include content="AlbumLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="fallback">1080p/fallback/picture.png</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[id],302)</param>
						<param name="get_additional_data">false</param>
						<param name="sync_501">true</param>
						<!--todo<param name="info1">$VAR[HomeAlbumInfo1]</param>
						<param name="info2">$VAR[HomeAlbumInfo2]</param>
						<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
						<param name="info2_color">$VAR[ContrastTextForegroundColor]</param>-->
					</include>

					<content>$PARAM[content]</content>
				</include>
			</control>
		</definition>
	</include>

	<!-- Placeholder for adding content when there is none (icon and text) -->
	<include name="HomeEmptyListInfoPlaceholder">
		<param name="visible"></param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<width>WIDTH_HOME_FALLBACK_CONTENT</width>
				<height>HEIGHT_HOME_FALLBACK_CONTENT</height>
				<centertop>50%</centertop>

				<!-- Icon -->
				<control type="image">
					<width>SIZE_HOME_FALLBACK_ICON</width>
					<height>SIZE_HOME_FALLBACK_ICON</height>
					<centerleft>50%</centerleft>
					<texture colordiffuse="FOREGROUND">$VAR[HomeEmptyListIcon]</texture>
				</control>
				<!-- Page title -->
				<control type="label">
					<width>WIDTH_HOME_FALLBACK_CONTENT</width>
					<height>FONT_SIZE_TITLE3</height>
					<top>100</top>
					<centerright>50%</centerright>
					<align>center</align>
					<font>TITLE3</font>
					<label>$VAR[HomeEmptyListTitle]</label>
				</control>
				<!-- Empty message -->
				<control type="label">
					<width>WIDTH_HOME_FALLBACK_CONTENT</width>
					<height>FONT_SIZE_BODY</height>
					<top>220</top>
					<centerright>50%</centerright>

					<align>center</align>
					<font>BODY</font>
					<label>No content found</label>
				</control>
			</control>
		</definition>
	</include>
	<!-- Placeholder for adding content when there is none (button) -->
	<include name="HomeEmptyListPlaceholder">
		<param name="visible">false</param>
		<param name="id"></param>
		<param name="label"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>

		<definition>
			<control type="group" id="97$PARAM[id]">
				<visible>$PARAM[visible]</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>
				<right>PADDING_BASE</right>
			
				<!-- "Add content" button -->
				<control type="button" id="$PARAM[id]">
					<top>OFFSET_HOME_LIST_AFTER_LABEL</top>
					<width>350</width>
					<height>120</height>
					<centerleft>50%</centerleft>

					<texturefocus colordiffuse="FOREGROUND_ACCENT" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
					<texturenofocus colordiffuse="BACKGROUND_OPAQUE50" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
					<textoffsety>4</textoffsety>
					<textoffsetx>38</textoffsetx>
					<textcolor>FOREGROUND</textcolor>
					<align>center</align>
					<label>$PARAM[label]</label>

					<onclick>$PARAM[onclick]</onclick>
					<onup>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],up)</onup>
					<ondown>RunScript(script.canvas.helper,navigate_home_lists,$PARAM[id],down)</ondown>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onfocus>RunScript(script.canvas.helper,reset_listitem_selection)</onfocus>
				</control>
			</control>
		</definition>
	</include>

	<!-- Main home content (lists of media) -->
	<include name="HomeListsContent">
		<param name="darken_art">$EXP[HasHomeMenuFocus]</param>

		<definition>
			<!-- Main lists -->
			<control type="grouplist" id="100">
				<orientation>vertical</orientation>
				<itemgap>0</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<bottom>0</bottom>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>
				<onback>SetFocus(1001,0)</onback>

				<!-- Continue watching -->
				<include content="HomeItemStrip">
					<param name="id">101</param>
					<param name="label">Continue watching</param>
					<param name="content">$VAR[HomeContinueWatchingContent]</param>
					<param name="menuid">201</param>
					<param name="onclick">RunScript(script.canvas.helper,navigate_movie_episode_videonav,101)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- Recently added episodes -->
				<include content="HomeItemStrip">
					<param name="id">102</param>
					<param name="label">Recently added episodes</param>
					<param name="content">$VAR[HomeRecentEpisodesContent]</param>
					<param name="menuid">201</param>
					<param name="onclick">RunScript(script.canvas.helper,navigate_movie_episode_videonav,102)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- Recently added movies -->
				<include content="HomeItemStrip">
					<param name="id">103</param>
					<param name="label">Recently added movies</param>
					<param name="content">$VAR[HomeRecentMoviesContent]</param>
					<param name="menuid">201</param>
					<param name="onclick">RunScript(script.canvas.helper,navigate_movie_episode_videonav,103)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- Recently added music -->
				<include content="HomeItemStrip">
					<param name="id">104</param>
					<param name="label">Recently added music</param>
					<param name="content">$VAR[HomeRecentSongsContent]</param>
					<param name="menuid">201</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- No recent content page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(101).NumItems,0) + Integer.IsEqual(Container(102).NumItems,0) + Integer.IsEqual(Container(103).NumItems,0) + Integer.IsEqual(Container(103).NumItems,0)</param>
					<param name="id">105</param>
					<param name="label">Add content</param>
					<param name="menuid">201</param>
				</include>
				<!-- Movies -->
				<include content="HomeItemWall">
					<param name="id">106</param>
					<param name="label">Movies</param>
					<param name="content">$VAR[HomeMoviesContent]</param>
					<param name="menuid">202</param>
					<param name="onclick">RunScript(script.canvas.helper,navigate_movie_episode_videonav,106)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- No movies page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(106).NumItems,0)</param>
					<param name="id">107</param>
					<param name="label">Add movies</param>
					<param name="menuid">202</param>
				</include>
				<!-- TV shows -->
				<include content="HomeItemWall">
					<param name="id">108</param>
					<param name="label">TV Shows</param>
					<param name="content">$VAR[HomeTVShowsContent]</param>
					<param name="menuid">203</param>
					<param name="onclick">ActivateWindow(Videos,videodb://tvshows/titles/$INFO[ListItem.DBID],return)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- No TV shows page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(108).NumItems,0)</param>
					<param name="id">109</param>
					<param name="label">Add TV shows</param>
					<param name="menuid">203</param>
				</include>
				<!-- Yoga With Adriene -->
				<include content="HomeItemStrip">
					<param name="id">110</param>
					<param name="label">Yoga</param>
					<param name="content">$VAR[HomeYogaContent]</param>
					<param name="menuid">204</param>
					<param name="onclick">ActivateWindow(Videos,videodb://tvshows/titles/$INFO[ListItem.Property(TvShowId)]/$INFO[ListItem.Season]/,return)</param>
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- No yoga page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(110).NumItems,0)</param>
					<param name="id">111</param>
					<param name="label">Add yoga</param>
					<param name="menuid">204</param>
				</include>
				<!-- Music -->
				<include content="HomeItemWall">
					<param name="id">112</param>
					<param name="label">Music</param>
					<param name="content">$VAR[HomeSongsContent]</param>
					<param name="menuid">205</param>
					<param name="onclick"></param><!--todo-->
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
				<!-- No music page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(112).NumItems,0)</param>
					<param name="id">113</param>
					<param name="label">Add music</param>
					<param name="menuid">205</param>
				</include>
				<!-- Fake pictures (empty page so full height wall can be shown) -->
				<include content="HomeItemEmptyPage">
					<param name="id">114</param>
					<param name="routing_id">302</param>
				</include>
				<!-- No pictures page -->
				<include content="HomeEmptyListPlaceholder">
					<param name="visible">Integer.IsEqual(Container(302).NumItems,0)</param>
					<param name="id">115</param>
					<param name="label">Add pictures</param>
					<param name="menuid">206</param>
				</include>
			</control>

			<!-- Pictures list (full height) -->
			<control type="grouplist" id="300">
				<orientation>vertical</orientation>
				<itemgap>0</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<height>SCREEN_HEIGHT</height>
				<onback>SetFocus(1001,0)</onback>

				<!-- Empty page for "visibility" -->
				<include content="HomeItemEmptyPageFullHeight">
					<param name="id">301</param>
				</include>
				<!-- Pictures -->
				<include content="HomeItemFullWall">
					<param name="id">302</param>
					<param name="label">Pictures</param>
					<param name="content">plugin://script.canvas.helper/pictures/</param>
					<param name="menuid">206</param>
					<param name="onclick"></param><!--todo-->
					<param name="darken_art">$PARAM[darken_art]</param>
				</include>
			</control>
		</definition>
	</include>

	<!-- Main menu -->
	<include name="HomeMainMenu">
		<definition>
			<control type="group">
				<width>WIDTH_HOME_MENU</width>
				
				<!-- Logo -->
				<control type="image">
					<width>SIZE_HOME_MENU_LOGO</width>
					<height>SIZE_HOME_MENU_LOGO</height>
					<centerleft>50%</centerleft>
					<texture colordiffuse="HIGHLIGHT">$VAR[LogoIcon]</texture>
					<aspectratio>keep</aspectratio>
				</control>

				<!-- Menu -->
				<control type="grouplist" id="200">
					<orientation>vertical</orientation>
					<itemgap>-20</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<top>200</top>
					<bottom>0</bottom>

					<include content="HomeMainMenuItem">
						<param name="id">201</param>
						<param name="icon">$VAR[HomeIcon]</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">202</param>
						<param name="icon">$VAR[MoviesIcon]</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">203</param>
						<param name="icon">$VAR[TVShowsIcon]</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">204</param>
						<param name="icon">$VAR[YogaIcon]</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">205</param>
						<param name="icon">$VAR[MusicIcon]</param>
						<param name="has_filter">true</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">206</param>
						<param name="icon">$VAR[PicturesIcon]</param>
						<param name="has_filter">true</param>
					</include>
					<include content="HomeMainMenuItem">
						<param name="id">207</param>
						<param name="icon">$VAR[MenuIcon]</param>
						<param name="is_menu_button">true</param>
					</include>
				</control>
			</control>
		</definition>
	</include>
	<include name="HomeMainMenuItem">
		<param name="id"></param>
		<param name="icon"></param>
		<param name="has_filter">false</param>
		<param name="is_menu_button">false</param>

		<definition>
			<!-- Icon button -->
			<control type="group">
				<width>WIDTH_HOME_MENU</width>
				<height>SIZE_HOME_MENU_ICON_SELECTION</height>

				<!-- Selected case (circle background, dark icon) -->
				<control type="group">
					<visible>String.IsEqual(Window(home).Property(Menu.ActiveId),$PARAM[id])</visible>
					<width>WIDTH_HOME_MENU</width>
					<height>SIZE_HOME_MENU_ICON_SELECTION</height>

					<!-- Circle background -->
					<control type="image">
						<width>SIZE_HOME_MENU_ICON_SELECTION</width>
						<height>SIZE_HOME_MENU_ICON_SELECTION</height>
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="FOREGROUND_ACCENT">1080p/diffuse/circle.png</texture>
						<bordertexture border="SIZE_ITEM_SHADOW_SMALLCIRCLE_DOUBLE" colordiffuse="BACKGROUND_OPAQUE75">1080p/diffuse/shadow-circle-small.png</bordertexture>
						<bordersize>SIZE_ITEM_SHADOW_SMALLCIRCLE</bordersize>
					</control>
					<!-- Icon -->
					<control type="image">
						<width>SIZE_HOME_MENU_ICON</width>
						<height>SIZE_HOME_MENU_ICON</height>
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="BACKGROUND_OPAQUE75">$PARAM[icon]</texture>
					</control>

					<!-- Chevron left (if there is filter) -->
					<control type="image">
						<visible>$PARAM[has_filter]</visible>

						<width>SIZE_HOME_MENU_ICON</width>
						<height>SIZE_HOME_MENU_ICON</height>
						<left>PADDING_BASE_60P</left>
						<centertop>50%</centertop>
						<texture colordiffuse="FOREGROUND_OPAQUE35" flipx="true">1080p/icons/chevron-right.png</texture>
						<aspectratio>keep</aspectratio>
					</control>
				</control>

				<!-- Unselected case (icon only, light color) -->
				<control type="image">
					<visible>!String.IsEqual(Window(home).Property(Menu.ActiveId),$PARAM[id])</visible>
					<width>SIZE_HOME_MENU_ICON</width>
					<height>SIZE_HOME_MENU_ICON</height>
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<texture colordiffuse="FOREGROUND_OPAQUE50">$PARAM[icon]</texture>
				</control>

				<!-- Hidden control -->
				<control type="button" id="$PARAM[id]">
					<visible allowhiddenfocus="true">false</visible>

					<onback condition="!Player.HasMedia">SetFocus(1001,0)</onback>
					<onup>RunScript(script.canvas.helper,navigate_home_menu,$PARAM[id],up)</onup>
					<ondown>RunScript(script.canvas.helper,navigate_home_menu,$PARAM[id],down)</ondown>
					<onright condition="!$PARAM[is_menu_button]">RunScript(script.canvas.helper,navigate_home_from_menu_to_lists,$PARAM[id])</onright>
					<onclick condition="!$PARAM[is_menu_button]">RunScript(script.canvas.helper,navigate_home_from_menu_to_lists,$PARAM[id])</onclick>
					<onclick condition="$PARAM[is_menu_button]">SetFocus(1001,0)</onclick>
					<onfocus>SetProperty(Menu.ActiveId,$PARAM[id],home)</onfocus>
				</control>
			</control>
		</definition>
	</include>

	<!--
		Hidden list with ID 501 that mimics the currently selected list in order to have
		the same list ID across all windows where to pick details from.
	-->
	<include name="HomeActiveItemSyncList">
		<definition>
			<control type="fixedlist" id="501">
				<autoscroll>false</autoscroll>
				<orientation>horizontal</orientation>
				<preloaditems>1</preloaditems>
				<width>0</width>
				<height>0</height>
				
				<itemlayout width="WIDTH_POSTER_LIST_ITEM_CONTAINER" height="HEIGHT_POSTER_LIST_ITEM_CONTAINER"></itemlayout>
				<focusedlayout width="WIDTH_POSTER_LIST_ITEM_CONTAINER" height="HEIGHT_POSTER_LIST_ITEM_CONTAINER"></focusedlayout>
				<content>$VAR[HomeActiveItemListContent]</content>

				<onback>SetFocus(200)</onback>
			</control>
		</definition>
	</include>


	<!-- Content for fake button with icon in flyout -->
	<include name="HomeButtonContentWithIconForFlyout">
		<param name="icon_circle_color">BACKGROUND_OPAQUE20</param>
		<param name="icon_color">BACKGROUND_INVERSE_OPAQUE50</param>
		<param name="icon">$INFO[ListItem.Art(thumb)]</param>
		<param name="text_color">FOREGROUND_OPAQUE75</param>
		<param name="text">$INFO[ListItem.Label]</param>

		<definition>
			<control type="group">
				<top>PADDING_HOME_FLYOUT_BUTTON_VERTICAL</top>
				<bottom>PADDING_HOME_FLYOUT_BUTTON_VERTICAL</bottom>
				<left>PADDING_BUTTON_VERTICAL</left>
				<right>PADDING_BUTTON_VERTICAL</right>

				<!-- Icon -->
				<control type="group">
					<width>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</width>
					<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>

					<!-- Background -->
					<control type="image">
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="$PARAM[icon_circle_color]">1080p/diffuse/circle.png</texture>
					</control>
					<!-- Icon -->
					<control type="image">
						<width>SIZE_HOME_FLYOUT_ICON</width>
						<height>SIZE_HOME_FLYOUT_ICON</height>
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="$PARAM[icon_color]">$PARAM[icon]</texture>
					</control>
				</control>

				<!-- Labels -->
				<control type="group">
					<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>
					<left>OFFSET_HOME_FLYOUT_BUTTON_CONTENT</left>

					<!-- First text line -->
					<control type="label">
						<top>OFFSET_HOME_FLYOUT_BUTTON_TEXT</top>
						<font>BODY_STRONG</font>
						<textcolor>$PARAM[text_color]</textcolor>
						<label>$PARAM[text]</label>
					</control>
				</control>
			</control>
		</definition>
	</include>
	<!-- Fake icon button in flyout -->
	<include name="HomeIconButtonForFlyout">
		<param name="icon_circle_color">BACKGROUND_OPAQUE20</param>
		<param name="icon_color">BACKGROUND_INVERSE_OPAQUE50</param>
		<param name="icon">$INFO[ListItem.Art(thumb)]</param>

		<definition>
			<control type="group">
				<width>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</width>
				<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>

				<!-- Background -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<texture colordiffuse="$PARAM[icon_circle_color]">1080p/diffuse/circle.png</texture>
				</control>
				<!-- Icon -->
				<control type="image">
					<width>SIZE_HOME_FLYOUT_ICON</width>
					<height>SIZE_HOME_FLYOUT_ICON</height>
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<texture colordiffuse="$PARAM[icon_color]">$PARAM[icon]</texture>
				</control>
			</control>
		</definition>
	</include>

	<!-- Flyout menu -->
	<include name="HomeMenuFlyout">
		<include content="StandardFlyoutBase">
			<param name="visible">$EXP[IsHomeMenuFlyoutVisible]</param>

			<include content="StandardFlyoutStructure">
				<!-- Horizontal list of icon buttons -->
				<control type="list" id="1000">
					<top>PADDING_BASE_60P</top>
					<left>OFFSET_HOME_FLYOUT_HORIZONTAL_LIST_LEFT</left>
					<orientation>horizontal</orientation>

					<onback condition="!$EXP[HasHomeLoaded]">SetFocus(99999)</onback>
					<onback condition="$EXP[HasHomeLoaded]">SetFocus(200)</onback>
					<ondown>SetFocus(1001,0)</ondown>
					<onclick>SetFocus(200)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<include content="HomeIconButtonForFlyout" />
					</itemlayout>
					<focusedlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is not actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Settings -->
						<item id="1">
							<thumb>$VAR[SettingsIcon]</thumb>
							<property name="onclick">RunScript(script.canvas.helper,navigate_home_to_active_settings,$INFO[Window(settings).Property(Settings.ActivePage)])</property>
						</item>
					</content>
				</control>

				<!-- Vertical list of buttons -->
				<control type="list" id="1001">
					<top>OFFSET_FLYOUT_LIST</top>
					<bottom>PADDING_BASE</bottom>
					<left>PADDING_BASE_50P</left>
					<right>PADDING_BASE_50P</right>

					<onback>SetFocus(200)</onback>
					<onup>SetFocus(1000,0)</onup>
					<onclick>SetFocus(200)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<include content="HomeButtonContentWithIconForFlyout" />
					</itemlayout>
					<focusedlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1001)</visible>
							<!-- Fake button selection -->
							<control type="image">
								<height>HEIGHT_HOME_FLYOUT_BUTTON</height>
								<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
							</control>
							<!-- Content -->
							<include content="HomeButtonContentWithIconForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
								<param name="text_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1001)</visible>
							<include content="HomeButtonContentWithIconForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Shutdown -->
						<item id="1">
							<thumb>$VAR[ShutdownIcon]</thumb>
							<label>Shutdown</label>
							<property name="onclick">PowerDown()</property>
						</item>
						<!-- Exit -->
						<item id="2">
							<thumb>$VAR[QuitIcon]</thumb>
							<label>Quit</label>
							<property name="onclick">Quit()</property>
						</item>
						<!-- Update libraries -->
						<item id="3">
							<thumb>$VAR[UpdateLibrariesIcon]</thumb>
							<label>Update libraries</label>
							<property name="onclick">UpdateLibrary()</property>
						</item>
						<!-- Addons -->
						<item id="4">
							<thumb>$VAR[AddonsIcon]</thumb>
							<label>Addons</label>
							<property name="onclick">ActivateWindow(addonbrowser)</property>
						</item>
						<!-- File manager -->
						<item id="5">
							<thumb>$VAR[FileManagerIcon]</thumb>
							<label>File manager</label>
							<property name="onclick">ActivateWindow(filebrowser)</property>
						</item>
						<!-- System info -->
						<item id="6">
							<thumb>$VAR[SystemInfoIcon]</thumb>
							<label>System info</label>
							<property name="onclick">ActivateWindow(systeminfo)</property>
						</item>
					</content>
				</control>
			</include>
		</include>
	</include>
	<!-- Flyout section options menu -->
	<include name="HomeFilterFlyout">
		<include content="StandardFlyoutBase">
			<param name="visible">$EXP[IsHomeFilterFlyoutVisible]</param>

			<include content="StandardFlyoutStructure">
				<control type="grouplist">
					<control type="label">
						<label>$VAR[test]</label>
					</control>
					<control type="button" id="1100">
						<onback>SetFocus(200)</onback>
						<onleft>SetFocus(200)</onleft>
						<onright>SetFocus(200)</onright>
						<label>Filter</label>
					</control>
				</control>
			</include>
		</include>
	</include>
</includes>
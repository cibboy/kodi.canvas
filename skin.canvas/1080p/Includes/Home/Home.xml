	<!-- Full height wall of media items. Form factor is based on content type -->
	<include name="HomeItemFullWall">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="content_type"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>
		<param name="darken_art">false</param>

		<definition>
			<control type="group" id="9$PARAM[id]">
				<visible>Container($PARAM[id]).IsUpdating | !Integer.IsEqual(Container($PARAM[id]).NumItems,0)</visible>
				<height>SCREEN_HEIGHT</height>

				<!-- Label -->
				<control type="label">
					<width>1000</width>
					<height>HEIGHT_DETAILS_TITLE</height>
					<aligny>center</aligny>
					<font>TITLE1</font>
					<textcolor>$VAR[ContrastTextHighlightColor]</textcolor>
					<label>$PARAM[label]</label>
				</control>

				<!-- Media item wall -->
				<include content="ItemWall">
					<param name="id">$PARAM[id]</param>

					<top>HEIGHT_DETAILS_TITLE_SECTION</top>
					<height>HEIGHT_HOME_FULL_WALL_CONTENT</height>

					<onfocus>RunScript(script.canvas.helper,clear_listitem_properties)</onfocus>
					<include content="HomeOnNavigateUp$PARAM[id]" />
					<include content="HomeOnNavigateDown$PARAM[id]" />
					<onright>noop</onright>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onclick>$PARAM[onclick]</onclick>

					<!-- Picure layout -->
					<include content="AlbumLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="fallback">$VAR[HomePictureFallbackArt]</param>
						<param name="overlay_icon">$VAR[HomePictureOverlayIcon]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[content_type],3)</param>
						<param name="get_additional_data">false</param>
						<param name="info1">$VAR[HomeAlbumInfo1]</param>
						<param name="info2">$VAR[HomeAlbumInfo2]</param>
						<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
						<param name="info2_color">$VAR[ColorsContrastForeground]</param>
						<param name="listid">$PARAM[id]</param>
					</include>

					<content>$PARAM[content]</content>
				</include>
			</control>
		</definition>
	</include>
	<!-- Empty placeholder of the same height as a strip, to be used when a page is shown in its place -->
	<include name="HomeEmptyItemStrip">
		<param name="id"></param>
		<param name="visible"></param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

				<!-- Hidden button to allow focus -->
				<control type="button" id="$PARAM[id]">
					<visible allowhiddenfocus="true">false</visible>
				</control>
			</control>
		</definition>
	</include>

	<!-- Add content page, to be used when no content for a category is found -->
	<include name="HomeAddSomethingPage">
		<param name="id"></param>
		<param name="icon"></param>
		<param name="title"></param>
		<param name="button"></param>
		<param name="visible"></param>
		<param name="menuid">7001</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<height>SCREEN_HEIGHT</height>
				<right>PADDING_BASE_40P</right>

				<control type="group">
					<height>500</height>
					<right>PADDING_BASE_60P</right>
					<centertop>50%</centertop>
					
					<!-- Icon -->
					<control type="image">
						<width>SIZE_HOME_FALLBACK_ICON</width>
						<height>SIZE_HOME_FALLBACK_ICON</height>
						<centerleft>50%</centerleft>
						<texture colordiffuse="FOREGROUND">$PARAM[icon]</texture>
					</control>
					<!-- Page title -->
					<control type="label">
						<width>WIDTH_HOME_FALLBACK_CONTENT</width>
						<height>FONT_SIZE_TITLE3</height>
						<top>100</top>
						<centerright>50%</centerright>
						<align>center</align>
						<font>TITLE3</font>
						<label>$PARAM[title]</label>
					</control>
					<!-- Empty message -->
					<control type="label">
						<width>WIDTH_HOME_FALLBACK_CONTENT</width>
						<height>FONT_SIZE_BODY</height>
						<top>220</top>
						<centerright>50%</centerright>

						<align>center</align>
						<font>BODY</font>
						<label>No content found</label>
					</control>

					<!-- "Add content" button -->
					<control type="button" id="$PARAM[id]">
						<top>300</top>
						<width>350</width>
						<height>120</height>
						<centerleft>50%</centerleft>

						<texturefocus colordiffuse="$VAR[ColorsAccentForeground]" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
						<texturenofocus colordiffuse="BACKGROUND_OPAQUE50" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
						<textoffsety>4</textoffsety>
						<textoffsetx>38</textoffsetx>
						<textcolor>FOREGROUND</textcolor>
						<align>center</align>
						<label>$PARAM[button]</label>

						<onclick>SetProperty(Settings.ActivePage,sources,settings)</onclick>
						<onclick>RunScript(script.canvas.helper,navigate_home_to_active_settings,mediasettings)</onclick>
						<include content="HomeOnNavigateUp$PARAM[id]" />
						<include content="HomeOnNavigateDown$PARAM[id]" />
						<onleft>SetFocus($PARAM[menuid])</onleft>
						<onback>SetFocus($PARAM[menuid])</onback>
						<onfocus>RunScript(script.canvas.helper,clear_listitem_properties)</onfocus>
					</control>
				</control>
			</control>
		</definition>
	</include>
	<!-- Empty placeholder of the same height as a page, to be used when a strip is shown in its place -->
	<include name="HomeEmptyPage">
		<param name="id"></param>
		<param name="visible"></param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<height>SCREEN_HEIGHT</height>

				<!-- Hidden button to allow focus -->
				<control type="button" id="$PARAM[id]">
					<visible allowhiddenfocus="true">false</visible>
				</control>
			</control>
		</definition>
	</include>

	<!-- Main home content (lists of media) -->
	<include name="HomeListsContent">
		<param name="darken_art">$EXP[HasHomeMenuFocus]</param>

		<definition>
			<!-- Lists with strip lists/walls -->
			<control type="grouplist" id="8000">
				<orientation>vertical</orientation>
				<itemgap>0</itemgap>
				<usecontrolcoords>true</usecontrolcoords>

				<bottom>0</bottom>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Home/Variables.xml" />
	<include file="Includes/Home/Expressions.xml" />

	<!-- Fallback element for when there is no content in a page -->
	<include name="HomeEmptyPageFallback">
		<param name="id"></param>
		<param name="title"></param>
		<param name="icon"></param>
		<param name="information"></param>
		<param name="button"></param>
		<param name="onclick">noop</param>
		<param name="onback">noop</param>
		<param name="onleft">noop</param>

		<definition>
			<control type="group">
				<width>WIDTH_HOME_FALLBACK_CONTENT</width>
				<height>HEIGHT_HOME_FALLBACK_CONTENT</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>

				<!-- Icon -->
				<control type="image">
					<width>100</width>
					<height>100</height>
					<centerleft>50%</centerleft>
					<texture colordiffuse="FOREGROUND">$PARAM[icon]</texture>
				</control>
				<!-- Page title -->
				<control type="label">
					<width>WIDTH_HOME_FALLBACK_CONTENT</width>
					<height>FONT_SIZE_TITLE2</height>
					<top>100</top>
					<centerright>50%</centerright>
					<align>center</align>
					<font>TITLE2</font>
					<label>$PARAM[title]</label>
				</control>
				<!-- Empty message -->
				<control type="label">
					<width>WIDTH_HOME_FALLBACK_CONTENT</width>
					<height>FONT_SIZE_BODY</height>
					<top>220</top>
					<centerright>50%</centerright>

					<align>center</align>
					<font>BODY</font>
					<label>$PARAM[information]</label>
				</control>
				<!-- Action button -->
				<control type="button" id="$PARAM[id]">
					<width>300</width>
					<height>120</height>
					<top>290</top>
					<centerright>50%</centerright>

					<texturefocus colordiffuse="FOREGROUND_ACCENT" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturefocus>
					<texturenofocus colordiffuse="BACKGROUND_OPAQUE50" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
					<textoffsety>4</textoffsety>
					<textoffsetx>38</textoffsetx>
					<textcolor>FOREGROUND</textcolor>
					<align>center</align>
					<label>$PARAM[button]</label>
					<onclick>$PARAM[onclick]</onclick>
					<onback>$PARAM[onback]</onback>
					<onleft>$PARAM[onleft]</onleft>
				</control>
			</control>
		</definition>
	</include>

	<!-- Main menu -->
	<include name="HomeMainMenu">
		<definition>
			<control type="group">
				<!-- Left/right shift + fade when the main menu loses/gains focus (except for "focus steal" and modal menu) -->
				<visible>$EXP[HasHomeMenuFocus]</visible>
				<include content="ShowHideFadeSlideHorizontalAnimation">
					<param name="slide_amount">-200</param>
					<param name="speed">ANIMATION_MID</param>
				</include>

				<left>PADDING_BASE</left>
				<top>PADDING_BASE</top>
				<bottom>PADDING_BASE</bottom>

				<!-- Hidden button to steal focus while loading -->
				<control type="button" id="9999">
					<include content="Hidden" />
					<!-- Fallback for endless loading -->
					<onback>SetFocus(1001,0)</onback>
					<!-- Fallback for side menu opening while loading -->
					<ondown condition="!$EXP[IsHomeLoading]">SetFocus(1)</ondown>
				</control>

				<!-- Logo -->
				<control type="image">
					<width>100</width>
					<height>70</height>
					<texture colordiffuse="HIGHLIGHT">special://xbmc/media/vendor_icon.png</texture>
					<aspectratio>keep</aspectratio>
				</control>
				<!-- Menu -->
				<control type="list" id="1">
					<top>220</top>
					<width>100</width>
					<bottom>0</bottom>
					<autoscroll>false</autoscroll>
					
					<onright>$INFO[Container(1).ListItem.Property(onright)]</onright>
					<onclick>$INFO[Container(1).ListItem.Property(onclick)]</onclick>
					<!-- Open flyout if not playing something in background -->
					<onback condition="!Player.HasMedia">SetFocus(1001,0)</onback>

					<focusedlayout height="90">
						<!-- Hidden onfocus control -->
						<control type="button">
							<include content="Hidden" />
							<onfocus>RunScript(script.canvas.helper,onchange_home_menu,$INFO[Container(1).ListItem.Property(name)])</onfocus>
						</control>
						<!-- Circle background -->
						<control type="image">
							<width>120</width>
							<height>120</height>
							<centertop>50%</centertop>
							<centerleft>50%</centerleft>
							<texture colordiffuse="FOREGROUND_ACCENT">1080p/diffuse/circle.png</texture>
							<bordertexture border="SIZE_ITEM_SHADOW_CIRCLE_DOUBLE" colordiffuse="BACKGROUND_OPAQUE75">1080p/diffuse/shadow-circle.png</bordertexture>
							<bordersize>SIZE_ITEM_SHADOW_CIRCLE</bordersize>
						</control>
						<!-- Icon -->
						<control type="image">
							<width>45</width>
							<height>45</height>
							<centertop>50%</centertop>
							<centerleft>50%</centerleft>
							<texture colordiffuse="BACKGROUND_OPAQUE75">$INFO[ListItem.Art(thumb)]</texture>
						</control>
					</focusedlayout>

					<itemlayout height="90">
						<!-- Icon -->
						<control type="image">
							<width>45</width>
							<height>45</height>
							<centertop>50%</centertop>
							<centerleft>50%</centerleft>
							<texture colordiffuse="FOREGROUND_OPAQUE50">$INFO[ListItem.Art(thumb)]</texture>
						</control>
					</itemlayout>

					<content>
						<!-- Home -->
						<item id="1">
							<thumb>$VAR[HomeIcon]</thumb>
							<property name="name">home</property>
							<property name="onright">SetFocus(100)</property>
							<property name="onclick">SetFocus(100)</property>
						</item>
						<!-- Movies -->
						<item id="2">
							<thumb>$VAR[MoviesIcon]</thumb>
							<property name="name">movies</property>
							<property name="onright">SetFocus(110)</property>
							<property name="onclick">SetFocus(110)</property>
						</item>
						<!-- TV shows -->
						<item id="3">
							<thumb>$VAR[TVShowsIcon]</thumb>
							<property name="name">tvshows</property>
							<property name="onright">SetFocus(120)</property>
							<property name="onclick">SetFocus(120)</property>
						</item>
						<!-- Yoga -->
						<item id="4">
							<thumb>$VAR[YogaIcon]</thumb>
							<property name="name">yoga</property>
							<property name="onright">SetFocus(130)</property>
							<property name="onclick">SetFocus(130)</property>
						</item>
						<!-- Music -->
						<item id="5">
							<thumb>$VAR[MusicIcon]</thumb>
							<property name="name">music</property>
							<property name="onright">SetFocus(140)</property>
							<property name="onclick">SetFocus(140)</property>
						</item>
						<!-- Pictures -->
						<item id="6">
							<thumb>$VAR[PicturesIcon]</thumb>
							<property name="name">pictures</property>
							<property name="onright">SetFocus(150)</property>
							<property name="onclick">SetFocus(150)</property>
						</item>
						<!-- Menu -->
						<item id="7">
							<thumb>$VAR[MenuIcon]</thumb>
							<property name="name">menu</property>
							<property name="onright">noop</property>
							<property name="onclick">SetFocus(1001,0)</property>
						</item>
					</content>
				</control>
			</control>
		</definition>
	</include>

	<!-- Content -->
	<include name="HomeContent">
		<definition>
			<!-- Loading spinner -->
			<control type="image">
				<visible>$EXP[IsHomeLoading]</visible>
				<animation effect="rotate" start="360" end="0" center="auto" time="ANIMATION_CRAWL" reversible="false" loop="true" condition="true">Conditional</animation>

				<width>100</width>
				<height>100</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-50.png</texture>
			</control>

			<control type="group">
				<!-- Left/right shift when the main menu loses/gains focus -->
				<animation condition="$EXP[HasHomeMenuFocus]" reversible="true">
					<effect type="slide" end="150,0" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>

				<!-- Padding + menu + padding -->
				<left>PADDING_MULT_120</left>
				<top>PADDING_BASE</top>

				<!-- Selection details -->
				<include content="SelectionDetails">
					<param name="visible">$EXP[HomeShowDetails]</param>
					<param name="clearlogo">$VAR[HomeDetailsClearlogo]</param>
					<param name="title">$VAR[HomeDetailsTitle]</param>
					<param name="has_clearlogo">$EXP[HasHomeDetailsClearlogo]</param>
					<param name="subtitle">$VAR[HomeDetailsSubtitle]</param>
					<param name="has_subtitle">$EXP[HasHomeDetailsSubtitle]</param>
					<param name="resolution">$VAR[HomeDetailsResolution]</param>
					<param name="has_resolution">$EXP[HasHomeDetailsResolution]</param>
					<param name="hdr">$VAR[HomeDetailsHdr]</param>
					<param name="has_hdr">$EXP[HasHomeDetailsHdr]</param>
					<param name="channels">$VAR[HomeDetailsAudioChannels]</param>
					<param name="has_channels">$EXP[HasHomeDetailsAudioChannels]</param>
					<param name="year">$VAR[HomeDetailsYear]</param>
					<param name="has_year">$EXP[HasHomeDetailsYear]</param>
					<param name="episode">$VAR[HomeDetailsEpisode]</param>
					<param name="has_episode">$EXP[HasHomeDetailsEpisode]</param>
					<param name="premiered">$VAR[HomeDetailsPremiered]</param>
					<param name="has_premiered">$EXP[HasHomeDetailsPremiered]</param>
					<param name="artist">$VAR[HomeDetailsArtist]</param>
					<param name="has_artist">$EXP[HasHomeDetailsArtist]</param>
					<param name="duration">$VAR[HomeDetailsDuration]</param>
					<param name="has_duration">$EXP[HasHomeDetailsDuration]</param>
					<param name="mpaa">$VAR[HomeDetailsMpaa]</param>
					<param name="has_mpaa">$EXP[HasHomeDetailsMpaa]</param>
					<param name="status">$VAR[HomeDetailsStatus]</param>
					<param name="has_status">$EXP[HasHomeDetailsStatus]</param>
					<param name="track">$VAR[HomeDetailsTrack]</param>
					<param name="has_track">$EXP[HasHomeDetailsTrack]</param>
					<param name="is_watched">$EXP[IsHomeDetailsWatched]</param>
					<param name="is_allnew">$EXP[IsHomeDetailsAllNew]</param>
					<param name="episodes_remaining">$VAR[HomeDetailsEpisodesRemaining]</param>
					<param name="has_episodes_remaining">$EXP[HasHomeDetailsEpisodesRemaining]</param>
					<param name="time_remaining">$VAR[HomeDetailsTimeRemaining]</param>
					<param name="has_time_remaining">$EXP[HasHomeDetailsTimeRemaining]</param>
					<param name="percentage_watched">$VAR[HomeDetailsWatchedPercentage]</param>
					<param name="genre">$VAR[HomeDetailsGenre]</param>
					<param name="has_genre">$EXP[HasHomeDetailsGenre]</param>
					<param name="plot">$VAR[HomeDetailsSummary]</param>
					<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
					<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
				</include>

				<!-- Items -->
				<control type="group">
					<!-- Home -->
					<control type="group">
						<visible>$EXP[IsHomeActivePageHome] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomePageHomeContent]</visible>
							<include content="FocusFadeAnimation">
								<param name="reference_id">100</param>
							</include>

							<include content="HomeEmptyPageFallback">
								<param name="id">100</param>
								<param name="information">Start with some content</param>
								<param name="button">Add content</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,0)</param>
								<param name="onleft">SetFocus(1,0)</param>
							</include>
						</control>

						<control type="grouplist" id="100">
							<visible>$EXP[HasHomePageHomeContent]</visible>
							<top>OFFSET_AFTER_DETAILS</top>
							<itemgap>OFFSET_HOME_STRIP</itemgap>
							<usecontrolcoords>true</usecontrolcoords>

							<!-- Continue watching -->
							<control type="group">
								<visible>$EXP[HasHomeContinueWatchingContent]</visible>
								<include content="FocusFadeAnimation">
									<param name="reference_id">101</param>
								</include>
								<height>HEIGHT_HOME_STRIP</height>

								<include content="PosterStrip">
									<param name="id">101</param>
									<param name="label">Continue watching</param>
									<param name="content">plugin://script.canvas.helper/continue_watching/?listid=101</param>
									<param name="art">$INFO[ListItem.Art(poster)]</param>
									<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
									<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
									<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,home,101)</param>
									<param name="onback">SetFocus(1,0)</param>
									<param name="onleft">SetFocus(1,0)</param>
									<param name="ondown">RunScript(script.canvas.helper,onmove_home_page_item,101,down)</param>
								</include>
							</control>

							<!-- Recently added episodes -->
							<control type="group">
								<visible>$EXP[HasHomeRecentEpisodesContent]</visible>
								<include content="FocusFadeAnimation">
									<param name="reference_id">102</param>
								</include>
								<height>HEIGHT_HOME_STRIP</height>

								<include content="LandscapeStrip">
									<param name="id">102</param>
									<param name="label">Recently added episodes</param>
									<param name="content">plugin://script.canvas.helper/recently_added_tvshow_episodes/?listid=102</param>
									<param name="art">$INFO[ListItem.Art(thumb)]</param>
									<param name="showinfo">true</param>
									<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
									<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
									<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,home,102)</param>
									<param name="onback">SetFocus(1,0)</param>
									<param name="onleft">SetFocus(1,0)</param>
									<param name="onup">RunScript(script.canvas.helper,onmove_home_page_item,102,up)</param>
									<param name="ondown">RunScript(script.canvas.helper,onmove_home_page_item,102,down)</param>
								</include>
							</control>

							<!-- Recently added movies -->
							<control type="group">
								<visible>$EXP[HasHomeRecentMoviesContent]</visible>
								<include content="FocusFadeAnimation">
									<param name="reference_id">103</param>
								</include>
								<height>HEIGHT_HOME_STRIP</height>

								<include content="PosterStrip">
									<param name="id">103</param>
									<param name="label">Recently added movies</param>
									<param name="content">plugin://script.canvas.helper/movies/?sort=dateadded&amp;order=descending&amp;limit=25&amp;listid=103</param>
									<param name="art">$INFO[ListItem.Art(poster)]</param>
									<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
									<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
									<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,home,103)</param>
									<param name="onback">SetFocus(1,0)</param>
									<param name="onleft">SetFocus(1,0)</param>
									<param name="onup">RunScript(script.canvas.helper,onmove_home_page_item,103,up)</param>
									<param name="ondown">RunScript(script.canvas.helper,onmove_home_page_item,103,down)</param>
								</include>
							</control>

							<!-- Recently added music -->
							<control type="group">
								<visible>$EXP[HasHomeRecentMusicContent]</visible>
								<include content="FocusFadeAnimation">
									<param name="reference_id">104</param>
								</include>
								<height>HEIGHT_HOME_STRIP</height>

								<include content="AlbumStrip">
									<param name="id">104</param>
									<param name="label">Recently added music</param>
									<param name="content">plugin://script.canvas.helper/songs/?sort=dateadded&amp;order=descending&amp;limit=25&amp;listid=104</param>
									<param name="art">$INFO[ListItem.Art(album.thumb)]</param>
									<param name="info1">$INFO[ListItem.Title]</param>
									<param name="info2">$INFO[ListItem.Album]</param>
									<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
									<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
									<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,home,104)</param>
									<param name="onback">SetFocus(1,0)</param>
									<param name="onleft">SetFocus(1,0)</param>
									<param name="onup">RunScript(script.canvas.helper,onmove_home_page_item,104,up)</param>
								</include>
							</control>
						</control>
					</control>

					<!-- Movies -->
					<control type="group" id="110">
						<visible>$EXP[IsHomeActivePageMovies] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>
						<include content="FocusFadeAnimation">
							<param name="reference_id">111</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomeMoviesContent]</visible>
							<include content="HomeEmptyPageFallback">
								<param name="id"></param>
								<param name="title">Movies</param>
								<param name="icon">$VAR[MoviesIcon]</param>
								<param name="information">No content found</param>
								<param name="button">Add movies</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,1)</param>
								<param name="onleft">SetFocus(1,1)</param>
							</include>
						</control>
						<!-- Actual movies -->
						<control type="group">
							<visible>$EXP[HasHomeMoviesContent]</visible>
							<include content="PosterWall">
								<param name="id">111</param>
								<param name="label">Movies</param>
								<param name="content">plugin://script.canvas.helper/movies/?listid=111</param>
								<param name="art">$INFO[ListItem.Art(poster)]</param>
								<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
								<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
								<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,movies,111)</param>
								<param name="onback">SetFocus(1,1)</param>
								<param name="onleft">SetFocus(1,1)</param>
							</include>
						</control>
					</control>

					<!-- TV shows -->
					<control type="group" id="120">
						<visible>$EXP[IsHomeActivePageTvShows] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>
						<include content="FocusFadeAnimation">
							<param name="reference_id">121</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomeTvShowsContent]</visible>
							<include content="HomeEmptyPageFallback">
								<param name="id"></param>
								<param name="title">TV Shows</param>
								<param name="icon">$VAR[TVShowsIcon]</param>
								<param name="information">No content found</param>
								<param name="button">Add TV Shows</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,2)</param>
								<param name="onleft">SetFocus(1,2)</param>
							</include>
						</control>
						<!-- Actual TV shows -->
						<control type="group">
							<visible>$EXP[HasHomeTvShowsContent]</visible>
							<include content="PosterWall">
								<param name="id">121</param>
								<param name="label">TV Shows</param>
								<param name="content">plugin://script.canvas.helper/tvshows/?exclude=Yoga with Adriene&amp;listid=121</param>
								<param name="art">$INFO[ListItem.Art(poster)]</param>
								<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
								<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
								<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,tvshows,121)</param>
								<param name="onback">SetFocus(1,2)</param>
								<param name="onleft">SetFocus(1,2)</param>
							</include>
						</control>
					</control>

					<!-- Yoga With Adriene -->
					<control type="group" id="130">
						<visible>$EXP[IsHomeActivePageYoga] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>
						<include content="FocusFadeAnimation">
							<param name="reference_id">131</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomeYogaContent]</visible>
							<include content="HomeEmptyPageFallback">
								<param name="id"></param>
								<param name="title">Yoga with Adriene</param>
								<param name="icon">$VAR[YogaIcon]</param>
								<param name="information">No content found</param>
								<param name="button">Add yoga</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,3)</param>
								<param name="onleft">SetFocus(1,3)</param>
							</include>
						</control>
						<!-- Actual Yoga With Adriene -->
						<control type="group">
							<visible>$EXP[HasHomeYogaContent]</visible>
							<top>OFFSET_AFTER_DETAILS</top>

							<include content="PosterStrip">
								<param name="id">131</param>
								<param name="label"></param>
								<param name="content">plugin://script.canvas.helper/seasons/?showtitle=Yoga with Adriene&amp;listid=131</param>
								<param name="art">$INFO[ListItem.Art(poster)]</param>
								<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
								<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
								<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,yoga,131)</param>
								<param name="onback">SetFocus(1,3)</param>
								<param name="onleft">SetFocus(1,3)</param>
							</include>
						</control>
					</control>

					<!-- Music -->
					<control type="group" id="140">
						<visible>$EXP[IsHomeActivePageMusic] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>
						<include content="FocusFadeAnimation">
							<param name="reference_id">141</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomeMusicContent]</visible>
							<include content="HomeEmptyPageFallback">
								<param name="id"></param>
								<param name="title">Music</param>
								<param name="icon">$VAR[MusicIcon]</param>
								<param name="information">No content found</param>
								<param name="button">Add music</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,4)</param>
								<param name="onleft">SetFocus(1,4)</param>
							</include>
						</control>
						<!-- Actual music -->
						<control type="group">
							<visible>$EXP[HasHomeMusicContent]</visible>
							<include content="AlbumWall">
								<param name="id">141</param>
								<param name="label">Music</param>
								<param name="content">plugin://script.canvas.helper/songs/?listid=141</param>
								<param name="art">$INFO[ListItem.Art(album.thumb)]</param>
								<param name="info1">$INFO[ListItem.Title]</param>
								<param name="info2">$INFO[ListItem.Album]</param>
								<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
								<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
								<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,music,141)</param>
								<param name="onback">SetFocus(1,4)</param>
								<param name="onleft">SetFocus(1,4)</param>
							</include>
						</control>
					</control>

					<!-- Pictures -->
					<control type="group" id="150">
						<visible>$EXP[IsHomeActivePagePictures] + !$EXP[IsHomeLoading]</visible>
						<include content="ShowHideFadeSlideVerticalAnimation">
							<param name="slide_amount">200</param>
							<param name="speed">ANIMATION_SLOW</param>
						</include>
						<include content="FocusFadeAnimation">
							<param name="reference_id">151</param>
						</include>

						<!-- Empty list fallback -->
						<control type="group">
							<visible>!$EXP[HasHomePicturesContent]</visible>
							<include content="HomeEmptyPageFallback">
								<param name="id"></param>
								<param name="title">Pictures</param>
								<param name="icon">$VAR[PicturesIcon]</param>
								<param name="information">No content found</param>
								<param name="button">Add pictures</param>
								<param name="onclick">noop</param>
								<param name="onback">SetFocus(1,5)</param>
								<param name="onleft">SetFocus(1,5)</param>
							</include>
						</control>
						<!-- Actual pictures -->
						<control type="group">
							<visible>$EXP[HasHomePicturesContent]</visible>
								<include content="AlbumWall">
								<param name="id">151</param>
								<param name="label">Music</param>
								<param name="content">plugin://script.canvas.helper/pictures/?listid=151</param>
								<param name="art">$INFO[ListItem.Art(album.thumb)]</param>
								<param name="info1">$INFO[ListItem.Title]</param>
								<param name="info2">$INFO[ListItem.Album]</param>
								<param name="foreground_color">$VAR[HomeContrastTextForegroundColor]</param>
								<param name="highlight_color">$VAR[HomeContrastTextHighlightColor]</param>
								<param name="onfocus">RunScript(script.canvas.helper,onfocus_home_page_item,music,151)</param>
								<param name="onback">SetFocus(1,5)</param>
								<param name="onleft">SetFocus(1,5)</param>
							</include>
						</control>
					</control>
				</control>
			</control>
		</definition>
	</include>


	<!-- Content for fake button with icon in flyout -->
	<include name="HomeButtonContentWithIconForFlyout">
		<param name="icon_circle_color">BACKGROUND_OPAQUE20</param>
		<param name="icon_color">BACKGROUND_INVERSE_OPAQUE50</param>
		<param name="icon">$INFO[ListItem.Art(thumb)]</param>
		<param name="text_color">FOREGROUND_OPAQUE75</param>
		<param name="text">$INFO[ListItem.Label]</param>

		<definition>
			<control type="group">
				<top>PADDING_HOME_FLYOUT_BUTTON_VERTICAL</top>
				<bottom>PADDING_HOME_FLYOUT_BUTTON_VERTICAL</bottom>
				<left>PADDING_BUTTON_VERTICAL</left>
				<right>PADDING_BUTTON_VERTICAL</right>

				<!-- Icon -->
				<control type="group">
					<width>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</width>
					<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>

					<!-- Background -->
					<control type="image">
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="$PARAM[icon_circle_color]">1080p/diffuse/circle.png</texture>
					</control>
					<!-- Icon -->
					<control type="image">
						<width>SIZE_HOME_FLYOUT_ICON</width>
						<height>SIZE_HOME_FLYOUT_ICON</height>
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<texture colordiffuse="$PARAM[icon_color]">$PARAM[icon]</texture>
					</control>
				</control>

				<!-- Labels -->
				<control type="group">
					<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>
					<left>OFFSET_HOME_FLYOUT_BUTTON_CONTENT</left>

					<!-- First text line -->
					<control type="label">
						<top>OFFSET_HOME_FLYOUT_BUTTON_TEXT</top>
						<font>BODY_STRONG</font>
						<textcolor>$PARAM[text_color]</textcolor>
						<label>$PARAM[text]</label>
					</control>
				</control>
			</control>
		</definition>
	</include>

	<!-- Fake icon button in flyout -->
	<include name="HomeIconButtonForFlyout">
		<param name="icon_circle_color">BACKGROUND_OPAQUE20</param>
		<param name="icon_color">BACKGROUND_INVERSE_OPAQUE50</param>
		<param name="icon">$INFO[ListItem.Art(thumb)]</param>

		<definition>
			<control type="group">
				<width>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</width>
				<height>HEIGHT_HOME_FLYOUT_BUTTON_CONTENT</height>

				<!-- Background -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<texture colordiffuse="$PARAM[icon_circle_color]">1080p/diffuse/circle.png</texture>
				</control>
				<!-- Icon -->
				<control type="image">
					<width>SIZE_HOME_FLYOUT_ICON</width>
					<height>SIZE_HOME_FLYOUT_ICON</height>
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<texture colordiffuse="$PARAM[icon_color]">$PARAM[icon]</texture>
				</control>
			</control>
		</definition>
	</include>


	<!-- Flyout menu -->
	<include name="HomeFlyoutMenu">
		<include content="StandardFlyoutBase">
			<param name="visible">$EXP[HasHomeFlyoutFocus]</param>

			<include content="StandardFlyoutStructure">
				<param name="visible">$EXP[HasHomeFlyoutFocus]</param>

				<!-- Horizontal list of icon buttons -->
				<control type="list" id="1000">
					<top>OFFSET_HOME_FLYOUT_HORIZONTAL_LIST_TOP</top>
					<left>OFFSET_HOME_FLYOUT_HORIZONTAL_LIST_LEFT</left>
					<orientation>horizontal</orientation>

					<onback>SetFocus(1)</onback>
					<ondown>SetFocus(1001,0)</ondown>
					<onclick>SetFocus(1)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<include content="HomeIconButtonForFlyout" />
					</itemlayout>
					<focusedlayout height="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER" width="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is not actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1000)</visible>
							<include content="HomeIconButtonForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Settings -->
						<item id="1">
							<thumb>$VAR[SettingsIcon]</thumb>
							<property name="onclick">RunScript(script.canvas.helper,home_to_active_settings,$INFO[Window(settings).Property(Settings.ActivePage)])</property>
						</item>
					</content>
				</control>

				<!-- Vertical list of buttons -->
				<control type="list" id="1001">
					<top>OFFSET_HOME_FLYOUT_LIST</top>
					<bottom>PADDING_BASE</bottom>
					<left>PADDING_HALF</left>
					<right>PADDING_HALF</right>

					<onback>SetFocus(1)</onback>
					<onup>SetFocus(1000,0)</onup>
					<onclick>SetFocus(1)</onclick>
					<onclick>$INFO[ListItem.Property(onclick)]</onclick>

					<itemlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<include content="HomeButtonContentWithIconForFlyout" />
					</itemlayout>
					<focusedlayout height="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>Control.HasFocus(1001)</visible>
							<!-- Fake button selection -->
							<control type="image">
								<height>HEIGHT_HOME_FLYOUT_BUTTON</height>
								<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
							</control>
							<!-- Content -->
							<include content="HomeButtonContentWithIconForFlyout">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
								<param name="text_color">FOREGROUND_INVERSE</param>
							</include>
						</control>
						<!-- When the list is actually focused -->
						<control type="group">
							<visible>!Control.HasFocus(1001)</visible>
							<include content="HomeButtonContentWithIconForFlyout" />
						</control>
					</focusedlayout>

					<content>
						<!-- Shutdown -->
						<item id="1">
							<thumb>$VAR[ShutdownIcon]</thumb>
							<label>Shutdown</label>
							<property name="onclick">PowerDown()</property>
						</item>
						<!-- Exit -->
						<item id="2">
							<thumb>$VAR[QuitIcon]</thumb>
							<label>Quit</label>
							<property name="onclick">Quit()</property>
						</item>
						<!-- Update libraries -->
						<item id="3">
							<thumb>$VAR[UpdateLibrariesIcon]</thumb>
							<label>Update libraries</label>
							<property name="onclick">UpdateLibrary()</property>
						</item>
						<!-- Reload home -->
						<item id="4">
							<thumb>$VAR[ReloadHomeIcon]</thumb>
							<label>Reload home</label>
							<property name="onclick">RunScript(script.canvas.helper,init_home)</property>
						</item>
						<!-- Addons -->
						<item id="5">
							<thumb>$VAR[AddonsIcon]</thumb>
							<label>Addons</label>
							<property name="onclick">ActivateWindow(addonbrowser)</property>
						</item>
						<!-- File manager -->
						<item id="6">
							<thumb>$VAR[FileManagerIcon]</thumb>
							<label>File manager</label>
							<property name="onclick">ActivateWindow(filebrowser)</property>
						</item>
						<!-- System info -->
						<item id="7">
							<thumb>$VAR[SystemInfoIcon]</thumb>
							<label>System info</label>
							<property name="onclick">ActivateWindow(systeminfo)</property>
						</item>
					</content>
				</control>
			</include>
		</include>
	</include>
</includes>
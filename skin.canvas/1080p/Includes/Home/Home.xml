<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Home/Variables.xml" />
	<include file="Includes/Home/Expressions.xml" />
	<include file="Includes/Home/Navigation.xml" />


	<!-- Horizontal list of media items. Form factor is based on content type -->
	<include name="HomeItemStrip">
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="content_type"></param>
		<param name="movement"></param>
		<param name="menuid"></param>
		<param name="onclick"></param>
		<param name="darken_art">false</param>

		<definition>
			<control type="group" id="8$PARAM[id]">
				<visible>Container($PARAM[id]).IsUpdating | !Integer.IsEqual(Container($PARAM[id]).NumItems,0)</visible>
				<height>HEIGHT_LIST_CONTAINER_WITH_LABEL</height>

				<!-- Label -->
				<include content="ListLabel">
					<param name="id">8$PARAM[id]1</param>
					<param name="label">$PARAM[label]</param>
					<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
				</include>

				<!-- Media item strip -->
				<include content="ItemStrip">
					<param name="id">$PARAM[id]</param>
					<param name="movement">$PARAM[movement]</param>

					<top>OFFSET_HOME_LIST_AFTER_LABEL</top>
					<height>HEIGHT_LIST_CONTAINER</height>

					<onfocus>RunScript(script.canvas.helper,populate_listitem_info_from_listitem,$PARAM[id])</onfocus>
					<include content="HomeOnNavigateUp$PARAM[id]" />
					<include content="HomeOnNavigateDown$PARAM[id]" />
					<onright>noop</onright>
					<onleft>SetFocus($PARAM[menuid])</onleft>
					<onback>SetFocus($PARAM[menuid])</onback>
					<onclick>$PARAM[onclick]</onclick>

					<!-- Season layout -->
					<include content="PosterLayout">
						<param name="art">$VAR[HomePosterArt]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[content_type],1)</param>
						<param name="listid">$PARAM[id]</param>
					</include>
					<!-- Episode layout -->
					<include content="LandscapeLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[content_type],2)</param>
						<param name="show_info">true</param>
						<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
						<param name="listid">$PARAM[id]</param>
					</include>
					<!-- Music layout -->
					<include content="AlbumLayout">
						<param name="art">$INFO[ListItem.Art(thumb)]</param>
						<param name="dark_unfocused">$PARAM[darken_art]</param>
						<param name="dark_focused">$PARAM[darken_art]</param>
						<param name="condition">Integer.IsEqual($PARAM[content_type],3)</param>
						<param name="info1">$VAR[HomeAlbumInfo1]</param>
						<param name="info2">$VAR[HomeAlbumInfo2]</param>
						<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
						<param name="info2_color">$VAR[ColorsContrastForeground]</param>
						<param name="listid">$PARAM[id]</param>
					</include>

					<content>$PARAM[content]</content>
				</include>
			</control>
		</definition>
	</include>
	<!-- Wall of media items for strip height. Form factor is based on content type -->
	<include name="HomeItemWall">

<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!--
		Has left menu focus?
		Consider true the following conditions:
		- Focus on actual left menu
		- Focus on "focus steal" inside left menu (when loading)
		- Focus on modal menu (only accessible through left menu)
	-->
	<expression name="HasHomeMenuFocus">Control.HasFocus(1) | Control.HasFocus(9999) | Control.HasFocus(1000)</expression>

	<!-- Is loading ongoing on home? -->
	<expression name="IsHomeLoading">String.IsEqual(Window(home).Property(Home.IsLoading),true)</expression>

	<!-- Is active page "home"? -->
	<expression name="IsHomeActivePageHome">String.IsEqual(Window(home).Property(Home.ActivePage),home)</expression>
	<!-- Is active page "movies"? -->
	<expression name="IsHomeActivePageMovies">String.IsEqual(Window(home).Property(Home.ActivePage),movies)</expression>
	<!-- Is active page "tvshows"? -->
	<expression name="IsHomeActivePageTvShows">String.IsEqual(Window(home).Property(Home.ActivePage),tvshows)</expression>
	<!-- Is active page "yoga"? -->
	<expression name="IsHomeActivePageYoga">String.IsEqual(Window(home).Property(Home.ActivePage),yoga)</expression>
	<!-- Is active page "music"? -->
	<expression name="IsHomeActivePageMusic">String.IsEqual(Window(home).Property(Home.ActivePage),music)</expression>
	<!-- Is active page "pictures"? -->
	<expression name="IsHomeActivePagePictures">String.IsEqual(Window(home).Property(Home.ActivePage),pictures)</expression>

	<!-- Has "home" page content? -->
	<expression name="HasHomePageHomeContent">
		String.IsEqual(Window(home).Property(List.101.HasContent),true) |
		String.IsEqual(Window(home).Property(List.102.HasContent),true) |
		String.IsEqual(Window(home).Property(List.103.HasContent),true) |
		String.IsEqual(Window(home).Property(List.104.HasContent),true)
	</expression>
	<!-- Has continue watching content? -->
	<expression name="HasHomeContinueWatchingContent">String.IsEqual(Window(home).Property(List.101.HasContent),true)</expression>
	<!-- Has recently added episodes content? -->
	<expression name="HasHomeRecentEpisodesContent">String.IsEqual(Window(home).Property(List.102.HasContent),true)</expression>
	<!-- Has recently added movies content? -->
	<expression name="HasHomeRecentMoviesContent">String.IsEqual(Window(home).Property(List.103.HasContent),true)</expression>
	<!-- Has recently added music content? -->
	<expression name="HasHomeRecentMusicContent">String.IsEqual(Window(home).Property(List.104.HasContent),true)</expression>
	<!-- Has movies content? -->
	<expression name="HasHomeMoviesContent">String.IsEqual(Window(home).Property(List.111.HasContent),true)</expression>
	<!-- Has tv shows content? -->
	<expression name="HasHomeTvShowsContent">String.IsEqual(Window(home).Property(List.121.HasContent),true)</expression>
	<!-- Has yoga content? -->
	<expression name="HasHomeYogaContent">String.IsEqual(Window(home).Property(List.131.HasContent),true)</expression>
	<!-- Has music content? -->
	<expression name="HasHomeMusicContent">String.IsEqual(Window(home).Property(List.141.HasContent),true)</expression>
	<!-- Has pictures content? -->
	<expression name="HasHomePicturesContent">String.IsEqual(Window(home).Property(List.151.HasContent),true)</expression>

	<!-- Show details? -->
	<expression name="HomeShowDetails">
		[!$EXP[IsHomeActivePagePictures] + !$EXP[IsHomeLoading]] +
		[
			[$EXP[IsHomeActivePageHome] + $EXP[HasHomePageHomeContent]] |
			[$EXP[IsHomeActivePageMovies] + $EXP[HasHomeMoviesContent]] |
			[$EXP[IsHomeActivePageTvShows] + $EXP[HasHomeTvShowsContent]] |
			[$EXP[IsHomeActivePageYoga] + $EXP[HasHomeYogaContent]] |
			[$EXP[IsHomeActivePageMusic] + $EXP[HasHomeMusicContent]] |
			[$EXP[IsHomeActivePagePictures] + $EXP[HasHomePicturesContent]]
		]
	</expression>
</includes>
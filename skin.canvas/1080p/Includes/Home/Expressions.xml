<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is first loading done? -->
	<expression name="HasHomeLoaded">String.IsEqual(Window(home).Property(Loaded),true)</expression>

	<!-- Is an empty list placeholder showing? -->
	<expression name="IsHomeEmptyListPlaceholderVisible">
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),105) |
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),107) |
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),109) |
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),111) |
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),113) |
		String.IsEqual(Window(home).Property(EmptyListPlaceholder),115)
	</expression>
	<!-- Is a full-height media list visible? -->
	<expression name="IsHomeFullHeightMediaListVisible">String.IsEqual(Window(home).Property(ActiveListId),302)</expression>

	<!-- Is left menu transitioning between items? -->
	<expression name="IsHomeMenuMoving">String.IsEqual(Window(home).Property(Menu.Moving),true)</expression>
	<!--
		Has left menu focus?
		Consider true any of the following conditions:
		- Focus on actual left menu
		- Left menu is transitioning from an item to another (takes a perceptible amount of ime)
	-->
	<expression name="HasHomeMenuFocus">
		Control.HasFocus(200) |
		Control.HasFocus(201) |
		Control.HasFocus(202) |
		Control.HasFocus(203) |
		Control.HasFocus(204) |
		Control.HasFocus(205) |
		Control.HasFocus(206) |
		Control.HasFocus(207) |
		$EXP[IsHomeMenuMoving]
	</expression>

	<!-- Is menu flyout visible? -->
	<expression name="IsHomeMenuFlyoutVisible">Control.HasFocus(1000) | Control.HasFocus(1001)</expression>
	<!-- Is filter flyout visible? -->
	<expression name="IsHomeFilterFlyoutVisible">Control.HasFocus(1100)</expression><!--todo-->
	<!--
		Is any flyout visible? Consider:
		- Menu flyout
		- Filter flyout
	-->
	<expression name="IsHomeFlyoutVisible">$EXP[IsHomeMenuFlyoutVisible] | $EXP[IsHomeFilterFlyoutVisible]</expression>
</includes>
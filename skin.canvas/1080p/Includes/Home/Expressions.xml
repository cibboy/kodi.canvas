<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is first loading done? -->
	<expression name="HasHomeLoaded">String.IsEqual(Window(home).Property(Loaded),true)</expression>

	<!-- Has left menu focus? -->
	<expression name="HasHomeMenuFocus">
		Control.HasFocus(7000) |
		Control.HasFocus(7001) |
		Control.HasFocus(7002) |
		Control.HasFocus(7003) |
		Control.HasFocus(7004) |
		Control.HasFocus(7005) |
		Control.HasFocus(7006) |
		Control.HasFocus(7007) |
		$EXP[IsHomeFlyoutVisible]
	</expression>

	<!-- Is home music active? -->
	<expression name="IsHomeMusicActive">Integer.IsEqual(Container(7000).Position,4)</expression>
	<!-- Is home pictures active? -->
	<expression name="IsHomePicturesActive">Integer.IsEqual(Container(7000).Position,5)</expression>

	<!-- Is home music type albums? -->
	<expression name="IsHomeMusicTypeAlbums">String.IsEqual(Skin.String(canvas.homemusic),album)</expression>
	<!-- Is home picture type albums? -->
	<expression name="IsHomePictureTypeAlbums">String.IsEqual(Skin.String(canvas.homepicture),album)</expression>

	<!-- Is home music sort by title? -->
	<expression name="IsHomeMusicSortByAlbum">String.IsEqual(Skin.String(canvas.musicsort),album)</expression>
	<expression name="IsHomeMusicSortByYear">String.IsEqual(Skin.String(canvas.musicsort),year)</expression>
	<expression name="IsHomeMusicSortByDateAdded">String.IsEqual(Skin.String(canvas.musicsort),dateadded)</expression>
	<expression name="IsHomeMusicSortByArtist">String.IsEqual(Skin.String(canvas.musicsort),artist)</expression>

	<!-- Is home music sort descending? -->
	<expression name="IsHomeMusicSortDescending">String.IsEqual(Skin.String(canvas.musicsortdirection),descending)</expression>

	<!-- Is menu flyout visible? -->
	<expression name="IsHomeMenuFlyoutVisible">Control.HasFocus(1000) | Control.HasFocus(1001)</expression>
	<!-- Is filter flyout visible? -->
	<expression name="IsHomeFilterFlyoutVisible">Control.HasFocus(1100)</expression>
	<!--
		Is any flyout visible? Consider:
		- Menu flyout
		- Filter flyout
	-->
	<expression name="IsHomeFlyoutVisible">$EXP[IsHomeMenuFlyoutVisible] | $EXP[IsHomeFilterFlyoutVisible]</expression>
</includes>
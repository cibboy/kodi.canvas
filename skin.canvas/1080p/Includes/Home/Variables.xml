	<!-- Time remaining -->
	<variable name="HomeDetailsTimeRemaining">
		<!-- Continue watching -->
		<value condition="$EXP[IsHomeContinueWatchingActive]">$INFO[Container(101).ListItem.Property(TimeRemainingString)] left</value>
		<!-- Recently added episodes -->
		<value condition="$EXP[IsHomeRecentlyAddedEpisodesActive]">$INFO[Container(102).ListItem.Property(TimeRemainingString)] left</value>
		<!-- Recently added movies -->
		<value condition="$EXP[IsHomeRecentlyAddedMoviesActive]">$INFO[Container(103).ListItem.Property(TimeRemainingString)] left</value>
		<!-- Movies -->
		<value condition="$EXP[IsHomeMoviesActive]">$INFO[Container(111).ListItem.Property(TimeRemainingString)] left</value>

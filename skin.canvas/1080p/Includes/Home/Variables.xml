		<value condition="$EXP[IsHomeContinueWatchingActive] + $EXP[IsHomeContinueWatchingMovie]">$INFO[Container(101).ListItem.Genre]</value>
		<!-- Recently added movies -->
		<value condition="$EXP[IsHomeRecentlyAddedMoviesActive]">$INFO[Container(103).ListItem.Genre]</value>
		<!-- Recently added music -->
		<value condition="$EXP[IsHomeRecentlyAddedMusicActive]">$INFO[Container(104).ListItem.Genre]</value>
		<!-- Movies -->

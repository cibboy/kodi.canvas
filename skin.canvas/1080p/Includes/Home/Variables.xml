		<value condition="$EXP[IsHomeTVShowsActive]">$INFO[Container(121).ListItem.Property(WatchedEpisodes)] of $INFO[Container(121).ListItem.Property(TotalEpisodes)] watched</value>
		<!-- Yoga -->
		<value condition="$EXP[IsHomeYogaActive]">$INFO[Container(131).ListItem.Property(WatchedEpisodes)] of $INFO[Container(131).ListItem.Property(TotalEpisodes)] watched</value>
	</variable>


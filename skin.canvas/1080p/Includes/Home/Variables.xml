	<!-- Mpaa -->
	<variable name="HomeDetailsMpaa">
		<!-- Continue watching -->
		<value condition="$EXP[IsHomeContinueWatchingActive]">$INFO[Container(101).ListItem.Mpaa]</value>
		<!-- Recently added episodes -->
		<value condition="$EXP[IsHomeRecentlyAddedEpisodesActive]">$INFO[Container(102).ListItem.Mpaa]</value>
		<!-- Recently added movies -->
		<value condition="$EXP[IsHomeRecentlyAddedMoviesActive]">$INFO[Container(103).ListItem.Mpaa]</value>
		<!-- Movies -->
		<value condition="$EXP[IsHomeMoviesActive]">$INFO[Container(111).ListItem.Mpaa]</value>
		<!-- TV shows -->

<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Poster art (depends on type of item in "continue watching") -->
	<variable name="HomePosterArt">
		<value condition="String.IsEqual(ListItem.DBTYPE,episode)">$INFO[ListItem.Art(tvshow.poster)]</value>
		<value>$INFO[ListItem.Art(poster)]</value>
	</variable>
	<!-- Picture fallback art (depends on type of item in pictures) -->
	<variable name="HomePictureFallbackArt">
		<value condition="String.IsEqual(ListItem.Property(Type),picture)">1080p/fallback/picture.png</value>
		<value condition="String.IsEqual(ListItem.Property(Type),picturealbum)">1080p/fallback/none.png</value>
	</variable>
	<!-- Picture overlay icon (only visible in albums) -->
	<variable name="HomePictureOverlayIcon">
		<value condition="String.IsEqual(ListItem.Property(Type),picturealbum)">1080p/icons/collection.png</value>
	</variable>
	<!-- First line of info in albums (depends on type, might be song, album, picture...) -->
	<variable name="HomeAlbumInfo1">
		<value condition="String.IsEqual(ListItem.DBTYPE,song)">$INFO[ListItem.Title]</value>
		<value condition="String.IsEqual(ListItem.DBTYPE,album)">$INFO[ListItem.Album]</value>
		<value>$INFO[ListItem.Label]</value>
	</variable>
	<!-- Second line of info in albums (depends on type, might be song, album, picture...) -->
	<variable name="HomeAlbumInfo2">
		<value condition="String.IsEqual(ListItem.DBTYPE,song)">$INFO[ListItem.Album]</value>
		<value condition="String.IsEqual(ListItem.DBTYPE,album)">$INFO[ListItem.Artist]</value>
		<value condition="String.IsEqual(ListItem.Property(Type),picture)">$INFO[ListItem.Property(Album)]</value>
		<value condition="String.IsEqual(ListItem.Property(Type),picturealbum)">Album</value>
	</variable>

	<!-- Empty list title -->
	<variable name="HomeEmptyListTitle">
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),105)">Kodi</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),107)">Movies</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),109)">TV Shows</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),111)">Yoga</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),113)">Music</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),115)">Pictures</value>
	</variable>
	<!-- Empty list icon -->
	<variable name="HomeEmptyListIcon">
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),105)">$VAR[LogoIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),107)">$VAR[MoviesIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),109)">$VAR[TVShowsIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),111)">$VAR[YogaIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),113)">$VAR[MusicIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),115)">$VAR[PicturesIcon]</value>
	</variable>

	<!-- Hidden media list content based on active list ID -->
	<variable name="HomeActiveItemListContent">
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),101)">$VAR[HomeContinueWatchingContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),102)">$VAR[HomeRecentEpisodesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),103)">$VAR[HomeRecentMoviesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),104)">$VAR[HomeRecentSongsContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),106)">$VAR[HomeMoviesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),108)">$VAR[HomeTVShowsContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),110)">$VAR[HomeYogaContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),112)">$VAR[HomeMusicContent]</value>
		<value>special://skin/playlists/empty.xsp</value>
	</variable>

	<!-- Home lists contents -->
	<variable name="HomeContinueWatchingContent"><value>plugin://script.canvas.helper/continue_watching/</value></variable>
	<variable name="HomeRecentEpisodesContent"><value>plugin://script.canvas.helper/recent_episodes/</value></variable>
	<variable name="HomeRecentMoviesContent"><value>special://skin/playlists/recent.movies.xsp</value></variable>
	<variable name="HomeRecentSongsContent"><value>special://skin/playlists/recent.songs.xsp</value></variable>
	<variable name="HomeMoviesContent"><value>special://skin/playlists/movies.xsp</value></variable>
	<variable name="HomeTVShowsContent"><value>special://skin/playlists/tvshows.xsp</value></variable>
	<variable name="HomeYogaContent"><value>plugin://script.canvas.helper/yoga/</value></variable>
	<variable name="HomeMusicContent">
		<value condition="$EXP[IsHomeMusicTypeAlbums]">special://skin/playlists/albums.xsp</value>
		<value>special://skin/playlists/songs.xsp</value>
	</variable>
	<variable name="HomePicturesContent">
		<value condition="$EXP[IsHomePictureTypeAlbums]">plugin://script.canvas.helper/pictures/?type=album</value>
		<value>plugin://script.canvas.helper/pictures/?type=picture</value>
	</variable>

	<!-- Home music onclick action -->
	<variable name="HomeMusicOnClick">
		<value condition="$EXP[IsHomeMusicTypeAlbums]">ActivateWindow(music,musicdb://albums/$INFO[ListItem.DBID],return)</value>
		<value>PlayMedia($INFO[ListItem.FileNameAndPath],noresume,playoffset=0)</value>
	</variable>
	<!-- Home picture onclick action -->
	<variable name="HomePictureOnClick">
		<value condition="$EXP[IsHomePictureTypeAlbums]">ActivateWindow(pictures,$INFO[ListItem.FolderPath],return)</value>
		<value>ShowPicture($INFO[ListItem.FileNameAndPath])</value>
	</variable>

	<!-- Home filter type onclick action -->
	<variable name="HomeFilterTypeOnClick">
		<value condition="$EXP[IsHomeMusicActive] + $EXP[IsHomeMusicTypeAlbums]">Skin.SetString(canvas.homemusic,song)</value>
		<value condition="$EXP[IsHomeMusicActive]">Skin.SetString(canvas.homemusic,album)</value>
		<value condition="$EXP[IsHomePicturesActive] + $EXP[IsHomePictureTypeAlbums]">Skin.SetString(canvas.homepicture,picture)</value>
		<value condition="$EXP[IsHomePicturesActive]">Skin.SetString(canvas.homepicture,album)</value>
	</variable>
	<!-- Home filter type onclick label -->
	<variable name="HomeFilterTypeLabel">
		<value condition="$EXP[IsHomeMusicActive] + $EXP[IsHomeMusicTypeAlbums]">View type: albums</value>
		<value condition="$EXP[IsHomeMusicActive]">View type: songs</value>
		<value condition="$EXP[IsHomePicturesActive] + $EXP[IsHomePictureTypeAlbums]">View type: albums</value>
		<value condition="$EXP[IsHomePicturesActive]">View type: pictures</value>
	</variable>
	
	
	<!-- Icons -->
	<variable name="LogoIcon"><value>special://xbmc/media/vendor_icon.png</value></variable>
	<variable name="HomeIcon"><value>1080p/icons/home.png</value></variable>
	<variable name="MoviesIcon"><value>1080p/icons/movies.png</value></variable>
	<variable name="TVShowsIcon"><value>1080p/icons/tvshows.png</value></variable>
	<variable name="YogaIcon"><value>1080p/icons/yoga.png</value></variable>
	<variable name="MusicIcon"><value>1080p/icons/music.png</value></variable>
	<variable name="PicturesIcon"><value>1080p/icons/pictures.png</value></variable>
	<variable name="MenuIcon"><value>1080p/icons/menu.png</value></variable>
	<variable name="SettingsIcon"><value>1080p/icons/settings.png</value></variable>
	<variable name="QuitIcon"><value>1080p/icons/exit.png</value></variable>
	<variable name="ShutdownIcon"><value>1080p/icons/shutdown.png</value></variable>
	<variable name="UpdateLibrariesIcon"><value>1080p/icons/reload.png</value></variable>
	<variable name="AddonsIcon"><value>1080p/icons/addon.png</value></variable>
	<variable name="FileManagerIcon"><value>1080p/icons/folder.png</value></variable>
	<variable name="SystemInfoIcon"><value>1080p/icons/systeminfo.png</value></variable>
	<variable name="PlayIcon"><value>1080p/icons/play.png</value></variable>
	<variable name="ShuffleIcon"><value>1080p/icons/shuffle-on.png</value></variable>
	<variable name="FilterTypeIcon">
		<value condition="$EXP[IsHomeMusicActive] + $EXP[IsHomeMusicTypeAlbums]">1080p/icons/collection.png</value>
		<value condition="$EXP[IsHomeMusicActive]">1080p/icons/music.png</value>
		<value condition="$EXP[IsHomePicturesActive] + $EXP[IsHomePictureTypeAlbums]">1080p/icons/collection.png</value>
		<value condition="$EXP[IsHomePicturesActive]">1080p/icons/pictures.png</value>
	</variable>


	<!-- Constants -->
	<constant name="HEIGHT_HOME_FALLBACK_CONTENT">590</constant>
	<constant name="WIDTH_HOME_FALLBACK_CONTENT">1720</constant>
	<constant name="SIZE_HOME_FALLBACK_ICON">100</constant>

	<constant name="HEIGHT_HOME_FULL_WALL_CONTENT">930</constant>
	<constant name="OFFSET_HOME_LIST_AFTER_LABEL">52</constant>	<!-- HEIGHT_LIST_CONTAINER_WITH_LABEL - HEIGHT_LIST_CONTAINER -->

	<constant name="WIDTH_HOME_MENU">300</constant>
	<constant name="OFFSET_HOME_MENU_END">260</constant>
	<constant name="OFFSET_HOME_MENU_END_NEG">-260</constant>
	<constant name="SIZE_HOME_MENU_LOGO">100</constant>
	<constant name="SIZE_HOME_MENU_ICON">45</constant>
	<constant name="SIZE_HOME_MENU_ICON_SELECTION">120</constant>

	<constant name="SIZE_HOME_FLYOUT_ICON">40</constant>
	<constant name="SIZE_HOME_FLYOUT_ICONBUTTON_CONTAINER">80</constant>
	<constant name="HEIGHT_HOME_FLYOUT_BUTTON_CONTAINER">120</constant>
	<constant name="HEIGHT_HOME_FLYOUT_BUTTON">140</constant>
	<constant name="HEIGHT_HOME_FLYOUT_BUTTON_CONTENT">70</constant>
	<constant name="PADDING_HOME_FLYOUT_BUTTON_VERTICAL">35</constant>
	<constant name="OFFSET_HOME_FLYOUT_BUTTON_CONTENT">90</constant>
	<constant name="OFFSET_HOME_FLYOUT_BUTTON_TEXT">7</constant>
</includes>
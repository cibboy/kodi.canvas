<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Poster art (depends on type of item in "continue watching") -->
	<variable name="HomePosterArt">
		<value condition="String.IsEqual(ListItem.DBTYPE,episode)">$INFO[ListItem.Art(tvshow.poster)]</value>
		<value>$INFO[ListItem.Art(poster)]</value>
	</variable>
	<!-- First line of info in albums (depends on type, might be song, album, picture...) -->
	<variable name="HomeAlbumInfo1">
		<value condition="String.IsEqual(ListItem.DBTYPE,song)">$INFO[ListItem.Title]</value>
		<!-- todo -->
	</variable>
	<!-- Second line of info in albums (depends on type, might be song, album, picture...) -->
	<variable name="HomeAlbumInfo2">
		<value condition="String.IsEqual(ListItem.DBTYPE,song)">$INFO[ListItem.Album]</value>
		<!-- todo -->
	</variable>

	<!-- Empty list title -->
	<variable name="HomeEmptyListTitle">
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),105)">Kodi</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),107)">Movies</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),109)">TV Shows</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),111)">Yoga</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),113)">Music</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),115)">Pictures</value>
	</variable>
	<!-- Empty list icon -->
	<variable name="HomeEmptyListIcon">
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),105)">$VAR[LogoIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),107)">$VAR[MoviesIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),109)">$VAR[TVShowsIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),111)">$VAR[YogaIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),113)">$VAR[MusicIcon]</value>
		<value condition="String.IsEqual(Window(home).Property(EmptyListPlaceholder),115)">$VAR[PicturesIcon]</value>
	</variable>

	<!-- Hidden media list content based on active list ID -->
	<variable name="HomeActiveItemListContent">
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),101)">$VAR[HomeContinueWatchingContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),102)">$VAR[HomeRecentEpisodesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),103)">$VAR[HomeRecentMoviesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),104)">$VAR[HomeRecentSongsContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),106)">$VAR[HomeMoviesContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),108)">$VAR[HomeTVShowsContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),110)">$VAR[HomeYogaContent]</value>
		<value condition="String.IsEqual(Window(home).Property(ActiveListId),112)">$VAR[HomeSongsContent]</value>
		<value>special://skin/playlists/empty.xsp</value>
	</variable>

	<!-- Home lists contents -->
	<variable name="HomeContinueWatchingContent"><value>plugin://script.canvas.helper/continue_watching/</value></variable>
	<variable name="HomeRecentEpisodesContent"><value>plugin://script.canvas.helper/recent_episodes/</value></variable>
	<variable name="HomeRecentMoviesContent"><value>special://skin/playlists/recent.movies.xsp</value></variable>
	<variable name="HomeRecentSongsContent"><value>special://skin/playlists/recent.songs.xsp</value></variable>
	<variable name="HomeMoviesContent"><value>special://skin/playlists/movies.xsp</value></variable>
	<variable name="HomeTVShowsContent"><value>special://skin/playlists/tvshows.xsp</value></variable>
	<variable name="HomeYogaContent"><value>plugin://script.canvas.helper/yoga/</value></variable>
	<variable name="HomeSongsContent"><value>special://skin/playlists/songs.xsp</value></variable>


	<!-- Icons -->
	<variable name="LogoIcon"><value>special://xbmc/media/vendor_icon.png</value></variable>
	<variable name="HomeIcon"><value>1080p/icons/home.png</value></variable>
	<variable name="MoviesIcon"><value>1080p/icons/movies.png</value></variable>
	<variable name="TVShowsIcon"><value>1080p/icons/tvshows.png</value></variable>
	<variable name="YogaIcon"><value>1080p/icons/yoga.png</value></variable>
	<variable name="MusicIcon"><value>1080p/icons/music.png</value></variable>
	<variable name="PicturesIcon"><value>1080p/icons/pictures.png</value></variable>
	<variable name="MenuIcon"><value>1080p/icons/menu.png</value></variable>
	<variable name="SettingsIcon"><value>1080p/icons/settings.png</value></variable>
	<variable name="QuitIcon"><value>1080p/icons/exit.png</value></variable>
	<variable name="ShutdownIcon"><value>1080p/icons/shutdown.png</value></variable>
	<variable name="UpdateLibrariesIcon"><value>1080p/icons/refresh.png</value></variable>
	<variable name="ReloadHomeIcon"><value>1080p/icons/reload.png</value></variable>
	<variable name="AddonsIcon"><value>1080p/icons/box.png</value></variable>
	<variable name="FileManagerIcon"><value>1080p/icons/folder.png</value></variable>
	<variable name="SystemInfoIcon"><value>1080p/icons/systeminfo.png</value></variable>



	<!-- Track -->
	<variable name="HomeDetailsTrack">
		<!-- Recently added music -->
		<value condition="$EXP[IsHomeRecentlyAddedMusicActive]">Track $NUMBER[$INFO[Container(104).ListItem.Property(Track)]]</value>
		<!-- Music -->
		<value condition="$EXP[IsHomeMusicActive]">Track $NUMBER[$INFO[Container(141).ListItem.Property(Track)]]</value>
	</variable>

	<!-- Genre -->
	<variable name="HomeDetailsGenre">

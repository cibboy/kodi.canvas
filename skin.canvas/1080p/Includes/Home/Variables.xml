		<value condition="$EXP[IsHomeRecentlyAddedMusicActive]">$INFO[Container(104).ListItem.Artist]</value>
		<!-- Music -->
		<value condition="$EXP[IsHomeMusicActive]">$INFO[Container(141).ListItem.Artist]</value>

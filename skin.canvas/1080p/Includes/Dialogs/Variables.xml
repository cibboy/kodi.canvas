<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Button background texture color diffuse to allow fade when focused but focus is not on its list -->
	<variable name="FileBrowserOptionButtonColor">
		<value condition="Control.HasFocus(451)">BACKGROUND_INVERSE_OPAQUE90</value>
		<value condition="!Control.HasFocus(451)">BACKGROUND_INVERSE_OPAQUE50</value>
	</variable>


	<!-- Constants -->
	<constant name="HEIGHT_DIALOG_LIMITED_LIST">510</constant>

	<constant name="HEIGHT_NOTIFICATION">140</constant>
	<constant name="WIDTH_NOTIFICATION">480</constant>
	<constant name="WIDTH_NOTIFICATION_BACKGROUND_MID">340</constant>	<!-- WIDTH_NOTIFICATION - (70 * 2) -->
	<constant name="SIZE_NOTIFICATION_ICON">80</constant>
	<constant name="PADDING_NOTIFICATION_CONTENT">30</constant>
	<constant name="PADDING_NOTIFICATION_CONTENT_AFTER_ICON">125</constant>	<!-- PADDING_NOTIFICATION_CONTENT + SIZE_NOTIFICATION_ICON + 15 -->

	<constant name="SIZE_KEY">110</constant>
	<constant name="WIDTH_KEY_DOUBLE">190</constant>	<!-- (SIZE_KEY * 2) - abs(PADDING_KEY) -->
	<constant name="PADDING_KEY">-30</constant>
	<constant name="WIDTH_KEYPAD">530</constant>	<!-- WIDTH_KEYPAD_CONTENT + (PADDING_BASE_50P * 2) -->
	<constant name="WIDTH_KEYBOARD">1600</constant>	<!-- WIDTH_KEYBOARD_CONTENT + WIDTH_KEYPAD_CONTENT + (PADDING_BASE_50P * 2) -->
	<constant name="WIDTH_KEYPAD_CONTENT">430</constant>
	<constant name="WIDTH_KEYBOARD_CONTENT">1070</constant>
	<constant name="HEIGHT_KEYBOARD_CONTENT">470</constant>
</includes>
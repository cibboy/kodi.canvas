<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Dialogs/Variables.xml" />

	<!-- Multi-option select dialog -->
	<include name="StandardDialogSelect">
		<include content="StandardFlyoutBase">
			<param name="visible">true</param>

			<include content="StandardFlyoutStructure">
				<control type="grouplist">
					<top>OFFSET_FLYOUT_LIST</top>
					<bottom>OFFSET_FLYOUT_LIST_BOTTOM</bottom>
					<left>PADDING_BASE_50P</left>
					<right>PADDING_BASE_50P</right>

					<itemgap>GAP_FLYOUT_GROUPLIST</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<!-- Header -->
					<control type="label" id="1">
						<left>PADDING_BASE_20P</left>
						<right>PADDING_BASE_20P</right>
						<width>100%</width>
						<height>150</height>
						<font>SUBTITLE</font>
						<wrapmultiline>true</wrapmultiline>
						<label></label>
					</control>

					<!-- Multiselect list -->
					<control type="list" id="3">
						<itemgap>GAP_FLYOUT_GROUPLIST</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<height>HEIGHT_FLYOUT_DIALOG_LIST</height>

						<!-- Close dialog on left, right, by simulating a click on OK (necessary for multiselects) -->
						<onleft>SendClick(5)</onleft>
						<onright>SendClick(5)</onright>

						<focusedlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<!-- Fake button selection -->
							<control type="image">
								<height>HEIGHT_BUTTON_DEFAULT</height>
								<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
							</control>

							<!-- Content -->
							<include content="SettingsOptionContentWithSelection">
								<param name="selectionmark_color">FOREGROUND_ACCENT_ALT</param>
								<param name="is_selected">ListItem.IsSelected</param>
								<param name="text_color">FOREGROUND_INVERSE</param>
								<param name="text_color_selected">FOREGROUND_ACCENT_ALT</param>
								<param name="text_scroll">true</param>
							</include>
						</focusedlayout>

						<itemlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<include content="SettingsOptionContentWithSelection">
								<param name="is_selected">ListItem.IsSelected</param>
								<param name="text_scroll">false</param>
							</include>
						</itemlayout>
					</control>

					<!-- Single selection list -->
					<control type="list" id="6">
						<itemgap>GAP_FLYOUT_GROUPLIST</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<height>HEIGHT_FLYOUT_DIALOG_LIST</height>

						<onright>Close</onright>

						<focusedlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<!-- Fake button selection -->
							<control type="image">
								<height>HEIGHT_BUTTON_DEFAULT</height>
								<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
							</control>
							<!-- Content -->
							<include content="SettingsOptionContentWithIcon">
								<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
								<param name="icon_color">FOREGROUND_INVERSE</param>
								<param name="icon_type_circle">true</param>
								<param name="icon">$INFO[ListItem.Icon]</param>
								<param name="text_color">FOREGROUND_INVERSE</param>
								<param name="text_color_selected">FOREGROUND_ACCENT_ALT</param>
								<param name="text">[CAPITALIZE]$INFO[ListItem.Label][/CAPITALIZE]</param>
								<param name="single_line">true</param>
								<param name="scroll">true</param>
							</include>
						</focusedlayout>

						<itemlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<include content="SettingsOptionContentWithIcon">
								<param name="icon_type_circle">true</param>
								<param name="icon">$INFO[ListItem.Icon]</param>
								<param name="text">[CAPITALIZE]$INFO[ListItem.Label][/CAPITALIZE]</param>
								<param name="single_line">true</param>
								<param name="scroll">false</param>
							</include>
						</itemlayout>
					</control>

					<!-- Padding -->
					<control type="label" id="999">
						<height>PADDING_BASE</height>
					</control>

					<!-- Ok/Get more -->
					<control type="button" id="5">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
					<!-- Cancel -->
					<control type="button" id="7">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
					<!-- Add/Get more -->
					<control type="button" id="8">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
				</control>
			</include>
		</include>
	</include>

	<!-- Confirmation dialog -->
	<include name="StandardDialogConfirm">
		<include content="StandardFlyoutBase">
			<param name="visible">true</param>

			<include content="StandardFlyoutStructure">
				<control type="grouplist">
					<top>OFFSET_FLYOUT_LIST</top>
					<bottom>OFFSET_FLYOUT_LIST_BOTTOM</bottom>
					<left>PADDING_BASE_50P</left>
					<right>PADDING_BASE_50P</right>

					<itemgap>GAP_FLYOUT_GROUPLIST</itemgap>
					<usecontrolcoords>true</usecontrolcoords>

					<control type="label" id="1">
						<left>PADDING_BASE_20P</left>
						<right>PADDING_BASE_20P</right>
						<width>100%</width>
						<height>150</height>
						<font>SUBTITLE</font>
						<wrapmultiline>true</wrapmultiline>
						<label></label>
					</control>
					<!-- Message -->
					<control type="textbox" id="9">
						<visible>!String.IsEmpty(Control.GetLabel(9))</visible>
						<width>100%</width>
						<height>100</height>
						<left>PADDING_BASE_20P</left>
						<right>PADDING_BASE_20P</right>
						<font>BODY</font>
						<textcolor>FOREGROUND_DARK</textcolor>
						<autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
					</control>

					<!-- Padding -->
					<control type="label">
						<height>PADDING_BASE</height>
					</control>

					<!-- Yes/Ok -->
					<control type="button" id="11">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
					<!-- No -->
					<control type="button" id="10">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
					<!-- Future -->
					<control type="button" id="12">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
				</control>
			</include>
		</include>
	</include>

	<!-- Color picker (not used outside settings?) -->
	<include name="StandardDialogColorPicker"></include>

	<!-- Dialog context menu -->
	<include name="StandardDialogContextMenu">
		<include content="StandardFlyoutBase">
			<param name="visible">true</param>

			<include content="StandardFlyoutStructure">
				<control type="grouplist" id="996">
					<top>OFFSET_FLYOUT_LIST</top>
					<bottom>OFFSET_FLYOUT_LIST_BOTTOM</bottom>
					<left>PADDING_BASE_50P</left>
					<right>PADDING_BASE_50P</right>

					<itemgap>GAP_FLYOUT_GROUPLIST</itemgap>
					<onleft>Close</onleft>

					<control type="button" id="1000">
						<width>100%</width>
						<height>HEIGHT_FLYOUT_BUTTON</height>
					</control>
				</control>
			</include>
		</include>
	</include>

	<!-- Multi-option select dialog -->

	<!-- Flyout menu -->
	<include name="StandardFlyoutBase">
		<param name="visible">false</param>
		<param name="show_clock">true</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>

				<!-- Darkening layer (with fade) -->
				<control type="group">
					<visible>$PARAM[visible]</visible>
					<include content="DarkeningLayer" />
				</control>

				<!-- Flyout background -->
				<include content="StandardFlyoutStructure">
					<param name="visible">$PARAM[visible]</param>

					<control type="image">
						<width>100%</width>
						<height>100%</height>
						<texture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_DIALOG">1080p/controls/button.png</texture>
					</control>
					<control type="image">
						<width>100%</width>
						<height>100%</height>
						<texture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND" diffuse="1080p/diffuse/box.png" flipy="true" flipx="true">1080p/diffuse/background.png</texture>
						<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
						<aspectratio scalediffuse="true">scale</aspectratio>
					</control>
				</include>

				<!-- Actual content -->
				<nested />

				<!-- Clock (no animation) -->
				<control type="group">
					<visible>$PARAM[show_clock]</visible>
					<include content="ShowHideFadeAnimation" />

					<include content="TopBar">
						<param name="show_background">false</param>
					</include>
				</control>
			</control>
		</definition>
	</include>
	<!-- Flyout menu structure (needs a separate include because <nested /> too deep is not supported -.-) -->
	<include name="StandardFlyoutStructure">
		<param name="visible">false</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<!-- Slide in from the side -->
				<include content="ShowHideFadeSlideHorizontalAnimation">
					<param name="slide_amount">300</param>
					<param name="speed">ANIMATION_MID</param>
				</include>

				<width>600</width>
				<right>PADDING_MULT_30</right>
				<top>PADDING_MULT_30</top>
				<bottom>PADDING_MULT_30</bottom>

				<!-- Content -->
				<nested />
			</control>
		</definition>
	</include>

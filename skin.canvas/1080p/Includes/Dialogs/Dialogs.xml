<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Dialogs/Variables.xml" />
	<include file="Includes/Dialogs/Expressions.xml" />

	<!-- Keyboard/keypad button -->
	<include name="KeyboardButtonSingle">
		<param name="id"></param>
		<param name="label"></param>
		<param name="onup"></param>
		<param name="ondown"></param>

		<definition>
			<control type="button" id="$PARAM[id]">
				<include content="FocusZoomAnimation">
					<param name="reference_id">$PARAM[id]</param>
				</include>

				<width>SIZE_KEY</width>
				<height>SIZE_KEY</height>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<align>center</align>
				<texturenofocus colordiffuse="BACKGROUND_OPAQUE20" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
				<label>$PARAM[label]</label>

				<onup>SetFocus($PARAM[onup])</onup>
				<ondown>SetFocus($PARAM[ondown])</ondown>
			</control>
		</definition>
	</include>
	<include name="KeyboardButtonCustom">
		<param name="visible">true</param>
		<param name="id"></param>
		<param name="type">button</param>
		<param name="width">WIDTH_KEY_DOUBLE</param>
		<param name="focus_amount">110</param>
		<param name="label"></param>
		<param name="icon"></param>
		<param name="icon_left">75</param>	<!-- (WIDTH_KEY_DOUBLE / 2) - (40 / 2) -->
		<param name="selected"></param>
		<param name="onup"></param>
		<param name="ondown"></param>
		<param name="onclick"></param>

		<definition>
			<control type="$PARAM[type]" id="$PARAM[id]">
				<visible>$PARAM[visible]</visible>
				<include content="FocusZoomAnimation">
					<param name="reference_id">$PARAM[id]</param>
					<param name="amount">$PARAM[focus_amount]</param>
				</include>

				<width>$PARAM[width]</width>
				<height>SIZE_KEY</height>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<selected>$PARAM[selected]</selected>
				<align>center</align>
				<label>$PARAM[label]</label>
				<texturenofocus colordiffuse="BACKGROUND_OPAQUE20" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
				<textureradioonfocus colordiffuse="FG_ACCENT_ALT">$PARAM[icon]</textureradioonfocus>
				<textureradioonnofocus colordiffuse="$VAR[ColorsAccentForeground]">$PARAM[icon]</textureradioonnofocus>
				<textureradioondisabled colordiffuse="$VAR[ColorsAccentForeground]">$PARAM[icon]</textureradioondisabled>
				<textureradioofffocus colordiffuse="FOREGROUND_INVERSE">$PARAM[icon]</textureradioofffocus>
				<textureradiooffnofocus colordiffuse="FOREGROUND_OPAQUE75">$PARAM[icon]</textureradiooffnofocus>
				<textureradiooffdisabled colordiffuse="FOREGROUND_OPAQUE35">$PARAM[icon]</textureradiooffdisabled>
				<radiowidth>40</radiowidth>
				<radioheight>40</radioheight>
				<radioposx>$PARAM[icon_left]l</radioposx>

				<onup>SetFocus($PARAM[onup])</onup>
				<ondown>SetFocus($PARAM[ondown])</ondown>
				<onclick>$PARAM[onclick]</onclick>
			</control>
		</definition>
	</include>


	<!-- Flyout menu background (for non-integrated version) -->
	<include name="StandardFlyoutBackground">
		<param name="visible">true</param>
		<param name="animation_show_condition">WindowOpen</param>
		<param name="animation_hide_condition">WindowClose</param>

		<definition>
			<!-- Darkening layer (with fade) -->
			<include content="DarkeningLayer">
				<param name="visible">$PARAM[visible]</param>
			</include>

			<!-- Actual background -->
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<animation type="$PARAM[animation_show_condition]">
					<effect type="slide" start="WIDTH_BACKGROUND_SPLIT_NARROW,0" end="0,0" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>
				<animation type="$PARAM[animation_hide_condition]" condition="$PARAM[close_animation]">
					<effect type="slide" start="0,0" end="WIDTH_BACKGROUND_SPLIT_NARROW,0" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>

				<right>0</right>
				<top>0</top>
				<bottom>0</bottom>
				<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>

				<!-- Background with shadow -->
				<control type="image">
					<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
					<height>100%</height>
					<texture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_DIALOG">1080p/controls/button.png</texture>
				</control>
				<!-- Border -->
				<control type="image">
					<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
					<height>100%</height>
					<texture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="FOREGROUND_OPAQUE5">1080p/diffuse/square-outline.png</texture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
				</control>
			</control>

			<!-- Clock (no animation) -->
			<control type="group">
				<visible>$PARAM[visible]</visible>

				<include content="TopBar">
					<param name="show_background">false</param>
				</include>
			</control>
		</definition>
	</include>

	<!-- Dialog main container -->
	<include name="DialogContainer">
		<param name="visible">true</param>
		<param name="close_animation">false</param>
		<param name="animation_show_condition">WindowOpen</param>
		<param name="animation_hide_condition">WindowClose</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<animation type="$PARAM[animation_show_condition]">
					<effect type="slide" start="WIDTH_BACKGROUND_SPLIT_NARROW,0" end="0,0" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>
				<animation type="$PARAM[animation_hide_condition]" condition="$PARAM[close_animation]">
					<effect type="slide" start="0,0" end="WIDTH_BACKGROUND_SPLIT_NARROW,0" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>

				<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
				<height>SCREEN_HEIGHT</height>
				<right>0</right>

				<!-- Content -->
				<nested />
			</control>
		</definition>
	</include>
	<!-- Dialog structure (needs a separate include because <nested /> too deep is not supported -.-) -->
	<include name="DialogContainerContent">
		<definition>
			<!-- List with title -->
			<control type="group">
				<top>PADDING_BASE_80P</top>
				<bottom>PADDING_BASE_80P</bottom>
				<left>PADDING_SETTINGS_NARROW_SIDE</left>
				<right>PADDING_SETTINGS_NARROW_SIDE</right>

				<!-- Content -->
				<nested />
			</control>
		</definition>
	</include>
	<!-- Standard dialog header -->
	<include name="StandardDialogHeader">
		<param name="id">1</param>

		<definition>
			<control type="label" id="$PARAM[id]">
				<width>560</width>
				<top>PADDING_BASE_30P</top>
				<height>FONT_SIZE_TITLE3</height>
				<right>PADDING_SETTINGS_TITLE</right>
				<left>PADDING_SETTINGS_TITLE</left>
				<font>TITLE3</font>
				<label></label>
			</control>
		</definition>
	</include>


	<!-- Dialog picture info layout -->
	<include name="DialogPictureInfoItemLayout">
		<definition>
			<control type="group">
				<right>0</right>
				<left>0</left>

				<!-- Label -->
				<control type="label">
					<height>FONT_SIZE_BODY</height>
					<font>CAPTION_STRONG</font>
					<textcolor>FOREGROUND</textcolor>
					<label>$INFO[ListItem.Label]</label>
				</control>
				<!-- Value -->
				<control type="label">
					<top>FONT_SIZE_BODY</top>
					<height>FONT_SIZE_BODY</height>
					<haspath>true</haspath>
					<font>CAPTION</font>
					<textcolor>FOREGROUND</textcolor>
					<label>$INFO[ListItem.Label2]</label>
					<haspath>true</haspath>
				</control>
			</control>
		</definition>
	</include>


	<!--
		Action button for info dialog. When unfocused it's just an icon, when focused it
		has a background and text.

		It's a workaround: can't use a group because we need autowidth from the button,
		but the button control is not flexible enough to include an icon (togglebutton
		doesn't support autowidth -.-).
		
		So we use a sequence of controls, most images, assign an id based on the selected
		button's id so navigation inside the grouplist works as expected and use negative
		<left> values (together with <usecontrolcoords> to true in grouplist) as to
		pack/overlap controls as needed.
	-->
	<include name="DialogInfoActionButton">
		<param name="id"></param>
		<param name="icon"></param>
		<param name="label"></param>
		<param name="onclick"></param>
		<param name="visible">true</param>

		<definition>
			<!-- Icon when button is not focused -->
			<control type="group" id="90$PARAM[id]">
				<visible>!Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_ICON_UNFOCUSED</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<!-- Background -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</height>
					<texture colordiffuse="FOREGROUND_OPAQUE20">1080p/diffuse/circle.png</texture>
				</control>
				<!-- Icon -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
					<texture colordiffuse="FOREGROUND_OPAQUE90">$PARAM[icon]</texture>
				</control>
			</control>

			<!-- Left part of the button (with space for icon) when focused -->
			<control type="image" id="91$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_START</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/round-button-extended-start.png</texture>
			</control>
			<!-- Icon when focused -->
			<control type="image" id="92$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<left>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED</left>
				<top>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP</top>
				<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
				<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
				<texture colordiffuse="BACKGROUND_OPAQUE75">$PARAM[icon]</texture>
			</control>
			<!-- Actual button (with autowidth text) -->
			<control type="button" id="$PARAM[id]">
				<visible>$PARAM[visible]</visible>
				<width>auto</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/round-button-middle.png</texturefocus>
				<textcolor>FOREGROUND_OPAQUE90</textcolor>
				<font>BODY2_STRONG</font>
				<focusedcolor>BACKGROUND_OPAQUE75</focusedcolor>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<label>$PARAM[label]</label>
				<onclick>$PARAM[onclick]</onclick>
			</control>
			<!-- Right part of the button when focused -->
			<control type="image" id="93$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_END</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="$VAR[ColorsAccentForeground]" flipx="true">1080p/controls/round-button-start.png</texture>
			</control>
		</definition>
	</include>


	<!-- Notification -->
	<include name="Notification">
		<param name="icon"></param>
		<param name="icon_fallback">1080p/icons/info.png</param>
		<param name="title"></param>
		<param name="message"></param>

		<definition>
			<control type="group">
				<animation type="WindowOpen"><effect type="slide" start="0,PADDING_BASE" end="0,0" time="ANIMATION_SLOW" tween="back" easing="out" reversible="true" /></animation>
				<animation type="WindowClose"><effect type="slide" start="0,0" end="0,PADDING_BASE" time="ANIMATION_SLOW" tween="back" easing="in" reversible="true" /></animation>

				<right>PADDING_BASE_80P</right>
				<bottom>PADDING_BASE_80P</bottom>
				<height>HEIGHT_NOTIFICATION</height>
				<width>WIDTH_NOTIFICATION</width>

				<!-- Background -->
				<control type="image">
					<width>70</width>
					<height>HEIGHT_NOTIFICATION</height>
					<texture colordiffuse="BACKGROUND_NOTIFICATION">1080p/controls/notification-start.png</texture>
				</control>
				<control type="image">
					<left>70</left>
					<width>WIDTH_NOTIFICATION_BACKGROUND_MID</width>
					<height>HEIGHT_NOTIFICATION</height>
					<texture colordiffuse="BACKGROUND_NOTIFICATION">1080p/controls/notification-middle.png</texture>
				</control>
				<control type="image">
					<right>0</right>
					<width>70</width>
					<height>HEIGHT_NOTIFICATION</height>
					<texture flipx="true" colordiffuse="BACKGROUND_NOTIFICATION">1080p/controls/notification-start.png</texture>
				</control>

				<!-- Icon -->
				<control type="image">
					<centertop>50%</centertop>
					<left>PADDING_NOTIFICATION_CONTENT</left>
					<width>SIZE_NOTIFICATION_ICON</width>
					<height>SIZE_NOTIFICATION_ICON</height>
					<texture fallback="$PARAM[icon_fallback]" diffuse="1080p/diffuse/circle.png">$PARAM[icon]</texture>
				</control>

				<!-- Title -->
				<control type="label">
					<top>PADDING_BASE_30P</top>
					<left>PADDING_NOTIFICATION_CONTENT_AFTER_ICON</left>
					<right>PADDING_NOTIFICATION_CONTENT</right>
					<height>FONT_SIZE_BODY</height>
					<font>BODY_STRONG</font>
					<label>$PARAM[title]</label>
				</control>
				<!-- Message -->
				<control type="label">
					<bottom>PADDING_BASE_50P</bottom>
					<left>PADDING_NOTIFICATION_CONTENT_AFTER_ICON</left>
					<right>PADDING_NOTIFICATION_CONTENT</right>
					<height>FONT_SIZE_CAPTION2</height>
					<font>CAPTION2</font>
					<label>$PARAM[message]</label>
				</control>
				
				<!-- Additional custom content -->
				<nested />
			</control>
		</definition>
	</include>
</includes>
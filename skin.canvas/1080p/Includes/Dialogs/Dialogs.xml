	<!-- Keyboard/keypad button -->
	<include name="KeyboardButtonSingle">
		<param name="id"></param>
		<param name="label"></param>
		<param name="onup"></param>
		<param name="ondown"></param>

		<definition>
			<control type="button" id="$PARAM[id]">
				<include content="FocusZoomAnimation">
					<param name="reference_id">$PARAM[id]</param>
				</include>

				<width>SIZE_KEY</width>
				<height>SIZE_KEY</height>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<align>center</align>
				<texturenofocus colordiffuse="BACKGROUND_OPAQUE20" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
				<label>$PARAM[label]</label>

				<onup>SetFocus($PARAM[onup])</onup>
				<ondown>SetFocus($PARAM[ondown])</ondown>
			</control>
		</definition>
	</include>
	<include name="KeyboardButtonCustom">
		<param name="visible">true</param>
		<param name="id"></param>
		<param name="type">button</param>
		<param name="width">WIDTH_KEY_DOUBLE</param>
		<param name="focus_amount">110</param>
		<param name="label"></param>
		<param name="icon"></param>
		<param name="icon_left">75</param>	<!-- (WIDTH_KEY_DOUBLE / 2) - (40 / 2) -->
		<param name="selected"></param>
		<param name="onup"></param>
		<param name="ondown"></param>
		<param name="onclick"></param>

		<definition>
			<control type="$PARAM[type]" id="$PARAM[id]">
				<visible>$PARAM[visible]</visible>
				<include content="FocusZoomAnimation">
					<param name="reference_id">$PARAM[id]</param>
					<param name="amount">$PARAM[focus_amount]</param>
				</include>

				<width>$PARAM[width]</width>
				<height>SIZE_KEY</height>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<selected>$PARAM[selected]</selected>
				<align>center</align>
				<label>$PARAM[label]</label>
				<texturenofocus colordiffuse="BACKGROUND_OPAQUE20" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texturenofocus>
				<textureradioonfocus colordiffuse="FOREGROUND_ACCENT_ALT">$PARAM[icon]</textureradioonfocus>
				<textureradioonnofocus colordiffuse="FOREGROUND_ACCENT">$PARAM[icon]</textureradioonnofocus>
				<textureradioondisabled colordiffuse="FOREGROUND_ACCENT">$PARAM[icon]</textureradioondisabled>
				<textureradioofffocus colordiffuse="FOREGROUND_INVERSE">$PARAM[icon]</textureradioofffocus>
				<textureradiooffnofocus colordiffuse="FOREGROUND_OPAQUE75">$PARAM[icon]</textureradiooffnofocus>
				<textureradiooffdisabled colordiffuse="FOREGROUND_OPAQUE35">$PARAM[icon]</textureradiooffdisabled>
				<radiowidth>40</radiowidth>
				<radioheight>40</radioheight>
				<radioposx>$PARAM[icon_left]l</radioposx>

				<onup>SetFocus($PARAM[onup])</onup>
				<ondown>SetFocus($PARAM[ondown])</ondown>
				<onclick>$PARAM[onclick]</onclick>
			</control>
		</definition>
	</include>

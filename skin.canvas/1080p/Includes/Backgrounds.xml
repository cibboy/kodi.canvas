<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Full screen background with quadrant blur -->
	<include name="BackgroundQuadrantBlur">
		<param name="visible">true</param>
		<param name="art"></param>
		<param name="show_art">true</param>
		<param name="blur"></param>
		<param name="blur_mode_squareoffset">false</param>
		<param name="fadetime">ANIMATION_CRAWL</param>
		<param name="art_fadetime">ANIMATION_SLOW</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">$PARAM[fadetime]</param>
				</include>

				<!-- Background blur quadrants -->
				<control type="group">
					<!-- Left -->
					<control type="group">
						<!-- Top (videos first, the music) -->
						<control type="image">
							<visible>!$PARAM[blur_mode_squareoffset]</visible>
							<width>67%</width>
							<height>67%</height>
							<right>67%</right>
							<bottom>33%</bottom>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="true" flipy="false">$PARAM[blur]</texture>
						</control>
						<control type="image">
							<visible>$PARAM[blur_mode_squareoffset]</visible>
							<width>75%</width>
							<height>67%</height>
							<right>25%</right>
							<bottom>33%</bottom>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="true" flipy="false">$PARAM[blur]</texture>
						</control>
						<!-- Bottom (videos first, the music) -->
						<control type="image">
							<visible>!$PARAM[blur_mode_squareoffset]</visible>
							<width>67%</width>
							<height>67%</height>
							<right>67%</right>
							<top>67%</top>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="true" flipy="true">$PARAM[blur]</texture>
						</control>
						<control type="image">
							<visible>$PARAM[blur_mode_squareoffset]</visible>
							<width>75%</width>
							<height>67%</height>
							<right>25%</right>
							<top>67%</top>
							<fadetime>ANIMATION_CRAWL</fadetime>
							<texture flipx="true" flipy="true">$PARAM[blur]</texture>
						</control>
					</control>
					<!-- Right -->
					<control type="group">
						<!-- Top (videos first, the music) -->
						<control type="image">
							<visible>!$PARAM[blur_mode_squareoffset]</visible>
							<width>67%</width>
							<height>67%</height>
							<left>33%</left>
							<bottom>33%</bottom>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="false" flipy="false">$PARAM[blur]</texture>
						</control>
						<control type="image">
							<visible>$PARAM[blur_mode_squareoffset]</visible>
							<width>75%</width>
							<height>67%</height>
							<left>75%</left>
							<bottom>33%</bottom>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="false" flipy="false">$PARAM[blur]</texture>
						</control>
						<!-- Bottom (videos first, the music) -->
						<control type="image">
							<visible>!$PARAM[blur_mode_squareoffset]</visible>
							<width>67%</width>
							<height>67%</height>
							<left>33%</left>
							<top>67%</top>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="false" flipy="true">$PARAM[blur]</texture>
						</control>
						<control type="image">
							<visible>$PARAM[blur_mode_squareoffset]</visible>
							<width>75%</width>
							<height>67%</height>
							<left>75%</left>
							<top>67%</top>
							<fadetime>$PARAM[fadetime]</fadetime>
							<texture flipx="false" flipy="true">$PARAM[blur]</texture>
						</control>
					</control>
					<!-- Darkening overlay -->
					<control type="image">
						<width>100%</width>
						<height>100%</height>
						<fadetime>$PARAM[fadetime]</fadetime>
						<texture colordiffuse="BACKGROUND_OPAQUE50" diffuse="1080p/diffuse/background.png">diffuse.png</texture>
					</control>
				</control>

				<!-- Art -->
				<control type="image">
					<visible>$PARAM[show_art]</visible>
					<include content="ShowHideFadeAnimation">
						<param name="speed">$PARAM[fadetime]</param>
					</include>

					<width>67%</width>
					<height>67%</height>
					<top>0</top>
					<right>0</right>
					<fadetime>$PARAM[art_fadetime]</fadetime>
					<texture diffuse="1080p/diffuse/fanart.png" background="true">$PARAM[art]</texture>
					<aspectratio align="right">keep</aspectratio>
				</control>
			</control>
		</definition>
	</include>

	<!-- Full screen background with direct blur -->
	<include name="BackgroundSingleBlur">
		<param name="visible">true</param>
		<param name="blur"></param>
		<param name="fadetime">ANIMATION_CRAWL</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">$PARAM[fadetime]</param>
				</include>

				<!-- Blur -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<fadetime>$PARAM[fadetime]</fadetime>
					<texture>$PARAM[blur]</texture>
				</control>

				<!-- Darkening overlay -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<fadetime>$PARAM[fadetime]</fadetime>
					<texture colordiffuse="BACKGROUND_OPAQUE10" diffuse="1080p/diffuse/background.png">diffuse.png</texture>
				</control>
			</control>
		</definition>
	</include>

	<!-- Full screen darkening layer -->
	<include name="DarkeningLayer">
		<param name="visible">true</param>
		<param name="colordiffuse">BACKGROUND_OPAQUE50</param>
		<param name="fade_speed">ANIMATION_SLOW</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>

		<definition>
			<control type="image">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">$PARAM[fade_speed]</param>
					<param name="visible_condition">$PARAM[visible_condition]</param>
					<param name="hidden_condition">$PARAM[hidden_condition]</param>
				</include>

				<width>100%</width>
				<height>100%</height>
				<fadetime>$PARAM[fade_speed]</fadetime>
				<texture colordiffuse="$PARAM[colordiffuse]">diffuse.png</texture>
			</control>
		</definition>
	</include>
</includes>
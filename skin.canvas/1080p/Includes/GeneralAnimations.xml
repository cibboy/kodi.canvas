<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Slide vertically and fade on visible/hidden -->
	<include name="ShowHideFadeSlideVerticalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>
		<param name="delay_in">0</param>
		<param name="delay_out">0</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>

		<definition>
			<animation type="$PARAM[visible_condition]">
				<effect type="slide" start="0,$PARAM[slide_amount]" end="0,0" time="$PARAM[speed]" delay="$PARAM[delay_in]" tween="circle" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" delay="$PARAM[delay_in]" tween="circle" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_condition]">
				<effect type="slide" start="0,0" end="0,$PARAM[slide_amount]" time="$PARAM[speed]" delay="$PARAM[delay_out]" tween="circle" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" delay="$PARAM[delay_out]" tween="circle" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Slide horizontally and fade on visible/hidden -->
	<include name="ShowHideFadeSlideHorizontalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>
		<param name="delay_in">0</param>
		<param name="delay_out">0</param>
		<param name="visible_type">Visible</param>
		<param name="hidden_type">Hidden</param>
		<param name="visible_condition">true</param>
		<param name="hidden_condition">true</param>
		<param name="tween">circle</param>

		<definition>
			<animation type="$PARAM[visible_type]" condition="$PARAM[visible_condition]">
				<effect type="slide" start="$PARAM[slide_amount],0" end="0,0" time="$PARAM[speed]" delay="$PARAM[delay_in]" tween="$PARAM[tween]" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" delay="$PARAM[delay_in]" tween="circle" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_type]" condition="$PARAM[hidden_condition]">
				<effect type="slide" start="0,0" end="$PARAM[slide_amount],0" time="$PARAM[speed]" delay="$PARAM[delay_out]" tween="$PARAM[tween]" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" delay="$PARAM[delay_out]" tween="circle" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Fade on visible/hidden -->
	<include name="ShowHideFadeAnimation">
		<param name="speed">ANIMATION_SLOW</param>
		<param name="delay_in">0</param>
		<param name="delay_out">0</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>
		<param name="tween">circle</param>

		<definition>
			<animation type="$PARAM[visible_condition]">
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" delay="$PARAM[delay_in]" tween="$PARAM[tween]" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_condition]">
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" delay="$PARAM[delay_out]" tween="$PARAM[tween]" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Zoom on focus -->
	<include name="FocusZoomAnimation">
		<param name="speed">ANIMATION_FAST</param>
		<param name="amount">110</param>
		<param name="reference_id"></param>

		<definition>
			<animation type="Focus"><effect type="zoom" start="100" end="$PARAM[amount]" time="$PARAM[speed]" tween="circle" easing="out" center="auto" condition="!Control.HasFocus($PARAM[reference_id])"/></animation>
			<animation type="Unfocus"><effect type="zoom" start="$PARAM[amount]" end="100" time="$PARAM[speed]" tween="circle" easing="out" center="auto" condition="Control.HasFocus($PARAM[reference_id])"/></animation>
		</definition>
	</include>

	<!-- Immediately hide with transparency (useful for faking a non visible control without really hiding it, i.e. lists that need reload) -->
	<include name="HideWithTransparency">
		<param name="condition_visible">true</param>
		<param name="condition_hidden">false</param>

		<definition>
			<animation effect="fade" start="100" end="100" time="0" tween="linear" easing="inout" condition="$PARAM[condition_visible]" reversible="false">Conditional</animation>
			<animation effect="fade" start="0" end="0" time="0" tween="linear" easing="inout" condition="$PARAM[condition_hidden]" reversible="false">Conditional</animation>
		</definition>
	</include>
</includes>
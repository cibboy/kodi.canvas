<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Slide vertically and fade on visible/hidden -->
	<include name="ShowHideFadeSlideVerticalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>

		<definition>
			<animation type="$PARAM[visible_condition]">
				<effect type="slide" start="0,$PARAM[slide_amount]" end="0,0" time="$PARAM[speed]" tween="circle" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_condition]">
				<effect type="slide" start="0,0" end="0,$PARAM[slide_amount]" time="$PARAM[speed]" tween="circle" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Slide horizontally and fade on visible/hidden -->
	<include name="ShowHideFadeSlideHorizontalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>

		<definition>
			<animation type="$PARAM[visible_condition]">
				<effect type="slide" start="$PARAM[slide_amount],0" end="0,0" time="$PARAM[speed]" tween="circle" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_condition]">
				<effect type="slide" start="0,0" end="$PARAM[slide_amount],0" time="$PARAM[speed]" tween="circle" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Fade on visible/hidden -->
	<include name="ShowHideFadeAnimation">
		<param name="speed">ANIMATION_SLOW</param>
		<param name="visible_condition">Visible</param>
		<param name="hidden_condition">Hidden</param>

		<definition>
			<animation type="$PARAM[visible_condition]">
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
			<animation type="$PARAM[hidden_condition]">
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="circle" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Fade on focus -->
	<include name="FocusFadeAnimation">
		<param name="speed">ANIMATION_SLOW</param>
		<param name="start">100</param>
		<param name="end">85</param>
		<param name="reference_id"></param>

		<definition>
			<animation effect="fade" start="$PARAM[start]" end="$PARAM[end]" time="$PARAM[speed]" tween="circle" easing="out" condition="!Control.HasFocus($PARAM[reference_id])">Conditional</animation>
			<animation effect="fade" start="$PARAM[end]" end="$PARAM[start]" time="$PARAM[speed]" tween="circle" easing="out" condition="Control.HasFocus($PARAM[reference_id])">Conditional</animation>
		</definition>
	</include>

	<!-- Zoom on focus -->
	<include name="FocusZoomAnimation">
		<param name="speed">ANIMATION_FAST</param>
		<param name="amount">110</param>
		<param name="reference_id"></param>

		<definition>
			<animation type="Focus"><effect type="zoom" start="100" end="$PARAM[amount]" time="$PARAM[speed]" tween="circle" easing="out" center="auto" condition="!Control.HasFocus($PARAM[reference_id])"/></animation>
			<animation type="Unfocus"><effect type="zoom" start="$PARAM[amount]" end="100" time="$PARAM[speed]" tween="circle" easing="out" center="auto" condition="Control.HasFocus($PARAM[reference_id])"/></animation>
		</definition>
	</include>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Slide vertically and fade on visible/hidden -->
	<include name="ShowHideFadeSlideVerticalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>

		<definition>
			<animation type="Visible">
				<effect type="slide" start="0,$PARAM[slide_amount]" end="0,0" time="$PARAM[speed]" tween="cubic" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
			<animation type="Hidden">
				<effect type="slide" start="0,0" end="0,$PARAM[slide_amount]" time="$PARAM[speed]" tween="cubic" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Slide horizontally and fade on visible/hidden -->
	<include name="ShowHideFadeSlideHorizontalAnimation">
		<param name="slide_amount">100</param>
		<param name="speed">ANIMATION_SLOW</param>

		<definition>
			<animation type="Visible">
				<effect type="slide" start="$PARAM[slide_amount],0" end="0,0" time="$PARAM[speed]" tween="cubic" easing="out" />
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
			<animation type="Hidden">
				<effect type="slide" start="0,0" end="$PARAM[slide_amount],0" time="$PARAM[speed]" tween="cubic" easing="out" />
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
		</definition>
	</include>

	<!-- Fade on visible/hidden -->
	<include name="ShowHideFadeAnimation">
		<param name="speed">ANIMATION_SLOW</param>

		<definition>
			<animation type="Visible">
				<effect type="fade" start="0" end="100" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
			<animation type="Hidden">
				<effect type="fade" start="100" end="0" time="$PARAM[speed]" tween="cubic" easing="out" />
			</animation>
		</definition>
	</include>
</includes>
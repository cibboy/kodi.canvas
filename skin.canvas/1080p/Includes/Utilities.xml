<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Center UI based on 16:9 aspect ratio -->
	<include name="Center169AspectRatio">
		<control type="group">
			<!-- Centering -->
			<width>SCREEN_WIDTH</width>
			<height>SCREEN_HEIGHT</height>
			<centertop>50%</centertop>
			<centerleft>50%</centerleft>

			<!-- Actual content -->
			<nested />

		</control>

		<!--
			Black bars. Kodi does not provide a way to hide
			overflow, so we need to compensate with black bars
			on 4 sides for potential overflow.
		-->
		<!-- Bottom -->
		<control type="group">
			<width>100%</width>
			<height>SCREEN_HEIGHT_HALF</height>
			<top>50%</top>

			<control type="image">
				<width>100%</width>
				<height>SCREEN_HEIGHT_HALF</height>
				<top>SCREEN_HEIGHT_HALF</top>
				<texture colordiffuse="FF000000">diffuse.png</texture>
			</control>
		</control>
		<!-- Top -->
		<control type="group">
			<width>100%</width>
			<height>SCREEN_HEIGHT_HALF</height>
			<bottom>50%</bottom>

			<control type="image">
				<width>100%</width>
				<height>SCREEN_HEIGHT_HALF</height>
				<top>SCREEN_HEIGHT_HALF_NEG</top>
				<texture colordiffuse="FF000000">diffuse.png</texture>
			</control>
		</control>
		<!-- Left -->
		<control type="group">
			<width>SCREEN_WIDTH_HALF</width>
			<height>100%</height>
			<right>50%</right>

			<control type="image">
				<width>SCREEN_WIDTH_HALF</width>
				<height>100%</height>
				<left>SCREEN_WIDTH_HALF_NEG</left>
				<texture colordiffuse="FF000000">diffuse.png</texture>
			</control>
		</control>
		<!-- Right -->
		<control type="group">
			<width>SCREEN_WIDTH_HALF</width>
			<height>100%</height>
			<left>50%</left>

			<control type="image">
				<width>SCREEN_WIDTH_HALF</width>
				<height>100%</height>
				<left>SCREEN_WIDTH_HALF</left>
				<texture colordiffuse="FF000000">diffuse.png</texture>
			</control>
		</control>
	</include>

	<!-- Redirector to video exit window when video is playing -->
	<include name="VideoPlayingRedirect">
		<onload condition="Player.HasVideo">ActivateWindow(1150)</onload>
	</include>


	<!-- Is info dialog visible? -->
	<expression name="IsDialogVideoInfoVisible">Window.IsActive(12003) | Window.IsActive(DialogVideoInfo.xml)</expression>
	<expression name="IsDialogMusicInfoVisible">Window.IsActive(12001) | Window.IsActive(DialogMusicInfo.xml)</expression>
	<expression name="IsDialogPictureInfoVisible">Window.IsActive(10139) | Window.IsActive(DialogPictureInfo.xml)</expression>
	<expression name="IsDialogInfoVisible">$EXP[IsDialogVideoInfoVisible] | $EXP[IsDialogMusicInfoVisible] | $EXP[IsDialogPictureInfoVisible]</expression>
	
	<!-- Is player visible? -->
	<expression name="IsMusicPlayerVisible">Window.IsActive(12006)</expression>
	<expression name="IsVideoPlayerVisible">Window.IsActive(12005) | Window.IsActive(1150)</expression>
	<expression name="IsPlayerVisible">$EXP[IsMusicPlayerVisible] | $EXP[IsVideoPlayerVisible]</expression>


	<!-- Is TV show theme playing? -->
	<expression name="IsTvShowThemePlaying">String.IsEqual(Window(home).Property(Player.PlayingTheme),true)</expression>


	<!-- List icon name translation -->
	<variable name="ListIconTranslated">
		<value condition="String.IsEqual(ListItem.Icon,DefaultHardDisk.png)">1080p/icons/drive.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFolder.png)">1080p/icons/folder.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultNetwork.png)">1080p/icons/network.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFile.png)">1080p/icons/file.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFolderBack.png)">1080p/icons/up.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddSource.png)">1080p/icons/add.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddon.png)">1080p/icons/addon.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsInstalled.png)">1080p/icons/addon-installed.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsUpdates.png)">1080p/icons/addon-update.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsRepo.png)">1080p/icons/addon-repo.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsZip.png)">1080p/icons/addon-zip.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsSearch.png)">1080p/icons/addon-search.png</value>
		<value>$INFO[ListItem.Icon]</value>
	</variable>
	<!-- List icon name translation (simplified) -->
	<variable name="ListIconTranslatedSimplified">
		<value condition="String.IsEqual(ListItem.Icon,DefaultHardDisk.png)">1080p/icons/drive.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFolder.png)">1080p/icons/folder.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultNetwork.png)">1080p/icons/network.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFile.png)">1080p/icons/file.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultFolderBack.png)">1080p/icons/up.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddSource.png)">1080p/icons/add.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddon.png)">1080p/icons/addon.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsInstalled.png)">1080p/icons/addon-installed.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsUpdates.png)">1080p/icons/addon-update.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsRepo.png)">1080p/icons/addon-repo.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsZip.png)">1080p/icons/addon-zip.png</value>
		<value condition="String.IsEqual(ListItem.Icon,DefaultAddonsSearch.png)">1080p/icons/addon-search.png</value>
		<value condition="ListItem.IsFolder">1080p/icons/folder.png</value>
		<value>1080p/icons/file.png</value>
	</variable>
	<!-- Is the translated icon a native icon? -->
	<expression name="IsListIconTranslatedNative">
		String.IsEqual(ListItem.Icon,DefaultHardDisk.png) |
		String.IsEqual(ListItem.Icon,DefaultFolder.png) |
		String.IsEqual(ListItem.Icon,DefaultNetwork.png) |
		String.IsEqual(ListItem.Icon,DefaultFile.png) |
		String.IsEqual(ListItem.Icon,DefaultFolderBack.png) |
		String.IsEqual(ListItem.Icon,DefaultAddSource.png) |
		String.IsEqual(ListItem.Icon,DefaultAddon.png) |
		String.IsEqual(ListItem.Icon,DefaultAddonsInstalled.png) |
		String.IsEqual(ListItem.Icon,DefaultAddonsUpdates.png) |
		String.IsEqual(ListItem.Icon,DefaultAddonsRepo.png) |
		String.IsEqual(ListItem.Icon,DefaultAddonsZip.png) |
		String.IsEqual(ListItem.Icon,DefaultAddonsSearch.png)
	</expression>
</includes>
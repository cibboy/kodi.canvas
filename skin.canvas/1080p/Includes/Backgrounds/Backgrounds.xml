<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/Backgrounds/Variables.xml" />
	<include file="Includes/Backgrounds/Expressions.xml" />

	<!-- Full screen background -->
	<include name="Background">
		<param name="show_art">true</param>

		<definition>
			<control type="group">
				<!-- Background blur -->
				<!-- Quadrants (all types, except music) -->
				<control type="group">
					<visible>!$EXP[IsBackgroundMusic]</visible>

					<!-- Left -->
					<control type="group">
						<!-- Top -->
						<control type="image">
							<width>67%</width>
							<height>67%</height>
							<right>67%</right>
							<fadetime>ANIMATION_CRAWL</fadetime>
							<texture fallback="1080p/fallback/bg.png" flipx="true" flipy="false">$VAR[BlurArt]</texture>
						</control>
						<!-- Bottom -->
						<control type="image">
							<width>67%</width>
							<height>67%</height>
							<right>67%</right>
							<top>67%</top>
							<fadetime>ANIMATION_CRAWL</fadetime>
							<texture fallback="1080p/fallback/bg.png" flipx="true" flipy="true">$VAR[BlurArt]</texture>
						</control>
					</control>
					<!-- Right -->
					<control type="group">
						<!-- Top -->
						<control type="image">
							<width>67%</width>
							<height>67%</height>
							<right>0</right>
							<fadetime>ANIMATION_CRAWL</fadetime>
							<texture fallback="1080p/fallback/bg.png" flipx="false" flipy="false">$VAR[BlurArt]</texture>
						</control>
						<!-- Bottom -->
						<control type="image">
							<width>67%</width>
							<height>67%</height>
							<right>0</right>
							<top>67%</top>
							<fadetime>ANIMATION_CRAWL</fadetime>
							<texture fallback="1080p/fallback/bg.png" flipx="false" flipy="true">$VAR[BlurArt]</texture>
						</control>
					</control>
					<!-- Darkening overlay -->
					<control type="image">
						<width>100%</width>
						<height>100%</height>
						<fadetime>ANIMATION_CRAWL</fadetime>
						<texture colordiffuse="FF000000" diffuse="1080p/diffuse/background.png">diffuse.png</texture>
					</control>
				</control>
				<!-- Full size (music) -->
				<control type="image">
					<visible>$EXP[IsBackgroundMusic]</visible>
					
					<width>100%</width>
					<height>100%</height>
					<fadetime>ANIMATION_CRAWL</fadetime>
					<texture fallback="1080p/fallback/bg.png" diffuse="1080p/diffuse/background_full.png">$VAR[BlurArt]</texture>
				</control>

				<!-- Art -->
				<control type="image">
					<visible>$PARAM[show_art]</visible>
					<include content="ShowHideFadeAnimation" />

					<width>67%</width>
					<height>67%</height>
					<top>0</top>
					<right>0</right>
					<fadetime>ANIMATION_SLOW</fadetime>
					<texture diffuse="1080p/diffuse/fanart.png" background="true">$VAR[BackgroundArt]</texture>
					<aspectratio align="right">keep</aspectratio>
				</control>
			</control>
		</definition>
	</include>

	<!-- Full screen darkening layer -->
	<include name="DarkeningLayer">
		<param name="visible">true</param>
		<param name="fade_speed">ANIMATION_SLOW</param>

		<definition>
			<control type="image">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">ANIMATION_MID</param>
				</include>

				<width>100%</width>
				<height>100%</height>
				<fadetime>$PARAM[fade_speed]</fadetime>
				<texture colordiffuse="BACKGROUND_OPAQUE50">diffuse.png</texture>
			</control>
		</definition>
	</include>

	<!-- Legibility darkening layer -->
	<include name="LegibilityDarkeningLayer">
		<param name="visible">true</param>
		<param name="fade_speed">ANIMATION_SLOW</param>

		<definition>
			<control type="image">
				<visible>$PARAM[visible]</visible>
				<include content="ShowHideFadeAnimation">
					<param name="speed">ANIMATION_MID</param>
				</include>

				<width>100%</width>
				<height>100%</height>
				<fadetime>$PARAM[fade_speed]</fadetime>
				<texture colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/legibility.png</texture>
			</control>
		</definition>
	</include>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Top-right art -->
	<variable name="BackgroundArt">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode)">$INFO[Container(101).ListItem.Art(tvshow.fanart)]</value>
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Art(fanart)]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Art(tvshow.fanart)]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Art(fanart)]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Art(album.thumb)]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),111)">$INFO[Container(111).ListItem.Art(fanart)]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),121)">$INFO[Container(121).ListItem.Art(fanart)]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),131) + !String.IsEmpty(Container(131).ListItem.Art(fanart))">$INFO[Container(131).ListItem.Art(fanart)]</value>
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),131)">$INFO[Container(131).ListItem.Art(tvshow.fanart)]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),141)">$INFO[Container(141).ListItem.Art(album.thumb)]</value>
	</variable>

	<!-- Full screen background blur -->
	<variable name="BlurArt">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),101) + String.IsEqual(Container(101).ListItem.Property(ItemType),episode)">$INFO[Container(101).ListItem.Property(BlurArt.TvShow)]</value>
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Property(BlurArt)]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Property(BlurArt.TvShow)]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Property(BlurArt)]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Property(BlurArt)]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),111)">$INFO[Container(111).ListItem.Property(BlurArt)]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),121)">$INFO[Container(121).ListItem.Property(BlurArt)]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),131) + !String.IsEmpty(Container(131).ListItem.Property(BlurArt.Season))">$INFO[Container(131).ListItem.Property(BlurArt.Season)]</value>
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),131)">$INFO[Container(131).ListItem.Property(BlurArt.TvShow)]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),141)">$INFO[Container(141).ListItem.Property(BlurArt)]</value>
	</variable>
</includes>
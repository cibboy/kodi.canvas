<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is TV show/season? -->
	<expression name="IsTVShowOrSeason">
		[String.IsEqual(Window.Property(ActiveListId),121)] |
		[String.IsEqual(Window.Property(ActiveListId),131)]
	</expression>

	<!-- Is video? -->
	<expression name="IsVideo">
		[String.IsEqual(Window.Property(ActiveListId),101)] |
		[String.IsEqual(Window.Property(ActiveListId),102)] |
		[String.IsEqual(Window.Property(ActiveListId),103)] |
		[String.IsEqual(Window.Property(ActiveListId),111)]
	</expression>
</includes>
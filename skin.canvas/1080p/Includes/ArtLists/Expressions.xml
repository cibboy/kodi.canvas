<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is TV show/season? -->
	<expression name="IsTVShowOrSeason">
		[String.IsEqual(ListItem.Property(ItemType),tvshow)] |
		[String.IsEqual(ListItem.Property(ItemType),season)]
	</expression>

	<!-- Is video? -->
	<expression name="IsVideo">
		[String.IsEqual(ListItem.Property(ItemType),movie)] |
		[String.IsEqual(ListItem.Property(ItemType),episode)]
	</expression>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is TV show/season? -->
	<expression name="IsTVShowOrSeason">
		[String.IsEqual(Window.Property(Home.ActiveListId),121)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),131)]
	</expression>

	<!-- Is video? -->
	<expression name="IsVideo">
		[String.IsEqual(Window.Property(Home.ActiveListId),101)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),102)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),103)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),111)]
	</expression>
</includes>
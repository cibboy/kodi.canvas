		<param name="content"></param>
		<param name="art"></param>
		<param name="fallback">1080p/fallback/music.png</param>
		<param name="isloading">false</param>
		<param name="info"></param>
		<param name="highlight_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="foreground_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="onclick">noop</param>
		<param name="onfocus">noop</param>
		<param name="onchange">noop</param>
		<param name="onback">noop</param>
		<param name="onup">noop</param>
		<param name="ondown">noop</param>
		<param name="onleft">noop</param>
		<param name="onright">noop</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<height>HEIGHT_ALBUM_STRIP_CONTAINER</height>

				<control type="label">
					<font>BODY_STRONG</font>
					<textcolor>$PARAM[foreground_color]</textcolor>
					<label>$PARAM[label]</label>
				</control>

				<control type="fixedlist" id="$PARAM[id]">
					<top>PADDING_MULT_120</top>
					<autoscroll>false</autoscroll>
					<orientation>horizontal</orientation>
					<include content="HomeOnClickMedia" />
					<onclick>$PARAM[onclick]</onclick>
					<onfocus>$PARAM[onfocus]</onfocus>
					<onback>$PARAM[onback]</onback>
					<onleft>$PARAM[onleft]</onleft>
					<onright>$PARAM[onright]</onright>
					<onup>$PARAM[onup]</onup>
					<ondown>$PARAM[ondown]</ondown>

					<itemlayout width="WIDTH_ALBUM_STRIP_ITEM_CONTAINER" height="HEIGHT_ALBUM_STRIP_CONTAINER">
						<control type="group">
							<!-- Album item -->
							<include content="ArtListsAlbum">
								<param name="art">$PARAM[art]</param>
								<param name="fallback">$PARAM[fallback]</param>
								<param name="isloading">$PARAM[isloading]</param>
							</include>

							<!-- Info -->
							<control type="group">
								<visible>!$PARAM[isloading]</visible>
								<top>OFFSET_ALBUM_INFO</top>


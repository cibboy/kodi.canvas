					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<control type="image">
					<visible>$PARAM[isloading]</visible>
					<width>WIDTH_ALBUM</width>
					<height>HEIGHT_ALBUM</height>

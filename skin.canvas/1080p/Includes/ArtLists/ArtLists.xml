	<!-- Horizontal strip of landscape elements, with label and optional logo -->
	<include name="LandscapeStrip">
		<param name="visible">true</param>
		<param name="id"></param>
		<param name="label"></param>
		<param name="content"></param>
		<param name="art"></param>
		<param name="fallback">1080p/fallback/landscape.png</param>
		<param name="isloading">false</param>
		<param name="showinfo">false</param>
		<param name="highlight_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="foreground_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="onclick">noop</param>
		<param name="onfocus">noop</param>
		<param name="onchange">noop</param>
		<param name="onback">noop</param>
		<param name="onup">noop</param>
		<param name="ondown">noop</param>
		<param name="onleft">noop</param>
		<param name="onright">noop</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>
				<height>HEIGHT_LANDSCAPE_STRIP_CONTAINER</height>

				<control type="label">
					<font>BODY_STRONG</font>
					<textcolor>$PARAM[foreground_color]</textcolor>
					<label>$PARAM[label]</label>
				</control>

				<control type="fixedlist" id="$PARAM[id]">
					<top>PADDING_MULT_120</top>
					<autoscroll>false</autoscroll>
					<orientation>horizontal</orientation>
					<include content="HomeOnClickMedia" />
					<onclick>$PARAM[onclick]</onclick>
					<onfocus>$PARAM[onfocus]</onfocus>
					<onback>$PARAM[onback]</onback>
					<onleft>$PARAM[onleft]</onleft>
					<onright>$PARAM[onright]</onright>
					<onup>$PARAM[onup]</onup>
					<ondown>$PARAM[ondown]</ondown>

					<itemlayout width="WIDTH_LANDSCAPE_STRIP_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE">
						<control type="group">
							<!-- Landscape item -->
							<include content="ArtListsLandscape">
								<param name="art">$PARAM[art]</param>
								<param name="fallback">$PARAM[fallback]</param>
								<param name="isloading">$PARAM[isloading]</param>
							</include>

							<!-- Info -->
							<control type="group">
								<visible>$PARAM[showinfo] + !$PARAM[isloading]</visible>
								<top>OFFSET_LANDSCAPE_STRIP_INFO</top>

								<control type="group">
									<top>SIZE_ITEM_SHADOW_ART</top>
									<left>SIZE_ITEM_SHADOW_ART</left>
									<right>SIZE_ITEM_SHADOW_ART</right>
									<width>100%</width>

									<!-- Title/clearlogo -->
									<control type="group">
										<left>PADDING_MULT_10</left>
										<right>PADDING_MULT_10</right>
										<height>HEIGHT_CLEARLOGO_SMALL</height>

										<!-- Title (if clearlogo not available) -->
										<control type="label">
											<visible>String.IsEmpty(ListItem.Property(Clearlogo.Small))</visible>

											<width>auto</width>
											<height>HEIGHT_CLEARLOGO_SMALL</height>
											<font>BODY_STRONG</font>
											<aligny>center</aligny>
											<textcolor>$PARAM[highlight_color]</textcolor>
											<label>$INFO[ListItem.TVShowTitle]</label>
										</control>
										<!-- Clearlogo -->
										<control type="image">
											<visible>!String.IsEmpty(ListItem.Property(Clearlogo.Small))</visible>

											<width>WIDTH_CLEARLOGO_SMALL</width>
											<height>HEIGHT_CLEARLOGO_SMALL</height>
											<fadetime>ANIMATION_FAST</fadetime>
											<texture background="true">$INFO[ListItem.Property(Clearlogo.Small)]</texture>
											<aspectratio align="left">keep</aspectratio>
										</control>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<right>-8</right>
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<width>100</width>
										<font>CAPTION2</font>
										<textcolor>$PARAM[foreground_color]</textcolor>
										<label>S$INFO[ListItem.Season]·E$INFO[ListItem.Episode]</label>
									</control>
									<!-- Episode title -->
									<control type="label">
										<left>PADDING_MULT_10</left>
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<width>340</width>
										<font>CAPTION2</font>
										<textcolor>$PARAM[foreground_color]</textcolor>
										<label>$INFO[ListItem.Title]</label>
									</control>
								</control>
							</control>
						</control>
					</itemlayout>
					
					<focusedlayout width="WIDTH_LANDSCAPE_STRIP_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE">
						<control type="group">
							<!-- Onchange action -->
							<control type="button">
								<include content="Hidden" />
								<onfocus>$PARAM[onchange]</onfocus>
							</control>

							<!-- Landscape item -->
							<include content="ArtListsLandscape">
								<param name="art">$PARAM[art]</param>
								<param name="fallback">$PARAM[fallback]</param>
								<param name="isloading">$PARAM[isloading]</param>
							</include>

							<!-- Info -->
							<control type="group">
								<visible>$PARAM[showinfo] + !$PARAM[isloading]</visible>
								<top>OFFSET_LANDSCAPE_STRIP_INFO</top>

								<control type="group">
									<top>SIZE_ITEM_SHADOW_ART</top>
									<left>SIZE_ITEM_SHADOW_ART</left>
									<right>SIZE_ITEM_SHADOW_ART</right>
									<width>100%</width>

									<!-- Title/clearlogo -->
									<control type="group">
										<left>PADDING_MULT_10</left>
										<right>PADDING_MULT_10</right>
										<height>HEIGHT_CLEARLOGO_SMALL</height>

										<!-- Title (if clearlogo not available) -->
										<control type="label">
											<visible>String.IsEmpty(ListItem.Property(Clearlogo.Small))</visible>

											<width>auto</width>
											<height>HEIGHT_CLEARLOGO_SMALL</height>
											<font>BODY_STRONG</font>
											<aligny>center</aligny>
											<textcolor>$PARAM[highlight_color]</textcolor>
											<label>$INFO[ListItem.TVShowTitle]</label>
										</control>
										<!-- Clearlogo -->
										<control type="image">
											<visible>!String.IsEmpty(ListItem.Property(Clearlogo.Small))</visible>

											<width>WIDTH_CLEARLOGO_SMALL</width>
											<height>HEIGHT_CLEARLOGO_SMALL</height>
											<fadetime>ANIMATION_FAST</fadetime>
											<texture background="true">$INFO[ListItem.Property(Clearlogo.Small)]</texture>
											<aspectratio align="left">keep</aspectratio>
										</control>
									</control>
									<!-- Season/episode -->
									<control type="label">
										<right>-8</right>
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<width>100</width>
										<font>CAPTION2</font>
										<textcolor>$PARAM[foreground_color]</textcolor>
										<label>S$INFO[ListItem.Season]·E$INFO[ListItem.Episode]</label>
									</control>
									<!-- Episode title -->
									<control type="label">
										<left>PADDING_MULT_10</left>
										<top>HEIGHT_CLEARLOGO_SMALL</top>
										<width>340</width>
										<font>CAPTION2</font>
										<textcolor>$PARAM[foreground_color]</textcolor>
										<label>$INFO[ListItem.Title]</label>
									</control>
								</control>
							</control>
						</control>
					</focusedlayout>

					<content>$PARAM[content]</content>
				</control>
			</control>
		</definition>
	</include>


<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/ArtLists/Variables.xml" />
	<include file="Includes/ArtLists/Expressions.xml" />

	<!-- Season/episode indicator for landscape -->
	<include name="ArtListsSeasonEpisodeTag">
		<definition>
			<control type="image">
				<width>WIDTH_LANDSCAPE</width>
				<texture colordiffuse="BACKGROUND" diffuse="1080p/diffuse/landscape.png">1080p/diffuse/corner.png</texture>
				<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
				<aspectratio scalediffuse="false">scale</aspectratio>
			</control>

			<control type="label">
				<top>SIZE_ITEM_SHADOW_ART</top>
				<right>SIZE_ITEM_SHADOW_ART_DOUBLE</right>
				<left>SIZE_ITEM_SHADOW_ART_DOUBLE</left>
				<label>S$INFO[ListItem.Season]·E$INFO[ListItem.Episode]</label>
				<font>CAPTION3_STRONG</font>
				<textcolor>FOREGROUND</textcolor>
				<align>right</align>
				<aligny>center</aligny>
				<height>HEIGHT_DETAILS_INFOLINE_TAG</height>
			</control>
		</definition>
	</include>
	<!-- Watched indicator -->
	<include name="ArtListsWatchedIcon">
		<param name="offset_top"></param>
		<param name="offset_right"></param>

		<definition>
			<control type="group">
				<visible>!ListItem.IsResumable + Integer.IsGreater(ListItem.PlayCount,0)</visible>
				<centertop>$PARAM[offset_top]</centertop>
				<centerright>$PARAM[offset_right]</centerright>
				<width>SIZE_LIST_WATCHED_ICON</width>
				<height>SIZE_LIST_WATCHED_ICON</height>

				<control type="image">
					<texture colordiffuse="BACKGROUND_OPAQUE75">1080p/icons/watched-bg.png</texture>
				</control>
				<control type="image">
					<texture colordiffuse="FOREGROUND_ACCENT">1080p/icons/check.png</texture>
				</control>
			</control>
		</definition>
	</include>
	<!-- Episodes indicator -->
	<include name="ArtListsEpisodesIcon">
		<param name="offset_top"></param>
		<param name="offset_right"></param>
		<param name="text"></param>

		<definition>
			<control type="group">
				<visible>$EXP[IsArtListTvShowOrSeason] + Integer.IsEqual(ListItem.PlayCount,0)</visible>
				<centertop>$PARAM[offset_top]</centertop>
				<centerright>$PARAM[offset_right]</centerright>
				<width>SIZE_LIST_RUNNING_ICON</width>
				<height>SIZE_LIST_RUNNING_ICON</height>

				<!-- Progress icon (dark background, empty circle, progress)-->
				<control type="image">
					<texture colordiffuse="BACKGROUND_OPAQUE50">1080p/progress/circle-bg.png</texture>
				</control>
				<control type="image">
					<texture colordiffuse="FOREGROUND_ACCENT" flipy="true" flipx="true">1080p/progress/circle-$INFO[ListItem.Property(WatchedEpisodePercent)].png</texture>
				</control>

				<!-- Number of episodes -->
				<control type="label">
					<centertop>48%</centertop>
					<centerright>50%</centerright>
					<width>auto</width>
					<height>FONT_SIZE_LABEL</height>
					<aligny>center</aligny>
					<align>center</align>
					<font>LABEL</font>
					<textcolor>HIGHLIGHT</textcolor>
					<label>$INFO[ListItem.Property(UnWatchedEpisodes)]</label>
				</control>
			</control>
		</definition>
	</include>
	<!-- Progress indicator -->
	<include name="ArtListsProgress">
		<param name="width"></param>
		<param name="offset_top"></param>
		<param name="offset_left"></param>

		<definition>
			<!-- Progress bar -->
			<control type="progress">
				<visible>$EXP[IsArtListVideo] + Integer.IsGreater(ListItem.PercentPlayed)</visible>
				<width>$PARAM[width]</width>
				<centertop>$PARAM[offset_top]</centertop>
				<centerleft>$PARAM[offset_left]</centerleft>
				<info>ListItem.PercentPlayed</info>
			</control>
		</definition>
	</include>
	

	<!-- Poster -->
	<include name="ArtListsPoster">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/poster.png</param>
		<param name="width">WIDTH_POSTER</param>
		<param name="height">HEIGHT_POSTER</param>
		<param name="darken">false</param>
		<param name="show_decorators">true</param>
		<param name="offset_top_icon">OFFSET_TOP_POSTER_STRIP_ICON</param>
		<param name="offset_right_icon">OFFSET_RIGHT_POSTER_STRIP_ICON</param>
		<param name="offset_top_progress">OFFSET_TOP_POSTER_PROGRESS</param>
		<param name="offset_left_progress">OFFSET_LEFT_POSTER_PROGRESS</param>

		<definition>
			<control type="group">
				<include content="FocusZoomAnimation" />
				<width>$PARAM[width]</width>
				<height>$PARAM[height]</height>

				<!-- Loading placeholder -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/poster.png">$PARAM[fallback]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Poster image -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture fallback="$PARAM[fallback]" background="true" diffuse="1080p/diffuse/poster.png">$PARAM[art]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Dark overlay, if requested -->
				<control type="image">
					<visible>$PARAM[darken]</visible>
					<animation type="Hidden"><effect type="fade" start="100" end="0" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>
					<animation type="Visible"><effect type="fade" start="0" end="100" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>

					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/poster.png" colordiffuse="BACKGROUND_OPAQUE50">diffuse.png</texture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				
				<!-- Decorators -->
				<control type="group">
					<visible>$PARAM[show_decorators]</visible>

					<!-- Watched indicator -->
					<include content="ArtListsWatchedIcon">
						<param name="offset_top">$PARAM[offset_top_icon]</param>
						<param name="offset_right">$PARAM[offset_right_icon]</param>
					</include>
					<!-- Episodes indicator -->
					<include content="ArtListsEpisodesIcon">
						<param name="offset_top">$PARAM[offset_top_icon]</param>
						<param name="offset_right">$PARAM[offset_right_icon]</param>
					</include>
					<!-- Progress -->
					<include content="ArtListsProgress">
						<param name="width">WIDTH_POSTER_PROGRESS</param>
						<param name="offset_top">$PARAM[offset_top_progress]</param>
						<param name="offset_left">$PARAM[offset_left_progress]</param>
					</include>
				</control>
			</control>
		</definition>
	</include>
	<!-- Landscape -->
	<include name="ArtListsLandscape">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/landscape.png</param>
		<param name="width">WIDTH_LANDSCAPE</param>
		<param name="height">HEIGHT_LANDSCAPE</param>
		<param name="darken">false</param>
		<param name="show_decorators">true</param>

		<definition>
			<control type="group">
				<include content="FocusZoomAnimation" />
				<width>$PARAM[width]</width>
				<height>$PARAM[height]</height>

				<!-- Loading placeholder -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/landscape.png">$PARAM[fallback]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Landscape image -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture fallback="$PARAM[fallback]" background="true" diffuse="1080p/diffuse/landscape.png">$PARAM[art]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Dark overlay, if requested -->
				<control type="image">
					<visible>$PARAM[darken]</visible>
					<animation type="Hidden"><effect type="fade" start="100" end="0" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>
					<animation type="Visible"><effect type="fade" start="0" end="100" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>

					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/landscape.png" colordiffuse="BACKGROUND_OPAQUE50">diffuse.png</texture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>

				<!-- Decorators -->
				<control type="group">
					<visible>$PARAM[show_decorators]</visible>

					<!-- Season/episode -->
					<include content="ArtListsSeasonEpisodeTag">
						<!--<param name="offset_top">OFFSET_TOP_LANDSCAPE_STRIP_ICON</param>
						<param name="offset_right">OFFSET_RIGHT_LANDSCAPE_STRIP_ICON</param>-->
					</include>
					<!-- Watched indicator -->
					<include content="ArtListsWatchedIcon">
						<param name="offset_top">OFFSET_TOP_LANDSCAPE_STRIP_ICON</param>
						<param name="offset_right">OFFSET_RIGHT_LANDSCAPE_STRIP_ICON</param>
					</include>
					<!-- Progress -->
					<include content="ArtListsProgress">
						<param name="width">WIDTH_LANDSCAPE_PROGRESS</param>
						<param name="offset_top">OFFSET_TOP_LANDSCAPE_PROGRESS</param>
						<param name="offset_left">OFFSET_LEFT_LANDSCAPE_PROGRESS</param>
					</include>
				</control>
			</control>
		</definition>
	</include>
	<!-- Album -->
	<include name="ArtListsAlbum">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/music.png</param>
		<param name="width">WIDTH_ALBUM</param>
		<param name="height">HEIGHT_ALBUM</param>
		<param name="darken">false</param>

		<definition>
			<control type="group">
				<include content="FocusZoomAnimation" />
				<width>$PARAM[width]</width>
				<height>$PARAM[height]</height>

				<!-- Loading placeholder -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/square.png">$PARAM[fallback]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Album image -->
				<control type="image">
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture fallback="$PARAM[fallback]" background="true" diffuse="1080p/diffuse/square.png">$PARAM[art]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Dark overlay, if requested -->
				<control type="image">
					<visible>$PARAM[darken]</visible>
					<animation type="Hidden"><effect type="fade" start="100" end="0" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>
					<animation type="Visible"><effect type="fade" start="0" end="100" time="ANIMATION_SLOW" tween="cubic" easing="out" /></animation>
					
					<width>$PARAM[width]</width>
					<height>$PARAM[height]</height>
					<texture diffuse="1080p/diffuse/square.png" colordiffuse="BACKGROUND_OPAQUE50">diffuse.png</texture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
			</control>
		</definition>
	</include>
	<!-- Person -->
	<include name="ArtListsPerson">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/person.png</param>

		<definition>
			<control type="group">
				<include content="FocusZoomAnimation">
					<param name="amount">115</param>
				</include>

				<!-- Loading placeholder -->
				<control type="image">
					<width>WIDTH_PERSON</width>
					<height>HEIGHT_PERSON</height>
					<texture diffuse="1080p/diffuse/circle.png">$PARAM[fallback]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_CIRCLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-circle.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_CIRCLE_DOUBLE</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<!-- Person image -->
				<control type="image">
					<width>WIDTH_PERSON</width>
					<height>HEIGHT_PERSON</height>
					<texture fallback="$PARAM[fallback]" background="true" diffuse="1080p/diffuse/circle.png">$PARAM[art]</texture>
					<bordertexture border="SIZE_ITEM_SHADOW_CIRCLE" colordiffuse="BACKGROUND_OPAQUE50">1080p/diffuse/shadow-circle.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_CIRCLE_DOUBLE</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
			</control>
		</definition>
	</include>

	<!-- Landscape info (clearlogo or TV show title) -->
	<include name="ArtListsLandscapeInfo">
		<param name="textcolor">HIGHLIGHT_CONTRAST_LIGHT</param>

		<definition>
			<control type="group">
				<top>HEIGHT_LANDSCAPE</top>
				<left>SIZE_ITEM_SHADOW_ART_DOUBLE</left>
				<right>SIZE_ITEM_SHADOW_ART_DOUBLE</right>
				<height>HEIGHT_LANDSCAPE_CLEARLOGO</height>

				<!-- Title (if clearlogo not available) -->
				<control type="label">
					<visible>String.IsEmpty(ListItem.Art(tvshow.clearlogo))</visible>
					<width>auto</width>
					<font>BODY2_STRONG</font>
					<textcolor>$PARAM[textcolor]</textcolor>
					<label>$INFO[ListItem.TVShowTitle]</label>
				</control>
				<!-- Clearlogo -->
				<control type="image">
					<width>WIDTH_LANDSCAPE_CLEARLOGO</width>
					<height>HEIGHT_LANDSCAPE_CLEARLOGO</height>
					<texture background="true">$INFO[ListItem.Art(tvshow.clearlogo)]</texture>
					<aspectratio align="left">keep</aspectratio>
				</control>
			</control>
		</definition>
	</include>
	<!-- Album info -->
	<include name="ArtListsAlbumInfo">
		<param name="info1"></param>
		<param name="info2"></param>
		<param name="info1_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="info2_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="scroll">false</param>

		<definition>
			<control type="group">
				<top>OFFSET_ALBUM_INFO</top>

				<control type="group">
					<top>SIZE_ITEM_SHADOW_ART</top>
					<left>SIZE_ITEM_SHADOW_ART</left>
					<right>SIZE_ITEM_SHADOW_ART</right>

					<!-- Info line 1 -->
					<control type="label">
						<width>auto</width>
						<font>CAPTION</font>
						<textcolor>$PARAM[info1_color]</textcolor>
						<label>$PARAM[info1]</label>
						<scroll>$PARAM[scroll]</scroll>
						<scrollspeed>40</scrollspeed>
					</control>
					<!-- Info line 2 -->
					<control type="label">
						<top>FONT_SIZE_BODY</top>
						<width>auto</width>
						<font>CAPTION2</font>
						<textcolor>$PARAM[info2_color]</textcolor>
						<label>$PARAM[info2]</label>
						<scroll>$PARAM[scroll]</scroll>
						<scrollspeed>40</scrollspeed>
					</control>
				</control>
			</control>
		</definition>
	</include>
	<!-- Actor info -->
	<include name="ArtListsPersonInfo">
		<param name="info1"></param>
		<param name="info2"></param>
		<param name="info1_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="info2_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="scroll">false</param>

		<definition>
			<control type="group">
				<top>OFFSET_PERSON_INFO</top>

				<control type="group">
					<top>SIZE_ITEM_SHADOW_ART</top>
					<left>SIZE_ITEM_SHADOW_ART</left>
					<right>SIZE_ITEM_SHADOW_ART</right>

					<!-- Info line 1 -->
					<control type="label">
						<width>auto</width>
						<font>CAPTION</font>
						<textcolor>$PARAM[info1_color]</textcolor>
						<label>$PARAM[info1]</label>
						<scroll>$PARAM[scroll]</scroll>
						<scrollspeed>40</scrollspeed>
					</control>
					<!-- Info line 2 -->
					<control type="label">
						<top>FONT_SIZE_BODY</top>
						<width>auto</width>
						<font>CAPTION2</font>
						<textcolor>$PARAM[info2_color]</textcolor>
						<label>$PARAM[info2]</label>
						<scroll>$PARAM[scroll]</scroll>
						<scrollspeed>40</scrollspeed>
					</control>
				</control>
			</control>
		</definition>
	</include>


	<!-- Onchange button -->
	<include name="ArtListsOnChangeButton">
		<param name="get_additional_data">true</param>
		<param name="sync_501">false</param>

		<definition>
			<control type="button">
				<visible allowhiddenfocus="true">false</visible>
				<onfocus condition="$PARAM[get_additional_data] + !$EXP[IsHomeMenuMoving]">RunScript(script.canvas.helper,get_additional_media_info_from_listitem,$INFO[ListItem.DBTYPE],$INFO[ListItem.DBID],$INFO[ListItem.CurrentItem],$PARAM[sync_501])</onfocus>
			</control>
		</definition>
	</include>


	<!-- Layout for list of poster elements -->
	<include name="PosterLayout">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/poster.png</param>
		<param name="dark_unfocused">false</param>
		<param name="dark_focused">false</param>
		<param name="condition">true</param>
		<param name="get_additional_data">true</param>
		<param name="sync_501">false</param>

		<definition>
			<itemlayout width="WIDTH_POSTER_LIST_ITEM_CONTAINER" height="HEIGHT_POSTER_LIST_ITEM_CONTAINER" condition="$PARAM[condition]">
				<control type="group">
					<!-- Poster -->
					<include content="ArtListsPoster">
						<param name="art">$PARAM[art]</param>
						<param name="fallback">$PARAM[fallback]</param>
						<param name="darken">$PARAM[dark_unfocused]</param>
					</include>
				</control>
			</itemlayout>

			<focusedlayout width="WIDTH_POSTER_LIST_ITEM_CONTAINER" height="HEIGHT_POSTER_LIST_ITEM_CONTAINER" condition="$PARAM[condition]">
				<control type="group">
					<!-- Onchange action -->
					<include content="ArtListsOnChangeButton">
						<param name="get_additional_data">$PARAM[get_additional_data]</param>
						<param name="sync_501">$PARAM[sync_501]</param>
					</include>

					<!-- Poster -->
					<include content="ArtListsPoster">
						<param name="art">$PARAM[art]</param>
						<param name="fallback">$PARAM[fallback]</param>
						<param name="darken">$PARAM[dark_focused]</param>
					</include>
				</control>
			</focusedlayout>
		</definition>
	</include>
	<!-- Layout for list of landscape elements -->
	<include name="LandscapeLayout">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/landscape.png</param>
		<param name="dark_unfocused">false</param>
		<param name="dark_focused">false</param>
		<param name="condition">true</param>
		<param name="show_info">false</param>
		<param name="textcolor">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="get_additional_data">true</param>
		<param name="sync_501">false</param>

		<definition>
			<itemlayout width="WIDTH_LANDSCAPE_LIST_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE_LIST_ITEM_CONTAINER" condition="$PARAM[condition]">
				<control type="group">
					<!-- Landscape item -->
					<include content="ArtListsLandscape">
						<param name="art">$PARAM[art]</param>
						<param name="fallback">$PARAM[fallback]</param>
						<param name="darken">$PARAM[dark_unfocused]</param>
					</include>

					<!-- Clearlogo or show title -->
					<include content="ArtListsLandscapeInfo" condition="$PARAM[show_info]">
						<param name="textcolor">$PARAM[textcolor]</param>
					</include>
				</control>
			</itemlayout>
			
			<focusedlayout width="WIDTH_LANDSCAPE_LIST_ITEM_CONTAINER" height="HEIGHT_LANDSCAPE_LIST_ITEM_CONTAINER" condition="$PARAM[condition]">
				<control type="group">
					<!-- Onchange action -->
					<include content="ArtListsOnChangeButton">
						<param name="get_additional_data">$PARAM[get_additional_data]</param>
						<param name="sync_501">$PARAM[sync_501]</param>
					</include>

					<!-- Landscape item -->
					<include content="ArtListsLandscape">
						<param name="art">$PARAM[art]</param>
						<param name="fallback">$PARAM[fallback]</param>
						<param name="darken">$PARAM[dark_focused]</param>
					</include>

					<!-- Clearlogo or show title -->
					<include content="ArtListsLandscapeInfo" condition="$PARAM[show_info]">
						<param name="textcolor">$PARAM[textcolor]</param>
					</include>
				</control>
			</focusedlayout>
		</definition>
	</include>
	<!-- Layout for list of square elements -->
	<include name="AlbumLayout">
		<param name="art"></param>
		<param name="fallback">1080p/fallback/music.png</param>
		<param name="dark_unfocused">false</param>
		<param name="dark_focused">false</param>
		<param name="condition">true</param>
		<param name="info1"></param>
		<param name="info2"></param>
		<param name="info1_color">HIGHLIGHT_CONTRAST_LIGHT</param>
		<param name="info2_color">FOREGROUND_CONTRAST_LIGHT</param>
		<param name="get_additional_data">true</param>
		<param name="sync_501">false</param>

		<definition>
			<itemlayout width="WIDTH_ALBUM_LIST_ITEM_CONTAINER" height="HEIGHT_ALBUM_LIST_ITEM_CONTAINER">
				<control type="group">
					<!-- Album item -->
					<include content="ArtListsAlbum">
						<param name="art">$PARAM[art]</param>
						<param name="fallback">$PARAM[fallback]</param>

					<bordertexture border="SIZE_ITEM_SHADOW_ART_DOUBLE" colordiffuse="BACKGROUND">1080p/diffuse/shadow-art.png</bordertexture>
					<bordersize>SIZE_ITEM_SHADOW_ART</bordersize>
					<aspectratio scalediffuse="false">scale</aspectratio>

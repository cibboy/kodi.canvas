<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="TopBar">
		<param name="show_background">true</param>

		<definition>
			<control type="group">
				<height>450</height>

				<!-- Darkening -->
				<control type="image">
					<visible>$PARAM[show_background]</visible>
					<width>100%</width>
					<height>450</height>
					<fadetime>ANIMATION_SLOW</fadetime>
					<texture colordiffuse="BACKGROUND_OPAQUE90">1080p/diffuse/corner.png</texture>
				</control>

				<!-- Clocks -->
				<control type="group">
					<top>PADDING_BASE_80P</top>
					<right>PADDING_BASE</right>

					<!-- Clock -->
					<control type="label">
						<align>right</align>
						<aligny>center</aligny>
						<height>FONT_SIZE_SUBTITLE</height>
						<font>CLOCK</font>
						<textcolor>FOREGROUND_OPAQUE75</textcolor>
						<label>$INFO[System.Time]</label>
					</control>

					<!-- ETA -->
					<control type="label">
						<visible>Player.HasMedia + !$EXP[IsTvShowThemePlaying]</visible>
						<top>35</top>
						<align>right</align>
						<aligny>center</aligny>
						<height>FONT_SIZE_SUBTITLE</height>
						<font>ETACLOCK</font>
						<textcolor>FOREGROUND_OPAQUE50</textcolor>
						<label>$INFO[Player.FinishTime]</label>
					</control>
				</control>
			</control>
		</definition>
	</include>
</includes>
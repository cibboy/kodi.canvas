<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/MediaNav/Variables.xml" />
	<include file="Includes/MediaNav/Expressions.xml" />

	<!-- Background -->
	<include name="MediaNavBackground">
		<definition>
			<!-- Background (fallback/default + blur quadrants/art) -->
			<control type="image">
				<width>100%</width>
				<height>100%</height>
				<texture>1080p/fallback/bg.png</texture>
			</control>
			<include content="BackgroundQuadrantBlur">
				<param name="visible">$EXP[IsMediaNavShowingMovie] | $EXP[IsMediaNavShowingSeasons] | $EXP[IsMediaNavShowingEpisodes]</param>
				<param name="art">$VAR[MediaNavBackgroundArt]</param>
				<param name="blur">$VAR[MediaNavBlurArt]</param>
			</include>
			<!-- Background (full size blur for music albums) -->
			<include content="BackgroundSingleBlur">
				<param name="visible">$EXP[IsMediaNavShowingMusicAlbum]</param>
				<param name="blur">$VAR[MediaNavBlurArt]</param>
				<param name="fadetime">ANIMATION_CRAWL</param>
			</include>
		</definition>
	</include>

	<!-- Selection details -->
	<include name="MediaNavSelectionDetails">
		<definition>
			<include content="SelectionDetails">
				<param name="visible">$EXP[IsMediaNavShowingMovie] | $EXP[IsMediaNavShowingSeasons] | $EXP[IsMediaNavShowingEpisodes]</param>
				<param name="clearlogo">$VAR[MediaNavDetailsClearlogo]</param>
				<param name="title">$VAR[MediaNavDetailsTitle]</param>
				<param name="has_clearlogo">$EXP[HasMediaNavDetailsClearlogo]</param>
				<param name="subtitle">$VAR[MediaNavDetailsSubtitle]</param>
				<param name="has_subtitle">$EXP[HasMediaNavDetailsSubtitle]</param>
				<param name="resolution">$VAR[MediaNavDetailsResolution]</param>
				<param name="has_resolution">$EXP[HasMediaNavDetailsResolution]</param>
				<param name="hdr">$VAR[MediaNavDetailsHdr]</param>
				<param name="has_hdr">$EXP[HasMediaNavDetailsHdr]</param>
				<param name="channels">$VAR[MediaNavDetailsAudioChannels]</param>
				<param name="has_channels">$EXP[HasMediaNavDetailsAudioChannels]</param>
				<param name="year">$VAR[MediaNavDetailsYear]</param>
				<param name="has_year">$EXP[HasMediaNavDetailsYear]</param>
				<param name="episode">$VAR[MediaNavDetailsEpisode]</param>
				<param name="has_episode">$EXP[HasMediaNavDetailsEpisode]</param>
				<param name="premiered">$VAR[MediaNavDetailsPremiered]</param>
				<param name="has_premiered">$EXP[HasMediaNavDetailsPremiered]</param>
				<param name="duration">$VAR[MediaNavDetailsDuration]</param>
				<param name="has_duration">$EXP[HasMediaNavDetailsDuration]</param>
				<param name="mpaa">$VAR[MediaNavDetailsMpaa]</param>
				<param name="has_mpaa">$EXP[HasMediaNavDetailsMpaa]</param>
				<param name="status">$VAR[MediaNavDetailsStatus]</param>
				<param name="has_status">$EXP[HasMediaNavDetailsStatus]</param>
				<param name="is_watched">$EXP[IsMediaNavDetailsWatched]</param>
				<param name="is_allnew">$EXP[IsMediaNavDetailsAllNew]</param>
				<param name="episodes_remaining">$VAR[MediaNavDetailsEpisodesRemaining]</param>
				<param name="has_episodes_remaining">$EXP[HasMediaNavDetailsEpisodesRemaining]</param>
				<param name="time_remaining">$VAR[MediaNavDetailsTimeRemaining]</param>
				<param name="has_time_remaining">$EXP[HasMediaNavDetailsTimeRemaining]</param>
				<param name="percentage_watched">$VAR[MediaNavDetailsWatchedPercentage]</param>
				<param name="genre">$VAR[MediaNavDetailsGenre]</param>
				<param name="has_genre">$EXP[HasMediaNavDetailsGenre]</param>
				<param name="plot">$VAR[MediaNavDetailsSummary]</param>
				<param name="foreground_color">$VAR[MediaNavContrastTextForegroundColor]</param>
				<param name="highlight_color">$VAR[MediaNavContrastTextHighlightColor]</param>
			</include>
		</definition>
	</include>


	<!-- Action button list -->
	<include name="MediaNavActionButtons">
		<definition>
			<control type="grouplist" id="500">
				<itemgap>0</itemgap>
				<orientation>horizontal</orientation>
				<usecontrolcoords>true</usecontrolcoords>
				<defaultcontrol always="true">510</defaultcontrol>

				<!-- Moving down goes to actors (movie), season list (TV show) or episodes (season and episode) -->
				<ondown condition="$EXP[IsMediaNavShowingMovie]">SetFocus(111)</ondown>
				<ondown condition="$EXP[IsMediaNavShowingSeasons]">SetFocus(101)</ondown>
				<ondown condition="$EXP[IsMediaNavShowingEpisodes]">SetFocus(102)</ondown>

				<!-- Play -->
				<include content="MediaNavActionButton" condition="$EXP[HasMediaNavActionPlay]">
					<param name="id">510</param>
					<param name="icon">$VAR[MediaNavPlayIcon]</param>
					<param name="label">$VAR[MediaNavPlayButtonLabel]</param>
				</include>
				<!-- Resume -->
				<include content="MediaNavActionButton" condition="$EXP[HasMediaNavActionResume]">
					<param name="id">511</param>
					<param name="icon">$VAR[MediaNavResumeIcon]</param>
					<param name="label">$VAR[MediaNavResumeButtonLabel]</param>
				</include>
				<!-- Play from start -->
				<include content="MediaNavActionButton" condition="$EXP[HasMediaNavActionPlayFromStart]">
					<param name="id">512</param>
					<param name="icon">$VAR[MediaNavPlayFromStartIcon]</param>
					<param name="label">$VAR[MediaNavPlayFromStartButtonLabel]</param>
				</include>
				<!-- Mark as unwatched -->
				<include content="MediaNavActionButton" condition="$EXP[HasMediaNavActionMarkAsUnwatched]">
					<param name="id">513</param>
					<param name="icon">$VAR[MediaNavWatchedIcon]</param>
					<param name="label">$VAR[MediaNavMarkAsUnwatchedButtonLabel]</param>
				</include>
				<!-- Mark as watched -->
				<include content="MediaNavActionButton" condition="$EXP[HasMediaNavActionMarkAsWatched]">
					<param name="id">514</param>
					<param name="icon">$VAR[MediaNavUnwatchedIcon]</param>
					<param name="label">$VAR[MediaNavMarkAsWatchedButtonLabel]</param>
				</include>
				<!-- Info -->
				<include content="MediaNavActionButton">
					<param name="id">515</param>
					<param name="icon">$VAR[MediaNavInfoIcon]</param>
					<param name="label">$VAR[MediaNavInfoButtonLabel]</param>
				</include>
				<!-- More -->
				<include content="MediaNavActionButton">
					<param name="id">516</param>
					<param name="icon">$VAR[MediaNavMoreIcon]</param>
					<param name="label">$VAR[MediaNavMoreButtonLabel]</param>
				</include>
			</control>
		</definition>
	</include>

	<!--
		Action button. When unfocused it's just an icon, when focused it has a background
		and text.

		It's a workaround: can't use a group because we need autowidth from the button,
		but the button control is not flexible enough to include an icon (togglebutton
		doesn't support autowidth -.-).
		
		So we use a sequence of controls, most images, assign an id based on the selected
		button's id so navigation inside the grouplist works as expected and use negative
		<left> values (together with <usecontrolcoords> to true in grouplist) as to
		pack/overlap controls as needed.
	-->
	<include name="MediaNavActionButton">
		<param name="id"></param>
		<param name="icon"></param>
		<param name="label"></param>

		<definition>
			<!-- Icon when button is not focused -->
			<control type="group" id="$PARAM[id]0">
				<visible>!Control.HasFocus($PARAM[id])</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_ICON_UNFOCUSED</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<!-- Background -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonBackgroundColor]">1080p/diffuse/circle.png</texture>
				</control>
				<!-- Icon -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonIconColor]">$PARAM[icon]</texture>
				</control>
			</control>

			<!-- Left part of the button (with space for icon) when focused -->
			<control type="image" id="$PARAM[id]1">
				<visible>Control.HasFocus($PARAM[id])</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_START</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="FOREGROUND_ACCENT">1080p/controls/round-button-extended-start.png</texture>
			</control>
			<!-- Icon when focused -->
			<control type="image" id="$PARAM[id]2">
				<visible>Control.HasFocus($PARAM[id])</visible>
				<left>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED</left>
				<top>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP</top>
				<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
				<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
				<texture colordiffuse="BACKGROUND_OPAQUE75">$PARAM[icon]</texture>
				<onclick><!--todo--></onclick>
			</control>
			<!-- Actual button (with autowidth text) -->
			<control type="button" id="$PARAM[id]">
				<width>auto</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<texturefocus colordiffuse="FOREGROUND_ACCENT">1080p/controls/round-button-middle.png</texturefocus>
				<textcolor>$VAR[MediaNavContrastButtonIconColor]</textcolor>
				<font>BODY2_STRONG</font>
				<focusedcolor>BACKGROUND_OPAQUE75</focusedcolor>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<label>$PARAM[label]</label>
			</control>
			<!-- Right part of the button when focused -->
			<control type="image" id="$PARAM[id]3">
				<visible>Control.HasFocus($PARAM[id])</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_END</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="FOREGROUND_ACCENT" flipx="true">1080p/controls/round-button-start.png</texture>
			</control>
		</definition>
	</include>


	<!-- Season list -->
	<include name="MediaNavSeasonList">
		<definition>
			<include content="PosterStrip">
				<param name="visible">$EXP[IsMediaNavShowingSeasons]</param>
				<param name="id">101</param>
				<param name="label">Seasons</param>
				<param name="content">plugin://script.canvas.helper/seasons/?dbpath=$INFO[Container.FolderPath]&amp;listid=101</param>
				<!--<param name="content">$INFO[Container.FolderPath]</param>-->
				<param name="art">$INFO[ListItem.Art(poster)]</param>
				<param name="foreground_color">$VAR[MediaNavContrastTextForegroundColor]</param>
				<param name="highlight_color">$VAR[MediaNavContrastTextHighlightColor]</param>
				<!--<param name="onclick">ActivateWindow(Videos,$INFO[Container.FolderPath]$INFO[ListItem.Season]/,return)</param>-->
				<param name="onclick">ActivateWindow(Videos,videodb://tvshows/titles/$INFO[ListItem.Property(tvshowid)]/$INFO[ListItem.Season]/?info=type=season::tvshowid=$INFO[ListItem.Property(tvshowid)]::season=$INFO[ListItem.Season],return)</param>
				<param name="onup">SetFocus(500)</param>
				<param name="ondown">SetFocus(111)</param>
			</include>
		</definition>
	</include>

	<!-- Episode list -->
	<include name="MediaNavEpisodeList">
		<definition>
			<include content="LandscapeStrip">
				<param name="visible">$EXP[IsMediaNavShowingEpisodes]</param>
				<param name="id">102</param>
				<param name="label"></param>
				<!--<param name="content">plugin://script.canvas.helper/episodes/?id=$INFO[Window(videos).Property(ItemDetails.Id)]</param>-->
				<param name="content">$INFO[Container.FolderPath]</param>
				<param name="art">$INFO[ListItem.Art(thumb)]</param>
				<param name="foreground_color">$VAR[MediaNavContrastTextForegroundColor]</param>
				<param name="highlight_color">$VAR[MediaNavContrastTextHighlightColor]</param>
				<param name="onup">SetFocus(500)</param>
				<param name="ondown">SetFocus(111)</param>
			</include>
		</definition>
	</include>

	<!-- Actor list -->
	<include name="MediaNavActorList">
		<include content="PersonStrip">
			<param name="visible">$EXP[IsMediaNavShowingMovie] | $EXP[IsMediaNavShowingSeasons] | $EXP[IsMediaNavShowingEpisodes]</param>
			<param name="id">111</param>
			<param name="label">Cast</param>
			<param name="content">plugin://script.canvas.helper/actors/?dbpath=$INFO[Container.FolderPath]&amp;listid=111</param>
			<param name="art">$INFO[ListItem.Property(Thumbnail)]</param>
			<param name="info1">$INFO[ListItem.Property(Name)]</param>
			<param name="info2">$INFO[ListItem.Property(Role)]</param>
			<param name="foreground_color">$VAR[MediaNavContrastTextForegroundColor]</param>
			<param name="highlight_color">$VAR[MediaNavContrastTextHighlightColor]</param>
			<param name="onup">SetFocus($VAR[MediaNavActorNavigateUpId])</param>
		</include>
	</include>


	<!-- Reset list/loading status on MyVideoNav -->
	<include name="MediaNavOnClickMedia">
		<onclick>SetProperty(List.101.IsLoading,true,videos)</onclick>
		<onclick>SetProperty(List.101.HasContent,false,videos)</onclick>
		<onclick>SetProperty(List.102.IsLoading,true,videos)</onclick>
		<onclick>SetProperty(List.102.HasContent,false,videos)</onclick>
		<onclick>SetProperty(List.111.IsLoading,true,videos)</onclick>
		<onclick>SetProperty(List.111.HasContent,false,videos)</onclick>
	</include>
</includes>
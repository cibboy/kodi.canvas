<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include file="Includes/MediaNav/Variables.xml" />
	<include file="Includes/MediaNav/Expressions.xml" />
	
	<!-- Horizontal list of media items. Form factor is based on content type -->
	<include name="MediaNavItemList">
		<definition>
			<!-- Label -->
			<include content="ListLabel">
				<param name="id">500</param>
				<param name="label">$VAR[MediaNavItemListHeader]</param>
				<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
			</include>

			<!-- Media item strip -->
			<include content="ItemStrip">
				<param name="id">501</param>

				<nested />

				<height>HEIGHT_LIST_CONTAINER</height>
				<onleft condition="$EXP[HasMediaNavNavigatePreviousSeason]">ReplaceWindow(Videos,$INFO[Window(home).Property(Navigation.PreviousSeason)],1)</onleft>
				<onleft>noop</onleft>
				<onright condition="$EXP[HasMediaNavNavigateNextSeason]">ReplaceWindow(Videos,$INFO[Window(home).Property(Navigation.NextSeason)],1)</onright>
				<onright>noop</onright>
				<onback condition="$EXP[IsDetailsItemTypeSeason]">ReplaceWindow(home)</onback>
				<onfocus condition="$EXP[IsMediaNavLibraryNavigation] + !Control.IsVisible(502)">Sendclick(2)</onfocus>
				<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetFocus(502)</onfocus>
				<onfocus condition="$EXP[IsMediaNavLibraryNavigation]">SetProperty(LibraryNav,true,videos)</onfocus>

				<!-- Season layout -->
				<include content="PosterLayout">
					<param name="art">$INFO[ListItem.Art(poster)]</param>
					<param name="condition">$EXP[IsDetailsItemTypeSeason]</param>
					<param name="dark_unfocused">$EXP[IsMediaNavActionBarFocused]</param>
					<param name="listid">501</param>
				</include>
				<!-- Episode layout -->
				<include content="LandscapeLayout">
					<param name="art">$INFO[ListItem.Art(thumb)]</param>
					<param name="condition">$EXP[IsDetailsItemTypeEpisode]</param>
					<param name="dark_unfocused">$EXP[IsMediaNavActionBarFocused]</param>
					<param name="listid">501</param>
				</include>
			</include>
		</definition>
	</include>

	<!-- List of media items for when accessed from library -->
	<include name="MediaNavItemListForLibrary">
		<param name="title"></param>

		<definition>
			<control type="group">
				<visible>$EXP[IsMediaNavLibraryNavigation]</visible>

				<!-- Background (monocolor) -->
				<include content="SettingsBackground" />
				
				<control type="group">
					<animation type="Conditional" condition="$EXP[IsSettingsDialogSettingsActive] | $EXP[IsSettingsDialogMediaSourceActive]">
						<effect type="slide" end="SCREEN_WIDTH_NEG,0" time="ANIMATION_SLOW" tween="circle" easing="out" />
					</animation>

					<!-- Background (structure split) -->
					<include content="FileNavBackgroundSplit" />

					<!-- Left side (title + list) -->
					<include content="FileNavItemList">
						<param name="id">502</param>
						<param name="title">$PARAM[title]</param>
					</include>

					<!-- Right side (details when no dialog is visible) -->
					<control type="group">
						<visible>!$EXP[IsSettingsAnyDialogActive] + !Window.IsVisible(DialogPictureInfo.xml)</visible>
						<include content="ShowHideFadeSlideHorizontalAnimation">
							<param name="slide_amount">-100</param>
						</include>

						<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
						<height>SCREEN_HEIGHT</height>
						<left>WIDTH_BACKGROUND_SPLIT_WIDE</left>

						<control type="group">
							<top>PADDING_BASE_80P</top>
							<bottom>PADDING_BASE</bottom>
							<right>PADDING_SETTINGS_NARROW_SIDE</right>
							<left>PADDING_SETTINGS_NARROW_SIDE</left>

							<control type="grouplist">
								<orientation>vertical</orientation>
								<itemgap>PADDING_BASE_20P</itemgap>
								<usecontrolcoords>true</usecontrolcoords>

								<top>PADDING_BASE</top>

								<!-- Icon -->
								<control type="image">
									<visible>$EXP[IsListIconTranslatedNative]</visible>
									<centerleft>50%</centerleft>
									<width>100</width>
									<height>100</height>
									<texture fallback="1080p/icons/file.png">$VAR[ListIconTranslated]</texture>
									<aspectratio>keep</aspectratio>
								</control>
								<!-- Preview -->
								<control type="image">
									<visible>!$EXP[IsListIconTranslatedNative]</visible>
									<centerleft>50%</centerleft>
									<width>500</width>
									<height>300</height>
									<texture fallback="1080p/fallback/file.png">$VAR[ListIconTranslated]</texture>
									<aspectratio>keep</aspectratio>
								</control>

								<!-- Size -->
								<include content="FileNavInfoLabel">
									<param name="visible">!String.IsEmpty(ListItem.Size)</param>
									<param name="label">Size</param>
									<param name="value">$INFO[ListItem.Size]</param>
								</include>
								<!-- File name -->
								<include content="FileNavInfoLabel">
									<param name="visible">!String.IsEmpty(ListItem.FileName) + !String.IsEqual(ListItem.FileName,add)</param>
									<param name="label">File name</param>
									<param name="value">$INFO[ListItem.FileName]</param>
								</include>
								<!-- Folder -->
								<include content="FileNavInfoLabel">
									<param name="visible">!String.IsEmpty(ListItem.Path) + !ListItem.IsFolder</param>
									<param name="label">Folder</param>
									<param name="value">$INFO[ListItem.Path]</param>
								</include>
								<!-- Path -->
								<include content="FileNavInfoLabel">
									<param name="visible">!String.IsEmpty(ListItem.FileNameAndPath) + !String.IsEqual(ListItem.FileNameAndPath,add)</param>
									<param name="label">Full path</param>
									<param name="value">$INFO[ListItem.FileNameAndPath]</param>
									<param name="wrap">true</param>
								</include>
								<!-- Add source (special case) -->
								<include content="FileNavInfoLabel">
									<param name="visible">String.IsEqual(ListItem.FileNameAndPath,add)</param>
									<param name="label">Add source</param>
								</include>
							</control>
						</control>
					</control>
				</control>
			</control>
		</definition>
	</include>

	<!-- Actor list -->
	<include name="MediaNavActorList">
		<param name="content">plugin://script.canvas.helper/actors/?dbid=$INFO[Container(501).ListItem.DBID]&amp;dbtype=$INFO[Container(501).ListItem.DBTYPE]</param>

		<definition>
			<!-- Label -->
			<include content="ListLabel">
				<param name="id">600</param>
				<param name="label">Actors</param>
				<param name="textcolor">$VAR[ContrastTextHighlightColor]</param>
			</include>

			<!-- Actor strip -->
			<include content="ItemStrip">
				<param name="id">601</param>

				<height>HEIGHT_LIST_CONTAINER</height>

				<!-- Person layout -->
				<include content="PersonLayout">
					<param name="art">$INFO[ListItem.Property(Thumbnail)]</param>
					<param name="info1">$INFO[ListItem.Property(Name)]</param>
					<param name="info2">$INFO[ListItem.Property(Role)]</param>
					<param name="info1_color">$VAR[ContrastTextHighlightColor]</param>
					<param name="info2_color">$VAR[ColorsContrastForeground]</param>
				</include>

				<content>$PARAM[content]</content>
			</include>
		</definition>
	</include>

	<!--
		Action button. When unfocused it's just an icon, when focused it has a background
		and text.

		It's a workaround: can't use a group because we need autowidth from the button,
		but the button control is not flexible enough to include an icon (togglebutton
		doesn't support autowidth -.-).
		
		So we use a sequence of controls, most images, assign an id based on the selected
		button's id so navigation inside the grouplist works as expected and use negative
		<left> values (together with <usecontrolcoords> to true in grouplist) as to
		pack/overlap controls as needed.
	-->
	<include name="MediaNavActionButton">
		<param name="id"></param>
		<param name="icon"></param>
		<param name="label"></param>
		<param name="action"></param>
		<param name="switch_to_601">false</param>
		<param name="visible">true</param>

		<definition>
			<!-- Icon when button is not focused -->
			<control type="group" id="90$PARAM[id]">
				<visible>!Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_ICON_UNFOCUSED</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<!-- Background -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonBackgroundColor]">1080p/diffuse/circle.png</texture>
				</control>
				<!-- Icon -->
				<control type="image">
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
					<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonIconColor]">$PARAM[icon]</texture>
				</control>
			</control>

			<!-- Left part of the button (with space for icon) when focused -->
			<control type="image" id="91$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_START</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/round-button-extended-start.png</texture>
			</control>
			<!-- Icon when focused -->
			<control type="image" id="92$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<left>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED</left>
				<top>OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP</top>
				<width>SIZE_MEDIANAV_ACTIONBUTTON_ICON</width>
				<height>SIZE_MEDIANAV_ACTIONBUTTON_ICON</height>
				<texture colordiffuse="BACKGROUND_OPAQUE75">$PARAM[icon]</texture>
			</control>
			<!-- Actual button (with autowidth text) -->
			<control type="button" id="$PARAM[id]">
				<visible>$PARAM[visible]</visible>
				<width>auto</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>

				<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/round-button-middle.png</texturefocus>
				<textcolor>$VAR[MediaNavContrastButtonIconColor]</textcolor>
				<font>BODY2_STRONG</font>
				<focusedcolor>BACKGROUND_OPAQUE75</focusedcolor>
				<textoffsety>0</textoffsety>
				<textoffsetx>0</textoffsetx>
				<label>$PARAM[label]</label>

				<onclick>SetFocus(501)</onclick>
				<onclick>$PARAM[action]</onclick>
				<onclick condition="$PARAM[switch_to_601]">SetFocus(601)</onclick>
			</control>
			<!-- Right part of the button when focused -->
			<control type="image" id="93$PARAM[id]">
				<visible>Control.HasFocus($PARAM[id]) + $PARAM[visible]</visible>
				<width>WIDTH_MEDIANAV_ACTIONBUTTON_END</width>
				<height>HEIGHT_MEDIANAV_ACTIONBUTTON</height>
				<texture colordiffuse="$VAR[ColorsAccentForeground]" flipx="true">1080p/controls/round-button-start.png</texture>
			</control>
		</definition>
	</include>
	<!-- Action button list -->
	<include name="MediaNavActionButtons">
		<param name="switch_to_601_on_more">false</param>

		<definition>
			<!--
				This needs the same ID as a non-focusable element in the media/actor grouplist
				(possibly before the first list), otherwise focusing does not work.
			-->
			<control type="grouplist" id="410">
				<itemgap>0</itemgap>
				<orientation>horizontal</orientation>
				<align>right</align>
				<usecontrolcoords>true</usecontrolcoords>
				<defaultcontrol always="true">411</defaultcontrol>

				<top>OFFSET_MEDIANAV_TOP_ACTIONBUTTONS</top>
				<right>PADDING_BASE_80P</right>
				<width>800</width>

				<onup>noop</onup>
				<ondown>SetFocus(400)</ondown>

				<!-- Play -->
				<include content="MediaNavActionButton">
					<param name="id">411</param>
					<param name="icon">$VAR[MediaNavPlayIcon]</param>
					<param name="label">$VAR[MediaNavPlayButtonLabel]</param>
					<param name="action">$VAR[MediaNavPlayButtonAction]</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[HasMediaNavActionPlay]</param>
				</include>
				<!-- Resume -->
				<include content="MediaNavActionButton">
					<param name="id">412</param>
					<param name="icon">$VAR[MediaNavResumeIcon]</param>
					<param name="label">$VAR[MediaNavResumeButtonLabel]</param>
					<param name="action">$VAR[MediaNavResumeButtonAction]</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[HasMediaNavActionResume]</param>
				</include>
				<!-- Play from start -->
				<include content="MediaNavActionButton">
					<param name="id">413</param>
					<param name="icon">$VAR[MediaNavPlayFromStartIcon]</param>
					<param name="label">$VAR[MediaNavPlayFromStartButtonLabel]</param>
					<param name="action">$VAR[MediaNavPlayButtonAction]</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[HasMediaNavActionPlayFromStart]</param>
				</include>
				<!-- Mark as unwatched -->
				<include content="MediaNavActionButton">
					<param name="id">414</param>
					<param name="icon">$VAR[MediaNavWatchedIcon]</param>
					<param name="label">$VAR[MediaNavMarkAsUnwatchedButtonLabel]</param>
					<param name="action">RunScript(script.canvas.helper,toggle_watched,$INFO[Container(501).ListItem.DBTYPE],$INFO[Container(501).ListItem.DBID],false)</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[HasMediaNavActionMarkAsUnwatched]</param>
				</include>
				<!-- Mark as watched -->
				<include content="MediaNavActionButton">
					<param name="id">415</param>
					<param name="icon">$VAR[MediaNavUnwatchedIcon]</param>
					<param name="label">$VAR[MediaNavMarkAsWatchedButtonLabel]</param>
					<param name="action">RunScript(script.canvas.helper,toggle_watched,$INFO[Container(501).ListItem.DBTYPE],$INFO[Container(501).ListItem.DBID],true)</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[HasMediaNavActionMarkAsWatched]</param>
				</include>
				<!-- Go to show -->
				<include content="MediaNavActionButton">
					<param name="id">416</param>
					<param name="icon">$VAR[MediaNavGoToShowIcon]</param>
					<param name="label">$VAR[MediaNavGoToShowButtonLabel]</param>
					<param name="action">RunScript(script.canvas.helper,navigate_to_show,videodb://tvshows/titles/$INFO[Container(501).ListItem.TVShowDBID]/)</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
					<param name="visible">$EXP[IsDetailsItemTypeEpisode]</param>
				</include>
				<!-- Info -->
				<include content="MediaNavActionButton">
					<param name="id">417</param>
					<param name="icon">$VAR[MediaNavInfoIcon]</param>
					<param name="label">$VAR[MediaNavInfoButtonLabel]</param>
					<param name="action">Action(Info)</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
				</include>
				<!-- More -->
				<include content="MediaNavActionButton">
					<param name="id">418</param>
					<param name="icon">$VAR[MediaNavMoreIcon]</param>
					<param name="label">$VAR[MediaNavMoreButtonLabel]</param>
					<param name="action">Action(ContextMenu)</param>
					<param name="switch_to_601">$PARAM[switch_to_601_on_more]</param>
				</include>
			</control>
		</definition>
	</include>

	<!-- Previous/next season indicators (for episode list view) -->
	<include name="MediaNavPrevNextSeasonIndicators">
		<param name="visible">true</param>

		<definition>
			<control type="group">
				<visible>$PARAM[visible]</visible>

				<bottom>0</bottom>
				<width>SCREEN_WIDTH</width>
				<height>HEIGHT_LIST_CONTAINER</height>

				<!-- Previous -->
				<control type="image">
					<visible>$EXP[HasMediaNavNavigatePreviousSeason]</visible>
					<centertop>OFFSET_MEDIANAV_TOP_PREVNEXT_INDICATOR</centertop>
					<centerleft>PADDING_BASE_50P</centerleft>
					<width>SIZE_MEDIANAV_PREVNEXT_INDICATOR</width>
					<height>SIZE_MEDIANAV_PREVNEXT_INDICATOR</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonBackgroundColor]" flipx="true">1080p/icons/chevron-right.png</texture>
				</control>
				<!-- Next -->
				<control type="image">
					<visible>$EXP[HasMediaNavNavigateNextSeason]</visible>
					<centertop>OFFSET_MEDIANAV_TOP_PREVNEXT_INDICATOR</centertop>
					<centerright>PADDING_BASE_50P</centerright>
					<width>SIZE_MEDIANAV_PREVNEXT_INDICATOR</width>
					<height>SIZE_MEDIANAV_PREVNEXT_INDICATOR</height>
					<texture colordiffuse="$VAR[MediaNavContrastButtonBackgroundColor]">1080p/icons/chevron-right.png</texture>
				</control>
			</control>
		</definition>
	</include>


	<!-- Album song list layout -->
	<include name="AlbumNavSongListLayoutContent">
		<param name="font"></param>
		<param name="highlight_background">TRANSPARENT</param>

		<definition>
			<control type="group">
				<width>WIDTH_ALBUMNAV_ITEM</width>
				<height>HEIGHT_ALBUMNAV_ITEM</height>

				<!-- Focus background -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<texture colordiffuse="$PARAM[highlight_background]">diffuse.png</texture>
				</control>

				<control type="group">
					<top>3</top>

					<!-- Playing icon -->
					<control type="image">
						<width>SIZE_ALBUMNAV_ICON</width>
						<height>SIZE_ALBUMNAV_ICON</height>
						<top>10</top>
						<left>PADDING_BASE_10P</left>
						<texture colordiffuse="$VAR[ColorsContrastForeground]">$VAR[AlbumNavSongIcon]</texture>
					</control>
					<!-- Song title -->
					<control type="label">
						<left>PADDING_BASE_50P</left>
						<width max="685">auto</width>	<!-- max: WIDTH_ALBUMNAV_ITEM - SIZE_ALBUMNAV_ICON - PADDING_BASE_50P - 40 - 100 -->
						<font>$PARAM[font]</font>
						<textcolor>$VAR[ColorsContrastForeground]</textcolor>
						<selectedcolor>$VAR[ColorsContrastForeground]</selectedcolor>
						<label>$INFO[ListItem.Title]</label>
					</control>
					<!-- Duration -->
					<control type="label">
						<right>PADDING_BASE_10P</right>
						<width>100</width>
						<font>$PARAM[font]</font>
						<textcolor>$VAR[ColorsContrastForeground]</textcolor>
						<selectedcolor>$VAR[ColorsContrastForeground]</selectedcolor>
						<align>right</align>
						<label>$INFO[ListItem.Duration]</label>
					</control>
				</control>
			</control>
		</definition>
	</include>


	<!-- File nav background split -->
	<include name="FileNavBackgroundSplit">
		<definition>
			<!-- Background split overlay -->
			<control type="group">
				<!-- Left -->
				<control type="image">
					<width>WIDTH_BACKGROUND_SPLIT_WIDE</width>
					<height>SCREEN_HEIGHT</height>
					<texture colordiffuse="BACKGROUND_OPAQUE20">diffuse.png</texture>
				</control>
				<!-- Right -->
				<control type="image">
					<left>WIDTH_BACKGROUND_SPLIT_WIDE</left>
					<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
					<height>SCREEN_HEIGHT</height>
					<texture colordiffuse="BACKGROUND_OPAQUE10">diffuse.png</texture>
				</control>
			</control>
			<!-- Additional repeat for when DialogSettings is open -->
			<control type="group">
				<left>SCREEN_WIDTH</left>

				<!-- Left -->
				<control type="image">
					<width>WIDTH_BACKGROUND_SPLIT_WIDE</width>
					<height>SCREEN_HEIGHT</height>
					<texture colordiffuse="BACKGROUND_OPAQUE20">diffuse.png</texture>
				</control>
				<!-- Right -->
				<control type="image">
					<left>WIDTH_BACKGROUND_SPLIT_WIDE</left>
					<width>WIDTH_BACKGROUND_SPLIT_NARROW</width>
					<height>SCREEN_HEIGHT</height>
					<texture colordiffuse="BACKGROUND_OPAQUE10">diffuse.png</texture>
				</control>
			</control>
		</definition>
	</include>

	<!-- File nav info label -->
	<include name="FileNavInfoLabel">
		<param name="visible">true</param>
		<param name="label"></param>
		<param name="value"></param>
		<param name="wrap">false</param>

		<definition>
			<!-- Label -->
			<control type="label">
				<visible>$PARAM[visible]</visible>
				<height>FONT_SIZE_BODY</height>
				<font>CAPTION_STRONG</font>
				<textcolor>FOREGROUND</textcolor>
				<label>$PARAM[label]</label>
			</control>
			<!-- Value (no wrap) -->
			<control type="label">
				<visible>$PARAM[visible] + !$PARAM[wrap]</visible>
				<top>-10</top>
				<width>100%</width>
				<height>FONT_SIZE_BODY</height>
				<haspath>true</haspath>
				<font>CAPTION</font>
				<textcolor>FOREGROUND</textcolor>
				<label>$PARAM[value]</label>
			</control>
			<!-- Value (with wrap) -->
			<control type="label">
				<visible>$PARAM[visible] + $PARAM[wrap]</visible>
				<top>-10</top>
				<width>100%</width>
				<height>300</height>
				<haspath>true</haspath>
				<wrapmultiline>true</wrapmultiline>
				<font>CAPTION</font>
				<textcolor>FOREGROUND</textcolor>
				<label>$PARAM[value]</label>
			</control>
		</definition>
	</include>

	<!-- File nav list -->
	<include name="FileNavItemList">
		<param name="id"></param>
		<param name="title"></param>

		<definition>
			<control type="group">
				<width>WIDTH_BACKGROUND_SPLIT_WIDE</width>
				<height>SCREEN_HEIGHT</height>

				<control type="group">
					<top>PADDING_BASE_80P</top>
					<bottom>PADDING_BASE</bottom>
					<left>PADDING_SETTINGS_WIDE_SIDE</left>
					<right>PADDING_SETTINGS_WIDE_SIDE</right>

					<!-- Title -->
					<control type="label">
						<width>auto</width>
						<height>FONT_SIZE_TITLE2</height>
						<right>PADDING_SETTINGS_TITLE</right>
						<left>PADDING_SETTINGS_TITLE</left>
						<font>TITLE2</font>
						<label>$PARAM[title]</label>
					</control>

					<control type="group">
						<top>OFFSET_SETTINGS_OPTIONS_START</top>

						<!-- List of sections -->
						<control type="list" id="$PARAM[id]">
							<left>0</left>
							<right>0</right>
							<autoscroll>false</autoscroll>

							<onright>Info</onright>

							<focusedlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
								<control type="button">
									<visible allowhiddenfocus="true">false</visible>
								</control>

								<!-- Fake button for selection (only when focus is in the actual list, not when on expert button) -->
								<control type="group">
									<visible>Control.HasFocus($PARAM[id])</visible>
									<!-- Fake button selection -->
									<control type="image">
										<height>HEIGHT_BUTTON_DEFAULT</height>
										<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
									</control>
									<!-- Content -->
									<include content="SettingsOptionContentWithIcon">
										<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
										<param name="text">$INFO[ListItem.Label]</param>
										<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
										<param name="icon_color">FOREGROUND_INVERSE</param>
										<param name="text_color">FOREGROUND_INVERSE</param>
										<param name="description">$INFO[ListItem.Label2]</param>
										<param name="description_color">FOREGROUND_INVERSE_OPAQUE75</param>
										<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
										<param name="scroll">true</param>
									</include>
								</control>
								<control type="group">
									<visible>!Control.HasFocus($PARAM[id])</visible>
									<include content="SettingsOptionContentWithIcon">
										<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
										<param name="text">$INFO[ListItem.Label]</param>
										<param name="description">$INFO[ListItem.Label2]</param>
										<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
										<param name="scroll">true</param>
									</include>
								</control>
							</focusedlayout>

							<itemlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
								<include content="SettingsOptionContentWithIcon">
									<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
									<param name="text">$INFO[ListItem.Label]</param>
									<param name="description">$INFO[ListItem.Label2]</param>
									<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
								</include>
							</itemlayout>
						</control>

						<!-- Chevrons up/down if more content is available -->
						<include content="SettingsUpDownChevrons">
							<param name="visible_up">Integer.IsGreater(Container($PARAM[id]).NumItems,6)</param>
							<param name="visible_down">Integer.IsGreater(Container($PARAM[id]).NumItems,6)</param>
						</include>
					</control>
				</control>
			</control>
		</definition>
	</include>
	<include name="FileNavItemFileList">
		<param name="id"></param>
		<param name="scrollbar_id"></param>
		<param name="path_id"></param>
		<param name="other_id"></param>
		<param name="list_name"></param>

		<definition>
			<control type="group">
				<include content="ShowHideFadeSlideHorizontalAnimation">
					<param name="slide_amount">-100</param>
					<param name="delay_in">ANIMATION_MID</param>
					<param name="visible_type">Conditional</param>
					<param name="hidden_type">Conditional</param>
					<param name="visible_condition">Control.HasFocus($PARAM[id]) | Control.HasFocus($PARAM[scrollbar_id])</param>
					<param name="hidden_condition">!Control.HasFocus($PARAM[id]) + !Control.HasFocus($PARAM[scrollbar_id])</param>
					<param name="tween">cubic</param>
				</include>

				<top>PADDING_BASE_125P</top>

				<!-- Name and path -->
				<control type="grouplist">
					<orientation>horizontal</orientation>
					<itemgap>PADDING_BASE_10P</itemgap>
					
					<height>FONT_SIZE_SUBTITLE</height>
					<right>PADDING_SETTINGS_TITLE</right>
					<left>PADDING_SETTINGS_TITLE</left>

					<!-- Name -->
					<control type="label">
						<width>auto</width>
						<height>FONT_SIZE_CAPTION</height>
						<font>CAPTION_STRONG</font>
						<label>$PARAM[list_name]</label>
					</control>
					<!-- Path -->
					<control type="label" id="$PARAM[path_id]">
						<width max="800">auto</width>
						<height>FONT_SIZE_CAPTION</height>
						<font>CAPTION</font>
						<haspath>true</haspath>
					</control>
				</control>

				<!-- Items and scrollbar -->
				<control type="group">
					<top>PADDING_BASE_50P</top>

					<!-- Items -->
					<control type="list" id="$PARAM[id]">
						<left>0</left>
						<right>PADDING_BASE_30P</right>
						<autoscroll>false</autoscroll>
						<pagecontrol>$PARAM[scrollbar_id]</pagecontrol>

						<onright condition="Control.IsVisible($PARAM[scrollbar_id])">SetFocus($PARAM[scrollbar_id])</onright>
						<onleft>SetFocus($PARAM[other_id])</onleft>

						<focusedlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<control type="button">
								<visible allowhiddenfocus="true">false</visible>
							</control>

							<!-- Fake button for selection (only when focus is in the actual list, not when on expert button) -->
							<control type="group">
								<visible>Control.HasFocus($PARAM[id])</visible>
								<!-- Fake button selection -->
								<control type="image">
									<height>HEIGHT_BUTTON_DEFAULT</height>
									<texture colordiffuse="BACKGROUND_INVERSE_OPAQUE90" border="SIZE_ITEM_SHADOW_ART_DOUBLE">1080p/controls/button.png</texture>
								</control>
								<!-- Content -->
								<include content="SettingsOptionContentWithIcon">
									<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
									<param name="text">$INFO[ListItem.Label]</param>
									<param name="icon_circle_color">BACKGROUND_INVERSE_OPAQUE90</param>
									<param name="icon_color">FOREGROUND_INVERSE</param>
									<param name="text_color">FOREGROUND_INVERSE</param>
									<param name="description">$INFO[ListItem.Label2]</param>
									<param name="description_color">FOREGROUND_INVERSE_OPAQUE75</param>
									<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
									<param name="scroll">true</param>
								</include>
							</control>
							<control type="group">
								<visible>!Control.HasFocus($PARAM[id])</visible>
								<include content="SettingsOptionContentWithIcon">
									<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
									<param name="text">$INFO[ListItem.Label]</param>
									<param name="description">$INFO[ListItem.Label2]</param>
									<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
									<param name="scroll">true</param>
								</include>
							</control>
						</focusedlayout>

						<itemlayout height="HEIGHT_SETTINGS_OPTION_CONTAINER">
							<include content="SettingsOptionContentWithIcon">
								<param name="icon">$VAR[ListIconTranslatedSimplified]</param>
								<param name="text">$INFO[ListItem.Label]</param>
								<param name="description">$INFO[ListItem.Label2]</param>
								<param name="single_line">String.IsEmpty(ListItem.Label2)</param>
							</include>
						</itemlayout>
					</control>

					<!-- Scrollbar -->
					<control type="scrollbar" id="$PARAM[scrollbar_id]">
						<right>PADDING_BASE_30P_NEG</right>
						<height>100%</height>
						<orientation>vertical</orientation>
						<onleft>SetFocus($PARAM[id])</onleft>
					</control>
				</control>
			</control>
		</definition>
	</include>
</includes>
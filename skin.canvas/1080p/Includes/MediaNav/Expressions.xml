<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Is library navigation? -->
	<expression name="IsMediaNavLibraryNavigation">
		[Window.IsVisible(MyVideoNav.xml) + String.IsEqual(Window(videos).Property(LibraryNav),true)] |
		[Window.IsVisible(MyMusicNav.xml) + String.IsEqual(Window(music).Property(LibraryNav),true)] |
		Window.Previous(SettingsCategory.xml)
	</expression>

	<!-- Is all new? -->
	<expression name="IsMediaNavAllNew">
		$EXP[IsDetailsItemTypeSeason] +
		Integer.IsEqual(Container(501).ListItem.Property(WatchedEpisodes),0)
	</expression>
	<!-- Is watched? -->
	<expression name="IsMediaNavWatched">
		!String.IsEmpty(Container(501).ListItem.PlayCount)
	</expression>
	<!-- Has time remaining? -->
	<expression name="HasMediaNavTimeRemaining">
		[$EXP[IsDetailsItemTypeEpisode] | $EXP[IsDetailsItemTypeMovie]] +
		Integer.IsGreater(Container(501).ListItem.PercentPlayed,0) +
		Integer.IsLess(Container(501).ListItem.PercentPlayed,100)
	</expression>
	<!-- Has episodes remaining? -->
	<expression name="HasMediaNavEpisodesRemaining">
		$EXP[IsDetailsItemTypeSeason] +
		String.IsEmpty(Container(501).ListItem.PlayCount)
	</expression>

	<!--
		Has play action?
		- All new
		- No time remaining and no episodes remaining
	-->
	<expression name="HasMediaNavActionPlay">
		[!$EXP[HasMediaNavTimeRemaining] + !$EXP[HasMediaNavEpisodesRemaining]] |
		$EXP[IsMediaNavAllNew]
	</expression>
	<!--
		Has resume action?
		- Has time or episodes remaining
		- Is not all new
		- Is not watched
	-->
	<expression name="HasMediaNavActionResume">
		[$EXP[HasMediaNavTimeRemaining] | $EXP[HasMediaNavEpisodesRemaining]] +
		!$EXP[IsMediaNavAllNew]
	</expression>
	<!-- Has play from start action? -->
	<expression name="HasMediaNavActionPlayFromStart">$EXP[HasMediaNavTimeRemaining]</expression>
	<!-- Has mark as unwatched action? -->
	<expression name="HasMediaNavActionMarkAsUnwatched">$EXP[IsMediaNavWatched]</expression>
	<!-- Has mark as watched action? -->
	<expression name="HasMediaNavActionMarkAsWatched">!$EXP[IsMediaNavWatched]</expression>

	<!-- Is action bar focused? -->
	<expression name="IsMediaNavActionBarFocused">
		Control.HasFocus(411) |
		Control.HasFocus(412) |
		Control.HasFocus(413) |
		Control.HasFocus(414) |
		Control.HasFocus(415) |
		Control.HasFocus(416) |
		Control.HasFocus(417) |
		Control.HasFocus(418)
	</expression>

	<!-- Has previous/next season available (for navigation from episodes)? -->
	<expression name="HasMediaNavNavigatePreviousSeason">$EXP[IsDetailsItemTypeEpisode] + !String.IsEmpty(Window(home).Property(Navigation.PreviousSeason))</expression>
	<expression name="HasMediaNavNavigateNextSeason">$EXP[IsDetailsItemTypeEpisode] + !String.IsEmpty(Window(home).Property(Navigation.NextSeason))</expression>
</includes>
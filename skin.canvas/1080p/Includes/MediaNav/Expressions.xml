<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- What type of media are we showing? -->
	<expression name="IsMediaNavMovie">String.IsEqual(Window(1101).Property(ItemDetails.Type),movie)</expression>
	<expression name="IsMediaNavTVShow">String.IsEqual(Window(1101).Property(ItemDetails.Type),tvshow)</expression>
	<expression name="IsMediaNavSeason">String.IsEqual(Window(1101).Property(ItemDetails.Type),season)</expression>
	<expression name="IsMediaNavEpisode">String.IsEqual(Window(1101).Property(ItemDetails.Type),episode)</expression>
	<expression name="IsMediaNavMusicAlbum">String.IsEqual(Window(1101).Property(ItemDetails.Type),album)</expression>
	<expression name="IsMediaNavPictureAlbum">String.IsEqual(Window(1101).Property(ItemDetails.Type),picture_album)</expression>


	<!-- Has studio? -->
	<expression name="HasMediaNavDetailsStudio">String.IsEqual(Window(1101).Property(CarryOver.Studio.Exists),true)</expression>

	<!-- Has clearlogo? -->
	<expression name="HasMediaNavDetailsClearlogo">String.IsEqual(Window(1101).Property(CarryOver.Clearlogo.Exists),true)</expression>

	<!-- Has subtitle? -->
	<expression name="HasMediaNavDetailsSubtitle">String.IsEqual(Window(1101).Property(CarryOver.Subtitle.Exists),true)</expression>

	<!-- Has resolution? -->
	<expression name="HasMediaNavDetailsResolution">String.IsEqual(Window(1101).Property(CarryOver.Resolution.Exists),true)</expression>

	<!-- Has HDR? -->
	<expression name="HasMediaNavDetailsHdr">String.IsEqual(Window(1101).Property(CarryOver.Hdr.Exists),true)</expression>

	<!-- Has audio channels? -->
	<expression name="HasMediaNavDetailsAudioChannels">String.IsEqual(Window(1101).Property(CarryOver.AudioChannels.Exists),true)</expression>

	<!-- Has year? -->
	<expression name="HasMediaNavDetailsYear">String.IsEqual(Window(1101).Property(CarryOver.Year.Exists),true)</expression>

	<!-- Has episode? -->
	<expression name="HasMediaNavDetailsEpisode">String.IsEqual(Window(1101).Property(CarryOver.Episode.Exists),true)</expression>

	<!-- Has premiered? -->
	<expression name="HasMediaNavDetailsPremiered">String.IsEqual(Window(1101).Property(CarryOver.Premiered.Exists),true)</expression>

	<!-- Has duration? -->
	<expression name="HasMediaNavDetailsDuration">String.IsEqual(Window(1101).Property(CarryOver.Duration.Exists),true)</expression>

	<!-- Has MPAA? -->
	<expression name="HasMediaNavDetailsMpaa">String.IsEqual(Window(1101).Property(CarryOver.Mpaa.Exists),true)</expression>

	<!-- Has status? -->
	<expression name="HasMediaNavDetailsStatus">String.IsEqual(Window(1101).Property(CarryOver.Status.Exists),true)</expression>

	<!-- Has genre? -->
	<expression name="HasMediaNavDetailsGenre">String.IsEqual(Window(1101).Property(CarryOver.Genre.Exists),true)</expression>

	<!-- Is watched? -->
	<expression name="IsMediaNavDetailsWatched">String.IsEqual(Window(1101).Property(CarryOver.IsWatched),true)</expression>

	<!-- Has time remaining? -->
	<expression name="HasMediaNavDetailsTimeRemaining">String.IsEqual(Window(1101).Property(CarryOver.TimeRemaining.Exists),true)</expression>

	<!-- Has episodes remaining? -->
	<expression name="HasMediaNavDetailsEpisodesRemaining">String.IsEqual(Window(1101).Property(CarryOver.EpisodesRemaining.Exists),true)</expression>

	<!-- Is all new? -->
	<expression name="IsMediaNavDetailsAllNew">String.IsEqual(Window(1101).Property(CarryOver.IsAllNew),true)</expression>


	<!-- Is the most suited text color again blur background light/dark? -->
	<expression name="IsMediaNavDetailsBestTextColorLight">String.IsEqual(Window(1101).Property(CarryOver.Colors.IsLight),true)</expression>
	<expression name="IsMediaNavDetailsBestTextColorDark">String.IsEqual(Window(1101).Property(CarryOver.Colors.IsDark),true)</expression>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<expression name="IsMediaNavShowingMovie">String.IsEqual(Container.Content,movie)</expression><!--todo-->
	<expression name="IsMediaNavShowingSeasons">String.IsEqual(Container.Content,seasons)</expression>
	<expression name="IsMediaNavShowingEpisodes">String.IsEqual(Container.Content,episodes)</expression>
	<expression name="IsMediaNavShowingMusicAlbum">String.IsEqual(Container.Content,album)</expression><!--todo-->
	<expression name="IsMediaNavShowingPictureAlbum">String.IsEqual(Container.Content,???)</expression><!--todo-->


	<!-- Has studio? -->
	<expression name="HasMediaNavDetailsStudio">
		[Control.HasFocus(101) + !String.IsEmpty(Container(101).ListItem.Studio)] |
		String.IsEqual(Window(videos).Property(CarryOver.Studio.Exists),true)
	</expression>

	<!-- Has clearlogo? -->
	<expression name="HasMediaNavDetailsClearlogo">
		[Control.HasFocus(101) + !String.IsEmpty(Container(101).ListItem.Property(Clearlogo.Big))] |
		String.IsEqual(Window(videos).Property(CarryOver.Clearlogo.Exists),true)
	</expression>

	<!-- Has title? -->
	<expression name="HasMediaNavDetailsTitle">
		[Control.HasFocus(101) + !String.IsEmpty(Container(101).ListItem.TVShowTitle)] |
		String.IsEqual(Window(videos).Property(CarryOver.Subtitle.Title),true)
	</expression>

	<!-- Has subtitle? -->
	<expression name="HasMediaNavDetailsSubtitle">
		[Control.HasFocus(101) + !String.IsEmpty(Container(101).ListItem.Title)] |
		String.IsEqual(Window(videos).Property(CarryOver.Subtitle.Exists),true)
	</expression>

	<!-- Has resolution? -->
	<expression name="HasMediaNavDetailsResolution">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.VideoResolution)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Resolution.Exists),true)]
	</expression>

	<!-- Has HDR? -->
	<expression name="HasMediaNavDetailsHdr">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.HdrType)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Hdr.Exists),true)]
	</expression>

	<!-- Has audio channels? -->
	<expression name="HasMediaNavDetailsAudioChannels">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Property(AudioChannels))] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.AudioChannels.Exists),true)]
	</expression>

	<!-- Has year? -->
	<expression name="HasMediaNavDetailsYear">
		!Control.HasFocus(102) +
		String.IsEqual(Window(videos).Property(CarryOver.Year.Exists),true)
	</expression>

	<!-- Has episode? -->
	<expression name="HasMediaNavDetailsEpisode">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Episode) + !String.IsEmpty(ListItem.Season)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Episode.Exists),true)]
	</expression>

	<!-- Has premiered? -->
	<expression name="HasMediaNavDetailsPremiered">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Premiered)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Premiered.Exists),true)]
	</expression>

	<!-- Has duration? -->
	<expression name="HasMediaNavDetailsDuration">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Property(DurationString))] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Duration.Exists),true)]
	</expression>

	<!-- Has MPAA? -->
	<expression name="HasMediaNavDetailsMpaa">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Mpaa)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.Mpaa.Exists),true)]
	</expression>

	<!-- Has status? -->
	<expression name="HasMediaNavDetailsStatus">
		!Control.HasFocus(102) +
		String.IsEqual(Window(videos).Property(CarryOver.Status.Exists),true)
	</expression>

	<!-- Has genre? -->
	<expression name="HasMediaNavDetailsGenre">
		!Control.HasFocus(101) +
		String.IsEqual(Window(videos).Property(CarryOver.Genre.Exists),true)
	</expression>

	<!-- Is watched? -->
	<expression name="IsMediaNavDetailsWatched">
		[Control.HasFocus(102) + Integer.IsGreater(ListItem.PlayCount,0)] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.IsWatched),true)]
	</expression>

	<!-- Has time remaining? -->
	<expression name="HasMediaNavDetailsTimeRemaining">
		[Control.HasFocus(102) + !String.IsEmpty(ListItem.Property(TimeRemainingString))] |
		[!Control.HasFocus(102) + String.IsEqual(Window(videos).Property(CarryOver.TimeRemaining.Exists),true)]
	</expression>

	<!-- Has episodes remaining? -->
	<expression name="HasMediaNavDetailsEpisodesRemaining">
		!Control.HasFocus(102) +
		String.IsEqual(Window(videos).Property(CarryOver.EpisodesRemaining.Exists),true)
	</expression>

	<!-- Is all new? -->
	<expression name="IsMediaNavDetailsAllNew">
		!Control.HasFocus(102) +
		String.IsEqual(Window(videos).Property(CarryOver.IsAllNew),true)
	</expression>

	<!-- Has summary? -->
	<expression name="HasMediaNavDetailsSummary">
		[Control.HasFocus(101) + !String.IsEmpty(Container(101).ListItem.Plot)] |
		String.IsEqual(Window(videos).Property(CarryOver.Subtitle.Summary),true)
	</expression>


	<!--
		Is the most suited text color again blur background light/dark?
		Consider:
		- Seasons
		- Episodes
		- Carryover
	-->
	<expression name="IsMediaNavDetailsBestTextColorLight">
		[Control.HasFocus(101) + [
			[!String.IsEmpty(Container(101).ListItem.Property(BlurArt.Season)) + String.IsEqual(Container(101).ListItem.Property(BlurArt.Season.TextColor),light)] |
			[String.IsEmpty(Container(101).ListItem.Property(BlurArt.Season)) + !String.IsEmpty(Container(101).ListItem.Property(BlurArt.TvShow)) + String.IsEqual(Container(101).ListItem.Property(BlurArt.TvShow.TextColor),light)]
		]] |
		String.IsEqual(Window(videos).Property(CarryOver.Colors.IsLight),true)
	</expression>
	<expression name="IsMediaNavDetailsBestTextColorDark">
		[Control.HasFocus(101) + [
			[!String.IsEmpty(Container(101).ListItem.Property(BlurArt.Season)) + String.IsEqual(Container(101).ListItem.Property(BlurArt.Season.TextColor),dark)] |
			[String.IsEmpty(Container(101).ListItem.Property(BlurArt.Season)) + !String.IsEmpty(Container(101).ListItem.Property(BlurArt.TvShow)) + String.IsEqual(Container(101).ListItem.Property(BlurArt.TvShow.TextColor),dark)]
		]] |
		String.IsEqual(Window(videos).Property(CarryOver.Colors.IsDark),true)
	</expression>


	<!--
		Has play action?
		- All new
		- No time remaining and no episodes remaining
	-->
	<expression name="HasMediaNavActionPlay">
		[!$EXP[HasMediaNavDetailsTimeRemaining] + !$EXP[HasMediaNavDetailsEpisodesRemaining]] |
		$EXP[IsMediaNavDetailsAllNew]
	</expression>
	<!--
		Has resume action?
		- Has time or episodes remaining
		- Is not all new
		- Is not watched
	-->
	<expression name="HasMediaNavActionResume">
		[$EXP[HasMediaNavDetailsTimeRemaining] | $EXP[HasMediaNavDetailsEpisodesRemaining]] +
		!$EXP[IsMediaNavDetailsAllNew] +
		!$EXP[IsMediaNavDetailsWatched]
	</expression>
	<!-- Has play from start action? -->
	<expression name="HasMediaNavActionPlayFromStart">$EXP[HasMediaNavDetailsTimeRemaining]</expression>
	<!-- Has mark as unwatched action? -->
	<expression name="HasMediaNavActionMarkAsUnwatched">$EXP[IsMediaNavDetailsWatched]</expression>
	<!-- Has mark as watched action? -->
	<expression name="HasMediaNavActionMarkAsWatched">!$EXP[IsMediaNavDetailsWatched]</expression>


	<!-- Is season list renderable (no loading, has content)? -->
	<expression name="IsMediaNavSeasonListRenderable">!String.IsEqual(Window(videos).Property(List.101.IsLoading),true) + String.IsEqual(Window(videos).Property(List.101.HasContent),true)</expression>
	<!-- Is episode list renderable (no loading, has content)? -->
	<expression name="IsMediaNavEpisodeListRenderable">!String.IsEqual(Window(videos).Property(List.102.IsLoading),true) + String.IsEqual(Window(videos).Property(List.102.HasContent),true)</expression>
	<!-- Is actor list renderable (no loading, has content)? -->
	<expression name="IsMediaNavActorListRenderable">!String.IsEqual(Window(videos).Property(List.111.IsLoading),true) + String.IsEqual(Window(videos).Property(List.111.HasContent),true)</expression>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Contrast text color (against blur art) -->
	<variable name="MediaNavContrastTextForegroundColor">
		<!-- Light color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorLight]">FOREGROUND_CONTRAST_LIGHT</value>
		<!-- Dark color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorDark]">FOREGROUND_CONTRAST_DARK</value>
		<!-- Fallback -->
		<value>FOREGROUND_CONTRAST_LIGHT</value>
	</variable>
	<variable name="MediaNavContrastTextHighlightColor">
		<!-- Light color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorLight]">HIGHLIGHT_CONTRAST_LIGHT</value>
		<!-- Dark color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorDark]">HIGHLIGHT_CONTRAST_DARK</value>
		<!-- Fallback -->
		<value>HIGHLIGHT_CONTRAST_LIGHT</value>
	</variable>

	<!-- Contrast color for buttons (against blur art) -->
	<variable name="MediaNavContrastButtonIconColor">
		<!-- Light color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorLight]">FOREGROUND_OPAQUE50</value>
		<!-- Dark color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorDark]">FOREGROUND_INVERSE_OPAQUE50</value>
		<!-- Fallback -->
		<value>FOREGROUND_OPAQUE50</value>
	</variable>
	<variable name="MediaNavContrastButtonBackgroundColor">
		<!-- Light color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorLight]">FOREGROUND_OPAQUE10</value>
		<!-- Dark color -->
		<value condition="$EXP[IsMediaNavDetailsBestTextColorDark]">FOREGROUND_INVERSE_OPAQUE10</value>
		<!-- Fallback -->
		<value>FOREGROUND_OPAQUE10</value>
	</variable>


	<!-- Studio -->
	<variable name="MediaNavDetailsStudio">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">1080p/studios/$INFO[ListItem.Studio].png</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Studio)]</value>
	</variable>

	<!-- Clearlogo -->
	<variable name="MediaNavDetailsClearlogo">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Property(Clearlogo.Big)]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Clearlogo)]</value>
	</variable>

	<!-- Title -->
	<variable name="MediaNavDetailsTitle">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.TVShowTitle]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Title)]</value>
	</variable>

	<!-- Subtitle -->
	<variable name="MediaNavDetailsSubtitle">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Title]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Subtitle)]</value>
	</variable>

	<!-- Resolution -->
	<variable name="MediaNavDetailsResolution">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.VideoResolution]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Resolution)]</value>
	</variable>

	<!-- HDR -->
	<variable name="MediaNavDetailsHdr">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102) + String.IsEqual(ListItem.HdrType,hdr10)">HDR</value>
		<value condition="Control.HasFocus(102) + String.IsEqual(ListItem.HdrType,dolbyvision)">Dolby Vision</value>
		<value condition="Control.HasFocus(102) + String.IsEqual(ListItem.HdrType,hlg)">HLG</value>
		<value condition="Control.HasFocus(102)">[UPPERCASE]$INFO[ListItem.HdrType][/UPPERCASE]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Hdr)]</value>
	</variable>

	<!-- Audio channels -->
	<variable name="MediaNavDetailsAudioChannels">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Property(AudioChannels)]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.AudioChannels)]</value>
	</variable>

	<!-- Year -->
	<variable name="MediaNavDetailsYear">
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Year)]</value>
	</variable>

	<!-- Episode -->
	<variable name="MediaNavDetailsEpisode">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">S$INFO[ListItem.Season]·E$INFO[ListItem.Episode]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Episode)]</value>
	</variable>

	<!-- Premiered -->
	<variable name="MediaNavDetailsPremiered">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Premiered]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Premiered)]</value>
	</variable>

	<!-- Duration -->
	<variable name="MediaNavDetailsDuration">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Property(DurationString)]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Duration)]</value>
	</variable>

	<!-- Mpaa -->
	<variable name="MediaNavDetailsMpaa">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Mpaa]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Mpaa)]</value>
	</variable>

	<!-- Status -->
	<variable name="MediaNavDetailsStatus">
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Status)]</value>
	</variable>

	<!-- Genre -->
	<variable name="MediaNavDetailsGenre">
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Genre)]</value>
	</variable>

	<!-- Time remaining -->
	<variable name="MediaNavDetailsTimeRemaining">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Property(TimeRemainingString)] left</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.TimeRemaining)]</value>
	</variable>

	<!-- Episodes remaining -->
	<variable name="MediaNavDetailsEpisodesRemaining">
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.EpisodesRemaining)]</value>
	</variable>

	<!-- Watched percentage -->
	<variable name="MediaNavDetailsWatchedPercentage">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Property(WatchedPercentage)]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.WatchedPercentage)]</value>
	</variable>

	<!-- Plot -->
	<variable name="MediaNavDetailsSummary">
		<!-- Episode specific -->
		<value condition="Control.HasFocus(102)">$INFO[ListItem.Plot]</value>
		<!-- Carryover -->
		<value>$INFO[Window(1101).Property(CarryOver.Summary)]</value>
	</variable>


	<!--
		Action button labels.
		Defining them as variables allows to hide the text when not focused.
		They include space for margin from icon.
	-->
	<variable name="MediaNavPlayButtonLabel"><value condition="Control.HasFocus(10)">  Play</value></variable>
	<variable name="MediaNavResumeButtonLabel"><value condition="Control.HasFocus(11)">  Resume</value></variable>
	<variable name="MediaNavPlayFromStartButtonLabel"><value condition="Control.HasFocus(12)">  Play from start</value></variable>
	<variable name="MediaNavMarkAsUnwatchedButtonLabel"><value condition="Control.HasFocus(13)">  Mark as unwatched</value></variable>
	<variable name="MediaNavMarkAsWatchedButtonLabel"><value condition="Control.HasFocus(14)">  Mark as watched</value></variable>
	<variable name="MediaNavInfoButtonLabel"><value condition="Control.HasFocus(15)">  Info</value></variable>
	<variable name="MediaNavMoreButtonLabel"><value condition="Control.HasFocus(16)">  More</value></variable>


	<!-- Onup from actor list, according to media type -->
	<variable name="MediaNavActorNavigateUpId">
		<!-- Movies -->
		<value condition="$EXP[IsMediaNavMovie]">1</value>
		<!-- TV shows -->
		<value condition="$EXP[IsMediaNavTVShow]">101</value>
		<!-- Episodes (applies also to seasons, as they both show all season episodes) -->
		<value condition="$EXP[IsMediaNavEpisode]">102</value>
	</variable>


	<!-- Icons -->
	<variable name="MediaNavPlayIcon"><value>1080p/icons/playc.png</value></variable>
	<variable name="MediaNavResumeIcon"><value>1080p/icons/resume.png</value></variable>
	<variable name="MediaNavPlayFromStartIcon"><value>1080p/icons/replay.png</value></variable>
	<variable name="MediaNavWatchedIcon"><value>1080p/icons/check.png</value></variable>
	<variable name="MediaNavUnwatchedIcon"><value>1080p/icons/check-empty.png</value></variable>
	<variable name="MediaNavInfoIcon"><value>1080p/icons/info.png</value></variable>
	<variable name="MediaNavMoreIcon"><value>1080p/icons/more.png</value></variable>


	<!-- Constants -->
	<constant name="HEIGHT_MEDIANAV_ACTIONBUTTON">80</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_START">70</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_END">40</constant>
	<constant name="SIZE_MEDIANAV_ACTIONBUTTON_ICON">40</constant>
	<constant name="SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND">60</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_ICON_UNFOCUSED">90</constant>
	<constant name="OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP">21</constant>
	<constant name="OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED">-40</constant>

	<constant name="OFFSET_MEDIANAV_AFTER_ACTIONBUTTONS">100</constant>
	<constant name="HEIGHT_MEDIANAV_LISTS_CONTAINER">490</constant>
</includes>
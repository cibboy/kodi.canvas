<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Type-aware header for the media list -->
	<variable name="MediaNavItemListHeader">
		<!-- Seasons -->
		<value condition="$EXP[IsDetailsItemTypeSeason]">Seasons</value>
		<!-- Episodes -->
		<value condition="$EXP[IsDetailsItemTypeEpisode]">Episodes</value>
	</variable>


	<!-- Contrast color for buttons (against blur art) -->
	<variable name="MediaNavContrastButtonIconColor">
		<!-- Light color -->
		<value condition="$EXP[IsBestTextColorLight]">FOREGROUND_OPAQUE90</value>
		<!-- Dark color -->
		<value condition="$EXP[IsBestTextColorDark]">HIGHLIGHT_OPAQUE75</value>
		<!-- Fallback -->
		<value>FOREGROUND_OPAQUE75</value>
	</variable>
	<variable name="MediaNavContrastButtonBackgroundColor">
		<!-- Light color -->
		<value condition="$EXP[IsBestTextColorLight]">FOREGROUND_INVERSE_OPAQUE50</value>
		<!-- Dark color -->
		<value condition="$EXP[IsBestTextColorDark]">FOREGROUND_INVERSE_OPAQUE50</value>
		<!-- Fallback -->
		<value>FOREGROUND_INVERSE_OPAQUE35</value>
	</variable>


	<!--
		Action button labels.
		Defining them as variables allows to hide the text when not focused.
		They include space for margin from icon.
	-->
	<variable name="MediaNavPlayButtonLabel">
		<value condition="Control.HasFocus(411) + $EXP[IsDetailsItemTypeSeason]">  Next episode</value>
		<value condition="Control.HasFocus(411)">  Play</value>
	</variable>
	<variable name="MediaNavResumeButtonLabel"><value condition="Control.HasFocus(412)">  Resume</value></variable>
	<variable name="MediaNavPlayFromStartButtonLabel"><value condition="Control.HasFocus(413)">  Play from start</value></variable>
	<variable name="MediaNavMarkAsUnwatchedButtonLabel"><value condition="Control.HasFocus(414)">  Mark as unwatched</value></variable>
	<variable name="MediaNavMarkAsWatchedButtonLabel"><value condition="Control.HasFocus(415)">  Mark as watched</value></variable>
	<variable name="MediaNavGoToShowButtonLabel"><value condition="Control.HasFocus(416)">  Go to show</value></variable>
	<variable name="MediaNavInfoButtonLabel"><value condition="Control.HasFocus(417)">  Info</value></variable>
	<variable name="MediaNavMoreButtonLabel"><value condition="Control.HasFocus(418)">  More</value></variable>

	<!-- Video nav "play" button action -->
	<variable name="MediaNavPlayButtonAction">
		<value condition="$EXP[IsDetailsItemTypeSeason] | $EXP[IsDetailsItemTypeTvShow]">PlayMedia($INFO[ListItem.FolderPath],isdir,noresume,playoffset=0)</value>
		<value>PlayMedia($INFO[ListItem.FileNameAndPath],noresume,playoffset=0)</value>
	</variable>
	<!-- Video nav "resume" button action -->
	<variable name="MediaNavResumeButtonAction">
		<value condition="$EXP[IsDetailsItemTypeSeason] | $EXP[IsDetailsItemTypeTvShow]">PlayMedia($INFO[ListItem.FolderPath],isdir,resume)</value>
		<value>PlayMedia($INFO[ListItem.FileNameAndPath],resume)</value>
	</variable>

	<!-- Album nav "play all" button -->
	<variable name="AlbumNavPlayAllButtonColor">
		<value condition="Control.HasFocus(94600)">$VAR[ColorsAccentForeground]</value>
		<value>FOREGROUND_OPAQUE20</value>
	</variable>
	<variable name="AlbumNavContrastButtonIconColor">
		<value condition="Control.HasFocus(94600)">BACKGROUND_OPAQUE75</value>
		<!-- Light color -->
		<value condition="$EXP[IsBestTextColorLight]">FOREGROUND_OPAQUE90</value>
		<!-- Dark color -->
		<value condition="$EXP[IsBestTextColorDark]">BACKGROUND_OPAQUE50</value>
		<!-- Fallback -->
		<value>FOREGROUND_OPAQUE75</value>
	</variable>


	<!-- Icons -->
	<variable name="MediaNavPlayIcon"><value>1080p/icons/playc.png</value></variable>
	<variable name="MediaNavResumeIcon"><value>1080p/icons/resume.png</value></variable>
	<variable name="MediaNavPlayFromStartIcon"><value>1080p/icons/replay.png</value></variable>
	<variable name="MediaNavWatchedIcon"><value>1080p/icons/check.png</value></variable>
	<variable name="MediaNavUnwatchedIcon"><value>1080p/icons/check-empty.png</value></variable>
	<variable name="MediaNavGoToShowIcon"><value>1080p/icons/tvshows.png</value></variable>
	<variable name="MediaNavInfoIcon"><value>1080p/icons/info.png</value></variable>
	<variable name="MediaNavMoreIcon"><value>1080p/icons/more.png</value></variable>
	<variable name="AlbumNavSongIcon">
		<value condition="ListItem.IsPlaying">1080p/icons/play.png</value>
		<value>1080p/icons/music.png</value>
	</variable>


	<!-- Constants -->
	<constant name="HEIGHT_MEDIANAV_ACTIONBUTTON">80</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_START">70</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_END">40</constant>
	<constant name="SIZE_MEDIANAV_ACTIONBUTTON_ICON">40</constant>
	<constant name="SIZE_MEDIANAV_ACTIONBUTTON_BACKGROUND">60</constant>
	<constant name="WIDTH_MEDIANAV_ACTIONBUTTON_ICON_UNFOCUSED">90</constant>
	<constant name="OFFSET_MEDIANAV_ACTIONBUTTON_ICON_TOP">21</constant>
	<constant name="OFFSET_MEDIANAV_ACTIONBUTTON_ICON_LEFT_FOCUSED">-40</constant>

	<constant name="OFFSET_MEDIANAV_TOP_ACTIONBUTTONS">360</constant>

	<constant name="SIZE_MEDIANAV_PREVNEXT_INDICATOR">80</constant>
	<constant name="OFFSET_MEDIANAV_TOP_PREVNEXT_INDICATOR">141</constant>		<!-- HEIGHT_LANDSCAPE / 2 -->

	<constant name="WIDTH_ALBUMNAV_ITEM">900</constant>
	<constant name="HEIGHT_ALBUMNAV_ITEM">50</constant>
	<constant name="SIZE_ALBUMNAV_ICON">25</constant>

	<constant name="SIZE_FILENAV_ITEM">150</constant>
	<constant name="SIZE_FILENAV_ICON">70</constant>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!--
		Has studio?
		- Continue watching
		- Recently added episodes
		- Recently added movies
		- Recently added music
		- Movies
		- TV shows
		- Yoga
		- Music
	-->
	<expression name="HasBottomBarStudio">
		[String.IsEqual(Window.Property(Home.ActiveListId),101) + !String.IsEmpty(Container(101).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),102) + !String.IsEmpty(Container(102).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),103) + !String.IsEmpty(Container(103).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),104) + !String.IsEmpty(Container(104).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),111) + !String.IsEmpty(Container(111).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),121) + !String.IsEmpty(Container(121).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),131) + !String.IsEmpty(Container(131).ListItem.Studio)] |
		[String.IsEqual(Window.Property(Home.ActiveListId),141) + !String.IsEmpty(Container(141).ListItem.Studio)]
	</expression>
</includes>
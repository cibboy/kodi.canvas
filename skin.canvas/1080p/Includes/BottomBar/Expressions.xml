<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!--
		Has studio?
		- Continue watching
		- Recently added episodes
		- Recently added movies
		- Recently added music
		- Movies
		- TV shows
		- Yoga
		- Music
	-->
	<expression name="HasBottomBarStudio">
		[String.IsEqual(Window(home).Property(Home.ActiveListId),101) + !String.IsEmpty(Container(101).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),102) + !String.IsEmpty(Container(102).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),103) + !String.IsEmpty(Container(103).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),104) + !String.IsEmpty(Container(104).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),110) + !String.IsEmpty(Container(110).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),120) + !String.IsEmpty(Container(120).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),130) + !String.IsEmpty(Container(130).ListItem.Studio)] |
		[String.IsEqual(Window(home).Property(Home.ActiveListId),140) + !String.IsEmpty(Container(140).ListItem.Studio)]
	</expression>
</includes>
<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Studio -->
	<variable name="BottomBarStudio">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Studio]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Studio]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Studio]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Studio]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),110)">$INFO[Container(110).ListItem.Studio]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),120)">$INFO[Container(120).ListItem.Studio]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),130)">$INFO[Container(130).ListItem.Studio]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window(home).Property(Home.ActiveListId),140)">$INFO[Container(140).ListItem.Studio]</value>
	</variable>
</includes>
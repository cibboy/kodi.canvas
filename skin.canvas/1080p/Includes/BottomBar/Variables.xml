<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Studio -->
	<variable name="BottomBarStudio">
		<!-- Continue watching -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),101)">$INFO[Container(101).ListItem.Studio]</value>
		<!-- Recently added episodes -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),102)">$INFO[Container(102).ListItem.Studio]</value>
		<!-- Recently added movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),103)">$INFO[Container(103).ListItem.Studio]</value>
		<!-- Recently added music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),104)">$INFO[Container(104).ListItem.Studio]</value>
		<!-- Movies -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),111)">$INFO[Container(111).ListItem.Studio]</value>
		<!-- TV shows -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),121)">$INFO[Container(121).ListItem.Studio]</value>
		<!-- Yoga -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),131)">$INFO[Container(131).ListItem.Studio]</value>
		<!-- Music -->
		<value condition="String.IsEqual(Window.Property(Home.ActiveListId),141)">$INFO[Container(141).ListItem.Studio]</value>
	</variable>
</includes>
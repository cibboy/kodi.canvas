<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>8</defaultcontrol>

	<controls>
		<!-- Background (monocolor) -->
		<include content="SettingsBackground" />

		<!-- Top-left mover -->
		<control type="mover" id="8">
			<left>0</left>
			<top>0</top>
			<width>128</width>
			<height>128</height>
			<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/cal-tl.png</texturefocus>
			<texturenofocus>1080p/controls/cal-tl.png</texturenofocus>
			<movingspeed acceleration="180" maxvelocity="300" resettimeout="200" delta="1">
				<eventconfig type="up" />
				<eventconfig type="down" />
				<eventconfig type="left" />
				<eventconfig type="right" />
			</movingspeed>
		</control>
		<!-- Bottom-right mover -->
		<control type="mover" id="9">
			<left>700</left>
			<top>500</top>
			<width>128</width>
			<height>128</height>
			<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/cal-br.png</texturefocus>
			<texturenofocus>1080p/controls/cal-br.png</texturenofocus>
			<movingspeed acceleration="180" maxvelocity="300" resettimeout="200" delta="1">
				<eventconfig type="up" />
				<eventconfig type="down" />
				<eventconfig type="left" />
				<eventconfig type="right" />
			</movingspeed>
		</control>
		<!-- Pixel aspect ratio -->
		<control type="resize" id="11">
			<left>0</left>
			<top>390</top>
			<width>500</width>
			<height>500</height>
			<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/cal-ratio.png</texturefocus>
			<texturenofocus>1080p/controls/cal-ratio.png</texturenofocus>
			<movingspeed acceleration="140" maxvelocity="300" resettimeout="180" delta="1">
				<eventconfig type="left" />
				<eventconfig type="right" />
			</movingspeed>
		</control>
		<!-- Subtitle position mover -->
		<control type="mover" id="10">
			<left>200</left>
			<top>500</top>
			<width>380</width>
			<height>90</height>
			<!-- NOTE: The image must have 40px of trasparent on top and bottom the bar -->
			<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/controls/cal-sub.png</texturefocus>
			<texturenofocus>1080p/controls/cal-sub.png</texturenofocus>
			<movingspeed acceleration="180" maxvelocity="300" resettimeout="200" delta="1">
				<eventconfig type="up" />
				<eventconfig type="down" />
			</movingspeed>
		</control>
		<!-- Reset calibration -->
		<control type="mover" id="12">
			<left>0</left>
			<top>900</top>
			<width>100</width>
			<height>100</height>
			<texturefocus colordiffuse="$VAR[ColorsAccentForeground]">1080p/icons/refresh.png</texturefocus>
			<texturenofocus>1080p/icons/refresh.png</texturenofocus>
		</control>

		<!-- Window title -->
		<control type="label">
			<left>0</left>
			<top>PADDING_BASE_50P</top>
			<width>100%</width>
			<align>center</align>
			<label>$LOCALIZE[214]</label>
			<font>TITLE3</font>
			<textcolor>HIGHLIGHT</textcolor>
		</control>
		<!-- Resolution info -->
		<control type="label" id="2">
			<left>0</left>
			<top>120</top>
			<width>100%</width>
			<align>center</align>
			<label></label>
			<font>BODY</font>
			<textcolor>FOREGROUND</textcolor>
		</control>
		<!-- Control description and help -->
		<control type="label" id="3">
			<left>0</left>
			<top>180</top>
			<width>100%</width>
			<align>center</align>
			<label></label>
			<font>BODY_STRONG</font>
			<textcolor>HIGHLIGHT</textcolor>
		</control>
		<!-- Calibration value -->
		<control type="label" id="4">
			<left>0</left>
			<bottom>240</bottom>
			<height>FONT_SIZE_SUBTITLE</height>
			<width>100%</width>
			<align>center</align>
			<label></label>
			<font>BODY2_STRONG</font>
			<textcolor>FOREGROUND</textcolor>
		</control>
	</controls>
</window>

<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- Prevent opening if from library navigation, as it wouldn't work as expected -->
	<defaultcontrol always="true">400</defaultcontrol>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Full version -->
			<control type="group">
				<visible>!$EXP[IsMediaNavLibraryNavigation]</visible>

				<include content="MusicInfoDetails">
					<param name="art">$INFO[ListItem.Art(thumb)]</param>
					<param name="art_fallback">1080p/fallback/music.png</param>
				</include>

				<!-- Additional details -->
				<control type="group">
					<bottom>PADDING_BASE</bottom>
					<right>PADDING_BASE_200P</right>
					<left>PADDING_BASE_200P</left>
					<height>HEIGHT_DETAILS_INFOLINE_TEXT</height>

					<!-- Path -->
					<include content="DetailsInfoLabelValue">
						<param name="label">Path</param>
						<param name="value">$VAR[DetailsFilePath]</param>
						<param name="visible">$EXP[HasDetailsFilePath]</param>
						<param name="width_limit">1500</param>
					</include>
				</control>

				<!-- Hidden focus -->
				<control type="button" id="400">
					<visible allowhiddenfocus="true">false</visible>
				</control>

				<!-- Clock -->
				<include content="TopBar" />
			</control>

			<!-- Library navigation integrated version -->
			<control type="group">
				<visible>$EXP[IsMediaNavLibraryNavigation] + !$EXP[IsSettingsAnyDialogActive]</visible>

				<include content="DialogContainer">
					<param name="close_animation">true</param>

					<include content="DialogContainerContent">
						<!-- Hidden focus -->
						<control type="button" id="400">
							<visible allowhiddenfocus="true">false</visible>
							<onfocus>Close</onfocus>
						</control>
					</include>
				</include>
			</control>
		</include>
	</controls>
</window>
<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">100</defaultcontrol>

	<controls>
		<include content="Center169AspectRatio">
			<!-- Composite OSD -->
			<control type="group">
				<include content="ShowHideFadeSlideVerticalAnimation">
					<param name="speed">ANIMATION_MID</param>
					<param name="visible_condition">WindowOpen</param>
					<param name="hidden_condition">WindowClose</param>
				</include>
				<animation type="Conditional" condition="Control.HasFocus(401) | Control.HasFocus(601)">
					<effect type="slide" start="0,0" end="0,SCREEN_HEIGHT_NEG" time="ANIMATION_MID" tween="circle" easing="out" />
				</animation>
				<!-- Hide when an advanced setting dialog is open -->
				<animation type="Conditional" condition="Window.IsVisible(DialogSettings.xml)">
					<effect type="fade" start="100" end="0" time="ANIMATION_MID" tween="linear" easing="out" />
				</animation>

				<!-- OSD -->
				<include content="PlayerOSD">
					<param name="onleft">SetFocus(203)</param>
					<param name="onright">SetFocus(201)</param>
					<param name="ondown">noop</param>

					<!-- Media info -->
					<control type="group">
						<left>PADDING_BASE_125P</left>
						<right>PADDING_BASE_125P</right>

						<!-- Title -->
						<control type="label">
							<bottom>310</bottom>
							<width>1500</width>
							<height>HEIGHT_OSD_CLEARLOGO</height>
							<aligny>center</aligny>
							<font>TITLE3</font>
							<textcolor>HIGHLIGHT</textcolor>
							<label>$VAR[DetailsTitle]</label>
						</control>

						<!-- Details left -->
						<control type="grouplist">
							<orientation>horizontal</orientation>
							<itemgap>PADDING_BASE_30P</itemgap>
							<usecontrolcoords>true</usecontrolcoords>

							<bottom>275</bottom>
							<height>FONT_SIZE_SUBTITLE</height>

							<!-- Album -->
							<control type="label">
								<height>FONT_SIZE_SUBTITLE</height>
								<width max="600">auto</width>
								<aligny>center</aligny>
								<font>BODY_STRONG</font>
								<textcolor>HIGHLIGHT</textcolor>
								<label>$VAR[DetailsTitle2]</label>
							</control>
							
							<!-- Duration -->
							<include content="PlayerOSDInfoText">	
								<param name="visible">$EXP[HasDetailsDuration]</param>
								<param name="text">$VAR[DetailsDuration]</param>
							</include>
						</control>
					</control>

					<!-- Additional controls -->
					<control type="grouplist" id="200">
						<orientation>horizontal</orientation>
						<itemgap>PADDING_BASE_20P_NEG</itemgap>
						<usecontrolcoords>true</usecontrolcoords>
						<defaultcontrol>201</defaultcontrol>

						<height>SIZE_OSD_BUTTON_BIG_FOCUS</height>
						<width>1000</width>
						<right>PADDING_BASE_125P</right>
						<centerbottom>PADDING_BASE_125P</centerbottom>
						<align>right</align>

						<onleft>SetFocus(103)</onleft>
						<onright>SetFocus(101)</onright>
						<onup>SetFocus(150)</onup>

						<!-- Repeat -->
						<include content="PlayerOSDButton">
							<param name="id">201</param>
							<param name="size">SIZE_OSD_BUTTON</param>
							<param name="size_focus">SIZE_OSD_BUTTON_FOCUS</param>
							<param name="size_icon">SIZE_OSD_BUTTON_ICON</param>
							<param name="icon">$VAR[PlayerOSDRepeatIcon]</param>
							<param name="action">PlayerControl(Repeat)</param>
						</include>
						<!-- Shuffle -->
						<include content="PlayerOSDButton">
							<param name="id">202</param>
							<param name="size">SIZE_OSD_BUTTON</param>
							<param name="size_focus">SIZE_OSD_BUTTON_FOCUS</param>
							<param name="size_icon">SIZE_OSD_BUTTON_ICON</param>
							<param name="icon">$VAR[PlayerOSDShuffleIcon]</param>
							<param name="action">PlayerControl(Random)</param>
						</include>
						<!-- Audio settings -->
						<include content="PlayerOSDButton">
							<param name="id">203</param>
							<param name="size">SIZE_OSD_BUTTON</param>
							<param name="size_focus">SIZE_OSD_BUTTON_FOCUS</param>
							<param name="size_icon">SIZE_OSD_BUTTON_ICON</param>
							<param name="icon">1080p/icons/speaker.png</param>
							<param name="action">ActivateWindow(osdaudiosettings)</param>
						</include>
					</control>
				</include>
			</control>

			<!-- Dialog darkening -->
			<include content="DarkeningLayer">
				<param name="visible">Window.IsVisible(DialogSettings.xml)</param>
				<param name="colordiffuse">C9000000</param>
				<param name="fade_speed">ANIMATION_MID</param>
			</include>

			<!-- Clock -->
			<control type="group">
				<include content="ShowHideFadeSlideVerticalAnimation">
					<param name="slide_amount">-100</param>
					<param name="speed">ANIMATION_MID</param>
					<param name="visible_condition">WindowOpen</param>
					<param name="hidden_condition">WindowClose</param>
				</include>

				<include content="TopBar" />
			</control>
		</include>
	</controls>
</window>